generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken  String?
  refreshTokenExpires DateTime?
}

model ShopConfig {
  id                  String   @id @default(cuid())
  shop                String   @unique

  assistantName       String   @default("AI Shopping Assistant")
  assistantTagline    String   @default("Smart Support for Every Step")
  greeting            String   @default("Hi! I'm your personal shopping assistant.")
  greetingCta         String   @default("What can I help you find today?")
  avatarUrl           String   @default("")
  bannerUrl           String   @default("")
  colorPrimary        String   @default("#2d6b4f")
  colorAccent         String   @default("#e8f5ee")
  colorCtaBg          String   @default("#e8f5ee")
  colorCtaText        String   @default("#2d6b4f")
  colorCtaHover       String   @default("#d6eee0")

  launcherPlaceholder String   @default("How can I help you today?")
  inputPlaceholder    String   @default("How can I help you today?")
  launcherWidth       String   @default("500")
  widgetPosition      String   @default("bottom-center")
  showBanner          Boolean  @default(true)

  cta1Label           String   @default("")
  cta1Message         String   @default("")
  cta2Label           String   @default("")
  cta2Message         String   @default("")
  cta3Label           String   @default("")
  cta3Message         String   @default("")
  cta4Label           String   @default("")
  cta4Message         String   @default("")

  qp1Label            String   @default("")
  qp1Message          String   @default("")
  qp2Label            String   @default("")
  qp2Message          String   @default("")
  qp3Label            String   @default("")
  qp3Message          String   @default("")
  qp4Label            String   @default("")
  qp4Message          String   @default("")

  ctaHint             String   @default("")
  disclaimerText      String   @default("Powered by AI")
  privacyUrl          String   @default("/pages/privacy-policy")

  // Cached translations of greetingCta for the welcome-CTA rotator.
  // JSON: { phrase: "...", results: [{code,dir,text}, ...] }.
  // Generated on demand via Anthropic Haiku (greeting-translation.server.js)
  // and refreshed when the cached `phrase` no longer matches the
  // current greetingCta. Empty `{}` = not yet generated.
  greetingCtaTranslations String   @default("{}")
  // Merchant toggle to disable the multilingual rotator entirely.
  // Default true so existing installs get the rotator on first deploy;
  // merchants can opt out via the theme block.
  rotateGreetingCta       Boolean  @default(true)

  anthropicApiKey     String   @default("")
  anthropicModel      String   @default("claude-sonnet-4-6")
  modelStrategy       String   @default("smart")
  yotpoApiKey         String   @default("")
  aftershipApiKey     String   @default("")

  showFollowUps       Boolean  @default(true)
  showFeedback        Boolean  @default(true)
  deduplicateColors   Boolean  @default(false)
  promptCaching       Boolean  @default(false)
  // Product card layout in the storefront chat widget.
  // "horizontal" (default): legacy — thumbnail left, title/price right,
  // capped at 3 cards stacked vertically. "showcase": square image
  // top, title/price/CTA below, up to 10 cards in a horizontal
  // scroll-snap row. Per-shop merchant preference.
  productCardStyle    String   @default("horizontal")
  klaviyoFormId       String   @default("")
  klaviyoCompanyId    String   @default("")
  klaviyoListId       String   @default("")
  klaviyoPrivateKey   String   @default("")
  yotpoLoyaltyApiKey  String   @default("")
  yotpoLoyaltyGuid    String   @default("")
  loyaltyDisplay      String   @default("points")
  loyaltyPointsPerDollar Int    @default(100)
  loyaltyRounding     String   @default("exact")

  hideOnUrls             String   @default("[]")
  categoryExclusions     String   @default("[]")
  categoryGroups         String   @default("[]")
  querySynonyms          String   @default("[]")
  similarMatchAttributes String   @default("[]")
  collectionLinks        String   @default("[]")
  fitPredictorEnabled    Boolean  @default(false)
  fitPredictorConfig     String   @default("{}")

  // Semantic search (opt-in per merchant). Provider is one of "", "voyage",
  // or "openai". Empty disables semantic search; keyword search is used.
  // API keys are encrypted at rest using app/utils/encryption.server.js.
  embeddingProvider      String   @default("")
  voyageApiKey           String   @default("")
  openaiApiKey           String   @default("")

  supportUrl          String   @default("")
  supportLabel        String   @default("Contact customer service")
  trackingPageUrl     String   @default("")
  returnsPageUrl      String   @default("")
  referralPageUrl     String   @default("")

  vipModeEnabled      Boolean  @default(false)
  showLoginPill       Boolean  @default(true)

  // CS-team cheat code: when a customer (or CS agent posing as one)
  // types this exact phrase in chat, the response is a server-built
  // dump of every currently-active campaign. Bypasses the AI for
  // determinism. Empty = feature disabled.
  campaignCheatCode   String   @default("")

  // RAG over knowledge files. When true, chat-prompt.server.js
  // retrieves the top-K most semantically relevant KnowledgeChunk
  // rows for the customer's latest message and injects only those
  // — instead of dumping every knowledge file in every prompt.
  // Default OFF: feature must be opted into per-shop. Requires
  // semantic search (embeddingProvider + apiKey) + a successful
  // backfill (npm run backfill:knowledge-chunks) before enabling.
  knowledgeRagEnabled Boolean  @default(false)

  plan                    String    @default("free")
  subscriptionId          String?
  subscriptionActivatedAt DateTime?

  rateLimitHits      Int      @default(0)
  rateLimitHitsMonth String   @default("")

  dailyCapEnabled    Boolean  @default(false)
  dailyCapMessages   Int      @default(200)

  // Updated on each /widget-config call from the storefront, throttled to
  // once every 5 minutes. Used by the home-page setup checklist to detect
  // whether the chat widget app embed is currently active in the merchant's
  // theme. Null means the widget has never been seen.
  lastWidgetSeenAt   DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model KnowledgeFile {
  id        String   @id @default(cuid())
  shop      String
  fileName  String
  fileType  String
  fileSize  Int
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
}

model Product {
  id               String           @id @default(cuid())
  shop             String
  shopifyId        String
  handle           String
  title            String
  vendor           String?
  productType      String?
  tags             String[]
  description      String?
  status           String?
  featuredImageUrl String?
  attributesJson   Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  variants         ProductVariant[]

  @@unique([shop, shopifyId])
  @@index([shop])
  @@index([shop, handle])
}

model ProductVariant {
  id               String   @id @default(cuid())
  productId        String
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  shopifyId        String
  sku              String?
  title            String?
  price            String?
  compareAtPrice   String?
  inventoryQty     Int?
  optionsJson      String?
  attributesJson   Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([productId, shopifyId])
  @@index([sku])
}

model AttributeMapping {
  id         String   @id @default(cuid())
  shop       String
  attribute  String
  sourceType String
  target     String   @default("product")
  namespace  String?
  key        String?
  prefix     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([shop, attribute])
  @@index([shop])
}

model CatalogSyncState {
  id            String    @id @default(cuid())
  shop          String    @unique
  status        String    @default("idle")
  lastSyncedAt  DateTime?
  lastError     String?
  productsCount Int       @default(0)
  syncedSoFar   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ProductEnrichment {
  id             String   @id @default(cuid())
  shop           String
  sku            String
  data           Json
  sourceFileId   String?
  sourceFileType String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([shop, sku])
  @@index([shop])
  @@index([sourceFileId])
}

model ChatUsage {
  id                       String   @id @default(cuid())
  shop                     String
  model                    String
  inputTokens              Int      @default(0)
  outputTokens             Int      @default(0)
  cacheCreationInputTokens Int      @default(0)
  cacheReadInputTokens     Int      @default(0)
  costUsd                  Float    @default(0)
  toolCalls                Int      @default(0)
  createdAt                DateTime @default(now())

  @@index([shop])
  @@index([shop, createdAt])
}

model ChatFeedback {
  id           String   @id @default(cuid())
  shop         String
  sessionId    String
  vote         String
  botResponse  String
  products     String[]
  conversation String?
  userHash     String?
  createdAt    DateTime @default(now())

  @@index([shop])
  @@index([shop, createdAt])
  @@index([createdAt])
}

model ChatProductMention {
  id        String   @id @default(cuid())
  shop      String
  handle    String
  title     String
  tool      String
  createdAt DateTime @default(now())

  @@index([shop])
  @@index([shop, createdAt])
  @@index([shop, handle])
  @@index([createdAt])
}

// One row per scheduled marketing campaign. The chat reads only
// campaigns where now is between startsAt and endsAt — auto-expires
// without manual cleanup. Multiple active campaigns can run at once
// (BOGO + sitewide % off + free shipping over $X all coexist).
model Campaign {
  id        String   @id @default(cuid())
  shop      String
  name      String
  content   String   // Markdown-ish text the chat reads as system context
  startsAt  DateTime
  endsAt    DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  @@index([shop, startsAt, endsAt])
}

// One row per order whose orders/create webhook arrived with the
// _seos_attributed cart attribute set by the chat widget on a product
// click. Lets the analytics + home page show "Chat-driven sales:
// N orders / $X revenue" without an extra Shopify API call.
//
// Idempotent on (shop, orderId) so webhook retries don't double-count.
model ChatConversion {
  id          String   @id @default(cuid())
  shop        String
  orderId     String
  orderName   String?
  totalAmount Float?
  currency    String?
  customerId  String?
  createdAt   DateTime @default(now())

  @@unique([shop, orderId])
  @@index([shop])
  @@index([shop, createdAt])
  @@index([createdAt])
}

// One row per chunk of a merchant's knowledge file (FAQs, brand
// voice, rules, etc.). Used by the RAG path in chat-prompt.server.js
// — instead of injecting the entire knowledge corpus on every turn
// (~10-30K chars), we embed each chunk once and retrieve the top-K
// most semantically relevant ones for the customer's current message.
//
// Chunks are typically split on section headers (Aetrex's `═══`
// dividers) so each chunk is a coherent topic. The embedding column
// itself is `vector(1024)` and lives outside the Prisma schema —
// added via raw SQL in the migration since Prisma doesn't natively
// support pgvector. Same pattern as Product.embedding.
//
// On knowledge-file update, all chunks for that sourceFileId are
// deleted and replaced (idempotent rebuild).
model KnowledgeChunk {
  id                 String    @id @default(cuid())
  shop               String
  sourceFileId       String?
  fileType           String
  sectionTitle       String?
  chunkIndex         Int
  content            String
  embeddingProvider  String?
  embeddingUpdatedAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([shop])
  @@index([shop, fileType])
  @@index([sourceFileId])
}
