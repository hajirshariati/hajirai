        "testimonial_WptKCX": {
          "type": "testimonial",
          "settings": {
            "icon": "quote",
            "text": "<p>Love this style! I’ve never been able to wear a shoe with any heel. These are so COMFORTABLE and attractive. Thank you Aetrex!</p>",
            "author": "Gina S.",
            "author_info": "",
            "author_url": "",
