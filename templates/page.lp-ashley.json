      "blocks": {
        "testimonial_i8hpLw": {
          "type": "testimonial",
          "settings": {
            "icon": "quote",
            "text": "<p>Beautifully Comfortable. I could walk in these all day. They are perfect for work.</p>",
            "author": "Marjolyn M.",
            "author_info": "",
