        },
        "text_GW6cKf": {
          "type": "text",
          "settings": {
            "text": "<p>Turnkey Footwear and Fit Recommendations</p>",
            "text_font": "body",
            "text_size": "subtext-custom",
            "text_max_size": 32,
            "text_line_height": 1.2,
            "text_letter_spacing": 0,
            "text_capitalize": false,
