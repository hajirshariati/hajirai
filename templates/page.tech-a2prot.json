        "heading_HaBHQJ": {
          "type": "heading",
          "settings": {
            "heading": "Foot Health & the Right Aetrex Solution for You",
            "heading_size": "title-sm",
            "heading_tag": "h2",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
