    "image_with_text_9Q3q77": {
      "type": "image-with-text",
      "blocks": {
        "text_jbNEFM": {
          "type": "text",
          "settings": {
            "text": "<p><strong>What is Morton’s Neuroma? </strong>Morton’s Neuroma is a common foot problem associated with pain, swelling and/or an inflammation of a nerve, usually at the ball-of-the-foot between the 3rd and 4th toes. Symptoms of this condition include sharp pain, burning, and possibly even a lack of feeling in the affected area. Morton’s Neuroma may also cause numbness, tingling, or cramping in the forefoot.<br/><br/><strong>Aetrex Morton’s Neuroma Orthotics:</strong><br/>Aetrex Morton’s Neuroma Orthotics are designed specifically with a metatarsal pad and removed gel pads between the 3rd and 4th metatarsal heads to offer a pressure free environment in your shoes. The strategically placed arch support helps provide balance and aligns your body from the ground up.</p><p><strong>Price:</strong> Available Now for $69.95</p>",
            "text_font": "body",
            "text_size": "subtext-md",
            "text_max_size": 32,
            "secondary_color": false,
