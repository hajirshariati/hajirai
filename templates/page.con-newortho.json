    "image_with_text_KYfa9x": {
      "type": "image-with-text",
      "blocks": {
        "text_AkjXbJ": {
          "type": "text",
          "settings": {
            "text": "<p><strong>What is Plantar Fasciitis? </strong>Plantar Fasciitis is an inflammation caused by excessive stretching of the plantar fascia. The plantar fascia is a broad band of fibrous tissue which runs along the bottom surface of the foot, attaching at the bottom of the calcaneus (heel bone) and extending to the forefoot. When the plantar fascia is excessively stretched, this can cause plantar fasciitis, which can also lead to heel pain, arch pain, and even heel spurs.</p><p></p><p><strong>The Aetrex Plantar Fasciitis Kit:</strong><br/>The Aetrex Plantar Fasciitis Kit includes 4 key tools to help relieve and prevent plantar fasciitis: Aetrex Compete Orthotics, Aetrex Maui Orthotic Flips, Aetrex Foot Roller and a Stretching Guide</p><p><strong>Price:</strong> $145.95 Value, Available Now for $95.95</p>",
            "text_font": "body",
            "text_size": "subtext-md",
            "text_max_size": 32,
            "secondary_color": false,
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
