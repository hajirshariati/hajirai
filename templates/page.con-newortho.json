    "image_with_text_y8caAd": {
      "type": "image-with-text",
      "blocks": {
        "text_jWbb3P": {
          "type": "text",
          "settings": {
            "text": "<p><strong>What is Metatarsalgia? </strong>Metatarsalgia is a general term used to denote a pain in the metatarsal region of the foot (the area just before the toes, more commonly referred to as the ball-of-the-foot). This is a common foot problem that can affect the bones and joints at the ball-of-the-foot. Metatarsalgia (ball-of-foot-pain) is often located under the 2nd, 3rd, and 4th metatarsal heads, or more isolated at the first metatarsal head (near the big toe).<br/><br/><strong>Aetrex Metatarsalgia Orthotics:</strong><br/>Aetrex Metatarsalgia Orthotics are specifically designed to relieve ball-of-foot discomfort with slow recovery memory foam and the inclusion of a metatarsal pad. The metatarsal pad helps distribute the body's weight evenly across the metatarsal bones, reducing the pressure on specific areas and preventing discomfort. These orthotics immediately customize to the foot, offering a pressure-free environment in your shoes. In addition, the strategically placed arch support aligns your body to help support your body from the ground up.</p><p><strong>Price:</strong> Available Now for $69.95</p>",
            "text_font": "body",
            "text_size": "subtext-md",
            "text_max_size": 32,
            "secondary_color": false,
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
