          "settings": {
            "liquid": "<!-- Container for the cloned Yotpo data -->\n<div style=\"justify-self: center;margin-bottom: -1em;\"><p>Customer Fit Insights</p></div>\n\n<div id=\"cloned-yotpo-data\"></div>\n\n<style>\n/* Make the container responsive with background */\n#cloned-yotpo-data {\n    width: 100%;\n    max-width: 100%;\n    box-sizing: border-box;\n    overflow: hidden;\n}\n\n/* Force background on all child elements */\n#cloned-yotpo-data .yotpo-header-lower-wrapper,\n#cloned-yotpo-data .yotpo-bottom-line-question-wrapper-horizontal,\n#cloned-yotpo-data .yotpo-review-question-wrapper {\n}\n\n/* Add position absolute to bottom-line wrapper - ONLY for cloned code */\n#cloned-yotpo-data .yotpo-bottom-line-question-wrapper-horizontal {\n    position: absolute;\n    width: -webkit-fill-available;\n}\n\n\n\n/* Center the main wrapper */\n#cloned-yotpo-data .yotpo-header-lower-wrapper {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n}\n\n/* Center the questions container */\n#cloned-yotpo-data .yotpo-custom-questions-range-question {\n    display: flex !important;\n    flex-wrap: wrap !important;\n    gap: 20px !important;\n    justify-content: center !important;\n    align-items: center !important;\n}\n\n/* Hide Arch Support */\n#cloned-yotpo-data .yotpo-custom-questions-range-question-wrapper[type=\"Rating\"] {\n    display: none !important;\n}\n\n/* Make Width and Size sections side by side and centered */\n#cloned-yotpo-data .yotpo-custom-questions-range-question-wrapper[type=\"Size\"] {\n    min-width: 200px !important;\n    max-width: 300px !important;\n    flex: 1 1 calc(50% - 10px) !important;\n    text-align: center;\n    margin: 0px;\n}\n\n/* Center text content */\n#cloned-yotpo-data .yotpo-custom-questions-range-question-title,\n#cloned-yotpo-data .yotpo-custom-questions-range-question-value {\n    text-align: center;\n}\n\n/* Mobile - stack vertically */\n@media (max-width: 640px) {\n    #cloned-yotpo-data {\n        padding: 12px 8px;\n    }\n    \n    #cloned-yotpo-data .yotpo-custom-questions-range-question-wrapper[type=\"Size\"] {\n        flex: 1 1 100% !important;\n        max-width: 100% !important;\n    }\n}\n</style>\n\n<!-- Script to clone the data -->\n<script>\nfunction cloneYotpoData() {\n    const originalWidget = document.querySelector('.yotpo-header-lower-wrapper');\n    \n    if (originalWidget) {\n        const clonedData = originalWidget.cloneNode(true);\n        const targetLocation = document.querySelector('#cloned-yotpo-data');\n        \n        if (targetLocation) {\n            targetLocation.innerHTML = '';\n            targetLocation.appendChild(clonedData);\n            copyComputedStyles(originalWidget, clonedData);\n            \n            // Force background color on cloned elements\n            applyBackground(clonedData);\n        }\n    }\n}\n\nfunction applyBackground(element) {\n    // Set background on main wrappers\n    const wrappers = element.querySelectorAll('.yotpo-header-lower-wrapper, .yotpo-bottom-line-question-wrapper-horizontal, .yotpo-review-question-wrapper');\n    wrappers.forEach(wrapper => {\n        wrapper.style.backgroundColor = '';\n    });\n}\n\nfunction copyComputedStyles(source, target) {\n    const sourceElements = source.querySelectorAll('*');\n    const targetElements = target.querySelectorAll('*');\n    \n    const sourceStyle = window.getComputedStyle(source);\n    for (let prop of sourceStyle) {\n        // Don't copy background-color from source, we want \n        if (prop !== 'background-color' && prop !== 'backgroundColor') {\n            target.style[prop] = sourceStyle.getPropertyValue(prop);\n        }\n    }\n    \n    sourceElements.forEach((srcEl, index) => {\n        if (targetElements[index]) {\n            const srcStyle = window.getComputedStyle(srcEl);\n            const importantProps = ['color', 'border', 'font-size', 'font-weight', 'font-family', 'display'];\n            importantProps.forEach(prop => {\n                targetElements[index].style[prop] = srcStyle.getPropertyValue(prop);\n            });\n            \n            // Only copy background for progress bars, not wrapper backgrounds\n            if (srcEl.classList.contains('yotpo-progress-bar-score')) {\n                targetElements[index].style.background = srcStyle.getPropertyValue('background');\n                targetElements[index].style.backgroundColor = srcStyle.getPropertyValue('background-color');\n            }\n        }\n    });\n}\n\nfunction waitForYotpo() {\n    const checkInterval = setInterval(() => {\n        const yotpoWidget = document.querySelector('.yotpo-header-lower-wrapper');\n        \n        if (yotpoWidget) {\n            clearInterval(checkInterval);\n            setTimeout(cloneYotpoData, 1000);\n        }\n    }, 500);\n    \n    setTimeout(() => {\n        clearInterval(checkInterval);\n    }, 10000);\n}\n\nif (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', waitForYotpo);\n} else {\n    waitForYotpo();\n}\n</script>"
