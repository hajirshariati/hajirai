          "type": "text",
          "settings": {
            "text": "<p>3. Provide Alignment & Support</p>",
            "text_font": "heading",
            "text_size": "subtext-custom",
            "text_max_size": 32,
            "text_line_height": 1.2,
            "text_letter_spacing": 0,
