    "image_with_text_GJDAhj": {
      "type": "image-with-text",
      "blocks": {
        "text_c6yDM7": {
          "type": "text",
          "settings": {
            "text": "<h2>Foot Conditions associated with Diabetes include:</h2>",
            "text_font": "body",
            "text_size": "subtext-md",
            "text_max_size": 32,
            "text_line_height": 1.6,
            "text_letter_spacing": 0,
            "text_capitalize": false,
            "secondary_color": false,
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "text_4kmETN": {
          "type": "text",
          "settings": {
            "text": "<p><strong>PERIPHERAL SENSORY NEUROPATHY</strong>• Nerve damage in the feet<br/><br/><strong>PERIPHERAL VASCULAR DISEASE & PERIPHERAL ARTERIAL DISEASE</strong>• Plaque build-up in the arteries reducing blood flow and the ability to heal<br/><br/><strong>CHARCOT FOOT</strong>• Structural damage caused by a lack of sensation and bone weakness. The arches are lost, and the foot may become boat shaped.<br/><br/><strong>DIABETIC FOOT ULCER</strong>• A sore developed when damaged skin goes unnoticed due to loss of sensation<br/></p>",
            "text_font": "body",
            "text_size": "subtext-md",
            "text_max_size": 32,
            "text_line_height": 1.6,
            "text_letter_spacing": 0,
            "text_capitalize": false,
