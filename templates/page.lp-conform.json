    "rich_text_4XiQkT": {
      "type": "rich-text",
      "blocks": {
        "text_LNmhDK": {
          "type": "text",
          "settings": {
            "text": "<h5><strong>Foot Conditions associated with Diabetes include:</strong></h5>",
            "text_font": "body",
            "text_size": "subtext-sm",
            "text_max_size": 30,
            "secondary_color": false,
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "text_YPMXNi": {
          "type": "text",
          "settings": {
            "text": "<ul><li><em><strong>Peripheral Sensory Neuropathy</strong></em></li></ul><p>Nerve damage in the feet</p><ul><li><em><strong>Peripheral Vascular Disease & Peripheral Arterial Disease</strong></em></li></ul><p>Plaque build-up in the arteries reducing blood flow and the ability to heal</p><ul><li><em><strong>Charcot Foot</strong></em></li></ul><p>Structural damage caused by a lack of sensation and bone weakness. The arches are lost, and the foot may become boat shaped./p&gt;</p><ul><li><em><strong>Diabetic Foot Ulcer</strong></em></li></ul><p>A sore developed when damaged skin goes unnoticed due to loss of sensation</p>",
            "text_font": "body",
            "text_size": "subtext-md",
            "text_max_size": 32,
            "secondary_color": false,
            "highlighted_text": "text",
            "highlighted_scribble": "circle"
          }
