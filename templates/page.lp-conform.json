    "image_with_text_Bad4Cj": {
      "type": "image-with-text",
      "blocks": {
        "heading_CkAbCW": {
          "type": "heading",
          "settings": {
            "heading": "About Diabetes & the Diabetic Foot",
            "heading_size": "title-sm",
            "heading_tag": "h2",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "text_QM7eC8": {
          "type": "text",
          "settings": {
            "text": "<p>Diabetes is a highly prevalent condition globally. It is defined as a metabolic disorder, and there are two main types. Type 1 is an autoimmune disease mostly found in children where the body’s immune system destroys the insulin-producing pancreatic beta-cells. It is found in 5 to 10 percent of patients with Diabetes. Type 2 accounts for the remaining 90 to 95 percent, frequently found in people over age 45. It’s associated with the physical inactivity of adolescents and the sugar-rich diets commonly adopted today.<br/></p>",
            "text_font": "body",
            "text_size": "subtext-md",
            "text_max_size": 32,
            "secondary_color": false,
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        }
      },
      "block_order": [
        "heading_CkAbCW",
        "text_QM7eC8"
      ],
