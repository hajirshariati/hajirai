<script>
  document.addEventListener('DOMContentLoaded', function () {
    if (!window.location.pathname.includes('explore-relief-for-')) return;

    document.querySelectorAll('.faq details').forEach(details => {
      if (!details.hasAttribute('data-opened-on-load')) {
        details.open = true;
        details.setAttribute('aria-expanded', 'true');
        details.setAttribute('data-opened-on-load', 'true');
      }
    });
  });
</script>









<!-- Hide Chat when Cart drawer is open -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  const observer = new MutationObserver((mutations) => {
    const cartDrawer = document.querySelector('#CartDrawer');
    const zendeskLauncher = document.querySelector('iframe#launcher');
    
    // Drawer is open when it does NOT have the 'hidden' attribute
    const isDrawerOpen = cartDrawer && !cartDrawer.hasAttribute('hidden');
    
    if (isDrawerOpen) {
      if (zendeskLauncher) zendeskLauncher.style.setProperty('z-index', '30', 'important');
    } else {
      if (zendeskLauncher) zendeskLauncher.style.setProperty('z-index', '999998', 'important');
    }
  });

  observer.observe(document.body, { attributes: true, subtree: true, attributeFilter: ['hidden'] });
});
</script>

 <script>
  (function () {
    var BREAKPOINT = 992;
  
    var observer = new IntersectionObserver(
      function (entries, obs) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;
          swapAttributes(entry.target);
          obs.unobserve(entry.target);
        });
      },
      {
        rootMargin: '20px 0px',
        threshold: 0,
      }
    );
  
    function swapAttributes(el) {
      var src = el.getAttribute('data-lazy-src');
      var srcset = el.getAttribute('data-lazy-srcset');
      if (src) el.setAttribute('src', src);
      if (srcset) el.setAttribute('srcset', srcset);
      el.removeAttribute('data-lazy-src');
      el.removeAttribute('data-lazy-srcset');
  
      var bg = el.getAttribute('data-lazy-bg');
      var swatchBg = el.getAttribute('data-lazy-swatch-bg');
      if (bg) {
        el.style.backgroundImage = 'url(' + bg + ')';
        el.removeAttribute('data-lazy-bg');
      }
      if (swatchBg) {
        el.style.setProperty('--swatch-background-image', 'url(' + swatchBg + ')');
        el.removeAttribute('data-lazy-swatch-bg');
      }
    }
  
    function observeElements() {
      var isDesktop = window.innerWidth > BREAKPOINT;
  
      document
        .querySelectorAll('img[data-lazy-src], [data-lazy-bg]')
        .forEach(function (el) {
          // Media snippet images (media-index-*): only lazy load on mobile
          // If desktop, swap immediately
          if (isDesktop && el.className.match(/media-index-/)) {
            swapAttributes(el);
          } else {
            observer.observe(el);
          }
        });
    }
  
    observeElements();
  
    new MutationObserver(observeElements).observe(document.body, {
      childList: true,
      subtree: true,
    });
  })();
 </script>

