{%- doc -%}
  Renders a responsive collection card with flexible image sources and customizable content.

  Supports block overrides, product counts, and graceful onboarding placeholders.

  @param {object} [collection] - Shopify collection object (shows placeholder if nil)
  @param {string} [custom_url] - Custom URL if link_type == url
  @param {string} [image_type] - Image source selection
  @param {string} [image_ratio] - Image aspect ratio class
  @param {boolean} [show_products_count] - Display product count badge
  @param {number} [position] - Card position for placeholder cycling (1-5)
  @param {object} [block] - Block object for content overrides
  @param {string} [title_position] - Title position: 'top', 'center', or 'bottom'
  @param {boolean} [title_shadow] - Enable drop shadow on title
{%- enddoc -%}

{%- liquid
  # choose link
  assign link_url = blank
  if custom_url != blank
    assign link_url = custom_url
  elsif collection
    assign link_url = collection.url
  endif

  # choose image source
  if image_type == 'collection' and collection and collection.image
    assign collection_image = collection.image
  elsif collection and collection.products.size > 0
    assign collection_image = collection.products.first.featured_media.preview_image
  endif

  # title with safe fallback
  if collection
    assign collection_title = collection.title
  else
    assign collection_title = 'Collection'
  endif

  # block overrides
  if block != blank
    if block.settings.image != blank
      assign collection_image = block.settings.image
    endif

    if block.settings.title != blank
      assign collection_title = block.settings.title
    endif

    if block.settings.description != blank
      assign collection_description = block.settings.description
    endif

    assign overlay_content = block.settings.overlay_content
  endif

  # adapt ratio fallback
  if image_ratio == 'adapt' and collection_image == blank
    assign image_ratio = 'wide'
  endif

  # title positioning and shadow
  assign card_text_position = title_position | default: 'bottom'
  assign title_shadow_class = ''
  if title_shadow
    assign title_shadow_class = ' collection-title-shadow'
  endif
-%}

<div
  class="card media-card media-card--{{ settings.card_style }}{% if overlay_content %} media-card--overlap{% endif %} title-position-{{ card_text_position }}"
  id="shopify-block-{{ block.id }}"
>
  {%- if overlay_content and block != blank -%}
    <style>
      #shopify-block-{{ block.id }} {
        {%- render 'section-variables', section: block -%}
      }
    </style>
  {%- endif -%}

  {%- if link_url != blank -%}
    <a
      href="{{ link_url }}"
      class="media-card__link flex flex-col w-full h-full relative"
      aria-label="{{ collection_title  }}"
    >
      <div class="media media--{{ image_ratio }} relative overflow-hidden">
        {%- if collection_image != blank -%}
{{-
  collection_image
  | image_url: width: collection_image.width
  | image_tag: loading: 'lazy', widths: '350,540,720,900', is: 'lazy-image'
-}}
        {%- else -%}
          <span class="block aspect-{{ image_ratio }}"></span>
        {%- endif -%}
      </div>

      <div class="media-card__content flex justify-between items-center gap-4 w-full text-{{ settings.collection_card_text_alignment }} text-postion-{{ card_text_position }}">
        <div class="media-card__text shrink-1 grid gap-0d5">
          <p>
            <span
              class="heading text-xl-3xl tracking-tighter leading-tight relative{{ title_shadow_class }}"
              style="font-size: {{ heading_font_size }}px"
            >
              {{- collection_title  -}}
              {%- if show_products_count and collection and collection.all_products_count > 0 -%}
                <small class="count font-medium absolute text-xs tracking-none whitespace-nowrap">
                  {{- collection.all_products_count -}}
                </small>
              {%- endif -%}
            </span>
          </p>
          {%- if collection_description != blank -%}
            <p class="leading-none text-xs xl:text-sm">{{ collection_description }}</p>
          {%- endif -%}
        </div>
        {%- render 'icon', icon: 'arrow-right', size: 'xs', class: 'transform shrink-0' -%}
      </div>
    </a>
  {%- else -%}
    <div class="media-card__link flex flex-col w-full h-full relative">
      <div class="media media--{{ image_ratio }} relative overflow-hidden">
        {%- liquid
          assign modulo = position | modulo: 5 | plus: 1
          assign placeholder = 'collection-' | append: modulo
          echo placeholder | placeholder_svg_tag: 'placeholder placeholder--transparent'
        -%}
      </div>
      <div class="media-card__content flex justify-between items-center gap-4 w-full text-{{ settings.collection_card_text_alignment }} text-postion-{{ card_text_position }}">
        <div class="media-card__text shrink-1 grid gap-0d5">
          <p>
            <span
              class="heading reversed-link text-xl-3xl tracking-tighter leading-tight relative{{ title_shadow_class }}"
              style="font-size: {{ heading_font_size }}px"
            >
              {{- collection_title  -}}
            </span>
          </p>
          {%- if collection_description != blank -%}
            <p class="leading-none text-xs xl:text-sm">{{ collection_description }}</p>
          {%- endif -%}
        </div>
        {%- render 'icon', icon: 'arrow-right', size: 'xs', class: 'transform shrink-0' -%}
      </div>
    </div>
  {%- endif -%}
</div>
