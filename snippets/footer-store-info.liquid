  {%- capture block_content -%}
    <div class="details__content">
      <div class="store-info flex flex-col gap-3">
      {% if block.settings.hours != blank %}
        <div class="store-info-content">
          {% if block.settings.hours_icon != blank %}
          <div class="store-info-icon">
            <img src="{{ block.settings.hours_icon | img_url: 'master' }}" alt="hours" />
          </div>
          {% endif %}
          <div class="store-info-text">
            {{ block.settings.hours }}
          </div>
        </div>
        {% endif %}
      {% if block.settings.phone != blank %}
        <div class="store-info-content">
          {% if block.settings.phone_icon != blank %}
          <div class="store-info-icon">
            <img src="{{ block.settings.phone_icon | img_url: 'master' }}" alt="phone" />
          </div>
          {% endif %}
          <a href="tel:{{ block.settings.phone }}" class="store-info-text reversed-link">{{ block.settings.phone }}</a>
        </div>
        {% endif %}
      {% if block.settings.contact_text != blank %}
        <div class="store-info-content">
          {% if block.settings.contact_icon != blank %}
          <div class="store-info-icon">
            <img src="{{ block.settings.contact_icon | img_url: 'master' }}" alt="contact" />
          </div>
          {% endif %}
          <a {% if block.settings.contact_url %}href="{{ block.settings.contact_url }}"{% endif %} class="store-info-text {% if block.settings.contact_url %} reversed-link{% endif %}">{{ block.settings.contact_text }}</a>
        </div>
        {% endif %}
      {% if block.settings.chat_text != blank %}
        <div class="store-info-content">
          {% if block.settings.chat_icon != blank %}
          <div class="store-info-icon">
            <img src="{{ block.settings.chat_icon | img_url: 'master' }}" alt="chat" />
          </div>
          {% endif %}
          <a onclick="openWidget()">Live Chat</a>
          <!--a {% if block.settings.chat_url %}href="{{ block.settings.chat_url }}"{% endif %} class="store-info-text {% if block.settings.chat_url %} reversed-link{% endif %}">{{ block.settings.chat_text }}</a-->
        </div>
        {% endif %}
      {% if block.settings.locator_text != blank %}
        <div class="store-info-content">
          {% if block.settings.locator_icon != blank %}
          <div class="store-info-icon">
            <img src="{{ block.settings.locator_icon | img_url: 'master' }}" alt="locator" />
          </div>
          {% endif %}
          <a {% if block.settings.locator_url %}href="{{ block.settings.locator_url }}"{% endif %} class="store-info-text {% if block.settings.locator_url %} reversed-link{% endif %}">{{ block.settings.locator_text }}</a>
        </div>
        {% endif %}
      </div>
    </div>
    <style>
      @media (min-width: 1280px) {
        .footer__item--{{ block.id }} { width: calc({{ block.settings.container_width }}% - var(--sp-12)); }
      }
    </style>
  {%- endcapture -%}
  
  {%- if block.settings.heading == blank -%}
    <div class="footer__item--{{ block.id }} no-details" {{ block.shopify_attributes }}>
      {{- block_content -}}
    </div>
  {%- else -%}
    <details class="footer__item--{{ block.id }} details active" is="footer-details"{% if block.settings.opened %} data-opened{% endif %} {{ block.shopify_attributes }}>
      <summary class="details__summary flex items-center justify-between gap-2 cursor-pointer">
        <span class="heading text-base-2xl font-medium lg:font-heading">{{ block.settings.heading | escape }}</span>
        {%- render 'icon', icon: 'chevron-up' -%}
      </summary>
      {{- block_content -}}
    </details>
  {%- endif -%}
