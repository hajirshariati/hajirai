{%- doc -%}
  Renders a free shipping progress bar showing cart progress toward threshold.

  Displays dynamic messaging and visual progress, excluding gift wrap costs.
  Supports an optional second threshold with a custom gift/reward message.

  @param {number} minimum_amount - Free shipping threshold in store currency
  @param {number} second_threshold_amount - Optional second threshold in store currency
  @param {string} second_threshold_message - Message to show when second threshold is met

  @example
  {% render 'free-shipping-bar', minimum_amount: 50, second_threshold_amount: 100, second_threshold_message: 'You unlocked a free gift!' %}
{%- enddoc -%}

{%- liquid
  assign minimum_amount_in_cents = minimum_amount | times: 100
  assign total_price = cart.total_price

  if linklists.gift-wrapping.links != blank and linklists.gift-wrapping.links.first.type == 'product_link'
    assign gift_wrapping = linklists.gift-wrapping.links.first
    assign gift_wrap_id = gift_wrapping.object.variants.first.id
    assign gift_wraps_in_cart = 0
    for item in cart.items
      if item.id == gift_wrap_id
        assign gift_wraps_in_cart = item.price
        break
      endif
    endfor
    assign total_price = total_price | minus: gift_wraps_in_cart
  endif

  assign has_second_threshold = false
  if second_threshold_amount != blank and second_threshold_amount != nil and second_threshold_amount != 0
    assign second_threshold_amount_in_cents = second_threshold_amount | times: 100
    if second_threshold_amount_in_cents > minimum_amount_in_cents
      assign has_second_threshold = true
    endif
  endif

  comment
    Determine which "stage" the cart is in:
    - stage 0: below free shipping threshold
    - stage 1: met free shipping, below second threshold (or no second threshold)
    - stage 2: met second threshold
  endcomment

  assign bar_stage = 0
  if has_second_threshold
    if total_price >= second_threshold_amount_in_cents
      assign bar_stage = 2
    elsif total_price >= minimum_amount_in_cents
      assign bar_stage = 1
    endif
  else
    if total_price >= minimum_amount_in_cents
      assign bar_stage = 1
    endif
  endif

  comment
    Progress calculation.
    - Stage 0: progress toward first threshold, capped at 100%
    - Stage 1: if second threshold exists, show progress from first to second threshold; otherwise 100%
    - Stage 2: 100%
  endcomment

  if bar_stage == 2
    assign progress_percent = 100
  elsif bar_stage == 1
    if has_second_threshold
      assign range = second_threshold_amount_in_cents | minus: minimum_amount_in_cents
      assign earned_in_range = total_price | minus: minimum_amount_in_cents
      assign progress_percent = earned_in_range | times: 1.0 | divided_by: range | at_most: 1 | times: 100 | round
    else
      assign progress_percent = 100
    endif
  else
    assign progress_percent = total_price | times: 1.0 | divided_by: minimum_amount_in_cents | at_most: 1 | times: 100 | round
  endif
-%}

<div class="free-shipping-bar grid gap-3 w-full">
  {%- if bar_stage == 2 -%}
    {{- second_threshold_message -}}

{%- elsif bar_stage == 1 -%}
    <span class="text-sm leading-tight">{{ 'general.cart.free_shipping.congratulations_html' | t }}</span>

  {%- else -%}
    {%- capture remaining_amount -%}<span class="font-bold">{{ total_price | minus: minimum_amount_in_cents | abs | money }}</span>{%- endcapture -%}
    <span class="text-sm leading-tight">{{ 'general.cart.free_shipping.remaining_html' | t: remaining_amount: remaining_amount }}</span>
  {%- endif -%}

  <progress-bar class="overflow-hidden rounded-full" style="--progress: {{ progress_percent }}%;"></progress-bar>
</div>
