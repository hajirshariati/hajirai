{%- doc -%}
  Renders a mobile navigation drawer with menu, localization, and account features.

  Slides from left with nested navigation, language/currency selectors, and footer actions.

  @param {object} section - Section object with navigation and localization settings

  @example
  {% render 'header-drawer', section: section %}
{%- enddoc -%}

{%- liquid
assign section_rendering_api = false
if section.index == nil
  assign section_rendering_api = true
endif
-%}

<menu-drawer id="MenuDrawer" class="menu-drawer drawer drawer--start z-30 fixed bottom-0 left-0 h-full w-full pointer-events-none"
  data-section-id="{{ section.id }}"
  hidden
>
  <overlay-element class="overlay fixed-modal invisible opacity-0 fixed bottom-0 left-0 w-full h-screen pointer-events-none" aria-controls="MenuDrawer" aria-expanded="false"></overlay-element>
  <div class="drawer__inner z-10 absolute top-0 flex flex-col w-full h-full overflow-hidden">
    <button class="drawer__close-menu absolute z-20 flex items-center justify-center w-10 h-10 rounded-full bg-white shadow-md" type="button" aria-controls="MenuDrawer" aria-expanded="false" aria-label="{{ 'general.accessibility.close' | t | escape }}">
      {%- render 'icon', icon: 'close' -%}
    </button>
    <gesture-element class="drawer__header flex justify-between opacity-0 invisible relative">
      <span class="drawer__title heading lg:text-3xl text-2xl leading-none tracking-tight"></span>
      <button class="button button--secondary button--close drawer__close hidden sm:flex items-center justify-center" type="button" is="hover-button" aria-controls="MenuDrawer" aria-expanded="false" aria-label="{{ 'general.accessibility.close' | t | escape }}">
        <span class="btn-fill" data-fill></span>
        <span class="btn-text">
          {%- render 'icon', icon: 'close', size: 'sm' -%}
        </span>
      </button>
    </gesture-element>
    <div class="drawer__content opacity-0 invisible flex flex-col h-full grow shrink">
      <nav class="relative grow overflow-hidden" role="navigation">
        <ul class="drawer__scrollable drawer__menu relative w-full h-full" role="list" data-parent>
          {%- assign main_menu = section.settings.menu_mobile | default: section.settings.menu -%}
          {% assign additional_menu_index = 0 %}
          {%- for link in section.settings.abra_additional_menu.links -%}
            {% assign additional_menu_index = forloop.index %}
            <li class="drawer__menu-group" data-abra-promo="{{ section.settings.abra_additional_menu_code | handleize }}">
              {%- liquid
                assign enable_mega_menu = false
                assign mega_menu_block = nil
                assign link_title_handle = link.title | downcase | handle
          
                for block in section.blocks
                  assign menu_title_handle = block.settings.menu_title | downcase | handle
                  if menu_title_handle == link_title_handle
                    assign enable_mega_menu = true
                    assign mega_menu_block = block
                    break
                  endif
                endfor
              -%}

              {%- if link.links != blank or enable_mega_menu -%}
                {%- render 'header-nav-drawer', section: section, link: link, enable_mega_menu: enable_mega_menu, enable_accordion_menu: section.settings.accordion_menu_mobile, block: mega_menu_block, position: forloop.index -%}
              {%- else -%}
                <a class="drawer__menu-item block heading text-2xl leading-none tracking-tight" href="{{ link.url }}">{{ link.title | escape }}</a>
              {%- endif -%}
            </li>
          {%- endfor -%}
          {%- for link in main_menu.links -%}
            {% assign index = forloop.index | plus: additional_menu_index %}
            <li class="drawer__menu-group">
              {%- liquid
                assign enable_mega_menu = false
                assign mega_menu_block = nil
                assign link_title_handle = link.title | downcase | handle
          
                for block in section.blocks
                  assign menu_title_handle = block.settings.menu_title | downcase | handle
                  if menu_title_handle == link_title_handle
                    assign enable_mega_menu = true
                    assign mega_menu_block = block
                    break
                  endif
                endfor
              -%}

              {%- if link.links != blank or enable_mega_menu -%}
                {%- render 'header-nav-drawer', section: section, link: link, enable_mega_menu: enable_mega_menu, enable_accordion_menu: section.settings.accordion_menu_mobile, block: mega_menu_block, position: index -%}
              {%- else -%}
                <a class="drawer__menu-item block heading text-2xl leading-none tracking-tight" href="{{ link.url }}">{{ link.title | escape }}</a>
              {%- endif -%}
            </li>
          {%- endfor -%}

          {%- comment -%} Section-level promo images {%- endcomment -%}
          {%- liquid
              assign section_show_promotions = false
              if section.settings.promo_image_1 != blank or section.settings.promo_image_2 != blank
                  assign section_show_promotions = true
              endif
          -%}

          {%- if section_show_promotions -%}
              <li class="drawer__menu-group drawer__promotions">
                  <ul class="mega-menu__list grid grid-cols-2 w-full h-full" role="list" tabindex="-1">
                      {%- for i in (1..2) -%}
                          {%- liquid
                              assign promo_image = 'promo_image_' | append: i
                              assign show_section_promotion = false

                              if section.settings[promo_image] != blank
                                  assign show_section_promotion = true
                              endif
                          -%}
                          {%- if show_section_promotion -%}
                              {%- liquid
                                  assign abra_promo_code = 'abra_promo_code_' | append: i
                                  assign promo_image_abra = 'promo_image_abra_' | append: i
                                  assign promo_image_ratio = 'promo_image_ratio_' | append: i
                                  assign promo_heading = 'promo_heading_' | append: i
                                  assign promo_subtext = 'promo_subtext_' | append: i
                                  assign promo_overlay_content = 'promo_overlay_content_' | append: i
                                  assign promo_link = 'promo_link_' | append: i
                                  assign promo_tag = 'promo_tag_' | append: i
                                  assign promo_color_text = 'promo_color_text_' | append: i
                                  assign promo_color_overlay = 'promo_color_overlay_' | append: i
                                  assign promo_overlay_opacity = 'promo_overlay_opacity_' | append: i
                              -%}
                              <li class="flex w-full">
                                  <div class="media-card media-card--{{ settings.card_style }}{% if section.settings[promo_overlay_content] %} media-card--overlap{% endif %}">
                                      <a
                                              class="media-card__link flex flex-col w-full h-full relative"
                                              {% if section.settings[promo_link] != blank %}
                                                  href="{{ section.settings[promo_link] }}"
                                              {% else %}
                                                  role="link" aria-disabled="true"
                                              {% endif %}
                                      >
                                            <div class="media-card__media"{% if section.settings[abra_promo_code] != blank %} data-abra-default="{{ section.settings[abra_promo_code] | handleize }}"{% endif %}>
                                              {%- assign image_alt = section.settings[promo_image].alt | default: section.settings[promo_heading] -%}
                                              <img
                                                src="{{ section.settings[promo_image] | img_url: '600x600' }}"
                                                alt="{{ image_alt | escape }}"
                                                loading="lazy"
                                                class="media-card__image w-full h-full object-cover"
                                                {% if section.settings[promo_image_ratio] != 'adapt' %}
                                                  style="aspect-ratio: {% case section.settings[promo_image_ratio] %}{% when 'square' %}1/1{% when 'portrait' %}3/4{% when 'landscape' %}4/3{% when 'wide' %}16/9{% endcase %};"
                                                {% endif %}
                                              >
                                              {%- if section.settings[promo_overlay_content] -%}
                                                  <div
                                                          class="media-card__overlay absolute left-0 top-0 w-full h-full opacity-{{ section.settings[promo_overlay_opacity] }}"
                                                          style="background-color: {{ section.settings[promo_color_overlay] }};"
                                                  ></div>
                                              {%- endif -%}
                                          </div>
                                          {% if section.settings[promo_image_abra] != blank %}
                                            <div class="media-card__media"{% if section.settings[abra_promo_code] != blank %} data-abra-promo="{{ section.settings[abra_promo_code] | handleize }}"{% endif %}>
                                              {%- assign image_alt = section.settings[promo_image_abra].alt | default: section.settings[promo_heading] -%}
                                              <img
                                                src="{{ section.settings[promo_image_abra] | img_url: '600x600' }}"
                                                alt="{{ image_alt | escape }}"
                                                loading="lazy"
                                                class="media-card__image w-full h-full object-cover"
                                              >
                                              {%- if section.settings[promo_overlay_content] -%}
                                                  <div
                                                          class="media-card__overlay absolute left-0 top-0 w-full h-full opacity-{{ section.settings[promo_overlay_opacity] }}"
                                                          style="background-color: {{ section.settings[promo_color_overlay] }};"
                                                  ></div>
                                              {%- endif -%}
                                            </div>
                                          {% endif %}
                                          {%- if section.settings[promo_heading] != blank or section.settings[promo_subtext] != blank or section.settings[promo_tag] != blank -%}
                                              <div class="media-card__content{% if section.settings[promo_overlay_content] %} absolute left-0 top-0 w-full h-full flex flex-col justify-end{% endif %}">
                                                  <div class="media-card__info{% if section.settings[promo_overlay_content] %} p-4{% else %} pt-4{% endif %}">
                                                      {%- if section.settings[promo_tag] != blank -%}
                                                          <p class="media-card__tag caption-large"{% if section.settings[promo_overlay_content] %} style="color: {{ section.settings[promo_color_text] }};"{% endif %}>
                                                              {{- section.settings[promo_tag] | escape -}}
                                                          </p>
                                                      {%- endif -%}
                                                      {%- if section.settings[promo_heading] != blank -%}
                                                          <h3 class="media-card__heading heading text-lg"{% if section.settings[promo_overlay_content] %} style="color: {{ section.settings[promo_color_text] }};"{% endif %}>
                                                              {{- section.settings[promo_heading] | escape -}}
                                                          </h3>
                                                      {%- endif -%}
                                                      {%- if section.settings[promo_subtext] != blank -%}
                                                          <div class="media-card__text rte"{% if section.settings[promo_overlay_content] %} style="color: {{ section.settings[promo_color_text] }};"{% endif %}>
                                                              {{- section.settings[promo_subtext] -}}
                                                          </div>
                                                      {%- endif -%}
                                                  </div>
                                              </div>
                                          {%- endif -%}
                                      </a>
                                  </div>
                              </li>
                          {%- endif -%}
                      {%- endfor -%}
                  </ul>
              </li>
          {%- endif -%}
        </ul>
      </nav>
      <div class="drawer__footer grid w-full">
        {%- liquid
          if section.settings.enable_language_selector and localization.available_languages.size > 1
            assign enable_language_selector = true
          endif
          if section.settings.enable_country_selector and localization.available_countries.size > 1
            assign enable_country_selector = true
          endif
        -%}
        {%- if enable_language_selector or enable_country_selector -%}
          <div class="drawer__footer-top flex">
            {%- if enable_language_selector -%}
              <button type="button" class="flex gap-3 grow items-center justify-between" aria-controls="LocalizationLanguage-{{ section.id }}" aria-expanded="false">
                {%- unless section_rendering_api -%}
                  <api-button class="api-only" data-id="header_drawer_localization_language_form" data-section-id="{{ section.id }}"></api-button>
                {%- endunless -%}
                <span class="text-sm leading-none flex items-center gap-2 w-auto">
                  {%- render 'icon', icon: 'language', size: 'xs', class: 'stroke-1 hidden md:block shrink-0' -%}
                  {{- localization.language.endonym_name | capitalize -}}
                </span>
                {%- render 'icon', icon: 'chevron-down', size: 'xs', class: 'shrink-0' -%}
              </button>
            {%- endif -%}
            {%- if enable_country_selector -%}
              <button type="button" class="flex gap-3 grow items-center justify-between" aria-controls="LocalizationCountry-{{ section.id }}" aria-expanded="false"> 
                {%- unless section_rendering_api -%}
                  <api-button class="api-only" data-id="header_drawer_localization_country_form" data-section-id="{{ section.id }}"></api-button>
                {%- endunless -%}
                <span class="text-sm leading-none flex items-center gap-2 w-auto">
                  {%- render 'icon', icon: 'currency', size: 'xs', class: 'stroke-1 hidden md:block shrink-0' -%}
                  {{- localization.country.name }} ({{ localization.country.currency.iso_code }} {{ localization.country.currency.symbol }})
                </span>
                {%- render 'icon', icon: 'chevron-down', size: 'xs', class: 'shrink-0' -%}
              </button>
            {%- endif -%}

            {%- if enable_language_selector -%}
              <modal-element id="LocalizationLanguage-{{ section.id }}" class="modal invisible absolute bottom-0 left-0 w-full h-full" role="dialog" hidden>
                <overlay-element class="fixed-modal opacity-0 z-1 absolute top-0 left-0 w-full h-full" aria-controls="LocalizationLanguage-{{ section.id }}" aria-expanded="false"></overlay-element>
                <div class="modal__container flex flex-col z-3 absolute left-0 bottom-0 w-full">
                  <button class="close items-center justify-center absolute top-0 right-0" type="button" is="magnet-button" aria-controls="LocalizationLanguage-{{ section.id }}" aria-expanded="false" aria-label="{{ 'general.accessibility.close' | t | escape }}">
                    <span class="inline-block" data-text>
                      {%- render 'icon', icon: 'close' -%}
                    </span>
                  </button>
                  {%- unless section_rendering_api -%}
                    <div class="modal__content flex flex-col overflow-hidden" id="header_drawer_localization_language_form"></div>
                  {%- else -%}
                    {%- form 'localization', id: 'header_drawer_localization_language_form', class: 'modal__content flex flex-col overflow-hidden', is: 'localization-listbox' -%}
                      <ul class="modal__scrollable listbox grid gap-1d5 xl:gap-2" role="list" tabindex="-1">
                        {%- for language in localization.available_languages -%}
                          <li class="opacity-0">
                            <a class="text-sm reversed-link{% if language.iso_code == localization.language.iso_code %} active{% endif %}"
                              href="#"
                              hreflang="{{ language.iso_code }}"
                              lang="{{ language.iso_code }}"
                              {% if language.iso_code == localization.language.iso_code %}
                                aria-current="true"
                              {% endif %}
                              data-value="{{ language.iso_code }}"
                              title="{{ language.endonym_name | capitalize | escape }}"
                              data-no-instant
                            >
                              {{- language.endonym_name | capitalize -}}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                      <input type="hidden" name="locale_code" value="{{ localization.language.iso_code }}" />
                    {%- endform -%}
                  {%- endunless -%}
                </div>
              </modal-element>
            {%- endif -%}
            {%- if enable_country_selector -%}
              <modal-element id="LocalizationCountry-{{ section.id }}" class="modal invisible absolute bottom-0 left-0 w-full h-full" role="dialog" hidden>
                <overlay-element class="fixed-modal opacity-0 z-1 absolute top-0 left-0 w-full h-full" aria-controls="LocalizationCountry-{{ section.id }}" aria-expanded="false"></overlay-element>
                <div class="modal__container flex flex-col z-3 absolute left-0 bottom-0 w-full">
                  <button class="close items-center justify-center absolute top-0 right-0" type="button" aria-controls="LocalizationCountry-{{ section.id }}" aria-expanded="false" is="magnet-button" aria-label="{{ 'general.accessibility.close' | t | escape }}">
                    <span class="inline-block" data-text>
                      {%- render 'icon', icon: 'close' -%}
                    </span>
                  </button>
                  {%- unless section_rendering_api -%}
                    <div class="modal__content flex flex-col overflow-hidden" id="header_drawer_localization_country_form"></div>
                  {%- else -%}
                    {%- form 'localization', id: 'header_drawer_localization_country_form', class: 'modal__content flex flex-col overflow-hidden', is: 'localization-listbox' -%}
                      {%- render 'corner', dir: 'top', prefix: 'dropdown' -%}
                      <ul class="modal__scrollable listbox grid gap-1d5 xl:gap-2" role="list" tabindex="-1">
                        {%- for country in localization.available_countries -%}
                          <li class="opacity-0">
                            <a class="text-sm reversed-link{% if country.iso_code == localization.country.iso_code %} active{% endif %}"
                              href="#"
                              {% if country.iso_code == localization.country.iso_code %}
                                aria-current="true"
                              {% endif %}
                              data-value="{{ country.iso_code }}"
                              title="{{ country.name | escape }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})"
                              data-no-instant
                            >
                              {{- country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                      <input type="hidden" name="country_code" value="{{ localization.country.iso_code }}" />
                    {%- endform -%}
                  {%- endunless -%}
                </div>
              </modal-element>
            {%- endif -%}
          </div>
        {%- endif -%}
        <div class="drawer__footer-bottom flex items-center justify-between gap-6">
          {%- if shop.customer_accounts_enabled -%}
            <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="button button--primary icon-with-text" is="hover-link" rel="nofollow">
              <span class="btn-fill" data-fill></span>
              <span class="btn-text">
                {%- liquid
                  render 'icon', icon: 'account-2', size: 'xs'
                  if customer
                    echo 'customer.account.title' | t
                  else
                    echo 'customer.login.title' | t
                  endif
                -%}
              </span>
            </a>
          {%- endif -%}
          {%- liquid
            if section.settings.show_social
              render 'social-icons', size: 'sm', gap: '6'
            endif
          -%}
        </div>
      </div>
    </div>
  </div>
</menu-drawer>
