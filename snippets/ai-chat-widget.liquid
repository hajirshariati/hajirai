{%- comment -%}
  AI Chat Widget – Aetrex Store (Redesigned)
  Renders a search-bar style launcher + modal chat widget powered by Claude AI + Shopify MCP.
  Controlled via Theme Settings > AI Chat Assistant.
{%- endcomment -%}

{%- if settings.ai_chat_enabled -%}
  {%- comment -%} Hide on technology pages if toggle is on {%- endcomment -%}
  {%- assign current_path = request.path | downcase -%}
  {%- if settings.ai_chat_hide_tech_pages and current_path contains '/pages/tech' -%}
    {%- comment -%} Tech page — bot hidden {%- endcomment -%}
  {%- else -%}
  {%- comment -%} Pass configuration to JavaScript {%- endcomment -%}
  <script>
    window.__AI_CHAT_CONFIG = {
      apiUrl: {{ settings.ai_chat_api_url | json }},
      shopDomain: {{ shop.permanent_domain | json }},
      greeting: {{ settings.ai_chat_greeting | default: "Hi, I'm Archie — your personal fit and comfort expert. I'll help you find the right shoes, sandals, or orthotics based on your foot type, support needs, and daily lifestyle." | json }},
      greetingCta: {{ settings.ai_chat_greeting_cta | default: "What can I help you find today?" | json }},
      avatarUrl: {% if settings.ai_chat_avatar != blank %}{{ settings.ai_chat_avatar | image_url: width: 200 | json }}{% else %}""{% endif %},
      bannerUrl: {% if settings.ai_chat_banner != blank %}{{ settings.ai_chat_banner | image_url: width: 800 | json }}{% else %}""{% endif %},
      assistantName: {{ settings.ai_chat_assistant_name | default: "Archie by Aetrex" | json }},
      assistantTagline: {{ settings.ai_chat_tagline | default: "Smart Support for Every Step" | json }},
      launcherPlaceholder: {{ settings.ai_chat_launcher_placeholder | default: "How can Archie help your feet today?" | json }},
      inputPlaceholder: {{ settings.ai_chat_input_placeholder | default: "How can Archie help your feet today?" | json }},
      widgetPosition: {{ settings.ai_chat_position | default: "bottom-center" | json }},
      cta1Label: {{ settings.ai_chat_cta1_label | default: "Women's Shoes" | json }},
      cta1Message: {{ settings.ai_chat_cta1_message | default: "Show me women's shoes" | json }},
      cta2Label: {{ settings.ai_chat_cta2_label | default: "Men's Shoes" | json }},
      cta2Message: {{ settings.ai_chat_cta2_message | default: "Show me men's shoes" | json }},
      cta3Label: {{ settings.ai_chat_cta3_label | default: "Orthotics" | json }},
      cta3Message: {{ settings.ai_chat_cta3_message | default: "Help me find the right orthotic" | json }},
      cta4Label: {{ settings.ai_chat_cta4_label | default: "Foot Pain Relief" | json }},
      cta4Message: {{ settings.ai_chat_cta4_message | default: "I have foot pain and need help" | json }},
      ctaHint: {{ settings.ai_chat_cta_hint | default: "" | json }},
      quickPick1Label: {{ settings.ai_chat_qp1_label | default: "Arch Support" | json }},
      quickPick1Message: {{ settings.ai_chat_qp1_message | default: "Show me shoes with the best arch support" | json }},
      quickPick2Label: {{ settings.ai_chat_qp2_label | default: "Flat Feet" | json }},
      quickPick2Message: {{ settings.ai_chat_qp2_message | default: "I have flat feet, what do you recommend?" | json }},
      quickPick3Label: {{ settings.ai_chat_qp3_label | default: "Walking Shoes" | json }},
      quickPick3Message: {{ settings.ai_chat_qp3_message | default: "Show me the best walking shoes" | json }},
      quickPick4Label: {{ settings.ai_chat_qp4_label | default: "Plantar Fasciitis" | json }},
      quickPick4Message: {{ settings.ai_chat_qp4_message | default: "I have plantar fasciitis, what shoes help?" | json }},
      showBanner: {{ settings.ai_chat_show_banner | default: true | json }},
      launcherWidth: {{ settings.ai_chat_launcher_width | default: "500" | json }},
      disclaimerText: {{ settings.ai_chat_disclaimer | default: "Powered by Aetrex fit technology · Not medical advice" | json }},
      privacyUrl: {{ settings.ai_chat_privacy_url | default: "/pages/privacy-policy" | json }}
    };
  </script>

  {%- comment -%} Inject custom colour properties if set {%- endcomment -%}
  <style>
    :root {
      {%- if settings.ai_chat_color_primary != blank -%}
        --ai-chat-color-primary: {{ settings.ai_chat_color_primary }};
      {%- endif -%}
      {%- if settings.ai_chat_color_accent != blank -%}
        --ai-chat-color-accent: {{ settings.ai_chat_color_accent }};
      {%- endif -%}
      {%- if settings.ai_chat_color_cta_bg != blank -%}
        --ai-chat-cta-bg: {{ settings.ai_chat_color_cta_bg }};
      {%- endif -%}
      {%- if settings.ai_chat_color_cta_text != blank -%}
        --ai-chat-cta-text: {{ settings.ai_chat_color_cta_text }};
      {%- endif -%}
      {%- if settings.ai_chat_color_cta_hover != blank -%}
        --ai-chat-cta-hover: {{ settings.ai_chat_color_cta_hover }};
      {%- endif -%}
    }
    .ai-chat-overlay.visible {
      background: rgba(0, 0, 0, 0.4) !important;
    }
    body.ai-chat-blurred > *:not(.ai-chat-overlay):not(.ai-chat-panel):not(.ai-chat-launcher) {
      filter: blur(6px) !important;
      pointer-events: none !important;
      user-select: none !important;
    }
    body.ai-chat-blurred {
      overflow: hidden !important;
    }
    .ai-chat-panel.ai-chat-glow { overflow: hidden; }
    .ai-chat-panel.ai-chat-glow::before {
      content: '';
      position: absolute;
      top: 50%; left: 50%;
      width: 150%; height: 150%;
      margin-top: -75%; margin-left: -75%;
      border-radius: 0;
      z-index: 9999;
      pointer-events: none;
      background: conic-gradient(
        from 0deg at 50% 50%,
        transparent 0deg,
        transparent 260deg,
        #2d6b4f 290deg,
        #3a9d6a 310deg,
        #b8956a 330deg,
        #d4c4a0 345deg,
        #b8956a 355deg,
        transparent 360deg
      );
      filter: blur(18px);
      opacity: 0;
      animation: ai-glow-spin 3s ease-in-out forwards;
    }
    .ai-chat-panel.ai-chat-glow::after {
      content: '';
      position: absolute;
      inset: 4px;
      background: #fff;
      border-radius: 12px;
      z-index: 9999;
      pointer-events: none;
      opacity: 0;
      animation: ai-glow-mask 3s ease-in-out forwards;
    }
    @keyframes ai-glow-spin {
      0%   { opacity: 0; transform: rotate(0deg); }
      8%   { opacity: 0.9; }
      85%  { opacity: 0.9; transform: rotate(360deg); }
      100% { opacity: 0; transform: rotate(400deg); }
    }
    @keyframes ai-glow-mask {
      0%   { opacity: 0; }
      8%   { opacity: 1; }
      85%  { opacity: 1; }
      100% { opacity: 0; }
    }
  </style>

  {{ 'ai-chat-widget.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'ai-chat-widget.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
{%- endif -%}
