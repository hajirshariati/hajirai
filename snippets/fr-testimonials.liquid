<section class="fr-testimonials">
  {% assign fr_testimonial_product_id = '' %}

  {% if product.metafields.custom.frontrow == 'mens' %}
    {% assign fr_testimonial_product_id = '3255' %}
  {% elsif product.metafields.custom.frontrow == 'skytech' %}
    {% assign fr_testimonial_product_id = '3252' %}
  {% elsif product.metafields.custom.frontrow == '20' %}
    {% assign fr_testimonial_product_id = '3250' %}
  {% elsif product.metafields.custom.frontrow == '05' %}
    {% assign fr_testimonial_product_id = '3248' %}
  {% elsif product.metafields.custom.frontrow == '00' %}
    {% assign fr_testimonial_product_id = '3246' %}
  {% endif %}

  {% if fr_testimonial_product_id != '' %}
    <script
      async
      type="text/javascript"
      src="https://app.thefrontrowhealth.com/api/widgets/script?presentation_type=qual&product_id={{ fr_testimonial_product_id }}">
    </script>

    <iframe
      id="frontrow-testimonials"
      class="iframe-frontrow-testimonials"
      frameborder="0"
      src="https://app.thefrontrowhealth.com/api/widgets?presentation_type=qual&product_id={{ fr_testimonial_product_id }}">
    </iframe>
  {% endif %}

  <style>
    iframe.iframe-frontrow-testimonials {
      width: 100%;
    }
    iframe.iframe-modal-testimonials {
      z-index: 99999998;
    }
  </style>
</section>
