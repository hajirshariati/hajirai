{% doc %}
  @prompt
    A magazine-style editorial layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-editorial-layout-{{ ai_gen_id }} {
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-editorial-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.content_spacing }}px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-editorial-hero-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    aspect-ratio: 16/9;
    background-color: {{ block.settings.image_background_color }};
  }

  .ai-editorial-hero-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-editorial-hero-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.image_background_color }};
    position: relative;
  }

  .ai-editorial-hero-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
    opacity: 0.3;
  }

  .ai-editorial-hero-overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(0, 0, 0, {{ block.settings.overlay_opacity | divided_by: 100.0 }}));
    padding: 40px;
    color: {{ block.settings.overlay_text_color }};
  }

  .ai-editorial-hero-category-{{ ai_gen_id }} {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: {{ block.settings.category_color }};
    margin-bottom: 8px;
    display: block;
  }

  .ai-editorial-hero-title-{{ ai_gen_id }} {
    font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    font-weight: {{ settings.type_header_font.weight }};
    font-size: {{ block.settings.hero_title_size }}px;
    line-height: 1.2;
    margin: 0 0 12px;
    color: {{ block.settings.overlay_text_color }};
  }

  .ai-editorial-hero-excerpt-{{ ai_gen_id }} {
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-size: {{ block.settings.hero_text_size }}px;
    line-height: 1.5;
    margin: 0 0 16px;
    color: {{ block.settings.overlay_text_color }};
    opacity: 0.9;
  }

  .ai-editorial-hero-meta-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.overlay_text_color }};
    opacity: 0.8;
  }

  .ai-editorial-content-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: {{ block.settings.content_spacing }}px;
    margin-top: {{ block.settings.content_spacing }}px;
  }

  .ai-editorial-main-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_spacing }}px;
  }

  .ai-editorial-article-{{ ai_gen_id }} {
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-size: {{ block.settings.body_text_size }}px;
    line-height: 1.7;
    color: {{ block.settings.text_color }};
  }

  .ai-editorial-article-{{ ai_gen_id }} h2 {
    font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    font-weight: {{ settings.type_header_font.weight }};
    font-size: {{ block.settings.subheading_size }}px;
    line-height: 1.3;
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px;
  }

  .ai-editorial-article-{{ ai_gen_id }} p {
    margin: 0 0 20px;
  }

  .ai-editorial-article-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-editorial-sidebar-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.sidebar_spacing }}px;
  }

  .ai-editorial-sidebar-item-{{ ai_gen_id }} {
    padding: {{ block.settings.sidebar_padding }}px;
    background-color: {{ block.settings.sidebar_background }};
    border-radius: {{ block.settings.sidebar_border_radius }}px;
    border: 1px solid {{ block.settings.sidebar_border_color }};
  }

  .ai-editorial-sidebar-title-{{ ai_gen_id }} {
    font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    font-weight: {{ settings.type_header_font.weight }};
    font-size: {{ block.settings.sidebar_title_size }}px;
    line-height: 1.3;
    color: {{ block.settings.sidebar_title_color }};
    margin: 0 0 12px;
  }

  .ai-editorial-sidebar-content-{{ ai_gen_id }} {
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-size: {{ block.settings.sidebar_text_size }}px;
    line-height: 1.5;
    color: {{ block.settings.sidebar_text_color }};
  }

  .ai-editorial-sidebar-content-{{ ai_gen_id }} p {
    margin: 0 0 12px;
  }

  .ai-editorial-sidebar-content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-editorial-quote-{{ ai_gen_id }} {
    border-left: 4px solid {{ block.settings.quote_accent_color }};
    padding: 24px;
    margin: 32px 0;
    background-color: {{ block.settings.quote_background }};
    border-radius: {{ block.settings.quote_border_radius }}px;
  }

  .ai-editorial-quote-text-{{ ai_gen_id }} {
    font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    font-size: {{ block.settings.quote_text_size }}px;
    line-height: 1.4;
    color: {{ block.settings.quote_text_color }};
    font-style: italic;
    margin: 0 0 12px;
  }

  .ai-editorial-quote-author-{{ ai_gen_id }} {
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-size: 14px;
    color: {{ block.settings.quote_author_color }};
    font-weight: 600;
    margin: 0;
  }

  .ai-editorial-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 6px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 768px) {
    .ai-editorial-layout-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.6 }}px 16px;
    }

    .ai-editorial-content-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.content_spacing | times: 0.8 }}px;
    }

    .ai-editorial-hero-overlay-{{ ai_gen_id }} {
      padding: 24px;
    }

    .ai-editorial-hero-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.hero_title_size | times: 0.8 }}px;
    }

    .ai-editorial-hero-excerpt-{{ ai_gen_id }} {
      font-size: {{ block.settings.hero_text_size | times: 0.9 }}px;
    }

    .ai-editorial-article-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_text_size | times: 0.9 }}px;
    }

    .ai-editorial-article-{{ ai_gen_id }} h2 {
      font-size: {{ block.settings.subheading_size | times: 0.8 }}px;
    }

    .ai-editorial-sidebar-item-{{ ai_gen_id }} {
      padding: {{ block.settings.sidebar_padding | times: 0.8 }}px;
    }

    .ai-editorial-quote-{{ ai_gen_id }} {
      padding: 20px;
      margin: 24px 0;
    }

    .ai-editorial-quote-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.quote_text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-editorial-layout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-editorial-container-{{ ai_gen_id }}">
    <div class="ai-editorial-hero-{{ ai_gen_id }}">
      {% if block.settings.hero_image %}
        <img
          src="{{ block.settings.hero_image | image_url: width: 1200 }}"
          alt="{{ block.settings.hero_image.alt | escape }}"
          class="ai-editorial-hero-image-{{ ai_gen_id }}"
          loading="lazy"
          width="{{ block.settings.hero_image.width }}"
          height="{{ block.settings.hero_image.height }}"
        >
      {% else %}
        <div class="ai-editorial-hero-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-editorial-empty-state-{{ ai_gen_id }}">
            Add a hero image to get started
          </div>
        </div>
      {% endif %}

      {% if block.settings.show_hero_overlay %}
        <div class="ai-editorial-hero-overlay-{{ ai_gen_id }}">
          {% if block.settings.hero_category != blank %}
            <span class="ai-editorial-hero-category-{{ ai_gen_id }}">{{ block.settings.hero_category }}</span>
          {% endif %}
          
          {% if block.settings.hero_title != blank %}
            <h1 class="ai-editorial-hero-title-{{ ai_gen_id }}">{{ block.settings.hero_title }}</h1>
          {% endif %}
          
          {% if block.settings.hero_excerpt != blank %}
            <p class="ai-editorial-hero-excerpt-{{ ai_gen_id }}">{{ block.settings.hero_excerpt }}</p>
          {% endif %}
          
          {% if block.settings.hero_author != blank or block.settings.hero_date != blank %}
            <div class="ai-editorial-hero-meta-{{ ai_gen_id }}">
              {% if block.settings.hero_author != blank %}
                By {{ block.settings.hero_author }}
              {% endif %}
              {% if block.settings.hero_author != blank and block.settings.hero_date != blank %}
                •
              {% endif %}
              {% if block.settings.hero_date != blank %}
                {{ block.settings.hero_date }}
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>

    <div class="ai-editorial-content-grid-{{ ai_gen_id }}">
      <div class="ai-editorial-main-content-{{ ai_gen_id }}">
        {% if block.settings.article_content != blank %}
          <div class="ai-editorial-article-{{ ai_gen_id }}">
            {{ block.settings.article_content }}
          </div>
        {% endif %}

        {% if block.settings.show_quote and block.settings.quote_text != blank %}
          <div class="ai-editorial-quote-{{ ai_gen_id }}">
            <p class="ai-editorial-quote-text-{{ ai_gen_id }}">"{{ block.settings.quote_text }}"</p>
            {% if block.settings.quote_author != blank %}
              <p class="ai-editorial-quote-author-{{ ai_gen_id }}">— {{ block.settings.quote_author }}</p>
            {% endif %}
          </div>
        {% endif %}
      </div>

      <div class="ai-editorial-sidebar-{{ ai_gen_id }}">
        {% if block.settings.sidebar_item_1_title != blank or block.settings.sidebar_item_1_content != blank %}
          <div class="ai-editorial-sidebar-item-{{ ai_gen_id }}">
            {% if block.settings.sidebar_item_1_title != blank %}
              <h3 class="ai-editorial-sidebar-title-{{ ai_gen_id }}">{{ block.settings.sidebar_item_1_title }}</h3>
            {% endif %}
            {% if block.settings.sidebar_item_1_content != blank %}
              <div class="ai-editorial-sidebar-content-{{ ai_gen_id }}">
                {{ block.settings.sidebar_item_1_content }}
              </div>
            {% endif %}
          </div>
        {% endif %}

        {% if block.settings.sidebar_item_2_title != blank or block.settings.sidebar_item_2_content != blank %}
          <div class="ai-editorial-sidebar-item-{{ ai_gen_id }}">
            {% if block.settings.sidebar_item_2_title != blank %}
              <h3 class="ai-editorial-sidebar-title-{{ ai_gen_id }}">{{ block.settings.sidebar_item_2_title }}</h3>
            {% endif %}
            {% if block.settings.sidebar_item_2_content != blank %}
              <div class="ai-editorial-sidebar-content-{{ ai_gen_id }}">
                {{ block.settings.sidebar_item_2_content }}
              </div>
            {% endif %}
          </div>
        {% endif %}

        {% if block.settings.sidebar_item_3_title != blank or block.settings.sidebar_item_3_content != blank %}
          <div class="ai-editorial-sidebar-item-{{ ai_gen_id }}">
            {% if block.settings.sidebar_item_3_title != blank %}
              <h3 class="ai-editorial-sidebar-title-{{ ai_gen_id }}">{{ block.settings.sidebar_item_3_title }}</h3>
            {% endif %}
            {% if block.settings.sidebar_item_3_content != blank %}
              <div class="ai-editorial-sidebar-content-{{ ai_gen_id }}">
                {{ block.settings.sidebar_item_3_content }}
              </div>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

