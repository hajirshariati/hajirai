{% doc %}
  @prompt
    I need to improve the Customer Login section — it should be modern and easy to access. It can have an image on one side and the Customer Login on the other., I need to improve the Customer Login section — it should be modern and easy to access. It can have an image on one side and the Customer Login on the other., I need this Customer Login section to be modern and easy to access. It can have an image on one side and the Customer Login on the other. The store login must work properly — I’m leaving you the code so you can make the login, links, and access functions work.
    
    <style>
      #shopify-section-{{ section.id }} {
        --section-padding-top: {{ section.settings.padding_top }}px;
        --section-padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    </style>
    
    {{ 'customer.css' | asset_url | stylesheet_tag }}
    
    <div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
      <div class="page-width relative">
        <div id="Recover" class="title-wrapper{% if section.settings.heading_size == 'title-xl' %} title-wrapper-lg{% endif %} text-center leading-none hidden gap-4">
          <{{ section.settings.heading_tag }} class="heading {{ section.settings.heading_size }}" tabindex="-1">
            <split-words class="split-words js-invisible block" data-animate="fade-up-large">{{ 'customer.recover_password.title' | t }}</split-words>
          </{{ section.settings.heading_tag }}>
          <p class="text-lg md:text-2xl">{{ 'customer.recover_password.subtext' | t }}</p>
        </div>
    
        <div class="customer hidden">
          {%- form 'recover_customer_password', class: 'grid gap-12' -%}
            {%- liquid
              if form.errors
                assign form_errors = form.errors | default_errors
                render 'alert', status: 'error', content: form_errors
              endif
    
              assign recover_success = form.posted_successfully?
            -%}
    
            <div class="field">
              <input
                required
                class="input is-floating{% if form.errors %} invalid{% endif %}"
                type="email"
                value=""
                name="email"
                id="RecoverEmail"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                place
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-customer-login-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: {{ block.settings.section_height }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    margin: {{ block.settings.margin_top }}px auto {{ block.settings.margin_bottom }}px;
    max-width: {{ block.settings.max_width }}px;
  }

  .ai-customer-login-image-{{ ai_gen_id }} {
    position: relative;
    background-color: {{ block.settings.image_background_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .ai-customer-login-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-customer-login-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.image_background_color }};
    position: relative;
  }

  .ai-customer-login-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
    color: {{ block.settings.text_color | color_modify: 'alpha', 0.3 }};
  }

  .ai-customer-login-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    background-color: rgba(255, 255, 255, 0.95);
    border-radius: 8px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
    backdrop-filter: blur(4px);
  }

  .ai-customer-login-form-container-{{ ai_gen_id }} {
    padding: {{ block.settings.form_padding }}px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background-color: {{ block.settings.form_background_color }};
  }

  .ai-customer-login-form-content-{{ ai_gen_id }} {
    max-width: 400px;
    width: 100%;
    margin: 0 auto;
  }

  .ai-customer-login-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 32px;
  }

  .ai-customer-login-title-{{ ai_gen_id }} {
    font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    font-weight: {{ settings.type_header_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px;
    line-height: 1.2;
    letter-spacing: {{ settings.type_header_spacing | divided_by: 1000.0 }}em;
  }

  .ai-customer-login-subtitle-{{ ai_gen_id }} {
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: {{ settings.type_body_line_height }};
    letter-spacing: {{ settings.type_body_spacing | divided_by: 1000.0 }}em;
  }

  .ai-customer-login-form-{{ ai_gen_id }} {
    display: grid;
    gap: 20px;
  }

  .ai-customer-login-field-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-customer-login-label-{{ ai_gen_id }} {
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-size: 14px;
    font-weight: 500;
    color: {{ block.settings.text_color }};
    margin-bottom: 8px;
    display: block;
  }

  .ai-customer-login-input-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px;
    border: {{ settings.inputs_border_thickness }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_background_color }};
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-size: 16px;
    color: {{ block.settings.text_color }};
    transition: all 0.3s ease;
    box-sizing: border-box;
  }

  .ai-customer-login-input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_color }};
    box-shadow: 0 0 0 3px {{ block.settings.input_focus_color | color_modify: 'alpha', 0.1 }};
  }

  .ai-customer-login-input-{{ ai_gen_id }}.invalid {
    border-color: {{ settings.color_error_text }};
  }

  .ai-customer-login-input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.placeholder_color }};
  }

  .ai-customer-login-button-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px 32px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ settings.buttons_border_thickness }}px solid {{ block.settings.button_background_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    {% if settings.type_button_font == 'heading' %}
      font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    {% else %}
      font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    {% endif %}
    font-size: {{ settings.type_button_size }}px;
    font-weight: {{ settings.type_button_weight }};
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 8px;
    {% if settings.type_button_capitalize %}
      text-transform: uppercase;
    {% endif %}
    letter-spacing: {{ settings.type_body_spacing | divided_by: 1000.0 }}em;
  }

  .ai-customer-login-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    border-color: {{ block.settings.button_hover_color }};
    {% if settings.buttons_hover == 'standard' %}
      transform: translateY(-1px);
    {% endif %}
  }

  .ai-customer-login-button-{{ ai_gen_id }}:active {
    transform: translateY(0);
  }

  .ai-customer-login-forgot-password-{{ ai_gen_id }} {
    text-align: center;
    margin-top: 16px;
  }

  .ai-customer-login-forgot-link-{{ ai_gen_id }} {
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-size: 14px;
    color: {{ block.settings.link_color }};
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .ai-customer-login-forgot-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
    text-decoration: underline;
  }

  .ai-customer-login-create-account-{{ ai_gen_id }} {
    text-align: center;
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid {{ block.settings.divider_color }};
  }

  .ai-customer-login-create-text-{{ ai_gen_id }} {
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-size: 14px;
    color: {{ block.settings.subtitle_color }};
    margin: 0 0 12px;
  }

  .ai-customer-login-create-link-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: transparent;
    color: {{ block.settings.secondary_button_color }};
    border: 2px solid {{ block.settings.secondary_button_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    {% if settings.type_button_font == 'heading' %}
      font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    {% else %}
      font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    {% endif %}
    font-size: {{ settings.type_button_size }}px;
    font-weight: {{ settings.type_button_weight }};
    text-decoration: none;
    transition: all 0.3s ease;
    {% if settings.type_button_capitalize %}
      text-transform: uppercase;
    {% endif %}
  }

  .ai-customer-login-create-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_button_color }};
    color: {{ block.settings.secondary_button_text_color }};
  }

  .ai-customer-login-alert-{{ ai_gen_id }} {
    padding: 12px 16px;
    border-radius: 8px;
    font-size: 14px;
    margin-bottom: 20px;
    line-height: 1.4;
  }

  .ai-customer-login-alert-error-{{ ai_gen_id }} {
    background-color: {{ settings.color_error_background }};
    color: {{ settings.color_error_text }};
    border-left: 4px solid {{ settings.color_error_text }};
  }

  .ai-customer-login-alert-success-{{ ai_gen_id }} {
    background-color: {{ settings.color_success_background }};
    color: {{ settings.color_success_text }};
    border-left: 4px solid {{ settings.color_success_text }};
  }

  .ai-customer-login-recover-{{ ai_gen_id }} {
    display: none;
  }

  .ai-customer-login-recover-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-customer-login-main-{{ ai_gen_id }}.hidden {
    display: none;
  }

  .ai-customer-login-back-link-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-size: 14px;
    color: {{ block.settings.link_color }};
    text-decoration: none;
    margin-bottom: 20px;
    transition: color 0.3s ease;
  }

  .ai-customer-login-back-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  @media screen and (max-width: 768px) {
    .ai-customer-login-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      min-height: auto;
      margin: {{ block.settings.margin_top | times: 0.5 }}px auto {{ block.settings.margin_bottom | times: 0.5 }}px;
    }

    {% if block.settings.mobile_layout == 'form_only' %}
      .ai-customer-login-image-{{ ai_gen_id }} {
        display: none;
      }
    {% else %}
      .ai-customer-login-image-{{ ai_gen_id }} {
        min-height: 200px;
        order: -1;
      }
    {% endif %}

    .ai-customer-login-form-container-{{ ai_gen_id }} {
      padding: {{ block.settings.form_padding | times: 0.7 }}px;
    }

    .ai-customer-login-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<customer-login-{{ ai_gen_id }} class="ai-customer-login-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-customer-login-image-{{ ai_gen_id }}">
    {% if block.settings.image %}
      <img
        src="{{ block.settings.image | image_url: width: 800 }}"
        alt="{{ block.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.height }}"
      >
    {% else %}
      <div class="ai-customer-login-image-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-customer-login-empty-state-{{ ai_gen_id }}">
          Add an image to enhance your login experience
        </div>
      </div>
    {% endif %}
  </div>

  <div class="ai-customer-login-form-container-{{ ai_gen_id }}">
    <div class="ai-customer-login-form-content-{{ ai_gen_id }}">
      
      <!-- Main Login Form -->
      <div class="ai-customer-login-main-{{ ai_gen_id }}">
        <div class="ai-customer-login-header-{{ ai_gen_id }}">
          <h1 class="ai-customer-login-title-{{ ai_gen_id }}">{{ block.settings.title }}</h1>
          {% if block.settings.subtitle != blank %}
            <p class="ai-customer-login-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
          {% endif %}
        </div>

        {% form 'customer_login', novalidate: 'novalidate' %}
          {% if form.errors %}
            <div class="ai-customer-login-alert-{{ ai_gen_id }} ai-customer-login-alert-error-{{ ai_gen_id }}">
              {{ form.errors | default_errors }}
            </div>
          {% endif %}

          <div class="ai-customer-login-form-{{ ai_gen_id }}">
            <div class="ai-customer-login-field-{{ ai_gen_id }}">
              <label for="CustomerEmail-{{ ai_gen_id }}" class="ai-customer-login-label-{{ ai_gen_id }}">
                Email address
              </label>
              <input
                type="email"
                name="customer[email]"
                id="CustomerEmail-{{ ai_gen_id }}"
                class="ai-customer-login-input-{{ ai_gen_id }}{% if form.errors contains 'email' %} invalid{% endif %}"
                autocomplete="email"
                autocorrect="off"
                autocapitalize="off"
                placeholder="Enter your email address"
                value="{{ form.email }}"
                {% if form.errors contains 'email' %}
                  aria-invalid="true"
                  aria-describedby="CustomerEmail-{{ ai_gen_id }}-error"
                {% endif %}
                required
              >
            </div>

            <div class="ai-customer-login-field-{{ ai_gen_id }}">
              <label for="CustomerPassword-{{ ai_gen_id }}" class="ai-customer-login-label-{{ ai_gen_id }}">
                Password
              </label>
              <input
                type="password"
                name="customer[password]"
                id="CustomerPassword-{{ ai_gen_id }}"
                class="ai-customer-login-input-{{ ai_gen_id }}{% if form.errors contains 'password' %} invalid{% endif %}"
                autocomplete="current-password"
                placeholder="Enter your password"
                {% if form.errors contains 'password' %}
                  aria-invalid="true"
                  aria-describedby="CustomerPassword-{{ ai_gen_id }}-error"
                {% endif %}
                required
              >
            </div>

            <button type="submit" class="ai-customer-login-button-{{ ai_gen_id }}">
              {{ block.settings.button_text }}
            </button>
          </div>
        {% endform %}

        {% if block.settings.show_forgot_password %}
          <div class="ai-customer-login-forgot-password-{{ ai_gen_id }}">
            <a href="#" class="ai-customer-login-forgot-link-{{ ai_gen_id }}" data-action="show-recover">
              Forgot your password?
            </a>
          </div>
        {% endif %}

        {% if block.settings.show_create_account %}
          <div class="ai-customer-login-create-account-{{ ai_gen_id }}">
            <p class="ai-customer-login-create-text-{{ ai_gen_id }}">Don't have an account?</p>
            <a href="{{ routes.account_register_url }}" class="ai-customer-login-create-link-{{ ai_gen_id }}">
              Create account
            </a>
          </div>
        {% endif %}
      </div>

      <!-- Password Recovery Form -->
      <div class="ai-customer-login-recover-{{ ai_gen_id }}">
        <a href="#" class="ai-customer-login-back-link-{{ ai_gen_id }}" data-action="show-login">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="m15 18-6-6 6-6"/>
          </svg>
          Back to login
        </a>

        <div class="ai-customer-login-header-{{ ai_gen_id }}">
          <h1 class="ai-customer-login-title-{{ ai_gen_id }}">Reset your password</h1>
          <p class="ai-customer-login-subtitle-{{ ai_gen_id }}">We'll send you an email to reset your password</p>
        </div>

        {% form 'recover_customer_password', novalidate: 'novalidate' %}
          {% if form.errors %}
            <div class="ai-customer-login-alert-{{ ai_gen_id }} ai-customer-login-alert-error-{{ ai_gen_id }}">
              {{ form.errors | default_errors }}
            </div>
          {% endif %}

          {% if form.posted_successfully? %}
            <div class="ai-customer-login-alert-{{ ai_gen_id }} ai-customer-login-alert-success-{{ ai_gen_id }}">
              We've sent you an email with a link to update your password.
            </div>
          {% endif %}

          <div class="ai-customer-login-form-{{ ai_gen_id }}">
            <div class="ai-customer-login-field-{{ ai_gen_id }}">
              <label for="RecoverEmail-{{ ai_gen_id }}" class="ai-customer-login-label-{{ ai_gen_id }}">
                Email address
              </label>
              <input
                type="email"
                name="email"
                id="RecoverEmail-{{ ai_gen_id }}"
                class="ai-customer-login-input-{{ ai_gen_id }}{% if form.errors contains 'email' %} invalid{% endif %}"
                autocomplete="email"
                autocorrect="off"
                autocapitalize="off"
                placeholder="Enter your email address"
                value="{{ form.email }}"
                {% if form.errors contains 'email' %}
                  aria-invalid="true"
                  aria-describedby="RecoverEmail-{{ ai_gen_id }}-error"
                {% endif %}
                required
              >
            </div>

            <button type="submit" class="ai-customer-login-button-{{ ai_gen_id }}">
              Send reset email
            </button>
          </div>
        {% endform %}
      </div>
    </div>
  </div>
</customer-login-{{ ai_gen_id }}>

<script>
  (function() {
    class CustomerLogin{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.mainForm = this.querySelector('.ai-customer-login-main-{{ ai_gen_id }}');
        this.recoverForm = this.querySelector('.ai-customer-login-recover-{{ ai_gen_id }}');
        this.showRecoverLink = this.querySelector('[data-action="show-recover"]');
        this.showLoginLink = this.querySelector('[data-action="show-login"]');
      }

      connectedCallback() {
        this.setupEventListeners();
        this.checkUrlHash();
      }

      setupEventListeners() {
        if (this.showRecoverLink) {
          this.showRecoverLink.addEventListener('click', (e) => {
            e.preventDefault();
            this.showRecoverForm();
          });
        }

        if (this.showLoginLink) {
          this.showLoginLink.addEventListener('click', (e) => {
            e.preventDefault();
            this.showLoginForm();
          });
        }
      }

      checkUrlHash() {
        if (window.location.hash === '#recover') {
          this.showRecoverForm();
        }
      }

      showRecoverForm() {
        this.mainForm.classList.add('hidden');
        this.recoverForm.classList.add('active');
        window.history.pushState({}, '', '#recover');
      }

      showLoginForm() {
        this.mainForm.classList.remove('hidden');
        this.recoverForm.classList.remove('active');
        window.history.pushState({}, '', window.location.pathname);
      }
    }

    customElements.define('customer-login-{{ ai_gen_id }}', CustomerLogin{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Customer login",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Welcome back"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Sign in to your account to continue shopping"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Sign in"
    },
    {
      "type": "checkbox",
      "id": "show_forgot_password",
      "label": "Show forgot password link",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_create_account",
      "label": "Show create account section",
      "default": true
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "color",
      "id": "image_background_color",
      "label": "Image background color",
      "default": "#f8f9fa"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "label": "Maximum width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "section_height",
      "min": 400,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Section height",
      "default": 600
    },
    {
      "type": "range",
      "id": "form_padding",
      "min": 20,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Form padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top margin",
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom margin",
      "default": 40
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile layout",
      "options": [
        {
          "value": "image_and_form",
          "label": "Show image and form"
        },
        {
          "value": "form_only",
          "label": "Show form only"
        }
      ],
      "default": "image_and_form"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "form_background_color",
      "label": "Form background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
