{% doc %}
  @prompt
    a section similar to how collection list section tiles look like. when you click a tile it flips to show subcategories where you can click on the subcategories

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-flip-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax({{ block.settings.min_tile_width }}px, 1fr));
    gap: {{ block.settings.grid_gap }}px;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-collection-flip-tile-{{ ai_gen_id }} {
    position: relative;
    height: {{ block.settings.tile_height }}px;
    perspective: 1000px;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-collection-flip-inner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    transition: transform 0.6s;
    transform-style: preserve-3d;
    cursor: pointer;
  }

  .ai-collection-flip-tile-{{ ai_gen_id }}.flipped .ai-collection-flip-inner-{{ ai_gen_id }} {
    transform: rotateY(180deg);
  }

  .ai-collection-flip-front-{{ ai_gen_id }},
  .ai-collection-flip-back-{{ ai_gen_id }} {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-collection-flip-back-{{ ai_gen_id }} {
    transform: rotateY(180deg);
    background-color: {{ block.settings.back_bg_color }};
    padding: 20px;
    display: flex;
    flex-direction: column;
  }

  .ai-collection-flip-front-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    align-items: flex-end;
    background-size: cover;
    background-position: center;
    background-color: {{ block.settings.placeholder_bg_color }};
  }

  .ai-collection-flip-front-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.placeholder_bg_color }};
  }

  .ai-collection-flip-front-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
    color: {{ block.settings.placeholder_icon_color }};
  }

  .ai-collection-flip-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, {{ block.settings.overlay_opacity | divided_by: 100.0 }}) 100%
    );
  }

  .ai-collection-flip-front-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    padding: 20px;
    width: 100%;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-collection-flip-title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    margin: 0 0 8px;
    line-height: 1.2;
  }

  .ai-collection-flip-description-{{ ai_gen_id }} {
    color: {{ block.settings.description_color }};
    font-size: {{ block.settings.description_size }}px;
    margin: 0;
    line-height: 1.4;
  }

  .ai-collection-flip-back-header-{{ ai_gen_id }} {
    margin-bottom: 20px;
  }

  .ai-collection-flip-back-title-{{ ai_gen_id }} {
    color: {{ block.settings.back_title_color }};
    font-size: {{ block.settings.back_title_size }}px;
    font-weight: 600;
    margin: 0 0 8px;
    line-height: 1.2;
  }

  .ai-collection-flip-back-subtitle-{{ ai_gen_id }} {
    color: {{ block.settings.back_subtitle_color }};
    font-size: {{ block.settings.back_subtitle_size }}px;
    margin: 0;
    opacity: 0.8;
  }

  .ai-collection-flip-subcategories-{{ ai_gen_id }} {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-collection-flip-subcategory-{{ ai_gen_id }} {
    display: block;
    padding: 12px 16px;
    background-color: {{ block.settings.subcategory_bg_color }};
    color: {{ block.settings.subcategory_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.subcategory_border_radius }}px;
    transition: all 0.3s ease;
    font-size: {{ block.settings.subcategory_text_size }}px;
    text-align: center;
    border: 1px solid transparent;
  }

  .ai-collection-flip-subcategory-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.subcategory_hover_bg_color }};
    color: {{ block.settings.subcategory_hover_text_color }};
    transform: translateY(-2px);
  }

  .ai-collection-flip-back-footer-{{ ai_gen_id }} {
    margin-top: 20px;
    text-align: center;
  }

  .ai-collection-flip-back-button-{{ ai_gen_id }} {
    background: none;
    border: 1px solid {{ block.settings.back_button_color }};
    color: {{ block.settings.back_button_color }};
    padding: 8px 16px;
    border-radius: {{ block.settings.subcategory_border_radius }}px;
    cursor: pointer;
    font-size: 14px;
    transition: all 0.3s ease;
  }

  .ai-collection-flip-back-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.back_button_color }};
    color: {{ block.settings.back_bg_color }};
  }

  .ai-collection-flip-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    background-color: rgba(255, 255, 255, 0.9);
    padding: 12px 20px;
    border-radius: 6px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-flip-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: {{ block.settings.grid_gap | times: 0.75 }}px;
    }

    .ai-collection-flip-tile-{{ ai_gen_id }} {
      height: {{ block.settings.tile_height | times: 0.8 }}px;
    }

    .ai-collection-flip-back-{{ ai_gen_id }} {
      padding: 16px;
    }

    .ai-collection-flip-front-content-{{ ai_gen_id }} {
      padding: 16px;
    }
  }
{% endstyle %}

<collection-flip-tiles-{{ ai_gen_id }}
  class="ai-collection-flip-grid-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% for i in (1..6) %}
    {% liquid
      assign collection_key = 'collection_' | append: i
      assign subcollection_1_key = 'subcollection_' | append: i | append: '_1'
      assign subcollection_2_key = 'subcollection_' | append: i | append: '_2'
      assign subcollection_3_key = 'subcollection_' | append: i | append: '_3'
      assign subcollection_4_key = 'subcollection_' | append: i | append: '_4'

      assign collection = block.settings[collection_key]
      assign subcollection_1 = block.settings[subcollection_1_key]
      assign subcollection_2 = block.settings[subcollection_2_key]
      assign subcollection_3 = block.settings[subcollection_3_key]
      assign subcollection_4 = block.settings[subcollection_4_key]
    %}

    {% if collection != blank %}
      <div class="ai-collection-flip-tile-{{ ai_gen_id }}" data-tile="{{ i }}">
        <div class="ai-collection-flip-inner-{{ ai_gen_id }}">
          <div class="ai-collection-flip-front-{{ ai_gen_id }}"
               {% if collection.featured_image %}
                 style="background-image: url('{{ collection.featured_image | image_url: width: 600 }}');"
               {% endif %}>
            
            {% unless collection.featured_image %}
              <div class="ai-collection-flip-front-placeholder-{{ ai_gen_id }}">
                {{ 'collection-1' | placeholder_svg_tag }}
              </div>
            {% endunless %}

            <div class="ai-collection-flip-overlay-{{ ai_gen_id }}"></div>
            
            <div class="ai-collection-flip-front-content-{{ ai_gen_id }}">
              <h3 class="ai-collection-flip-title-{{ ai_gen_id }}">{{ collection.title }}</h3>
              {% if collection.description != blank %}
                <p class="ai-collection-flip-description-{{ ai_gen_id }}">
                  {{ collection.description | strip_html | truncate: 80 }}
                </p>
              {% endif %}
            </div>
          </div>

          <div class="ai-collection-flip-back-{{ ai_gen_id }}">
            <div class="ai-collection-flip-back-header-{{ ai_gen_id }}">
              <h3 class="ai-collection-flip-back-title-{{ ai_gen_id }}">{{ collection.title }}</h3>
              <p class="ai-collection-flip-back-subtitle-{{ ai_gen_id }}">{{ block.settings.subcategory_label }}</p>
            </div>

            <div class="ai-collection-flip-subcategories-{{ ai_gen_id }}">
              {% if subcollection_1 != blank %}
                <a href="{{ subcollection_1.url }}" class="ai-collection-flip-subcategory-{{ ai_gen_id }}">
                  {{ subcollection_1.title }}
                </a>
              {% endif %}
              {% if subcollection_2 != blank %}
                <a href="{{ subcollection_2.url }}" class="ai-collection-flip-subcategory-{{ ai_gen_id }}">
                  {{ subcollection_2.title }}
                </a>
              {% endif %}
              {% if subcollection_3 != blank %}
                <a href="{{ subcollection_3.url }}" class="ai-collection-flip-subcategory-{{ ai_gen_id }}">
                  {{ subcollection_3.title }}
                </a>
              {% endif %}
              {% if subcollection_4 != blank %}
                <a href="{{ subcollection_4.url }}" class="ai-collection-flip-subcategory-{{ ai_gen_id }}">
                  {{ subcollection_4.title }}
                </a>
              {% endif %}

              {% if subcollection_1 == blank and subcollection_2 == blank and subcollection_3 == blank and subcollection_4 == blank %}
                <div class="ai-collection-flip-subcategory-{{ ai_gen_id }}" style="opacity: 0.5; cursor: default;">
                  Add subcategories in settings
                </div>
              {% endif %}
            </div>

            <div class="ai-collection-flip-back-footer-{{ ai_gen_id }}">
              <button class="ai-collection-flip-back-button-{{ ai_gen_id }}" data-action="flip-back">
                Back
              </button>
            </div>
          </div>
        </div>
      </div>
    {% endif %}
  {% endfor %}

  {% if block.settings.collection_1 == blank and block.settings.collection_2 == blank and block.settings.collection_3 == blank %}
    <div class="ai-collection-flip-tile-{{ ai_gen_id }}">
      <div class="ai-collection-flip-inner-{{ ai_gen_id }}">
        <div class="ai-collection-flip-front-{{ ai_gen_id }}">
          <div class="ai-collection-flip-front-placeholder-{{ ai_gen_id }}">
            {{ 'collection-1' | placeholder_svg_tag }}
          </div>
          <div class="ai-collection-flip-overlay-{{ ai_gen_id }}"></div>
          <div class="ai-collection-flip-empty-state-{{ ai_gen_id }}">
            Add collections in block settings
          </div>
        </div>
      </div>
    </div>
  {% endif %}
</collection-flip-tiles-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionFlipTiles{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.tiles = this.querySelectorAll('.ai-collection-flip-tile-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.tiles.forEach((tile) => {
          const inner = tile.querySelector('.ai-collection-flip-inner-{{ ai_gen_id }}');
          const backButton = tile.querySelector('.ai-collection-flip-back-button-{{ ai_gen_id }}');

          inner.addEventListener('click', (e) => {
            if (e.target.closest('.ai-collection-flip-back-{{ ai_gen_id }}')) {
              return;
            }
            
            this.tiles.forEach((otherTile) => {
              if (otherTile !== tile) {
                otherTile.classList.remove('flipped');
              }
            });

            tile.classList.add('flipped');
          });

          if (backButton) {
            backButton.addEventListener('click', (e) => {
              e.stopPropagation();
              tile.classList.remove('flipped');
            });
          }
        });

        document.addEventListener('click', (e) => {
          if (!e.target.closest('.ai-collection-flip-tile-{{ ai_gen_id }}')) {
            this.tiles.forEach((tile) => {
              tile.classList.remove('flipped');
            });
          }
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') {
            this.tiles.forEach((tile) => {
              tile.classList.remove('flipped');
            });
          }
        });
      }
    }

    customElements.define('collection-flip-tiles-{{ ai_gen_id }}', CollectionFlipTiles{{ ai_gen_id }});
  })();
</script>

