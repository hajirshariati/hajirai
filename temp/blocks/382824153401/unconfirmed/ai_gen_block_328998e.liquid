{% doc %}
  @prompt
    create a product comparisons section that allow customers to choose betwwen up to 4 products from a specific collection list i choose on customizer. make sure it's mobile friendly. allow me too add product metafields as comparisons
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-comparison-{{ ai_gen_id }} {
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
  }

  .ai-product-comparison__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-product-comparison__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-product-comparison__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px;
    font-weight: 700;
  }

  .ai-product-comparison__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-product-comparison__selector-{{ ai_gen_id }} {
    margin-bottom: 40px;
  }

  .ai-product-comparison__selector-title-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 16px;
    color: {{ block.settings.text_color }};
  }

  .ai-product-comparison__product-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-bottom: 20px;
  }

  .ai-product-comparison__product-option-{{ ai_gen_id }} {
    border: 2px solid #e5e5e5;
    border-radius: 8px;
    padding: 16px;
    cursor: pointer;
    transition: all 0.3s ease;
    background: white;
  }

  .ai-product-comparison__product-option-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.accent_color }};
  }

  .ai-product-comparison__product-option-{{ ai_gen_id }}.selected {
    border-color: {{ block.settings.accent_color }};
    background-color: {{ block.settings.accent_color | color_modify: 'alpha', 0.1 }};
  }

  .ai-product-comparison__product-image-{{ ai_gen_id }} {
    width: 100%;
    height: 120px;
    object-fit: cover;
    border-radius: 4px;
    margin-bottom: 12px;
  }

  .ai-product-comparison__product-title-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .ai-product-comparison__product-price-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.price_color }};
    margin: 0;
  }

  .ai-product-comparison__compare-button-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    padding: 12px 24px;
    border-radius: 6px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
    margin-top: 20px;
  }

  .ai-product-comparison__compare-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-product-comparison__compare-button-{{ ai_gen_id }}:disabled {
    background-color: #ccc;
    cursor: not-allowed;
  }

  .ai-product-comparison__table-container-{{ ai_gen_id }} {
    overflow-x: auto;
    margin-top: 40px;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-product-comparison__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    background: white;
    min-width: 600px;
  }

  .ai-product-comparison__table-{{ ai_gen_id }} th,
  .ai-product-comparison__table-{{ ai_gen_id }} td {
    padding: 16px;
    text-align: left;
    border-bottom: 1px solid #e5e5e5;
    vertical-align: top;
  }

  .ai-product-comparison__table-{{ ai_gen_id }} th {
    background-color: {{ block.settings.table_header_bg }};
    color: {{ block.settings.table_header_text }};
    font-weight: 600;
    position: sticky;
    top: 0;
    z-index: 1;
  }

  .ai-product-comparison__table-{{ ai_gen_id }} .product-header {
    text-align: center;
    padding: 20px 16px;
  }

  .ai-product-comparison__table-image-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 4px;
    margin: 0 auto 12px;
    display: block;
  }

  .ai-product-comparison__table-title-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .ai-product-comparison__table-price-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.price_color }};
    margin: 0 0 12px;
  }

  .ai-product-comparison__view-button-{{ ai_gen_id }} {
    background-color: {{ block.settings.accent_color }};
    color: white;
    border: none;
    padding: 8px 16px;
    border-radius: 4px;
    font-size: 12px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
  }

  .ai-product-comparison__view-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.accent_color | color_darken: 10 }};
  }

  .ai-product-comparison__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  .ai-product-comparison__empty-state-{{ ai_gen_id }} h3 {
    margin: 0 0 16px;
    font-size: 24px;
  }

  .ai-product-comparison__empty-state-{{ ai_gen_id }} p {
    margin: 0;
    font-size: 16px;
  }

  @media screen and (max-width: 768px) {
    .ai-product-comparison-{{ ai_gen_id }} {
      padding: 20px 16px;
    }

    .ai-product-comparison__product-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 12px;
    }

    .ai-product-comparison__product-option-{{ ai_gen_id }} {
      padding: 12px;
    }

    .ai-product-comparison__product-image-{{ ai_gen_id }} {
      height: 100px;
    }

    .ai-product-comparison__table-{{ ai_gen_id }} th,
    .ai-product-comparison__table-{{ ai_gen_id }} td {
      padding: 12px 8px;
      font-size: 14px;
    }

    .ai-product-comparison__table-image-{{ ai_gen_id }} {
      width: 60px;
      height: 60px;
    }
  }

  @media screen and (max-width: 480px) {
    .ai-product-comparison__product-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }

    .ai-product-comparison__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<product-comparison-{{ ai_gen_id }}
  class="ai-product-comparison-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-product-comparison__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subtitle != blank %}
      <div class="ai-product-comparison__header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-product-comparison__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <p class="ai-product-comparison__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.collection != blank %}
      <div class="ai-product-comparison__selector-{{ ai_gen_id }}">
        <h3 class="ai-product-comparison__selector-title-{{ ai_gen_id }}">Select products to compare (up to 4):</h3>
        
        <div class="ai-product-comparison__product-grid-{{ ai_gen_id }}">
          {% for product in block.settings.collection.products limit: 12 %}
            <div 
              class="ai-product-comparison__product-option-{{ ai_gen_id }}"
              data-product-id="{{ product.id }}"
              data-product-handle="{{ product.handle }}"
            >
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 200 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-product-comparison__product-image-{{ ai_gen_id }}"
                  loading="lazy"
                >
              {% else %}
                <div class="ai-product-comparison__product-image-{{ ai_gen_id }}" style="background-color: #f5f5f5; display: flex; align-items: center; justify-content: center;">
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {% endif %}
              <h4 class="ai-product-comparison__product-title-{{ ai_gen_id }}">{{ product.title }}</h4>
              <p class="ai-product-comparison__product-price-{{ ai_gen_id }}">{{ product.price | money }}</p>
            </div>
          {% endfor %}
        </div>

        <button 
          class="ai-product-comparison__compare-button-{{ ai_gen_id }}"
          id="compare-button-{{ ai_gen_id }}"
          disabled
        >
          Compare Selected Products
        </button>
      </div>

      <div 
        class="ai-product-comparison__table-container-{{ ai_gen_id }}"
        id="comparison-table-{{ ai_gen_id }}"
        style="display: none;"
      >
        <table class="ai-product-comparison__table-{{ ai_gen_id }}">
          <thead>
            <tr>
              <th style="width: 200px;">Features</th>
              <th class="product-header" id="product-1-header-{{ ai_gen_id }}"></th>
              <th class="product-header" id="product-2-header-{{ ai_gen_id }}"></th>
              <th class="product-header" id="product-3-header-{{ ai_gen_id }}"></th>
              <th class="product-header" id="product-4-header-{{ ai_gen_id }}"></th>
            </tr>
          </thead>
          <tbody id="comparison-body-{{ ai_gen_id }}">
            <tr>
              <td><strong>Price</strong></td>
              <td id="product-1-price-{{ ai_gen_id }}"></td>
              <td id="product-2-price-{{ ai_gen_id }}"></td>
              <td id="product-3-price-{{ ai_gen_id }}"></td>
              <td id="product-4-price-{{ ai_gen_id }}"></td>
            </tr>
            <tr>
              <td><strong>Description</strong></td>
              <td id="product-1-description-{{ ai_gen_id }}"></td>
              <td id="product-2-description-{{ ai_gen_id }}"></td>
              <td id="product-3-description-{{ ai_gen_id }}"></td>
              <td id="product-4-description-{{ ai_gen_id }}"></td>
            </tr>
            {% if block.settings.metafield_1_key != blank %}
              <tr>
                <td><strong>{{ block.settings.metafield_1_label }}</strong></td>
                <td id="product-1-meta1-{{ ai_gen_id }}"></td>
                <td id="product-2-meta1-{{ ai_gen_id }}"></td>
                <td id="product-3-meta1-{{ ai_gen_id }}"></td>
                <td id="product-4-meta1-{{ ai_gen_id }}"></td>
              </tr>
            {% endif %}
            {% if block.settings.metafield_2_key != blank %}
              <tr>
                <td><strong>{{ block.settings.metafield_2_label }}</strong></td>
                <td id="product-1-meta2-{{ ai_gen_id }}"></td>
                <td id="product-2-meta2-{{ ai_gen_id }}"></td>
                <td id="product-3-meta2-{{ ai_gen_id }}"></td>
                <td id="product-4-meta2-{{ ai_gen_id }}"></td>
              </tr>
            {% endif %}
            {% if block.settings.metafield_3_key != blank %}
              <tr>
                <td><strong>{{ block.settings.metafield_3_label }}</strong></td>
                <td id="product-1-meta3-{{ ai_gen_id }}"></td>
                <td id="product-2-meta3-{{ ai_gen_id }}"></td>
                <td id="product-3-meta3-{{ ai_gen_id }}"></td>
                <td id="product-4-meta3-{{ ai_gen_id }}"></td>
              </tr>
            {% endif %}
            {% if block.settings.metafield_4_key != blank %}
              <tr>
                <td><strong>{{ block.settings.metafield_4_label }}</strong></td>
                <td id="product-1-meta4-{{ ai_gen_id }}"></td>
                <td id="product-2-meta4-{{ ai_gen_id }}"></td>
                <td id="product-3-meta4-{{ ai_gen_id }}"></td>
                <td id="product-4-meta4-{{ ai_gen_id }}"></td>
              </tr>
            {% endif %}
            {% if block.settings.metafield_5_key != blank %}
              <tr>
                <td><strong>{{ block.settings.metafield_5_label }}</strong></td>
                <td id="product-1-meta5-{{ ai_gen_id }}"></td>
                <td id="product-2-meta5-{{ ai_gen_id }}"></td>
                <td id="product-3-meta5-{{ ai_gen_id }}"></td>
                <td id="product-4-meta5-{{ ai_gen_id }}"></td>
              </tr>
            {% endif %}
            <tr>
              <td><strong>Actions</strong></td>
              <td id="product-1-action-{{ ai_gen_id }}"></td>
              <td id="product-2-action-{{ ai_gen_id }}"></td>
              <td id="product-3-action-{{ ai_gen_id }}"></td>
              <td id="product-4-action-{{ ai_gen_id }}"></td>
            </tr>
          </tbody>
        </table>
      </div>
    {% else %}
      <div class="ai-product-comparison__empty-state-{{ ai_gen_id }}">
        <h3>No Collection Selected</h3>
        <p>Please select a collection in the theme customizer to display products for comparison.</p>
      </div>
    {% endif %}
  </div>
</product-comparison-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductComparison{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.selectedProducts = [];
        this.maxProducts = 4;
        this.productData = {};
      }

      connectedCallback() {
        this.setupEventListeners();
        this.loadProductData();
      }

      setupEventListeners() {
        const productOptions = this.querySelectorAll('.ai-product-comparison__product-option-{{ ai_gen_id }}');
        const compareButton = this.querySelector('#compare-button-{{ ai_gen_id }}');

        productOptions.forEach(option => {
          option.addEventListener('click', () => this.toggleProduct(option));
        });

        if (compareButton) {
          compareButton.addEventListener('click', () => this.showComparison());
        }
      }

      async loadProductData() {
        const productOptions = this.querySelectorAll('.ai-product-comparison__product-option-{{ ai_gen_id }}');
        
        for (const option of productOptions) {
          const productHandle = option.dataset.productHandle;
          if (productHandle) {
            try {
              const response = await fetch(`/products/${productHandle}.js`);
              const productData = await response.json();
              this.productData[productHandle] = productData;
            } catch (error) {
              console.error('Error loading product data:', error);
            }
          }
        }
      }

      toggleProduct(option) {
        const productId = option.dataset.productId;
        const productHandle = option.dataset.productHandle;
        
        if (option.classList.contains('selected')) {
          option.classList.remove('selected');
          this.selectedProducts = this.selectedProducts.filter(p => p.id !== productId);
        } else {
          if (this.selectedProducts.length < this.maxProducts) {
            option.classList.add('selected');
            this.selectedProducts.push({
              id: productId,
              handle: productHandle,
              element: option
            });
          }
        }

        this.updateCompareButton();
      }

      updateCompareButton() {
        const compareButton = this.querySelector('#compare-button-{{ ai_gen_id }}');
        if (compareButton) {
          compareButton.disabled = this.selectedProducts.length < 2;
          compareButton.textContent = `Compare Selected Products (${this.selectedProducts.length})`;
        }
      }

      showComparison() {
        const tableContainer = this.querySelector('#comparison-table-{{ ai_gen_id }}');
        if (!tableContainer) return;

        this.populateComparisonTable();
        tableContainer.style.display = 'block';
        tableContainer.scrollIntoView({ behavior: 'smooth' });
      }

      populateComparisonTable() {
        this.selectedProducts.forEach((product, index) => {
          const productData = this.productData[product.handle];
          if (!productData) return;

          const columnIndex = index + 1;
          
          const headerCell = this.querySelector(`#product-${columnIndex}-header-{{ ai_gen_id }}`);
          if (headerCell) {
            headerCell.innerHTML = `
              ${productData.featured_image ? 
                `<img src="${productData.featured_image}" alt="${productData.title}" class="ai-product-comparison__table-image-{{ ai_gen_id }}">` : 
                ''
              }
              <div class="ai-product-comparison__table-title-{{ ai_gen_id }}">${productData.title}</div>
              <div class="ai-product-comparison__table-price-{{ ai_gen_id }}">${this.formatPrice(productData.price)}</div>
              <a href="/products/${product.handle}" class="ai-product-comparison__view-button-{{ ai_gen_id }}">View Product</a>
            `;
            headerCell.style.display = 'table-cell';
          }

          const priceCell = this.querySelector(`#product-${columnIndex}-price-{{ ai_gen_id }}`);
          if (priceCell) {
            priceCell.textContent = this.formatPrice(productData.price);
            priceCell.style.display = 'table-cell';
          }

          const descriptionCell = this.querySelector(`#product-${columnIndex}-description-{{ ai_gen_id }}`);
          if (descriptionCell) {
            const description = productData.description || 'No description available';
            descriptionCell.textContent = description.length > 100 ? 
              description.substring(0, 100) + '...' : description;
            descriptionCell.style.display = 'table-cell';
          }

          {% if block.settings.metafield_1_key != blank %}
            this.populateMetafield(productData, columnIndex, 'meta1', '{{ block.settings.metafield_1_key }}');
          {% endif %}
          {% if block.settings.metafield_2_key != blank %}
            this.populateMetafield(productData, columnIndex, 'meta2', '{{ block.settings.metafield_2_key }}');
          {% endif %}
          {% if block.settings.metafield_3_key != blank %}
            this.populateMetafield(productData, columnIndex, 'meta3', '{{ block.settings.metafield_3_key }}');
          {% endif %}
          {% if block.settings.metafield_4_key != blank %}
            this.populateMetafield(productData, columnIndex, 'meta4', '{{ block.settings.metafield_4_key }}');
          {% endif %}
          {% if block.settings.metafield_5_key != blank %}
            this.populateMetafield(productData, columnIndex, 'meta5', '{{ block.settings.metafield_5_key }}');
          {% endif %}

          const actionCell = this.querySelector(`#product-${columnIndex}-action-{{ ai_gen_id }}`);
          if (actionCell) {
            actionCell.innerHTML = `<a href="/products/${product.handle}" class="ai-product-comparison__view-button-{{ ai_gen_id }}">View Details</a>`;
            actionCell.style.display = 'table-cell';
          }
        });

        for (let i = this.selectedProducts.length + 1; i <= this.maxProducts; i++) {
          const headerCell = this.querySelector(`#product-${i}-header-{{ ai_gen_id }}`);
          const priceCell = this.querySelector(`#product-${i}-price-{{ ai_gen_id }}`);
          const descriptionCell = this.querySelector(`#product-${i}-description-{{ ai_gen_id }}`);
          const actionCell = this.querySelector(`#product-${i}-action-{{ ai_gen_id }}`);
          
          if (headerCell) headerCell.style.display = 'none';
          if (priceCell) priceCell.style.display = 'none';
          if (descriptionCell) descriptionCell.style.display = 'none';
          if (actionCell) actionCell.style.display = 'none';

          {% if block.settings.metafield_1_key != blank %}
            const meta1Cell = this.querySelector(`#product-${i}-meta1-{{ ai_gen_id }}`);
            if (meta1Cell) meta1Cell.style.display = 'none';
          {% endif %}
          {% if block.settings.metafield_2_key != blank %}
            const meta2Cell = this.querySelector(`#product-${i}-meta2-{{ ai_gen_id }}`);
            if (meta2Cell) meta2Cell.style.display = 'none';
          {% endif %}
          {% if block.settings.metafield_3_key != blank %}
            const meta3Cell = this.querySelector(`#product-${i}-meta3-{{ ai_gen_id }}`);
            if (meta3Cell) meta3Cell.style.display = 'none';
          {% endif %}
          {% if block.settings.metafield_4_key != blank %}
            const meta4Cell = this.querySelector(`#product-${i}-meta4-{{ ai_gen_id }}`);
            if (meta4Cell) meta4Cell.style.display = 'none';
          {% endif %}
          {% if block.settings.metafield_5_key != blank %}
            const meta5Cell = this.querySelector(`#product-${i}-meta5-{{ ai_gen_id }}`);
            if (meta5Cell) meta5Cell.style.display = 'none';
          {% endif %}
        }
      }

      populateMetafield(productData, columnIndex, metaType, metafieldKey) {
        const cell = this.querySelector(`#product-${columnIndex}-${metaType}-{{ ai_gen_id }}`);
        if (cell) {
          const metaValue = this.getMetafieldValue(productData, metafieldKey);
          cell.textContent = metaValue || 'N/A';
          cell.style.display = 'table-cell';
        }
      }

      getMetafieldValue(productData, metafieldKey) {
        if (!productData.metafields || !metafieldKey) return null;
        
        const [namespace, key] = metafieldKey.split('.');
        if (productData.metafields[namespace] && productData.metafields[namespace][key]) {
          return productData.metafields[namespace][key];
        }
        
        return null;
      }

      formatPrice(price) {
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: 'USD'
        }).format(price / 100);
      }
    }

    customElements.define('product-comparison-{{ ai_gen_id }}', ProductComparison{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Product comparison",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Compare Products"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Select up to 4 products to compare their features side by side"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "header",
      "content": "Metafields"
    },
    {
      "type": "text",
      "id": "metafield_1_key",
      "label": "Metafield 1 key",
      "info": "Format: namespace.key (e.g., custom.material)"
    },
    {
      "type": "text",
      "id": "metafield_1_label",
      "label": "Metafield 1 label",
      "default": "Material"
    },
    {
      "type": "text",
      "id": "metafield_2_key",
      "label": "Metafield 2 key",
      "info": "Format: namespace.key (e.g., custom.size)"
    },
    {
      "type": "text",
      "id": "metafield_2_label",
      "label": "Metafield 2 label",
      "default": "Size"
    },
    {
      "type": "text",
      "id": "metafield_3_key",
      "label": "Metafield 3 key",
      "info": "Format: namespace.key (e.g., custom.weight)"
    },
    {
      "type": "text",
      "id": "metafield_3_label",
      "label": "Metafield 3 label",
      "default": "Weight"
    },
    {
      "type": "text",
      "id": "metafield_4_key",
      "label": "Metafield 4 key",
      "info": "Format: namespace.key (e.g., custom.warranty)"
    },
    {
      "type": "text",
      "id": "metafield_4_label",
      "label": "Metafield 4 label",
      "default": "Warranty"
    },
    {
      "type": "text",
      "id": "metafield_5_key",
      "label": "Metafield 5 key",
      "info": "Format: namespace.key (e.g., custom.features)"
    },
    {
      "type": "text",
      "id": "metafield_5_label",
      "label": "Metafield 5 label",
      "default": "Features"
    },
    {
      "type": "header",
      "content": "Style"
    },
