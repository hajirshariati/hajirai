<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- render 'section-variables', section: section -%}
    {%- assign visible_products = section.settings.visible_products | default: 3 | plus: 0 -%}
    --values-columns-count: {{ section.blocks.size | at_most: visible_products }};
  }
</style>

<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}"{% if section.settings.transparent_header %} allow-transparent-header{% endif %}>
  <div class="page-width{% if section.settings.full_width %} page-width--full{% endif %} relative">
    {%- render 'section-heading', section: section -%}

    {%- if section.settings.highlight_differences -%}
      <div class="text-center">
        <label class="comparison-highlight button icon-with-text" for="ComparisonHighlight-{{ section.id }}" aria-label="Highlight differences">
          <span class="btn-text">
            Highlight differences
            <input id="ComparisonHighlight-{{ section.id }}" name="comparison-highlight" class="switch" type="checkbox" value="1" is="comparison-highlight" aria-controls="ProductComparison-{{ section.id }}">
          </span>
        </label>
      </div>
    {%- endif -%}
    
    <comparison-table class="comparison-table product-comparison grid gap-4 scroll-area" id="ProductComparison-{{ section.id }}">
      {%- assign tfoot_content = blank -%}
      {%- assign visible_products = section.settings.visible_products | default: 3 | plus: 0 -%}
      {%- assign max_index = visible_products | minus: 1 -%}
      {%- capture thead_content -%}
        {%- for i in (0..max_index) -%}
          {%- assign block = section.blocks[i] -%}
          {%- if block != blank -%}
            <div class="comparison-table__column grid gap-4">
              {%- if section.blocks.size > visible_products -%}
                <div class="comparison-table__selector w-full relative">
                  <select id="ProductComparison-{{ section.id }}-{{ forloop.index }}"
                    class="select cursor-pointer"
                    is="product-comparison"
                    data-column="{{ forloop.index }}"
                    data-section-id="{{ section.id }}"
                    aria-controls="ProductComparison-{{ section.id }}"
                  >
                    {%- for block in section.blocks -%}
                      {%- if block.settings.product != blank -%}
                        <option value="{{ block.settings.product.id }}"{% if forloop.index == forloop.parentloop.index %} selected{% endif %}>{{ block.settings.product.title }}</option>
                      {%- endif -%}
                    {%- endfor -%}
                  </select>
                  {%- render 'icon', icon: 'chevron-up', size: 'sm', class: 'absolute pointer-events-none' -%}
                </div>
              {%- endif -%}
{%- if block.settings.product != blank -%}
  {%- if block.settings.product_badge_image != blank -%}
    {%- assign badge_align = block.settings.product_badge_position | default: 'center' -%}
    {%- assign badge_width = block.settings.product_badge_width | default: 100 -%}
    <div class="comparison-table__badge{% if badge_align == 'left' %} text-left{% elsif badge_align == 'right' %} text-right{% else %} text-center{% endif %}" style="margin-bottom: 12px;">
      <img src="{{ block.settings.product_badge_image | image_url: width: badge_width }}"
           alt="{{ block.settings.product_badge_image.alt | escape }}"
           width="{{ badge_width }}"
           loading="lazy"
           style="display: inline-block; max-width: 100%;">
    </div>
  {%- endif -%}
  {%- liquid
    assign card_product = block.settings.product
                  assign first_available_variant = blank
                  if card_product.has_only_default_variant == false and section.settings.first_available_variant
                    assign first_available_variant = card_product.first_available_variant
                  endif
                  assign featured_media = first_available_variant.featured_media | default: card_product.featured_media
                -%}
                <div class="horizontal-product flex items-start flex-col gap-4 md:flex-row md:gap-6" data-product="{{ forloop.index }}">
                  <a class="horizontal-product__media media media--{{ settings.product_image_ratio }}{% unless settings.product_image_fill %} media--contain{% endunless %} relative overflow-hidden shrink-0" href="{{ card_product.url }}">
                    {%- liquid
                      if featured_media
                        echo featured_media | image_url: width: featured_media.width | image_tag: loading: 'lazy', widths: '180,360,540', is: 'lazy-image'
                      else
                        echo 'product-1' | placeholder_svg_tag
                      endif
                    -%}
                  </a>
                  <div class="horizontal-product__details grow flex flex-col justify-start align-self-center gap-1d5 w-full">
                    <div class="flex flex-col gap-1">
                      <div class="block">
                        {%- if section.settings.show_vendor -%}
                          <p class="horizontal-product__vendor text-xs text-opacity">{{ card_product.vendor }}</p>
                        {%- endif -%}
                        <a href="{{ card_product.url }}" class="horizontal-product__title reversed-link font-medium text-base leading-tight">{{ block.settings.custom_product_name | default: card_product.title }}</a>
                      </div>
                      {%- if first_available_variant != blank -%}
                        <p class="text-xs text-opacity leading-tight">{{ first_available_variant.title }}</p>
                      {%- endif -%}
                    </div>
                    <div class="flex flex-col gap-1">
                      {%- liquid
                        if section.settings.show_price
                          if first_available_variant != blank
                            render 'product-price', product: card_product, variant: first_available_variant, use_variant: true, class: 'flex flex-wrap items-end gap-2 text-sm'
                          else
                            render 'product-price', product: card_product, class: 'flex flex-wrap items-end gap-2 text-sm'
                          endif
                        endif
                      -%}
                    </div>
                  </div>
                </div>
{%- capture tfoot_content -%}
                  {{- tfoot_content -}}
                  <div class="comparison-table__column" data-product-action="{{ forloop.index }}">
                    <a href="{{ card_product.url }}" class="button button--primary w-full" is="hover-link" aria-label="{{ block.settings.primary_cta_label | default: 'Select Size' }}">
                      <span class="btn-fill" data-fill></span>
                      <span class="btn-text">
                        {{ block.settings.primary_cta_label | default: 'Select Size' }}
                      </span>
                    </a>
                    {%- if block.settings.secondary_cta_label != blank -%}
                      <a href="{{ block.settings.secondary_cta_link | default: card_product.url }}"
                        class="button {{ block.settings.secondary_cta_style }} w-full" style="margin-top: 8px;"
                        is="hover-link"
                        aria-label="{{ block.settings.secondary_cta_label }}"
                        {% if block.settings.secondary_cta_external %}target="_blank" rel="noopener"{% endif %}>
                        <span class="btn-fill" data-fill></span>
                        <span class="btn-text">
                          {{ block.settings.secondary_cta_label }}
                          {%- if block.settings.secondary_cta_icon -%}
                            {%- render 'icon', icon: 'arrow-right', size: 'sm' -%}
                          {%- endif -%}
                        </span>
                      </a>
                    {%- endif -%}
                  </div>
                {%- endcapture -%}
              {%- else -%}
                <div class="horizontal-product flex items-start flex-col gap-4 md:flex-row md:gap-6" data-product="{{ forloop.index }}">
                  <div class="horizontal-product__media media media--{{ settings.product_image_ratio }}{% unless settings.product_image_fill %} media--contain{% endunless %} relative overflow-hidden shrink-0" href="{{ card_product.url }}">
                    {{- 'product-1' | placeholder_svg_tag -}}
                  </div>
                  <div class="horizontal-product__details grow flex flex-col justify-start align-self-center gap-1d5 w-full">
                    <div class="flex flex-col gap-1">
                      <div class="block">
                        {%- if section.settings.show_vendor -%}
                          <p class="horizontal-product__vendor text-xs text-opacity">Vendor</p>
                        {%- endif -%}
                        <a href="#" class="horizontal-product__title reversed-link font-medium text-base leading-tight">Product title</a>
                      </div>
                    </div>
                    <div class="flex flex-col gap-1">
                      {%- liquid
                        if section.settings.show_price
                          render 'product-price', product: blank, class: 'flex flex-wrap items-end gap-2 text-sm'
                        endif
                      -%}
                    </div>
                  </div>
                </div>
{%- capture tfoot_content -%}
                  {{- tfoot_content -}}
                  <div class="comparison-table__column" data-product-action="{{ forloop.index }}">
                    <a href="#" class="button button--primary w-full" is="hover-link" aria-label="{{ block.settings.primary_cta_label | default: 'Select Size' }}">
                      <span class="btn-fill" data-fill></span>
                      <span class="btn-text">
                        {{ block.settings.primary_cta_label | default: 'Select Size' }}
                      </span>
                    </a>
                  </div>
                {%- endcapture -%}
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endcapture -%}

      <div class="comparison-table__row grid grid-cols-{{ visible_products }} gap-6 thead">
        {{- thead_content -}}
      </div>

      {%- if section.settings.sticky_product_info -%}
        <div class="comparison-table__sticky page-width{% if section.settings.full_width %} page-width--full{% endif %} scroll-area fixed z-1 top-0 left-0 w-full opacity-0 invisible">
          <div class="comparison-table__row grid grid-cols-{{ visible_products }} gap-6 sticky">
            {%- liquid
              assign thead_content = thead_content | replace: 'is="product-comparison"', ''
              assign thead_content = thead_content | replace: 'id="ProductComparison-', 'id="ProductComparisonSticky-'
              assign thead_content = thead_content | replace: 'data-product=', 'data-product-sticky='
              echo thead_content
            -%}
          </div>
        </div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        {%- assign row_count = 0 -%}
        {%- for i in (1..25) -%}
          {%- liquid
            assign heading_key = 'heading_' | append: i
            assign value_key = 'value_' | append: i
            assign first_block = section.blocks[0]
            assign first_block_heading = first_block.settings[heading_key]
            assign first_block_value = first_block.settings[value_key]
          -%}
          {%- if first_block_heading != blank -%}
            {%- if first_block_heading contains '####' -%}
              {%- liquid
                assign row_count = 0
                assign allow_render_row = false
                if first_block_value != blank
                  assign allow_render_row = true
                endif
              -%}
              <div class="comparison-table__head heading text-base lg:text-lg xl:text-xl font-medium leading-tight">
                <span class="comparison-table__column">{{ first_block_heading | replace: '####', '' | strip }}</span>
              </div>
            {%- else -%}
              {%- assign allow_render_row = true -%}
            {%- endif -%}
            {%- if allow_render_row == true -%}
              {%- assign row_count = row_count | plus: 1 -%}
              {%- assign row_modulo = row_count | modulo: 2 -%}
              <div class="comparison-table__row grid grid-cols-{{ visible_products }} gap-6{% if row_modulo == 0 %} even{% else %} odd{% endif %}">
                {%- for i in (0..max_index) -%}
                  {%- assign block = section.blocks[i] -%}
                  {%- if block != blank -%}
                    {%- liquid
                      assign heading = block.settings[heading_key]
                      assign value = block.settings[value_key]
                      assign stripped_value = value | strip_html | strip | upcase
                    -%}
                    <div class="comparison-table__column {{ block.settings.text_size }} rte" data-column="{{ forloop.index }}" data-index="{{ forloop.parentloop.index }}">
                      {%- unless first_block_heading contains '####' -%}
                        <p class="h6 leading-tight tracking-none">{{ heading }}</p>
                      {%- endunless -%}
                      {%- liquid
                        if stripped_value == 'FALSE'
                          capture value
                            render 'icon', icon: 'close-circle-filled'
                          endcapture
                        elsif stripped_value == 'TRUE'
                          capture value
                            render 'icon', icon: 'check-circle-filled'
                          endcapture
                        else
                          assign value = value | default: '—'
                        endif
                        echo value | strip_newlines
                      -%}
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}

        <div class="comparison-table__row grid grid-cols-{{ visible_products }} gap-6 tfoot">
          {{- tfoot_content -}}
        </div>

        <script>
          theme.ProductComparisonJSON = theme.ProductComparisonJSON || {};
          theme.ProductComparisonJSON["{{ section.id }}"] = {
            {%- for block in section.blocks -%}
              {%- if block.settings.product != blank -%}
                "{{ block.settings.product.id }}": {
                  {%- for i in (1..25) -%}
                    {%- liquid
                      assign heading_key = 'heading_' | append: i
                      assign value_key = 'value_' | append: i
                      assign heading = block.settings[heading_key]
                      assign value = block.settings[value_key]

                      assign stripped_value = value | strip_html | strip | upcase
                      if stripped_value == 'FALSE'
                        capture value
                          render 'icon', icon: 'close-circle-filled'
                        endcapture
                      elsif stripped_value == 'TRUE'
                        capture value
                          render 'icon', icon: 'check-circle-filled'
                        endcapture
                      else
                        assign value = value | default: '—'
                      endif

                      assign first_block_heading = section.blocks[0].settings[heading_key]
                      if first_block_heading contains '####'
                        assign heading = ''
                      endif
                    -%}
                    {%- if first_block_heading != blank -%}
                      "heading_{{ i }}": "{{ heading | escape }}",
                      "value_{{ i }}": "{{ value | strip_newlines | escape }}",
                    {%- endif -%}
                  {%- endfor -%}
                },
              {%- endif -%}
            {%- endfor -%}
          }
        </script>
        {%- for block in section.blocks -%}
          {%- if block.settings.product != blank -%}
            <script type="text/mustache" id="ProductComparisonInfo-{{ section.id }}-{{ block.settings.product.id }}">
              {%- if block.settings.product != blank -%}
                {%- liquid
                  assign card_product = block.settings.product
                  assign first_available_variant = blank
                  if card_product.has_only_default_variant == false and section.settings.first_available_variant
                    assign first_available_variant = card_product.first_available_variant
                  endif
                  assign featured_media = first_available_variant.featured_media | default: card_product.featured_media
                -%}
                <div class="horizontal-product flex items-start flex-col gap-4 md:flex-row md:gap-6">
                  <a class="horizontal-product__media media media--{{ settings.product_image_ratio }}{% unless settings.product_image_fill %} media--contain{% endunless %} relative overflow-hidden shrink-0" href="{{ card_product.url }}">
                    {%- liquid
                      if featured_media
                        echo featured_media | image_url: width: featured_media.width | image_tag: loading: 'lazy', widths: '180,360,540', is: 'lazy-image'
                      else
                        echo 'product-1' | placeholder_svg_tag
                      endif
                    -%}
                  </a>
                  <div class="horizontal-product__details grow flex flex-col justify-start align-self-center gap-1d5 w-full">
                    <div class="flex flex-col gap-1">
                      <div class="block">
                        {%- if section.settings.show_vendor -%}
                          <p class="horizontal-product__vendor text-xs text-opacity">{{ card_product.vendor }}</p>
                        {%- endif -%}
                        <a href="{{ card_product.url }}" class="horizontal-product__title reversed-link font-medium text-base leading-tight">{{ block.settings.custom_product_name | default: card_product.title }}</a>
                      </div>
                      {%- if first_available_variant != blank -%}
                        <p class="text-xs text-opacity leading-tight">{{ first_available_variant.title }}</p>
                      {%- endif -%}
                    </div>
                    <div class="flex flex-col gap-1">
                      {%- liquid
                        if section.settings.show_price
                          if first_available_variant != blank
                            render 'product-price', product: card_product, variant: first_available_variant, use_variant: true, class: 'flex flex-wrap items-end gap-2 text-sm'
                          else
                            render 'product-price', product: card_product, class: 'flex flex-wrap items-end gap-2 text-sm'
                          endif
                        endif
                      -%}
                    </div>
                  </div>
                </div>
              {%- endif -%}
            </script>
            <script type="text/mustache" id="ProductComparisonAction-{{ section.id }}-{{ block.settings.product.id }}">
              {%- if block.settings.product != blank -%}
                {%- liquid
                  assign card_product = block.settings.product
                  assign first_available_variant = blank
                  if card_product.has_only_default_variant == false and section.settings.first_available_variant
                    assign first_available_variant = card_product.first_available_variant
                  endif
                -%}
<a href="{{ card_product.url }}" class="button button--primary w-full" is="hover-link" aria-label="{{ block.settings.primary_cta_label | default: 'Select Size' }}">
                  <span class="btn-fill" data-fill></span>
                  <span class="btn-text">
                    {{ block.settings.primary_cta_label | default: 'Select Size' }}
                  </span>
                </a>
                {%- if block.settings.secondary_cta_label != blank -%}
                  <a href="{{ block.settings.secondary_cta_link | default: card_product.url }}"
                    class="button {{ block.settings.secondary_cta_style }} w-full" style="margin-top: 8px;"
                    is="hover-link"
                    aria-label="{{ block.settings.secondary_cta_label }}"
                    {% if block.settings.secondary_cta_external %}target="_blank" rel="noopener"{% endif %}>
                    <span class="btn-fill" data-fill></span>
                    <span class="btn-text">
                      {{ block.settings.secondary_cta_label }}
                      {%- if block.settings.secondary_cta_icon -%}
                        {%- render 'icon', icon: 'arrow-right', size: 'sm' -%}
                      {%- endif -%}
                    </span>
                  </a>
                {%- endif -%}
              {%- endif -%}
            </script>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </comparison-table>
  </div>
</div>

{% schema %}
{
  "name": "Product comparison",
  "class": "comparison-table-section",
  "settings": [
{
  "type": "select",
  "id": "visible_products",
  "options": [
    {
      "value": "2",
      "label": "2 products"
    },
    {
      "value": "3",
      "label": "3 products"
    },
    {
      "value": "4",
      "label": "4 products"
    }
  ],
  "label": "Number of visible products",
  "info": "Choose how many products to display. Additional products will appear in dropdowns.",
  "default": "3"
},
    {
      "type": "checkbox",
      "id": "highlight_differences",
      "label": "Highlight differences",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "sticky_product_info",
      "label": "Sticky product info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "first_available_variant",
      "default": true,
      "label": "Show first available variant"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": true,
      "label": "Show vendor"
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "default": true,
      "label": "Show price"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Product comparison"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "title-sm",
          "label": "Small"
        },
        {
          "value": "title-md",
          "label": "Medium"
        },
        {
          "value": "title-lg tracking-heading",
          "label": "Large"
        },
        {
          "value": "title-xl tracking-heading",
          "label": "Extra large"
        }
      ],
      "default": "title-md",
      "label": "Heading size"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        {
          "value": "text-left md:items-end md:flex-row",
          "label": "Left"
        },
        {
          "value": "text-center md:items-center",
          "label": "Center"
        },
        {
          "value": "text-right md:items-end md:flex-row-reverse",
          "label": "Right"
        }
      ],
      "default": "text-center md:items-center"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        },
        {
          "value": "div",
          "label": "div"
        },
        {
          "value": "span",
          "label": "span"
        },
        {
          "value": "p",
          "label": "p"
        }
      ],
      "default": "h2",
      "label": "Heading tag",
      "info": "Choose the HTML tag for the heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "info": "Leave blank to hide button"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "visible_if": "{{ section.settings.button_label != blank }}",
      "type": "checkbox",
      "id": "button_external",
      "label": "Open link in new tab",
      "default": false
    },
    {
      "visible_if": "{{ section.settings.button_label != blank }}",
      "type": "checkbox",
      "id": "button_icon",
      "label": "Show button icon",
      "default": true
    },
    {
      "type": "header",
      "content": "Highlight",
      "info": "Highlight text in heading"
    },
    {
      "type": "select",
      "id": "highlighted_text",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "text",
          "label": "Text"
        },
        {
          "value": "full_text",
          "label": "Full text"
        },
        {
          "value": "half_text",
          "label": "Half text"
        },
        {
          "value": "underline",
          "label": "Underline"
        },
        {
          "value": "marker",
          "label": "Marker"
        },
        {
          "value": "stencil",
          "label": "Stencil"
        },
        {
          "value": "scribble",
          "label": "Scribble"
        }
      ],
      "default": "none",
      "label": "Highlighted text style"
    },
    {
      "visible_if": "{{ section.settings.highlighted_text == 'scribble' }}",
      "type": "select",
      "id": "highlighted_scribble",
      "options": [
        {
          "value": "circle",
          "label": "Circle"
        },
        {
          "value": "basic-underline",
          "label": "Basic underline"
        },
        {
          "value": "sketch-underline",
          "label": "Sketch underline"
        },
        {
          "value": "squiggle-underline",
          "label": "Squiggle underline"
        },
        {
          "value": "squiggle-underline-2",
          "label": "Squiggle underline 2"
        }
      ],
      "default": "circle",
      "label": "Scribble style",
      "info": "Choose the scribble style for highlighted text"
    },
    {
      "visible_if": "{{ section.settings.highlighted_text != 'none' }}",
      "type": "checkbox",
      "id": "highlighted_reveal",
      "label": "Reveal on scroll",
      "default": false
    },
    {
      "type": "header",
      "content": "Colors",
      "info": "Customize section colors"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Text color"
    },
    {
      "type": "color",
      "id": "color_background",
      "label": "Background color"
    },
    {
      "type": "color_background",
      "id": "gradient_background",
      "label": "Background gradient"
    },
    {
      "type": "color",
      "id": "color_highlight",
      "label": "Highlight color"
    },
    {
      "type": "color_background",
      "id": "gradient_highlight",
      "label": "Highlight gradient"
    },
    {
