{% comment %}
  Shopify Custom Liquid Section: Zendesk FAQ Renderer
  Pulls articles from Zendesk Help Center and displays full content.
{% endcomment %}

<div class="faq-section" id="faq-list">
  <h2>Frequently Asked Questions</h2>
  <p>Loading FAQs…</p>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const container = document.getElementById('faq-list');
  container.innerHTML = '<p>Loading FAQs…</p>';

  let allArticles = [];
  let displayedCount = 0;
  const articlesPerLoad = 10; // Show 10 at a time

  // Step 1: fetch list of articles
  fetch('https://support.aetrex.com/api/v2/help_center/en-us/articles.json?per_page=50')
    .then(res => res.json())
    .then(data => {
      allArticles = data.articles;
      container.innerHTML = ''; // clear loading text
      
      // Load first batch
      loadMoreArticles();
    })
    .catch(err => {
      console.error('Error fetching articles list:', err);
      container.innerHTML = '<p>Unable to load FAQs at this time.</p>';
    });

  function loadMoreArticles() {
    const articlesToLoad = allArticles.slice(displayedCount, displayedCount + articlesPerLoad);
    
    // Remove existing "Load More" button if it exists
    const existingBtn = document.getElementById('load-more-btn');
    if (existingBtn) existingBtn.remove();

    // Create an array of promises for all article fetches
    const fetchPromises = articlesToLoad.map((article, index) => {
      return fetch(`https://support.aetrex.com/api/v2/help_center/articles/${article.id}.json`)
        .then(res => res.json())
        .then(articleData => {
          // Get the body content
          const body = articleData.article?.body || 
                      articleData.article?.body_html || 
                      'Content not available';
          
          return {
            index: index,
            title: article.title,
            body: body
          };
        })
        .catch(err => {
          console.error('Error fetching article:', article.id, err);
          return null;
        });
    });

    // Wait for all articles to load, then render them IN ORDER
    Promise.all(fetchPromises).then((articlesData) => {
      // Sort by original index to maintain order
      articlesData.sort((a, b) => {
        if (!a) return 1;
        if (!b) return -1;
        return a.index - b.index;
      });

      // Render articles in correct order
      articlesData.forEach(articleData => {
        if (!articleData) return;

        const articleEl = document.createElement('div');
        articleEl.className = 'faq-article';
        
        const btn = document.createElement('button');
        btn.className = 'faq-question';
        btn.textContent = articleData.title;
        
        const ans = document.createElement('div');
        ans.className = 'faq-answer';
        ans.innerHTML = articleData.body;
        ans.style.display = 'none';
        
        // Append elements
        articleEl.appendChild(btn);
        articleEl.appendChild(ans);
        container.appendChild(articleEl);

        // Collapsible toggle
        btn.addEventListener('click', () => {
          ans.style.display = (ans.style.display === 'block') ? 'none' : 'block';
        });
      });

      displayedCount += articlesToLoad.length;

      // Add "Load More" button if there are more articles
      if (displayedCount < allArticles.length) {
        const loadMoreBtn = document.createElement('button');
        loadMoreBtn.id = 'load-more-btn';
        loadMoreBtn.className = 'load-more-button';
        loadMoreBtn.textContent = `Load More (${allArticles.length - displayedCount} remaining)`;
        loadMoreBtn.addEventListener('click', loadMoreArticles);
        container.appendChild(loadMoreBtn);
      }
    });
  }
});
</script>

<style>
.faq-section { 
  max-width: 800px; 
  margin: 2rem auto; 
  padding: 2rem;
  background: #f4f4f4;
  font-family: sans-serif; 
}
.faq-section h2 { 
  text-align: center; 
  margin-bottom: 2rem; 
}
.faq-article { 
  margin-bottom: 1rem; 
}
.faq-question { 
  width: 100%; 
  text-align: left; 
  padding: 0.75rem 1rem; 
  margin-bottom: 0.25rem; 
  background: #ffffff; 
  border: none; 
  cursor: pointer; 
  font-size: 1.1rem; 
  transition: background 0.3s;
}
.faq-question:hover { 
  background: #e0e0e0; 
}
.faq-answer { 
  display: none; 
  padding: 0.75rem 1rem; 
  border-left: 3px solid #007bff; 
  background: #ffffff; 
  margin-bottom: 1rem; 
}
/* Style links in answers */
.faq-answer a {
  color: #007bff;
  text-decoration: underline;
}
.faq-answer a:hover {
  color: #0056b3;
}
/* Load More button */
.load-more-button {
  display: block;
  margin: 2rem auto;
  padding: 0.75rem 2rem;
  background: #007bff;
  color: white;
  border: none;
  border-radius: 4px;
  font-size: 1rem;
  cursor: pointer;
  transition: background 0.3s;
}
.load-more-button:hover {
  background: #0056b3;
}
</style>

