{% comment %}
  Shopify Custom Liquid Section: Zendesk FAQ Renderer
  Pulls articles from Zendesk Help Center and displays full content.
{% endcomment %}

<div class="faq-section" id="faq-list">
  <h2>Frequently Asked Questions</h2>
  <p>Loading FAQs…</p>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const container = document.getElementById('faq-list');
  container.innerHTML = '<p>Loading FAQs…</p>';

  // Step 1: fetch list of articles
  fetch('https://support.aetrex.com/api/v2/help_center/en-us/articles.json?per_page=50')
    .then(res => res.json())
    .then(data => {
      container.innerHTML = ''; // clear loading text

      // Step 2: fetch each article's full content
      data.articles.forEach(article => {
        fetch(`https://support.aetrex.com/api/v2/help_center/articles/${article.id}.json`)
          .then(res => res.json())
          .then(articleData => {
            const articleEl = document.createElement('div');
            articleEl.className = 'faq-article';
            articleEl.innerHTML = `
              <button class="faq-question">${article.title}</button>
              <div class="faq-answer">${articleData.article.body_html}</div>
            `;
            container.appendChild(articleEl);

            // Collapsible toggle
            const btn = articleEl.querySelector('.faq-question');
            const ans = articleEl.querySelector('.faq-answer');
            btn.addEventListener('click', () => {
              ans.style.display = (ans.style.display === 'block') ? 'none' : 'block';
            });
          })
          .catch(err => console.error('Error fetching article:', err));
      });
    })
    .catch(err => {
      console.error('Error fetching articles list:', err);
      container.innerHTML = '<p>Unable to load FAQs at this time.</p>';
    });
});
</script>

<style>
.faq-section { 
  max-width: 800px; 
  margin: 2rem auto; 
  font-family: sans-serif; 
}
.faq-section h2 { 
  text-align: center; 
  margin-bottom: 2rem; 
}
.faq-article { 
  margin-bottom: 1rem; 
}
.faq-question { 
  width: 100%; 
  text-align: left; 
  padding: 0.75rem 1rem; 
  margin-bottom: 0.25rem; 
  background: #f7f7f7; 
  border: none; 
  cursor: pointer; 
  font-size: 1.1rem; 
  transition: background 0.3s;
}
.faq-question:hover { 
  background: #e0e0e0; 
}
.faq-answer { 
  display: none; 
  padding: 0.75rem 1rem; 
  border-left: 3px solid #007bff; 
  background: #fafafa; 
  margin-bottom: 1rem; 
}
</style>

{% schema %}
{
  "name": "Zendesk FAQ",
  "tag": "section",
  "settings": [],
  "blocks": [],
  "max_blocks": 1,
  "presets": [
    {
      "name": "Zendesk FAQ Section"
    }
  ]
}
{% endschema %}
