<style>

/* ===============================
   DESKTOP / MOBILE BEHAVIOR
================================ */

@media (min-width: 769px) {
  #shopify-section-{{ section.id }} .dynamic-feature__dot {
    pointer-events: none;
    cursor: default;
  }
}

@media (max-width: 767px) {
  .hotspot__content {
    display: none !important;
  }
}

/* ===============================
   MODAL POINTER EVENTS FIX
================================ */

.x-modal,
.x-modal .overlay {
  pointer-events: none;
}

.x-modal:not(.invisible),
.x-modal:not(.invisible) .overlay {
  pointer-events: auto;
}

#shopify-section-{{ section.id }} .drawer__scrollable {
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* ===============================
   SECTION VARIABLES
================================ */

#shopify-section-{{ section.id }} {
  --section-padding-top: {{ section.settings.padding_top }}px;
  --section-padding-bottom: {{ section.settings.padding_bottom }}px;
}

/* ===============================
   STRUCTURE
================================ */

#shopify-section-{{ section.id }} .dynamic-feature {
  position: relative;
  overflow: visible;
}

#shopify-section-{{ section.id }} .dynamic-feature__wrapper,
#shopify-section-{{ section.id }} .dynamic-feature__media {
  position: relative;
  width: 100%;
}

#shopify-section-{{ section.id }} .dynamic-feature__image {
  display: block;
  width: 100%;
  height: auto;
  position: relative;
  z-index: 1;
}

/* ===============================
   SVG LINES
================================ */

#shopify-section-{{ section.id }} .dynamic-feature__lines {
  position: absolute;
  inset: 0;
  z-index: 5;
  pointer-events: none;
}

.dynamic-feature__line {
  stroke: {{ section.settings.line_color | default: '#000000' }};
  stroke-width: {{ section.settings.line_width | default: 2 }};
  fill: none;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-dasharray: var(--line-length, 1000);
  stroke-dashoffset: var(--line-length, 1000);
  animation: none;
}

@keyframes drawLine {
  to { stroke-dashoffset: 0; }
}
/* ===============================
   DOTS (HIDDEN BY DEFAULT)
================================ */

#shopify-section-{{ section.id }} .dynamic-feature__dot {
  position: absolute;
  transform: translate(-50%, -50%);
  z-index: 20;
  opacity: 1;
  visibility: visible;
}

#shopify-section-{{ section.id }} .dynamic-feature__dot-inner {
  width: {{ section.settings.dot_size | default: 20 }}px;
  height: {{ section.settings.dot_size | default: 20 }}px;
  background: {{ section.settings.dot_color | default: '#ffffff' }};
  border: {{ section.settings.dot_border_width | default: 3 }}px solid {{ section.settings.dot_border_color | default: '#000000' }};
  border-radius: 50%;
  box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  transform: scale(0);
  transition: transform 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Animate dots in - FIXED */
#shopify-section-{{ section.id }} .dynamic-feature.is-visible .dynamic-feature__dot-inner {
  transform: scale(1) !important;
}

/* Hover only when visible & desktop */
@media (hover: hover) and (pointer: fine) {
  #shopify-section-{{ section.id }} .dynamic-feature.is-visible .dynamic-feature__dot:hover .dynamic-feature__dot-inner {
    transform: scale(1.3) !important;
    box-shadow: 0 4px 16px rgba(0,0,0,0.25) !important;
  }
}

/* Stagger dot animation */
{%- for block in section.blocks -%}
#shopify-section-{{ section.id }} #shopify-block-{{ block.id }} .dynamic-feature__dot-inner {
  transition-delay: {{ forloop.index0 | times: 0.1 }}s;
}
{%- endfor -%}

/* ===============================
   CONTENT CALLOUTS
================================ */

#shopify-section-{{ section.id }} .dynamic-feature__content {
  position: absolute;
  pointer-events: auto;
  opacity: 0;
  transform: translateY(10px);
}

@keyframes fadeInContent {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

#shopify-section-{{ section.id }} .dynamic-feature__callout {
  background: {{ section.settings.callout_background | default: '#ffffff' }};
  padding: 16px 20px;
  border-radius: {{ section.settings.callout_radius | default: 8 }}px;
  ox-shadow: 0 4px 12px rgba(0,0,0,0.15);
  max-width: {{ section.settings.callout_max_width | default: 220 }}px;
  order: 1px solid rgba(0,0,0,0.1);
}

#shopify-section-{{ section.id }} .dynamic-feature__callout-title {
  font-weight: 700;
  font-size: 14px;
  margin-bottom: 8px;
}

#shopify-section-{{ section.id }} .dynamic-feature__callout-text {
  font-size: 12px;
  line-height: 1.4;
}

/* ===============================
   MOBILE ADJUSTMENTS
================================ */

@media (max-width: 768px) {
  #shopify-section-{{ section.id }} .dynamic-feature__lines,
  #shopify-section-{{ section.id }} .dynamic-feature__content {
    display: none;
  }

  #shopify-section-{{ section.id }} .dynamic-feature__dot {
    pointer-events: auto;
  }

  #shopify-section-{{ section.id }} .dynamic-feature__dot-inner {
    width: {{ section.settings.dot_size_mobile | default: 16 }}px !important;
    height: {{ section.settings.dot_size_mobile | default: 16 }}px !important;
    transform: scale(1) !important;
  }
}

/* ===============================
   MOBILE DRAWER / MODAL
================================ */

#shopify-section-{{ section.id }} .x-modal {
  position: fixed;
  inset: 0;
  z-index: 30;
  pointer-events: none;
  opacity: 0;
  visibility: hidden;
}

#shopify-section-{{ section.id }} .x-modal[open] {
  pointer-events: auto;
  opacity: 1;
  visibility: visible;
}

#shopify-section-{{ section.id }} overlay-element {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.3);
  z-index: 5;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.25s ease;
}

#shopify-section-{{ section.id }} .x-modal[open] overlay-element {
  opacity: 1;
  visibility: visible;
}

#shopify-section-{{ section.id }} .drawer__inner {
  position: absolute;
  inset: 0;
  transform: translateY(100%);
  transition: transform 0.35s ease;
}

#shopify-section-{{ section.id }} .x-modal[open] .drawer__inner {
  transform: translateY(0);
}

/* ===============================
   SCROLL TRIGGER
================================ */

.dynamic-feature.is-visible .dynamic-feature__line {
  animation: drawLine 2.5s ease-out forwards;
}

.dynamic-feature.is-visible .dynamic-feature__content {
  animation: fadeInContent 0.8s ease-out forwards;
}
</style>


<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}" data-section-id="{{ section.id }}">
  <div class="{% unless section.settings.full_width %}page-width {% endunless %}relative" style="width: fit-content;">
    {%- if section.settings.heading != blank -%}
      <div class="mb-8">
        <h2 class="heading title-md">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="dynamic-feature relative">
      <div class="dynamic-feature__wrapper">
        <div class="dynamic-feature__media relative w-full">
          {%- if section.settings.image != blank -%}
            <picture>
              {%- if section.settings.image_mobile -%}
                <source media="(max-width: 767px)" srcset="{{ section.settings.image_mobile | image_url: width: '400x' }} 400w, {{ section.settings.image_mobile | image_url: width: '800x' }} 800w">
              {%- endif -%}
              <img src="{{ section.settings.image | image_url: width: '1200x' }}" alt="{{ section.settings.image.alt }}" class="dynamic-feature__image w-full block">
            </picture>
          {%- else -%}
            <div class="bg-gray-200 w-full aspect-square flex items-center justify-center">
              <span class="text-gray-500">No image selected</span>
            </div>
          {%- endif -%}

    <svg class="dynamic-feature__lines" viewBox="0 0 100 100" preserveAspectRatio="none">
      {% for block in section.blocks %}
        <path
          class="dynamic-feature__line"
          data-start-x="{{ block.settings.horizontal }}"
          data-start-y="{{ block.settings.vertical }}"
          data-end-x="{{ block.settings.text_horizontal }}"
          data-end-y="{{ block.settings.text_vertical }}"
          data-breaks="{{ block.settings.line_breaks | default: 1 }}"
        />
      {% endfor %}
    </svg>

          {%- for block in section.blocks -%}
            {%- if block.type == 'feature' -%}
              <div class="dynamic-feature__dot" id="shopify-block-{{ block.id }}" style="left: {{ block.settings.horizontal }}%; top: {{ block.settings.vertical }}%;" {{ block.shopify_attributes }}>
                <div class="dynamic-feature__dot-inner"></div>
              </div>

              <div  class="dynamic-feature__content{% if block.settings.text_horizontal < 20 %} with-left{% elsif block.settings.text_horizontal > 80 %} with-right{% endif %}{% if block.settings.text_vertical > 70 %} with-bottom{% endif %}" style="left: {{ block.settings.text_horizontal }}%; top: {{ block.settings.text_vertical }}%; animation-delay: {{ forloop.index0 | times: 0.1 | plus: 1.8 }}s;">
                <div class="dynamic-feature__callout">
                  {%- if block.settings.heading != blank -%}
                    <p class="dynamic-feature__callout-title">{{ block.settings.heading }}</p>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <p class="dynamic-feature__callout-text">{{ block.settings.text }}</p>
                  {%- endif -%}
                </div>
              </div>

             <x-modal
  id="Feature-{{ section.id }}-{{ block.id }}"
  class="x-modal drawer z-30 fixed bottom-0 left-0 h-full w-full pointer-events-none invisible"
  role="dialog"
  aria-modal="true"
  aria-label="{{ block.settings.heading | escape }}"
  aria-hidden="true"
>

                <overlay-element class="overlay fixed-modal invisible opacity-0 fixed bottom-0 left-0 w-full h-screen pointer-events-none" aria-controls="Feature-{{ section.id }}-{{ block.id }}" aria-expanded="false"></overlay-element>
                <div class="drawer__inner z-10 absolute top-0 flex flex-col w-full h-full overflow-hidden">
                  <button class="drawer__close-menu absolute z-20 flex items-center justify-center w-10 h-10 rounded-full bg-white shadow-md" type="button" aria-label="{{ 'general.accessibility.close' | t | escape }}">
                    {%- render 'icon', icon: 'close' -%}
                  </button>
                  <gesture-element class="drawer__header flex justify-between opacity-0 invisible relative">
                    <span class="drawer__title heading title-md">{{ block.settings.heading | escape }}</span>
                    <button class="button button--secondary button--close drawer__close hidden sm:flex items-center justify-center" type="button" is="hover-button" aria-controls="Feature-{{ section.id }}-{{ block.id }}" aria-expanded="false" aria-label="{{ 'general.accessibility.close' | t | escape }}">
                      <span class="btn-fill" data-fill></span>
                      <span class="btn-text">×</span>
                    </button>
                  </gesture-element>
                  <div class="drawer__content opacity-0 invisible flex flex-col h-full grow shrink">
                    <div class="drawer__scrollable relative flex flex-col gap-5 md:gap-7 grow shrink">
                      <div class="rte text-base md:text-lg">{{ block.settings.text }}</div>
                    </div>
                  </div>
                </div>
              </x-modal>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</div>

<script>
class DynamicFeatureSection {
  constructor(section) {
    this.section = section;
    this.sectionId = section.dataset.sectionId;
    this.svg = section.querySelector('.dynamic-feature__lines');
    this.lines = this.svg?.querySelectorAll('.dynamic-feature__line') || [];
    this.media = section.querySelector('.dynamic-feature__media');
    this.isMobile = window.innerWidth <= 768;

    this.init();
    window.addEventListener('resize', () => this.onResize());
  }

init() {
    if (this.isMobile) {
      // On mobile, add is-visible immediately since we don't need line animations
      this.section.querySelector('.dynamic-feature').classList.add('is-visible');
      return;
    }
    this.setupObserver();
  }

  onResize() {
    const wasMobile = this.isMobile;
    this.isMobile = window.innerWidth <= 768;
    if (wasMobile !== this.isMobile && !this.isMobile) {
      this.drawLines();
    }
  }

  setupObserver() {
    const observer = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
if (entry.isIntersecting) {
  this.section
    .querySelector('.dynamic-feature')
    .classList.add('is-visible');

  this.drawLines(true);
  observer.disconnect();
}

        });
      },
      { threshold: 0.4 }
    );

    observer.observe(this.section);
  }

  drawLines(animate = false) {
    const mediaRect = this.media.getBoundingClientRect();
    const contents = this.section.querySelectorAll('.dynamic-feature__content');

    this.lines.forEach((line, index) => {
      const sx = parseFloat(line.dataset.startX);
      const sy = parseFloat(line.dataset.startY);
      const hasBend = parseInt(line.dataset.breaks, 10) === 1;

      const content = contents[index];
      if (!content) return;

      const box = content.getBoundingClientRect();
      const GAP_PX = 12;

      const goingRight = box.left > mediaRect.left + (sx / 100) * mediaRect.width;

      const endXPx = goingRight
        ? box.left - GAP_PX
        : box.right + GAP_PX;

      const endX =
        ((endXPx - mediaRect.left) / mediaRect.width) * 100;

      const endY =
        ((box.top + box.height / 2 - mediaRect.top) / mediaRect.height) * 100;

      const deltaY = Math.abs(endY - sy);
      const MIN_BEND_DISTANCE = 3;

      let path;

      if (!hasBend || deltaY < MIN_BEND_DISTANCE) {
        path = `M ${sx},${sy} L ${endX},${endY}`;
      } else {
        const goingRight = endX > sx;
        const elbowX = goingRight
          ? sx + Math.abs(endX - sx) * 0.5
          : sx - Math.abs(endX - sx) * 0.5;

        const radius = Math.min(4, Math.abs(endX - sx) / 4);
        const vertDir = endY > sy ? 1 : -1;

        path = `
          M ${sx},${sy}
          L ${elbowX - radius * (goingRight ? 1 : -1)},${sy}
          Q ${elbowX},${sy} ${elbowX},${sy + radius * vertDir}
          L ${elbowX},${endY - radius * vertDir}
          Q ${elbowX},${endY} ${elbowX + radius * (goingRight ? 1 : -1)},${endY}
          L ${endX},${endY}
        `;
      }

      line.setAttribute('d', path);

      const length = line.getTotalLength();

      line.style.setProperty('--line-length', length);
      line.style.strokeDasharray = length;
      line.style.strokeDashoffset = length;

      if (animate) {
        line.style.animation = `drawLine 2.5s ease-out forwards`;
        line.style.animationDelay = `${index * 1.35}s`;
      }
    });
  }
}

function initDynamicFeatures(scope = document) {
  scope.querySelectorAll('[data-section-id]').forEach(section => {
    if (section.querySelector('.dynamic-feature')) {
      new DynamicFeatureSection(section);
    }
  });
}

document.addEventListener('DOMContentLoaded', () => initDynamicFeatures());
document.addEventListener('shopify:section:load', e => initDynamicFeatures(e.target));
</script>

<script>
(function () {
  function handleModals(scope = document) {
    // Handle all x-modal elements
    scope.querySelectorAll('.x-modal').forEach(modal => {
      // Get overlay and close buttons
      const overlay = modal.querySelector('overlay-element');
      const closeButtons = modal.querySelectorAll('.drawer__close-menu, .drawer__close');

      // Handle overlay click
      if (overlay) {
        overlay.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          modal.removeAttribute('open');
          modal.hidden = true;
        });
      }

      // Handle close button clicks
      closeButtons.forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
modal.removeAttribute('open');
modal.classList.add('invisible');
modal.setAttribute('aria-hidden', 'true');


        });
      });
    });

    // Handle hotspot clicks to open modals
    scope.querySelectorAll('.dynamic-feature__dot').forEach(dot => {
      if (dot.dataset.handlerBound) return;
      dot.dataset.handlerBound = 'true';

      dot.addEventListener('click', (e) => {
          if (window.innerWidth > 768) return; // 🚫 desktop

        e.preventDefault();
        e.stopPropagation();
        
        const blockId = dot.id.replace('shopify-block-', '');
        const section = dot.closest('[data-section-id]');
        const modal = section.querySelector(
          `#Feature-${section.dataset.sectionId}-${blockId}`
        );

        if (modal) {
modal.setAttribute('open', '');
modal.classList.remove('invisible');
modal.setAttribute('aria-hidden', 'false');


        }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', () => handleModals());
  document.addEventListener('shopify:section:load', e => handleModals(e.target));
})();
</script>

