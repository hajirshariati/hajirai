<style>
#shopify-section-{{ section.id }} {
  --section-padding-top: {{ section.settings.padding_top }}px;
  --section-padding-bottom: {{ section.settings.padding_bottom }}px;
}

#shopify-section-{{ section.id }} .dynamic-feature {
  position: relative;
  overflow: hidden;
}

.dynamic-feature__lines {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.dynamic-feature__line {
  stroke: {{ section.settings.line_color }};
  stroke-width: {{ section.settings.line_width }};
  fill: none;
  stroke-linecap: round;
  stroke-linejoin: round;

  /* 🔑 fixes thick line issue */
  vector-effect: non-scaling-stroke;
  shape-rendering: geometricPrecision;

  animation: drawLine 1.2s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

@keyframes drawLine {
  to { stroke-dashoffset: 0; }
}

.dynamic-feature__dot {
  position: absolute;
  transform: translate(-50%, -50%);
  z-index: 5;
}

.dynamic-feature__dot-inner {
  width: {{ section.settings.dot_size }}px;
  height: {{ section.settings.dot_size }}px;
  border-radius: 50%;
  background: {{ section.settings.dot_color }};
  border: {{ section.settings.dot_border_width }}px solid {{ section.settings.dot_border_color }};
}

.dynamic-feature__content {
  position: absolute;
  opacity: 0;
  animation: fadeIn 0.6s ease-out forwards;
  animation-delay: 1.4s;
}

@keyframes fadeIn {
  to { opacity: 1; transform: translateY(0); }
}

.dynamic-feature__callout {
  background: {{ section.settings.callout_background }};
  padding: 16px 20px;
  border-radius: {{ section.settings.callout_radius }}px;
  max-width: {{ section.settings.callout_max_width }}px;
  box-shadow: 0 4px 12px rgba(0,0,0,.15);
}
</style>

<div class="dynamic-feature" data-section-id="{{ section.id }}">
  <div class="dynamic-feature__media">
    <img
      src="{{ section.settings.image | image_url: width: 1200 }}"
      class="dynamic-feature__image"
      alt=""
    >

    <svg class="dynamic-feature__lines" viewBox="0 0 100 100" preserveAspectRatio="none">
      {% for block in section.blocks %}
        <path
          class="dynamic-feature__line"
          data-start-x="{{ block.settings.horizontal }}"
          data-start-y="{{ block.settings.vertical }}"
          data-end-x="{{ block.settings.text_horizontal }}"
          data-end-y="{{ block.settings.text_vertical }}"
          data-breaks="{{ block.settings.line_breaks | default: 1 }}"
        />
      {% endfor %}
    </svg>

    {% for block in section.blocks %}
      <div
        class="dynamic-feature__dot"
        style="left: {{ block.settings.horizontal }}%; top: {{ block.settings.vertical }}%;"
      >
        <div class="dynamic-feature__dot-inner"></div>
      </div>

      <div
        class="dynamic-feature__content"
        style="left: {{ block.settings.text_horizontal }}%; top: {{ block.settings.text_vertical }}%;"
      >
        <div class="dynamic-feature__callout">
          <p><strong>{{ block.settings.heading }}</strong></p>
          <p>{{ block.settings.text }}</p>
        </div>
      </div>
    {% endfor %}
  </div>
</div>

<script>
class DynamicFeature {
  constructor(section) {
    this.section = section;
    this.svg = section.querySelector('svg');
    this.lines = this.svg.querySelectorAll('.dynamic-feature__line');
    this.contents = section.querySelectorAll('.dynamic-feature__content');
    this.draw();
  }

  generatePath(sx, sy, ex, ey, breaks) {
    const points = [{ x: sx, y: sy }];

    for (let i = 1; i <= breaks; i++) {
      const t = i / (breaks + 1);
      points.push({
        x: sx + (ex - sx) * t + (Math.random() * 8 - 4),
        y: sy + (ey - sy) * t + (Math.random() * 8 - 4)
      });
    }

    points.push({ x: ex, y: ey });

    return points.map((p, i) =>
      `${i === 0 ? 'M' : 'L'} ${p.x},${p.y}`
    ).join(' ');
  }

  draw() {
    this.lines.forEach((line, i) => {
      let sx = +line.dataset.startX;
      let sy = +line.dataset.startY;
      let ex = +line.dataset.endX;
      let ey = +line.dataset.endY;
      const breaks = +line.dataset.breaks;

      /* 🔑 stop before callout */
      const content = this.contents[i];
      if (content) {
        const contentRect = content.getBoundingClientRect();
        const svgRect = this.svg.getBoundingClientRect();
        ex = ((contentRect.left - svgRect.left) / svgRect.width) * 100 - 1.5;
      }

      const path = this.generatePath(sx, sy, ex, ey, breaks);
      line.setAttribute('d', path);

      const length = line.getTotalLength();
      line.style.strokeDasharray = length;
      line.style.strokeDashoffset = length;
      line.style.animationDelay = `${0.3 + i * 0.2}s`;
    });
  }
}

document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('.dynamic-feature').forEach(section => {
    new DynamicFeature(section);
  });
});
</script>


