{% comment %}
  Compare Modal Section
  - Renders a CTA button whose text is configurable in the schema
  - Clicking that button opens an Apple-style comparison modal
  - Tabs: Design | Camera | Chip | Battery | Price/Storage
  - Each tab can have multiple slides navigated with prev/next arrows
{% endcomment %}

<div class="compare-section" data-compare-section>
  <button
    class="compare-cta-btn"
    data-compare-open
    aria-haspopup="dialog"
  >
    {{ section.settings.cta_text | default: 'Compare models' }}
  </button>
</div>

<!-- ===================== MODAL ===================== -->
<div
  class="ric-modal ric-modal-scrim ric-modal-scrim-blur"
  id="compare-modal"
  aria-modal="true"
  role="dialog"
  aria-labelledby="compare-modal-headline"
  tabindex="-1"
  data-compare-modal
  hidden
>
  <div class="ric-modal-overlay-container" data-compare-backdrop>
    <div class="ric-modal-overlay">

      <!-- Header -->
      <div class="modal-header">
        <h2 class="modal-header-headline" id="compare-modal-headline">
          {{ section.settings.modal_headline | default: 'Compare latest models.' }}
        </h2>
      </div>

