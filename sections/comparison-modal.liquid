          <path d="m20.1211 18 3.4395-3.4395c.5859-.5854.5859-1.5356 0-2.1211-.5859-.5859-1.5352-.5859-2.1211 0l-3.4395 3.4395-3.4395-3.4395c-.5859-.5859-1.5352-.5859-2.1211 0-.5859.5854-.5859 1.5356 0 2.1211l3.4395 3.4395-3.4395 3.4395c-.5859.5854-.5859 1.5356 0 2.1211.293.293.6768.4395 1.0605.4395s.7676-.1465 1.0605-.4395l3.4395-3.4395 3.4395 3.4395c.293.293.6768.4395 1.0605.4395s.7676-.1465 1.0605-.4395c.5859-.5854.5859-1.5356 0-2.1211l-3.4395-3.4395z"/>
        </svg>
      </button>

    </div>
  </div>
</div>

<style>
/* ===================== RESET / BASE ===================== */
#shopify-section-{{ section.id }} *,
#shopify-section-{{ section.id }} *::before,
#shopify-section-{{ section.id }} *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

/* ===================== CTA BUTTON ===================== */
.compare-cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 12px 28px;
  background: #0071e3;
  color: #fff;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Helvetica Neue", sans-serif;
  font-size: 17px;
  font-weight: 400;
  letter-spacing: -0.022em;
  border: none;
  border-radius: 980px;
  cursor: pointer;
  transition: background 0.2s ease, transform 0.1s ease;
  text-decoration: none;
  white-space: nowrap;
}
.compare-cta-btn:hover { background: #0077ed; }
.compare-cta-btn:active { transform: scale(0.97); }

/* ===================== MODAL SCRIM ===================== */
.ric-modal {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.48);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}
.ric-modal.is-open {
  opacity: 1;
  pointer-events: all;
}

/* ===================== OVERLAY ===================== */
.ric-modal-overlay-container {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
}
.ric-modal-overlay {
  position: relative;
  background: #fff;
  border-radius: 20px;
  width: 100%;
  max-width: 780px;
  max-height: 90vh;
  overflow-y: auto;
  overflow-x: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 30px 80px rgba(0,0,0,0.3);
  transform: translateY(20px) scale(0.98);
  transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
}
.ric-modal.is-open .ric-modal-overlay {
  transform: translateY(0) scale(1);
}

/* ===================== MODAL HEADER ===================== */
.modal-header {
  padding: 44px 32px 0;
  position: sticky;
  top: 0;
  background: #fff;
  z-index: 10;
  border-radius: 20px 20px 0 0;
}
.modal-header-headline {
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Helvetica Neue", sans-serif;
  font-size: clamp(24px, 3.5vw, 36px);
  font-weight: 700;
  letter-spacing: -0.03em;
  color: #1d1d1f;
  line-height: 1.08;
}

/* ===================== TAB NAV ===================== */
.tabnav-wrapper {
  padding: 20px 32px 0;
  position: sticky;
  top: 0;
  background: #fff;
  z-index: 9;
}
.tabnav {
  position: relative;
  display: inline-flex;
  background: #f5f5f7;
  border-radius: 980px;
  padding: 4px;
}
.tabnav-items {
  list-style: none;
  display: flex;
  gap: 2px;
  position: relative;
  z-index: 2;
}
.tabnav-item { display: flex; }
.tabnav-link {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  border-radius: 980px;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", sans-serif;
  font-size: 13px;
  font-weight: 500;
  color: #1d1d1f;
  text-decoration: none;
  transition: color 0.2s;
  white-space: nowrap;
  cursor: pointer;
  position: relative;
  z-index: 2;
}
.tabnav-icon { display: flex; align-items: center; flex-shrink: 0; }
.tabnav-indicator {
  position: absolute;
  top: 4px;
  left: 4px;
  height: calc(100% - 8px);
  background: #fff;
  border-radius: 980px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.12);
  transition: transform 0.3s cubic-bezier(0.4,0,0.2,1), width 0.3s cubic-bezier(0.4,0,0.2,1);
  z-index: 1;
  pointer-events: none;
}
.tabnav-item-active .tabnav-link { color: #1d1d1f; }

/* ===================== GALLERY WRAPPER ===================== */
.compare-gallery-wrapper {
  position: relative;
  padding: 24px 32px 32px;
  flex: 1;
}

/* ===================== PRODUCT NAME TAGS ===================== */
.product-names-overlay {
  display: flex;
  gap: 0;
  margin-bottom: 12px;
}
.product-name-tag {
  flex: 1;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", sans-serif;
  font-size: 12px;
  font-weight: 600;
  color: #6e6e73;
  letter-spacing: 0.02em;
  text-transform: uppercase;
  text-align: center;
}

/* ===================== SLIDE GROUPS ===================== */
.slide-group { display: block; }
.slide-group.hidden { display: none; }

/* ===================== SLIDE (row of 3 cards) ===================== */
.slide { display: none; }
.slide.active { display: flex; gap: 12px; }

/* ===================== GALLERY CARD ===================== */
.gallery-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12px;
  min-width: 0;
}
.gallery-card-img-placeholder {
  position: relative;
  width: 100%;
  aspect-ratio: 3/4;
  border-radius: 12px;
  display: flex;
  align-items: flex-end;
  padding: 12px;
  overflow: hidden;
}
.gallery-card-img-placeholder img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  position: absolute;
  inset: 0;
  border-radius: 12px;
}
.img-label {
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", sans-serif;
  font-size: 11px;
  font-weight: 600;
  color: rgba(255,255,255,0.85);
  letter-spacing: 0.04em;
  text-transform: uppercase;
  position: relative;
  z-index: 1;
}
.copy-container {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 0 4px;
}
.card-headline {
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Helvetica Neue", sans-serif;
  font-size: clamp(13px, 1.6vw, 16px);
  font-weight: 600;
  color: #1d1d1f;
  letter-spacing: -0.022em;
  line-height: 1.25;
}
.card-callout {
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Helvetica Neue", sans-serif;
  font-size: clamp(24px, 3vw, 36px);
  font-weight: 700;
  color: #1d1d1f;
  letter-spacing: -0.04em;
  line-height: 1;
}
.card-feature {
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", sans-serif;
  font-size: clamp(11px, 1.3vw, 13px);
  color: #6e6e73;
  line-height: 1.5;
}
.zoom-levels {
  list-style: none;
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 4px;
}
.zoom-levels li {
  background: #f5f5f7;
  border-radius: 980px;
  padding: 3px 10px;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", sans-serif;
  font-size: 12px;
  font-weight: 500;
  color: #1d1d1f;
}

/* ===================== PADDLE NAV ===================== */
.paddlenav {
  display: flex;
  justify-content: center;
  gap: 12px;
  margin-top: 24px;
}
.paddlenav-arrow {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: #f5f5f7;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
  flex-shrink: 0;
}
.paddlenav-arrow:hover:not(:disabled) { background: #e8e8ed; }
.paddlenav-arrow:disabled { opacity: 0.3; cursor: default; }
.paddlenav-arrow svg { width: 20px; height: 20px; fill: #1d1d1f; }

/* ===================== CLOSE BUTTON ===================== */
.ric-modal-close-button {
  position: absolute;
  top: 16px;
  right: 16px;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: #f5f5f7;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s, transform 0.1s;
  z-index: 20;
}
.ric-modal-close-button:hover { background: #e8e8ed; }
.ric-modal-close-button:active { transform: scale(0.92); }
.ric-modal-close-button svg { fill: #1d1d1f; }

/* ===================== RESPONSIVE ===================== */
@media (max-width: 600px) {
  .modal-header, .tabnav-wrapper { padding-left: 20px; padding-right: 20px; }
  .compare-gallery-wrapper { padding: 16px 20px 24px; }
  .tabnav-link { padding: 7px 10px; font-size: 11px; }
  .tabnav-icon { display: none; }
  .slide.active { flex-direction: column; }
  .gallery-card-img-placeholder { aspect-ratio: 16/9; }
  .product-names-overlay { flex-direction: column; gap: 0; }
  .product-name-tag { text-align: left; padding: 2px 0; }
}
</style>

<script>
(function() {
  const section = document.querySelector('[data-compare-section]') 
    || document.currentScript.closest('section') 
    || document.body;

  const modal        = document.querySelector('[data-compare-modal]');
  const backdrop     = document.querySelector('[data-compare-backdrop]');
  const openBtn      = document.querySelector('[data-compare-open]');
  const closeBtn     = document.querySelector('[data-compare-close]');
  const tabLinks     = document.querySelectorAll('[data-tab-control]');
  const indicator    = document.querySelector('[data-tabnav-indicator]');
  const prevBtn      = document.querySelector('[data-gallery-prev]');
  const nextBtn      = document.querySelector('[data-gallery-next]');

  if (!modal) return;

  let currentTab = 'design';
  let currentSlide = 0;

  // ---------- helpers ----------
  function getSlides() {
    return modal.querySelectorAll(`[data-slide-group="${currentTab}"] [data-slide]`);
  }

  function updatePaddles() {
    const slides = getSlides();
    prevBtn.disabled = currentSlide === 0;
    nextBtn.disabled = currentSlide >= slides.length - 1;
  }

  function showSlide(index) {
    const slides = getSlides();
    slides.forEach((s, i) => s.classList.toggle('active', i === index));
    currentSlide = index;
    updatePaddles();
  }

  function positionIndicator(linkEl) {
    if (!indicator || !linkEl) return;
    const nav   = indicator.closest('.tabnav');
    const navR  = nav.getBoundingClientRect();
    const linkR = linkEl.closest('.tabnav-item').getBoundingClientRect();
    indicator.style.width  = linkR.width + 'px';
    indicator.style.transform = `translateX(${linkR.left - navR.left - 4}px)`;
  }

  function switchTab(tab) {
    currentTab = tab;
    currentSlide = 0;

    // hide all slide groups, show target
    modal.querySelectorAll('[data-slide-group]').forEach(g => {
      g.classList.toggle('hidden', g.dataset.slideGroup !== tab);
    });

    // mark active tab
    tabLinks.forEach(l => {
      const active = l.dataset.tabControl === tab;
      l.setAttribute('aria-current', active ? 'true' : 'false');
      l.closest('.tabnav-item').classList.toggle('tabnav-item-active', active);
      if (active) positionIndicator(l);
    });

    showSlide(0);
  }

  // ---------- open / close ----------
  function openModal() {
    modal.removeAttribute('hidden');
    requestAnimationFrame(() => modal.classList.add('is-open'));
    document.body.style.overflow = 'hidden';
    switchTab('design');
    closeBtn.focus();
  }

  function closeModal() {
    modal.classList.remove('is-open');
    document.body.style.overflow = '';
    setTimeout(() => modal.setAttribute('hidden', ''), 320);
    openBtn && openBtn.focus();
  }

  // ---------- event listeners ----------
  openBtn && openBtn.addEventListener('click', openModal);
  closeBtn && closeBtn.addEventListener('click', closeModal);

  // close on backdrop click
  backdrop && backdrop.addEventListener('click', function(e) {
    if (e.target === backdrop) closeModal();
  });

  // ESC key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
  });

  // tabs
  tabLinks.forEach(link => {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      switchTab(link.dataset.tabControl);
    });
  });

  // paddle nav
  prevBtn && prevBtn.addEventListener('click', () => showSlide(currentSlide - 1));
  nextBtn && nextBtn.addEventListener('click', () => showSlide(currentSlide + 1));

  // init indicator after fonts/layout
  window.addEventListener('load', () => {
    const activeLink = modal.querySelector('[data-tab-control="design"]');
    positionIndicator(activeLink);
  });
})();
</script>

