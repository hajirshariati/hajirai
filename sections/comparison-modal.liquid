{% comment %}
  compare-modal.liquid
  Apple-style horizontal compare modal — fully customizable in the Theme Customizer
  Supports 1–3 products, all content/images editable via schema settings
{% endcomment %}

{% liquid
  assign product_count = section.settings.product_count | plus: 0
  if product_count < 1
    assign product_count = 1
  endif
  if product_count > 3
    assign product_count = 3
  endif
%}

<div class="acm-trigger-wrap" id="acm-trigger-{{ section.id }}">
  <button class="acm-cta-btn" data-acm-open="{{ section.id }}">
    {{ section.settings.cta_text | default: 'Compare models' }}
  </button>
</div>

{%- comment -%} ============ MODAL ============ {%- endcomment -%}
<div
  class="acm-scrim"
  id="acm-modal-{{ section.id }}"
  role="dialog"
  aria-modal="true"
  aria-labelledby="acm-headline-{{ section.id }}"
  aria-hidden="true"
  data-acm-modal="{{ section.id }}"
>
  <div class="acm-backdrop" data-acm-backdrop="{{ section.id }}"></div>

  <div class="acm-sheet">
    {%- comment -%} Close {%- endcomment -%}
    <button class="acm-close" data-acm-close="{{ section.id }}" aria-label="Close">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    {%- comment -%} Headline {%- endcomment -%}
    <div class="acm-header">
      <h2 class="acm-headline" id="acm-headline-{{ section.id }}">{{ section.settings.modal_headline | default: 'Compare latest models.' }}</h2>
    </div>

    {%- comment -%} Tab Nav {%- endcomment -%}
    {%- assign tab_ids    = 'design,camera,chip,battery,price' | split: ',' -%}
    {%- assign tab_labels = 'Design,Camera,Chip,Battery,Price'  | split: ',' -%}
    <nav class="acm-tabnav" aria-label="Compare categories">
      <ul class="acm-tabs" role="list">
        {%- for tab_id in tab_ids -%}
          <li class="acm-tab" data-tab="{{ tab_id }}" role="listitem">
            <button
              class="acm-tab-btn{% if forloop.first %} is-active{% endif %}"
              data-tab-btn="{{ tab_id }}"
              aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
            >
              <span class="acm-tab-icon">
                {%- if tab_id == 'design' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 25 25" fill="currentColor"><path d="m11.2515 20c.157.375.3848.7115.6626 1h-4.9141c-1.1046 0-2-.8954-2-2v-13c0-1.1046.8954-2 2-2h6c1.1046 0 2 .8954 2 2v.5h-.75c-.0857 0-.166.0188-.25.0253v-.5253c0-.5514-.4486-1-1-1h-6c-.5514 0-1 .4486-1 1v13c0 .5514.4486 1 1 1zm-2.0016-14c-.2764 0-.5.2236-.5.5s.2236.5.5.5h1.5c.2764 0 .5-.2236.5-.5s-.2236-.5-.5-.5zm10.7501 3.75v9c0 1.2427-1.0073 2.25-2.25 2.25h-3.5c-.2246 0-.4373-.043-.6421-.1042-.5059-.1515-.9406-.4667-1.228-.8958-.2395-.3577-.3799-.7872-.3799-1.25v-9c0-1.157.8766-2.0989 2-2.2249.0831-.0093 3.75-.0251 3.75-.0251 1.2427 0 2.25 1.0073 2.25 2.25zm-1 0c0-.6892-.5608-1.25-1.25-1.25h-3.5c-.0886 0-.1665.033-.25.0505-.5657.1194-1 .5989-1 1.1995v9c0 .4419.2439.8125.5911 1.0349.1942.1245.4116.2151.6589.2151h3.5c.6892 0 1.25-.5608 1.25-1.25zm-2.2501-.25h-1.5c-.0931 0-.1753.0322-.2499.0764-.1469.087-.2501.2402-.2501.4236s.1033.3365.2501.4236c.0746.0442.1567.0764.2499.0764h1.5c.2764 0 .5-.2236.5-.5s-.2236-.5-.5-.5z"/></svg>
                {%- elsif tab_id == 'camera' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 25 25" fill="currentColor"><path d="m14.1304 5c.6078 0 .7352.1111.976.37l.7201.8072c.6138.6906 1.0953.8228 2.0607.8228h2.5475c1.1411 0 1.5653.4194 1.5653 1.5475v9.9134c0 1.122-.4242 1.5391-1.5653 1.5391h-15.8694c-1.1411 0-1.5653-.4171-1.5653-1.5391v-9.9134c0-1.1281.4242-1.5475 1.5653-1.5475h2.4176c.9667 0 1.4484-.1324 2.0557-.817l.7274-.8055c.2444-.2685.3678-.3775.9736-.3775zm0-1h-3.3907c-.87 0-1.2698.2172-1.7131.7043l-.7302.8085c-.4088.4608-.6181.4872-1.3135.4872h-2.4176c-1.6953 0-2.5653.8695-2.5653 2.5475v9.9134c0 1.6696.87 2.5391 2.5653 2.5391h15.8694c1.6963 0 2.5653-.8695 2.5653-2.5391v-9.9134c0-1.678-.869-2.5475-2.5653-2.5475h-2.5475c-.6954 0-.8959-.0175-1.3135-.4872l-.7212-.8085c-.4524-.4871-.8521-.7043-1.7221-.7043zm-1.6259 5.7423c2.1035 0 3.7514 1.6489 3.7514 3.7538 0 2.1093-1.6479 3.7617-3.7514 3.7617-2.1086 0-3.7604-1.6523-3.7604-3.7617 0-2.105 1.6518-3.7538 3.7604-3.7538m0-.9923c-2.6362 0-4.7545 2.1055-4.7545 4.7461 0 2.6489 2.1183 4.7539 4.7545 4.7539 2.6281 0 4.7455-2.105 4.7455-4.7539 0-2.6406-2.1085-4.7461-4.7455-4.7461z"/></svg>
                {%- elsif tab_id == 'chip' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 25 25" fill="currentColor"><path d="m15.75 8h-6.5c-.6903 0-1.25.5597-1.25 1.25v6.5c0 .6903.5597 1.25 1.25 1.25h6.5c.6903 0 1.25-.5597 1.25-1.25v-6.5c0-.6903-.5597-1.25-1.25-1.25zm.25 7.75c0 .1378-.1122.25-.25.25h-6.5c-.1378 0-.25-.1122-.25-.25v-6.5c0-.1378.1122-.25.25-.25h6.5c.1378 0 .25.1122.25.25zm5-2.75c.2761 0 .5-.2239.5-.5s-.2239-.5-.5-.5h-2v-2h2c.2761 0 .5-.2239.5-.5s-.2239-.5-.5-.5h-2v-1c0-1.3807-.6193-2-2-2h-1v-2c0-.2761-.2239-.5-.5-.5s-.5.2239-.5.5v2h-2v-2c0-.2761-.2239-.5-.5-.5s-.5.2239-.5.5v2h-2v-2c0-.2761-.2239-.5-.5-.5s-.5.2239-.5.5v2h-1c-1.3807 0-2 .6193-2 2v1h-2c-.2761 0-.5.2239-.5.5s.2239.5.5.5h2v2h-2c-.2761 0-.5.2239-.5.5s.2239.5.5.5h2v2h-2c-.2761 0-.5.2239-.5.5s.2239.5.5.5h2v1c0 1.3807.6193 2 2 2h1v2c0 .2761.2239.5.5.5s.5-.2239.5-.5v-2h2v2c0 .2761.2239.5.5.5s.5-.2239.5-.5v-2h2v2c0 .2761.2239.5.5.5s.5-.2239.5-.5v-2h1c1.3807 0 2-.6193 2-2v-1h2c.2761 0 .5-.2239.5-.5s-.2239-.5-.5-.5h-2v-2zm-3 4c0 .8271-.1729 1-1 1h-9c-.8271 0-1-.1729-1-1v-9c0-.8271.1729-1 1-1h9c.8271 0 1 .1729 1 1z"/></svg>
                {%- elsif tab_id == 'battery' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 25 25" fill="currentColor"><path d="M19,10.5v4c0,.8271-.6729,1.5-1.5,1.5H4.5c-.8271,0-1.5-.6729-1.5-1.5v-4c0-.8271,.6729-1.5,1.5-1.5h13c.8271,0,1.5,.6729,1.5,1.5Zm2,0v4c0,1.9297-1.5703,3.5-3.5,3.5H4.5c-1.9297,0-3.5-1.5703-3.5-3.5v-4c0-1.9297,1.5703-3.5,3.5-3.5h13c1.9297,0,3.5,1.5703,3.5,3.5Zm-1,0c0-1.3789-1.1211-2.5-2.5-2.5H4.5c-1.3789,0-2.5,1.1211-2.5,2.5v4c0,1.3789,1.1211,2.5,2.5,2.5h13c1.3789,0,2.5-1.1211,2.5-2.5v-4Zm2,4c.6382-.0409,1.5-.8213,1.5-2.004,0-1.1746-.8618-1.9631-1.5-1.996v4Z"/></svg>
                {%- elsif tab_id == 'price' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 25 25" fill="currentColor"><path d="M12.5,3A9.5,9.5,0,1,0,22,12.5,9.5,9.5,0,0,0,12.5,3Zm0,18a8.5,8.5,0,1,1,8.5-8.5A8.51,8.51,0,0,1,12.5,21ZM12.124,17.529v-.742a2.774,2.774,0,0,1-2.676-1.992.446.446,0,0,1,.459-.479.477.477,0,0,1,.479.41A1.854,1.854,0,0,0,12.124,15.9V12.764l-.107-.02c-1.6-.381-2.412-1.1-2.412-2.275a2.494,2.494,0,0,1,2.52-2.324V7.471A.367.367,0,0,1,12.5,7.08a.374.374,0,0,1,.391.391v.674a2.7,2.7,0,0,1,2.51,1.885.444.444,0,0,1-.469.459.479.479,0,0,1-.479-.4,1.768,1.768,0,0,0-1.6-1.309V12l.205.039c1.66.332,2.49,1.084,2.49,2.344,0,1.387-1.143,2.295-2.7,2.412v.732a.374.374,0,0,1-.391.391A.367.367,0,0,1,12.124,17.529Zm0-8.467c-.928.117-1.562.664-1.562,1.367,0,.674.488,1.084,1.494,1.357l.068.02ZM12.9,15.9c1.1-.1,1.729-.684,1.729-1.465,0-.713-.43-1.143-1.514-1.426l-.215-.049Z"/></svg>
                {%- endif -%}
              </span>
              <span class="acm-tab-label">{{ tab_labels[forloop.index0] }}</span>
            </button>
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    {%- comment -%} Gallery {%- endcomment -%}
    <div class="acm-gallery" data-acm-gallery>

      {%- comment -%} Product column headers {%- endcomment -%}
      <div class="acm-col-headers acm-cols-{{ product_count }}">
        {%- for i in (1..product_count) -%}
          {%- assign name_key  = 'p' | append: i | append: '_name' -%}
          {%- assign badge_key = 'p' | append: i | append: '_badge' -%}
          <div class="acm-col-header">
            <span class="acm-product-name">{{ section.settings[name_key] | default: 'Product' }}</span>
            {%- if section.settings[badge_key] != blank -%}
              <span class="acm-product-badge">{{ section.settings[badge_key] }}</span>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      {%- comment -%} Tab panels + slides {%- endcomment -%}
      {%- for tab_id in tab_ids -%}
        <div class="acm-tab-panel{% unless forloop.first %} is-hidden{% endunless %}" data-panel="{{ tab_id }}">

          {%- comment -%} SLIDE 1 {%- endcomment -%}
          <div class="acm-slide is-active" data-slide="0">
            <div class="acm-cards acm-cols-{{ product_count }}">
              {%- for i in (1..product_count) -%}
                {%- assign img_key  = 'p' | append: i | append: '_' | append: tab_id | append: '_img' -%}
                {%- assign head_key = 'p' | append: i | append: '_' | append: tab_id | append: '_headline' -%}
                {%- assign feat_key = 'p' | append: i | append: '_' | append: tab_id | append: '_feature' -%}
                {%- assign call_key = 'p' | append: i | append: '_' | append: tab_id | append: '_callout' -%}
                <div class="acm-card">
                  {%- if section.settings[img_key] != blank -%}
                    <div class="acm-card-img">
                      <img src="{{ section.settings[img_key] | image_url: width: 600 }}"
                           alt="{{ section.settings[img_key].alt | default: '' }}"
                           loading="lazy" width="600">
                    </div>
                  {%- endif -%}
                  <div class="acm-card-copy">
                    {%- if section.settings[call_key] != blank -%}
                      <p class="acm-callout">{{ section.settings[call_key] }}</p>
                    {%- endif -%}
                    {%- if section.settings[head_key] != blank -%}
                      <p class="acm-card-headline">{{ section.settings[head_key] }}</p>
                    {%- endif -%}
                    {%- if section.settings[feat_key] != blank -%}
                      <p class="acm-card-feature">{{ section.settings[feat_key] | newline_to_br }}</p>
                    {%- endif -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
          </div>

          {%- comment -%} SLIDE 2 (only shown if any product has s2_headline set) {%- endcomment -%}
          {%- assign has_slide2 = false -%}
          {%- for i in (1..product_count) -%}
            {%- assign s2h = 'p' | append: i | append: '_' | append: tab_id | append: '_s2_headline' -%}
            {%- if section.settings[s2h] != blank -%}{%- assign has_slide2 = true -%}{%- endif -%}
          {%- endfor -%}
          {%- if has_slide2 -%}
            <div class="acm-slide" data-slide="1">
              <div class="acm-cards acm-cols-{{ product_count }}">
                {%- for i in (1..product_count) -%}
                  {%- assign s2img  = 'p' | append: i | append: '_' | append: tab_id | append: '_s2_img' -%}
                  {%- assign s2head = 'p' | append: i | append: '_' | append: tab_id | append: '_s2_headline' -%}
                  {%- assign s2feat = 'p' | append: i | append: '_' | append: tab_id | append: '_s2_feature' -%}
                  {%- assign s2call = 'p' | append: i | append: '_' | append: tab_id | append: '_s2_callout' -%}
                  <div class="acm-card">
                    {%- if section.settings[s2img] != blank -%}
                      <div class="acm-card-img">
                        <img src="{{ section.settings[s2img] | image_url: width: 600 }}" alt="" loading="lazy" width="600">
                      </div>
                    {%- endif -%}
                    <div class="acm-card-copy">
                      {%- if section.settings[s2call] != blank -%}
                        <p class="acm-callout">{{ section.settings[s2call] }}</p>
                      {%- endif -%}
                      {%- if section.settings[s2head] != blank -%}
                        <p class="acm-card-headline">{{ section.settings[s2head] }}</p>
                      {%- endif -%}
                      {%- if section.settings[s2feat] != blank -%}
                        <p class="acm-card-feature">{{ section.settings[s2feat] | newline_to_br }}</p>
                      {%- endif -%}
                    </div>
                  </div>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}

        </div>
      {%- endfor -%}

      {%- comment -%} Paddle nav {%- endcomment -%}
      <div class="acm-paddlenav">
        <button class="acm-paddle acm-paddle-prev" data-acm-prev aria-label="Previous" disabled>
          <svg viewBox="0 0 36 36" width="16" height="16" fill="currentColor">
            <path d="m20 25c-.38 0-.77-.15-1.06-.44l-5.5-5.5c-.59-.59-.59-1.54 0-2.12l5.5-5.5c.59-.59 1.54-.59 2.12 0 .59.59.59 1.54 0 2.12l-4.44 4.44 4.44 4.44c.59.59.59 1.54 0 2.12-.29.29-.68.44-1.06.44z"/>
          </svg>
        </button>
        <button class="acm-paddle acm-paddle-next" data-acm-next aria-label="Next">
          <svg viewBox="0 0 36 36" width="16" height="16" fill="currentColor">
            <path d="m22.56 16.94-5.51-5.5c-.59-.59-1.53-.58-2.12 0-.58.59-.58 1.54 0 2.12l4.44 4.44-4.44 4.44c-.59.58-.59 1.53 0 2.12.29.29.68.44 1.06.44.38 0 .76-.15 1.06-.44l5.51-5.5c.28-.28.44-.66.44-1.06s-.16-.78-.44-1.06z"/>
          </svg>
        </button>
      </div>

    </div>{%- comment -%} end gallery {%- endcomment -%}
  </div>{%- comment -%} end sheet {%- endcomment -%}
</div>{%- comment -%} end modal {%- endcomment -%}

<style>
/* Reset scoped to this section */
.acm-scrim *, .acm-scrim *::before, .acm-scrim *::after,
.acm-trigger-wrap * {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}
.acm-scrim, .acm-scrim * {
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "SF Pro Text", "Helvetica Neue", Arial, sans-serif;
}

/* ── Trigger ── */
.acm-trigger-wrap { display: flex; }
.acm-cta-btn {
  display: inline-flex;
  align-items: center;
  padding: 12px 24px;
  background: #0071e3;
  color: #fff;
  font-size: 17px;
  font-weight: 400;
  letter-spacing: -.022em;
  line-height: 1.17648;
  border: none;
  border-radius: 980px;
  cursor: pointer;
  white-space: nowrap;
  transition: background .2s;
}
.acm-cta-btn:hover { background: #0077ed; }

/* ── Scrim ── */
.acm-scrim {
  position: fixed;
  inset: 0;
  z-index: 99999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background: rgba(0,0,0,.52);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  opacity: 0;
  pointer-events: none;
  transition: opacity .28s ease;
}
@media (min-width: 736px) { .acm-scrim { align-items: center; } }
.acm-scrim.is-open { opacity: 1; pointer-events: all; }
.acm-backdrop { position: absolute; inset: 0; }

/* ── Sheet ── */
.acm-sheet {
  position: relative;
  background: #fff;
  width: 100%;
  max-width: 860px;
  max-height: 90vh;
  border-radius: 20px 20px 0 0;
  overflow-y: auto;
  overflow-x: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -4px 60px rgba(0,0,0,.2);
  transform: translateY(48px);
  transition: transform .36s cubic-bezier(.4,0,.2,1);
  -webkit-overflow-scrolling: touch;
}
@media (min-width: 736px) {
  .acm-sheet {
    border-radius: 20px;
    transform: scale(.96) translateY(24px);
    max-height: 86vh;
  }
}
.acm-scrim.is-open .acm-sheet { transform: none; }

/* ── Close ── */
.acm-close {
  position: absolute;
  top: 16px; right: 16px;
  width: 30px; height: 30px;
  border-radius: 50%;
  background: #e8e8ed;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1d1d1f;
  z-index: 30;
  flex-shrink: 0;
  transition: background .15s;
}
.acm-close:hover { background: #d2d2d7; }

/* ── Header ── */
.acm-header { padding: 40px 28px 0; }
.acm-headline {
  font-size: clamp(28px, 5.5vw, 44px);
  font-weight: 700;
  letter-spacing: -.04em;
  color: #1d1d1f;
  line-height: 1.07;
  padding-right: 36px;
}

/* ── Tab nav ── */
.acm-tabnav {
  padding: 18px 28px 0;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.acm-tabnav::-webkit-scrollbar { display: none; }
.acm-tabs {
  list-style: none;
  display: inline-flex;
  background: #f5f5f7;
  border-radius: 980px;
  padding: 4px;
  gap: 2px;
  min-width: max-content;
}
.acm-tab { display: flex; }
.acm-tab-btn {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 8px 15px;
  border-radius: 980px;
  border: none;
  background: transparent;
  font-size: 13px;
  font-weight: 500;
  color: #6e6e73;
  cursor: pointer;
  white-space: nowrap;
  letter-spacing: -.01em;
  transition: color .15s;
}
.acm-tab-btn:hover { color: #1d1d1f; }
.acm-tab-btn.is-active {
  background: #fff;
  color: #1d1d1f;
  box-shadow: 0 2px 8px rgba(0,0,0,.12);
}
.acm-tab-icon {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

/* ── Gallery ── */
.acm-gallery {
  padding: 22px 28px 36px;
  flex: 1;
}

/* ── Column headers ── */
.acm-col-headers {
  display: grid;
  gap: 10px;
  margin-bottom: 8px;
  padding: 0 2px;
}
.acm-col-header {
  display: flex;
  align-items: baseline;
  gap: 6px;
}
.acm-product-name {
  font-size: 14px;
  font-weight: 600;
  color: #1d1d1f;
  letter-spacing: -.022em;
}
.acm-product-badge {
  font-size: 11px;
  font-weight: 500;
  color: #e8713a;
}

/* Grid columns */
.acm-cols-1 { grid-template-columns: 1fr; }
.acm-cols-2 { grid-template-columns: 1fr 1fr; }
.acm-cols-3 { grid-template-columns: 1fr 1fr 1fr; }

/* ── Panels & Slides ── */
.acm-tab-panel { display: block; }
.acm-tab-panel.is-hidden { display: none; }
.acm-slide { display: none; }
.acm-slide.is-active { display: block; }

/* ── Cards ── */
.acm-cards {
  display: grid;
  gap: 10px;
  align-items: start;
}
.acm-card {
  background: #f5f5f7;
  border-radius: 14px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}
.acm-card-img {
  width: 100%;
  aspect-ratio: 3/4;
  overflow: hidden;
  background: #e8e8ed;
  flex-shrink: 0;
}
.acm-card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.acm-card-copy {
  padding: 14px 14px 16px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.acm-callout {
  font-size: clamp(28px, 4.5vw, 44px);
  font-weight: 700;
  letter-spacing: -.04em;
  color: #1d1d1f;
  line-height: 1;
}
.acm-card-headline {
  font-size: clamp(13px, 1.8vw, 16px);
  font-weight: 600;
  color: #1d1d1f;
  letter-spacing: -.022em;
  line-height: 1.22;
}
.acm-card-feature {
  font-size: clamp(10px, 1.3vw, 11px);
  color: #6e6e73;
  letter-spacing: .03em;
  text-transform: uppercase;
  line-height: 1.7;
  margin-top: 2px;
}

/* ── Paddle nav ── */
.acm-paddlenav {
  display: flex;
  justify-content: center;
  gap: 10px;
  margin-top: 18px;
}
.acm-paddle {
  width: 32px; height: 32px;
  border-radius: 50%;
  border: none;
  background: #f5f5f7;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1d1d1f;
  transition: background .15s;
}
.acm-paddle:hover:not(:disabled) { background: #e8e8ed; }
.acm-paddle:disabled { opacity: .28; cursor: default; }

/* ── Mobile ── */
@media (max-width: 500px) {
  .acm-header  { padding: 32px 20px 0; }
  .acm-tabnav  { padding-left: 20px; }
  .acm-gallery { padding: 18px 20px 28px; }
  .acm-cards.acm-cols-3 { grid-template-columns: 1fr; }
  .acm-cards.acm-cols-2 { grid-template-columns: 1fr 1fr; }
  .acm-col-headers.acm-cols-3 { grid-template-columns: 1fr; }
  .acm-card-img { aspect-ratio: 16/9; }
}
</style>

<script>
(function() {
  var sid      = {{ section.id | json }};
  var modal    = document.querySelector('[data-acm-modal="' + sid + '"]');
  if (!modal) return;

  var backdrop = document.querySelector('[data-acm-backdrop="' + sid + '"]');
  var openBtns = document.querySelectorAll('[data-acm-open="' + sid + '"]');
  var closeBtn = modal.querySelector('[data-acm-close]');
  var prevBtn  = modal.querySelector('[data-acm-prev]');
  var nextBtn  = modal.querySelector('[data-acm-next]');
  var tabBtns  = modal.querySelectorAll('[data-tab-btn]');
  var panels   = modal.querySelectorAll('[data-panel]');

  var currentTab   = 'design';
  var currentSlide = 0;

  function getSlides() {
    var panel = modal.querySelector('[data-panel="' + currentTab + '"]');
    return panel ? Array.from(panel.querySelectorAll('[data-slide]')) : [];
  }

  function updatePaddles() {
    var slides = getSlides();
    if (prevBtn) prevBtn.disabled = currentSlide === 0;
    if (nextBtn) nextBtn.disabled = currentSlide >= slides.length - 1;
  }

  function showSlide(idx) {
    var slides = getSlides();
    slides.forEach(function(s, i) { s.classList.toggle('is-active', i === idx); });
    currentSlide = idx;
    updatePaddles();
  }

  function switchTab(tab) {
    currentTab   = tab;
    currentSlide = 0;
    panels.forEach(function(p) { p.classList.toggle('is-hidden', p.dataset.panel !== tab); });
    tabBtns.forEach(function(b) {
      var on = b.dataset.tabBtn === tab;
      b.classList.toggle('is-active', on);
      b.setAttribute('aria-current', on ? 'true' : 'false');
    });
    showSlide(0);
  }

  function openModal() {
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(function() { modal.classList.add('is-open'); });
    switchTab('design');
    if (closeBtn) closeBtn.focus();
  }

  function closeModal() {
    modal.classList.remove('is-open');
    document.body.style.overflow = '';
    setTimeout(function() { modal.setAttribute('aria-hidden', 'true'); }, 300);
  }

  openBtns.forEach(function(b)  { b.addEventListener('click', openModal); });
  if (closeBtn)  closeBtn.addEventListener('click', closeModal);
  if (backdrop)  backdrop.addEventListener('click', closeModal);
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
  });
  tabBtns.forEach(function(btn) {
    btn.addEventListener('click', function() { switchTab(btn.dataset.tabBtn); });
  });
  if (prevBtn) prevBtn.addEventListener('click', function() { showSlide(currentSlide - 1); });
  if (nextBtn) nextBtn.addEventListener('click', function() { showSlide(currentSlide + 1); });
})();
</script>

