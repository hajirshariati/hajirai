<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
</style>

{{ 'customer.css' | asset_url | stylesheet_tag }}

<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="page-width{% if section.settings.full_width %} page-width--full{% endif %} relative">
    <div class="title-wrapper{% if section.settings.heading_size == 'title-xl' %} title-wrapper-lg{% endif %} leading-none grid gap-4 md:flex {{ section.settings.heading_alignment }} md:justify-between">
      <{{ section.settings.heading_tag }} class="heading {{ section.settings.heading_size }}">
        <split-words class="split-words js-invisible block" data-animate="fade-up-large">{{ 'customer.account.title' | t }}</split-words>
      </{{ section.settings.heading_tag }}>
      <p>
        <a class="button button--secondary icon-with-text" href="{{ routes.account_logout_url }}" is="hover-link" data-no-instant>
          <span class="btn-fill" data-fill></span>
          <span class="btn-text">
            {%- liquid
              render 'icon', icon: 'power', size: 'sm'
              echo 'customer.account.log_out' | t
            -%}
          </span>
        </a>
      </p>
    </div>
    
    <div class="customer__content flex flex-col lg:flex-row">
 <div class="grow flex flex-col gap-5 md:gap-8">
  <h2 class="text-xl-3xl font-medium">{{ 'customer.orders.title' | t }}</h2>

  {%- paginate customer.orders by 20 -%}
    {%- if customer.orders.size > 0 -%}
      <table role="table" class="order-history">
        <caption class="sr-only">{{ 'customer.orders.title' | t }}</caption>
        <thead role="rowgroup">
          <tr role="row">
            <th id="ColumnOrder" scope="col" role="columnheader">{{ 'customer.orders.order_number' | t }}</th>
            <th id="ColumnDate" scope="col" role="columnheader">{{ 'customer.orders.date' | t }}</th>
            <th id="ColumnPayment" scope="col" role="columnheader">{{ 'customer.orders.payment_status' | t }}</th>
            <th id="ColumnFulfillment" scope="col" role="columnheader">{{ 'customer.orders.fulfillment_status' | t }}</th>
            <!--th id="ColumnTotal" scope="col" role="columnheader">{{ 'customer.orders.total' | t }}</th-->
            <th id="ColumnReturn" scope="col" role="columnheader"></th>
          </tr>
        </thead>
        <tbody role="rowgroup">
          {%- for order in customer.orders -%}
            {%- assign order_date = order.created_at | date: '%s' | plus: 0 -%}
            {%- assign current_date = 'now' | date: '%s' | plus: 0 -%}
            {%- assign days_difference = current_date | minus: order_date | divided_by: 86400 -%}
            
            <tr role="row">
              <td
                id="RowOrder"
                role="cell"
                headers="ColumnOrder"
                data-label="{{ 'customer.orders.order_number' | t | escape }}"
              >
                <a class="link font-medium leading-none" href="{{ order.customer_url }}" aria-label="{{ 'customer.orders.order_number_link' | t: number: order.name | escape }}">
                  {{- order.name -}}
                </a>
              </td>
              <td headers="RowOrder ColumnDate" role="cell" data-label="{{ 'customer.orders.date' | t | escape }}">
                {{- order.created_at | time_tag: format: 'date' -}}
              </td>
              <td headers="RowOrder ColumnPayment" role="cell" data-label="{{ 'customer.orders.payment_status' | t | escape }}">
                {{- order.financial_status_label -}}
              </td>
              <td headers="RowOrder ColumnFulfillment" role="cell" data-label="{{ 'customer.orders.fulfillment_status' | t | escape }}">
                {{- order.fulfillment_status_label -}}
                {%- if order.fulfillment_status == 'fulfilled' -%}
<br><button 
  type="button" 
  class="track-order-btn" 
  data-order-number="{{ order.name }}" 
  data-email="{{ customer.email }}"
style="font-weight: bold;color: rgb(255, 107, 43);border: none;cursor: pointer;margin-left: 10px;white-space: nowrap;opacity: 1;background: #e7e7e7b3;padding: 5px 10px;border-radius: 14px;"
  onclick="openTracking('{{ order.name }}', '{{ customer.email }}')"
>
  <svg class="icon icon-truck icon-lg inline-block" viewBox="0 0 24 24" stroke="currentColor" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path class="fill" d="M18.2 2.00001H15.8C14.1198 2.00001 13.2798 2.00001 12.638 2.32699C12.0735 2.61461 11.6146 3.07355 11.327 3.63804C11 4.27977 11 5.11985 11 6.80001V7.80001C11 8.92011 11 9.48017 10.782 9.90799C10.5903 10.2843 10.2843 10.5903 9.90798 10.782C9.48016 11 8.9201 11 7.8 11H4.2C3.0799 11 2.51984 11 2.09202 11.218C1.71569 11.4097 1.40973 11.7157 1.21799 12.092C1 12.5198 1 13.0799 1 14.2V16C1 16.9319 1 17.3978 1.15224 17.7654C1.35523 18.2554 1.74458 18.6448 2.23463 18.8478C2.60218 19 3.06812 19 4 19C4 17.3432 5.34315 16 7 16C8.65685 16 10 17.3432 10 19H14C14 17.3432 15.3431 16 17 16C18.6569 16 20 17.3432 20 19C21.6569 19 23 17.6569 23 16V6.80001C23 5.11985 23 4.27977 22.673 3.63804C22.3854 3.07355 21.9265 2.61461 21.362 2.32699C20.7202 2.00001 19.8802 2.00001 18.2 2.00001Z"></path>
    <path d="M10 19H14M10 19C10 20.6569 8.65685 22 7 22C5.34315 22 4 20.6569 4 19M10 19C10 17.3432 8.65685 16 7 16C5.34315 16 4 17.3432 4 19M14 19C14 20.6569 15.3431 22 17 22C18.6569 22 20 20.6569 20 19M14 19C14 17.3432 15.3431 16 17 16C18.6569 16 20 17.3432 20 19M20 19V19C21.6569 19 23 17.6569 23 16V6.80001C23 5.11985 23 4.27977 22.673 3.63804C22.3854 3.07355 21.9265 2.61461 21.362 2.32699C20.7202 2.00001 19.8802 2.00001 18.2 2.00001H15.8C14.1198 2.00001 13.2798 2.00001 12.638 2.32699C12.0735 2.61461 11.6146 3.07355 11.327 3.63804C11 4.27977 11 5.11985 11 6.80001V7.80001C11 8.92011 11 9.48017 10.782 9.90799C10.5903 10.2843 10.2843 10.5903 9.90798 10.782C9.48016 11 8.92011 11 7.8 11H1.5M4 19V19C3.06812 19 2.60218 19 2.23463 18.8478C1.74458 18.6448 1.35523 18.2554 1.15224 17.7654C1 17.3978 1 16.9319 1 16V12.7727C1 12.1129 1 11.783 1.05245 11.4623C1.09902 11.1776 1.17626 10.8987 1.28282 10.6306C1.40284 10.3286 1.57257 10.0457 1.91205 9.47993L2.13566 9.10724C2.8155 7.97417 3.15542 7.40764 3.62342 6.99612C4.03758 6.63195 4.52256 6.35736 5.04791 6.18959C5.64157 6.00001 6.30225 6.00001 7.62362 6.00001H11" stroke-linecap="round" stroke-linejoin="round"></path>
  </svg>
  Track
</button>


                {%- endif -%}
              </td>
          
              <!--td headers="RowOrder ColumnTotal" role="cell" data-label="{{ 'customer.orders.total' | t | escape }}">
                {{- order.total_net_amount | money_with_currency -}}
              </td-->
         
<td headers="RowOrder ColumnReturn" role="cell" data-label="Return">
  {%- assign order_date = order.created_at | date: "%s" | plus: 0 -%}
  {%- assign today = "now" | date: "%s" | plus: 0 -%}
  {%- assign holiday_start = "2025-11-01" | date: "%s" | plus: 0 -%}
  {%- assign holiday_end = "2025-12-24" | date: "%s" | plus: 0 -%}
  {%- assign extended_return_end = "2026-01-31" | date: "%s" | plus: 0 -%}

  {%- assign is_holiday_order = false -%}
  {%- if order_date >= holiday_start -%}
    {%- if order_date <= holiday_end -%}
      {%- assign is_holiday_order = true -%}
    {%- endif -%}
  {%- endif -%}

  {%- assign within_extended_period = false -%}
  {%- if today <= extended_return_end -%}
    {%- assign within_extended_period = true -%}
  {%- endif -%}

  {%- if order.fulfillment_status == 'fulfilled' -%}
    {%- if is_holiday_order and within_extended_period -%}
       <span style="font-size: small;color: #1a7f37; text-wrap-mode: nowrap;">Holiday Return Eligible</span>
      <a href="https://www.aetrex.com/apps/aftership-returns-center" is="hover-link">
        <span class="btn-fill" data-fill></span>
        <span class="btn-text" style="color:#ffffff;text-wrap-mode:nowrap;background:#171717;padding:5px 10px;border-radius:14px;">
          Start a Return 
        </span>
      </a>
    {%- elsif days_difference <= 30 -%}
     <span style="font-size: small;color: #ffffff; text-wrap-mode: nowrap;">-</span>
      <a href="https://www.aetrex.com/apps/aftership-returns-center" is="hover-link">
        <span class="btn-fill" data-fill></span>
        <span class="btn-text" style="color:#ffffff;text-wrap-mode:nowrap;background:#171717;padding:5px 10px;border-radius:14px;">
          Start a Return
        </span>
      </a>
    {%- else -%}
      <span style="color:#666;text-wrap-mode:nowrap;font-size:small;">
        Return window closed
      </span>
    {%- endif -%}
  {%- endif -%}
</td>

            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    {%- else -%}
      <p class="text-base md:text-lg">{{ 'customer.orders.none' | t }}</p>
    {%- endif -%}

    {%- liquid
      if paginate.pages > 1
        render 'pagination', paginate: paginate
      endif
    -%}
  {%- endpaginate -%}
</div>

<script src="https://username.aftership.com/tracking-clips/sdk.js"></script>
<script>
  // Initialize AfterShip Tracking Clips when SDK loads
  let clips;
  
  function initializeAfterShip() {
    if (window.AfterShipTrackingClips) {
      clips = new window.AfterShipTrackingClips("c4310971d8c744f48e557d60b2fb6ca6");
    }
  }
  
  // Initialize on load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeAfterShip);
  } else {
    initializeAfterShip();
  }
  
  // Function to open tracking modal
  function openTracking(orderNumber, email) {
    if (!clips) {
      initializeAfterShip();
    }
    
    if (clips) {
      clips.open({
        orderNumber: orderNumber,
        email: email
      });
    } else {
      console.error('AfterShip Tracking SDK not loaded');
    }
  }
</script>

      <div class="grow-0">
        <sticky-element class="customer__sidebar flex flex-col gap-5 md:gap-7d5 sticky top-0">
          <h2 class="text-xl-3xl font-medium">{{ 'customer.account.details' | t }}</h2>
          <div class="text-base md:text-lg">{{ customer.default_address | format_address }}</div>
          <div>
            <a class="button button--primary icon-with-text" href="{{ routes.account_addresses_url }}" is="hover-link">
              <span class="btn-fill" data-fill></span>
              <span class="btn-text">
                {%- render 'icon', icon: 'pin', size: 'xs' -%}
                {{- 'customer.account.view_addresses' | t }} ({{ customer.addresses_count }})
              </span>
            </a>
          </div>

 
<hr>
<h2 class="text-xl-3xl font-medium">Need Help?</h2>
<p>Our world-class customer service team is eager to assist you.</p>
            <a class="button button--primary icon-with-text" href="/pages/contact-us" is="hover-link">
              <span class="btn-fill" data-fill></span>
              <span class="btn-text">
                Visit our Support Hub
              </span>
            </a>


 
<hr>

<div class="yotpo-widget-instance" data-yotpo-instance-id="1064497"></div>            

        </sticky-element>
 
      </div>
    </div>
  </div>


 



</div>

{% schema %}
{
  "name": "t:sections.main-account.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.global.settings.header__heading.content"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "title-sm",
          "label": "t:sections.global.settings.heading_size.options__1.label"
        },
        {
          "value": "title-md",
          "label": "t:sections.global.settings.heading_size.options__2.label"
        },
        {
          "value": "title-lg tracking-heading",
          "label": "t:sections.global.settings.heading_size.options__3.label"
        },
        {
          "value": "title-xl tracking-heading",
          "label": "t:sections.global.settings.heading_size.options__4.label"
        }
      ],
      "default": "title-xl tracking-heading",
      "label": "t:sections.global.settings.heading_size.label"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:sections.global.settings.heading_alignment.label",
      "options": [
        {
          "value": "md:items-end",
          "label": "t:sections.global.settings.heading_alignment.options__1.label"
        },
        {
          "value": "md:items-center md:flex-col",
          "label": "t:sections.global.settings.heading_alignment.options__2.label"
        },
        {
          "value": "md:items-end md:flex-row-reverse",
          "label": "t:sections.global.settings.heading_alignment.options__3.label"
        }
      ],
      "default": "md:items-end"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.global.settings.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.global.settings.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.global.settings.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.global.settings.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.global.settings.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.global.settings.heading_tag.options__6.label"
        },
        {
          "value": "div",
          "label": "t:sections.global.settings.heading_tag.options__7.label"
        },
        {
          "value": "span",
          "label": "t:sections.global.settings.heading_tag.options__8.label"
        },
        {
          "value": "p",
          "label": "t:sections.global.settings.heading_tag.options__9.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.global.settings.heading_tag.label",
      "info": "t:sections.global.settings.heading_tag.info"
    },
    {
      "type": "header",
      "content": "t:sections.global.settings.header__section.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.global.settings.padding_top.label",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.global.settings.padding_bottom.label",
      "default": 100
    },
    {
      "type": "checkbox",
      "id": "divider",
      "label": "t:sections.global.settings.divider.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "t:sections.global.settings.full_width.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "rounded",
      "default": false,
      "label": "t:sections.global.settings.rounded.label"
    }
  ]
}
{% endschema %}
