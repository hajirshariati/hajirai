<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
</style>

{{ 'customer.css' | asset_url | stylesheet_tag }}

<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="{% if section.settings.layout_width == 'narrow' %}page-width{% elsif section.settings.layout_width == 'medium' %}container{% else %}page-width{% endif %} relative">
    
    {%- comment -%} Two Column Layout: Left for custom sections, Right for login {%- endcomment -%}
    <div class="grid lg:grid-cols-2 {% if section.settings.layout_width == 'narrow' %}lg:gap-8{% elsif section.settings.layout_width == 'medium' %}lg:gap-12{% else %}lg:gap-20{% endif %} gap-8">
      
      {%- comment -%} LOGIN FORMS - Shows FIRST on mobile, RIGHT on desktop {%- endcomment -%}
      <div class="lg:order-2" style="border-radius: 2em; padding: 3em 0em; background: #f6f6f6;">
        
        <div id="Recover" class="title-wrapper{% if section.settings.heading_size == 'title-xl' %} title-wrapper-lg{% endif %} text-center leading-none hidden gap-4">
          <{{ section.settings.heading_tag }} class="heading {{ section.settings.heading_size }}" tabindex="-1">
            <split-words class="split-words js-invisible block" data-animate="fade-up-large">{{ 'customer.recover_password.title' | t }}</split-words>
          </{{ section.settings.heading_tag }}>
          <p class="text-lg md:text-2xl">{{ 'customer.recover_password.subtext' | t }}</p>
        </div>

        <div class="customer hidden">
          {%- form 'recover_customer_password', class: 'grid gap-12' -%}
            {%- liquid
              if form.errors
                assign form_errors = form.errors | default_errors
                render 'alert', status: 'error', content: form_errors
              endif

              assign recover_success = form.posted_successfully?
            -%}

            <div class="field">
              <input
                required
                class="input is-floating{% if form.errors %} invalid{% endif %}"
                type="email"
                value=""
                name="email"
                id="RecoverEmail"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                placeholder="{{ 'customer.recover_password.email' | t | escape }}"
                {%- if form.errors %} autofocus{% endif -%}
              />
              <label class="label is-floating" for="RecoverEmail">{{ 'customer.recover_password.email' | t }}</label>
            </div>

            <div class="grid gap-8">
              <button class="button button--primary button--fixed" type="submit" is="hover-button">
                <span class="btn-fill" data-fill></span>
                <span class="btn-text">{{ 'customer.recover_password.submit' | t }}</span>
              </button>
              
              <p class="text-center">
                <a class="inline-flex items-center gap-2" href="#login">
                  {%- render 'icon', icon: 'return', size: 'sm' -%}
                  <span class="link text-lg leading-none">{{ 'customer.recover_password.cancel' | t }}</span>
                </a>
              </p>
            </div>
          {%- endform -%}
        </div>

        <div id="Login" class="title-wrapper{% if section.settings.heading_size == 'title-xl' %} title-wrapper-lg{% endif %} text-center">
          <{{ section.settings.heading_tag }} class="heading {{ section.settings.heading_size }}">
            <split-words class="split-words js-invisible block" data-animate="fade-up-large">{{ 'customer.login.title' | t }}</split-words>
          </{{ section.settings.heading_tag }}>
        </div>
        
        <div class="customer">
          {%- form 'customer_login', class: 'grid gap-12' -%}
            {%- liquid
              if form.errors
                assign form_errors = form.errors | default_errors
                render 'alert', status: 'error', content: form_errors
              endif

              if recover_success == true
                assign success_message = 'customer.recover_password.success' | t
                render 'alert', status: 'success', content: success_message
              endif
            -%}

            {%- if section.settings.enable_shop_login_button -%}
              <div class="sign-in-with-shop-provider rte text-center">
                {{- shop | login_button -}}
                <p>{{ 'customer.login.alternate_provider_separator' | t }}</p>
              </div>
            {%- endif -%}
            
            <div class="grid gap-5">
              <div class="field">
                <input
                  required
                  class="input is-floating{% if form.errors contains 'form' %} invalid{% endif %}"
                  type="email"
                  name="customer[email]"
                  id="CustomerEmail"
                  autocomplete="email"
                  autocorrect="off"
                  autocapitalize="off"
                  placeholder="{{ 'customer.login.email' | t | escape }}"
                />
                <label class="label is-floating" for="CustomerEmail">{{ 'customer.login.email' | t }}</label>
              </div>

              {%- if form.password_needed -%}
                <div class="field">
                  <input
                    required
                    class="input is-floating{% if form.errors contains 'form' %} invalid{% endif %}"
                    type="password"
                    value=""
                    name="customer[password]"
                    id="CustomerPassword"
                    autocomplete="current-password"
                    placeholder="{{ 'customer.login.password' | t | escape }}"
                  />
                  <label class="label is-floating" for="CustomerPassword">{{ 'customer.login.password' | t }}</label>
                </div>

                <p>
                  <a class="link" href="#Recover">{{ 'customer.login.forgot_password' | t }}</a>
                </p>
              {%- endif -%}
            </div>

            <div class="grid gap-8">
              <div class="button-group grid gap-4 md:grid-cols-2">
                <button class="button button--primary button--fixed" type="submit" is="hover-button">
                  <span class="btn-fill" data-fill></span>
                  <span class="btn-text">{{ 'customer.login.submit' | t }}</span>
                </button>
                <a class="button button--secondary button--fixed" href="{{ routes.account_register_url }}" is="hover-link">
                  <span class="btn-fill" data-fill></span>
                  <span class="btn-text">{{ 'customer.login.create_account' | t }}</span>
                </a>
              </div>
              
              <p class="text-center">
                <a class="inline-flex items-center gap-2" href="{{ routes.root_url }}">
                  {%- render 'icon', icon: 'return', size: 'sm' -%}
                  <span class="link text-lg leading-none">{{ 'customer.login.return' | t }}</span>
                </a>
              </p>
            </div>
          {%- endform -%}
        </div>
        
        {%- if shop.checkout.guest_login -%}
          <!--div>
            <hr>
            <h2>{{ 'customer.login.guest_title' | t }}</h2>

            {%- form 'guest_login' -%}
              <button class="button" type="submit">
                {{ 'customer.login.guest_continue' | t }}
              </button>
            {%- endform -%}
          </div-->
        {%- endif -%}
        
      </div>
      {%- comment -%} CUSTOM BLOCKS - Shows SECOND on mobile, LEFT on desktop {%- endcomment -%}
      <div class="lg:order-1 flex flex-col justify-center" style="background: #d3e3ec; border-radius: 2em;">
        {%- for block in section.blocks -%}
          <div class="login-custom-block{% if block.settings.add_spacing %} mb-8{% endif %}" 
               style="{% if block.settings.background_color != blank %}background-color: {{ block.settings.background_color }};{% endif %}{% if block.settings.padding != blank %} padding: {{ block.settings.padding }}px;{% endif %}{% if block.settings.border_radius != blank %} border-radius: {{ block.settings.border_radius }}px;{% endif %}"
               {{ block.shopify_attributes }}>
            {%- case block.type -%}
              
              {%- when 'heading' -%}
                <{{ block.settings.heading_tag }} class="heading {{ block.settings.heading_size }}{% if block.settings.text_align != blank %} text-{{ block.settings.text_align }}{% endif %}"
                    style="{% if block.settings.text_color != blank %}color: {{ block.settings.text_color }};{% endif %}">
                  {{ block.settings.heading }}
                </{{ block.settings.heading_tag }}>
              
              {%- when 'text' -%}
                <div class="rte {{ block.settings.text_size }}{% if block.settings.text_align != blank %} text-{{ block.settings.text_align }}{% endif %}"
                     style="{% if block.settings.text_color != blank %}color: {{ block.settings.text_color }};{% endif %}">
                  {{ block.settings.text }}
                </div>
              
              {%- when 'icon_with_text' -%}
                <div class="flex {% if block.settings.icon_position == 'top' %}flex-col items-{{ block.settings.text_align }}{% else %}items-start{% endif %} gap-4"  style="align-items: center;">
                  {%- if block.settings.icon_image != blank -%}
                    <div class="{% if block.settings.icon_position == 'left' %}flex-shrink-0{% endif %}" >
                      {%- liquid
                        assign icon_width = 24
                        if block.settings.icon_size == 'sm'
                          assign icon_width = 20
                        elsif block.settings.icon_size == 'md'
                          assign icon_width = 32
                        elsif block.settings.icon_size == 'lg'
                          assign icon_width = 48
                        elsif block.settings.icon_size == 'xl'
                          assign icon_width = 64
                        endif
                      -%}
                      <img 
                        src="{{ block.settings.icon_image | image_url: width: icon_width }}" 
                        alt="{{ block.settings.icon_image.alt | default: block.settings.icon_heading | escape }}"
                        width="{{ icon_width }}"
                        height="{{ icon_width }}"
                        loading="lazy"
                        style="width: {{ icon_width }}px; height: auto;"
                      />
                    </div>
                  {%- endif -%}
                  <div class="flex-1{% if block.settings.text_align != blank %} text-{{ block.settings.text_align }}{% endif %}">
                    {%- if block.settings.icon_heading != blank -%}
                      <h3 class="{{ block.settings.icon_heading_size }} mb-2" style="{% if block.settings.text_color != blank %}color: {{ block.settings.text_color }};{% endif %}">
                        {{ block.settings.icon_heading }}
                      </h3>
                    {%- endif -%}
                    {%- if block.settings.icon_text != blank -%}
                      <div class="rte {{ block.settings.text_size }}" style="{% if block.settings.text_color != blank %}color: {{ block.settings.text_color }};{% endif %}">
                        {{ block.settings.icon_text }}
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              
              {%- when 'image' -%}
                {%- if block.settings.image != blank -%}
                  <div class="{% if block.settings.text_align != blank %}text-{{ block.settings.text_align }}{% endif %}">
                    <img 
                      src="{{ block.settings.image | image_url: width: 800 }}" 
                      alt="{{ block.settings.image.alt | escape }}"
                      loading="lazy"
                      width="{{ block.settings.image.width }}"
                      height="{{ block.settings.image.height }}"
                      style="{% if block.settings.image_width != blank %}max-width: {{ block.settings.image_width }}%;{% endif %} height: auto;"
                    />
                  </div>
                {%- endif -%}
              
              {%- when 'button' -%}
                {%- if block.settings.button_label != blank -%}
                  <div class="{% if block.settings.text_align != blank %}text-{{ block.settings.text_align }}{% endif %}">
                    <a 
                      href="{{ block.settings.button_link }}" 
                      class="button {{ block.settings.button_style }} button--fixed"
                      is="hover-link"
                    >
                      <span class="btn-fill" data-fill></span>
                      <span class="btn-text">{{ block.settings.button_label }}</span>
                    </a>
                  </div>
                {%- endif -%}
              
              {%- when 'spacer' -%}
                <div style="height: {{ block.settings.height }}px;"></div>
              
            {%- endcase -%}
          </div>
        {%- endfor -%}
      </div>
      
    </div>
  </div>
</div>

