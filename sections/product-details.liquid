<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- render 'section-variables', section: section -%}
    --section-grid-gap: {{ section.settings.grid_horizontal }}px;
  }
</style>

{%- assign description = section.blocks | where: "type", "description" | first -%}
{%- assign specifications = section.blocks | where: "type", "specification" -%}
{%- liquid
  assign specifications = section.blocks | where: "type", "specification"
  assign description = section.blocks | where: "type", "description" | first
  assign enable_split_mode = false
  if product.description != blank and description != blank and description.settings.split_mode == true
    assign enable_split_mode = true
  endif
-%}

<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}{% if enable_split_mode == false %} specifications-section{% endif %}">
  <div class="page-width{% if section.settings.full_width %} page-width--full{% endif %} relative">
    {%- render 'section-heading', section: section -%}

    <div class="specifications {{ section.settings.style }} flex flex-col lg:flex-row">
      <div class="grow{% if description != blank and description.settings.split_mode == true %} flex flex-col items-start lg:grid grid-cols-2 gap-8 lg:gap-14{% endif %}">
        {%- if enable_split_mode == true -%}
          <sticky-element class="lg:sticky top-0 flex flex-col gap-1d5" {{ description.shopify_attributes }}>
            {%- if description.settings.heading != blank -%}
              <div class="heading text-base md:text-lg font-medium leading-none normal-case flex items-center gap-2d5 md:gap-3">
                {%- if description.settings.icon_image != blank -%}
                  {%- liquid
                    if description.settings.iwidth == 'fit'
                      assign icon_width = description.settings.icon_image.width
                    else
                      assign icon_width = description.settings.icon_width
                    endif
                  -%}
                  <figure class="media media--transparent relative inline-block">
                    {%- capture sizes -%}{{ icon_width }}px{%- endcapture -%}
                    {%- capture widths -%}{{ icon_width }}, {{ icon_width | times: 2 | at_most: description.settings.icon_image.width }}{%- endcapture -%}
                    {%- assign image_alt = description.settings.icon_image.alt | default: description.settings.accessibility_info | escape -%}
                    {%- assign image_alt = image_alt | default: description.settings.heading | escape -%}
                    {{- description.settings.icon_image | image_url: width: description.settings.icon_image.width | image_tag: loading: 'lazy', sizes: sizes, widths: widths, alt: image_alt, class: 'image-fit' -}}
                  </figure>
                {%- elsif description.settings.icon != 'none' -%}
                  {%- liquid
                    if description.settings.iwidth == 'fit'
                      render 'icon-guarantee', icon: description.settings.icon, size: 'lg', class: 'inline-block'
                    else
                      render 'icon-guarantee', icon: description.settings.icon, size: 'custom', class: 'inline-block', width: description.settings.icon_width
                    endif
                  -%}
                {%- endif -%}
                {{- description.settings.heading | escape -}}
                
              </div>
            {%- endif -%}
            <div class="specification text-base rte">
              {{- product.description -}}
            </div>
          </sticky-element>
        {%- endif -%}
        <accordions-details class="accordions w-full">
          {%- assign first_row = true -%}
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'description' -%}
                {%- if product.description != blank and block.settings.split_mode == false -%}
                  {%- if block.settings.heading != blank -%}
                    <div class="accordion">
                      <details class="details" is="accordion-details"{% if section.settings.open_first_row and first_row %} open{% endif %} {{ block.shopify_attributes }}>
                        <summary class="details__summary flex items-center justify-between gap-2 cursor-pointer">
                          <span class="heading text-base-xl font-medium leading-none flex items-center gap-2d5 md:gap-3">
                            {%- if block.settings.icon_image != blank -%}
                              {%- liquid
                                if block.settings.iwidth == 'fit'
                                  assign icon_width = block.settings.icon_image.width
                                else
                                  assign icon_width = block.settings.icon_width
                                endif
                              -%}
                              <figure class="media media--transparent relative inline-block">
                                {%- capture sizes -%}{{ icon_width }}px{%- endcapture -%}
                                {%- capture widths -%}{{ icon_width }}, {{ icon_width | times: 2 | at_most: block.settings.icon_image.width }}{%- endcapture -%}
                                {%- assign image_alt = block.settings.icon_image.alt | default: block.settings.accessibility_info | escape -%}
                                {%- assign image_alt = image_alt | default: block.settings.heading | escape -%}
                                {{- block.settings.icon_image | image_url: width: block.settings.icon_image.width | image_tag: loading: 'lazy', sizes: sizes, widths: widths, alt: image_alt, class: 'image-fit' -}}
                              </figure>
                            {%- elsif block.settings.icon != 'none' -%}
                              {%- liquid
                                if block.settings.iwidth == 'fit'
                                  render 'icon-guarantee', icon: block.settings.icon, size: 'lg', class: 'inline-block'
                                else
                                  render 'icon-guarantee', icon: block.settings.icon, size: 'custom', class: 'inline-block', width: block.settings.icon_width
                                endif
                              -%}
                            {%- endif -%}
                            {{- block.settings.heading | escape -}}
                          </span>
                          {%- render 'icon', icon: 'plus-2', size: 'xs', class: 'shrink-0' -%}
                        </summary>
                        <div class="details__content text-base rte">
                          <div class="specification">
                            {{- product.description -}}
                          </div>
                        </div>
                      </details>
                    </div>
                  {%- else -%}
                    <div class="text-base rte" {{ block.shopify_attributes }}>
                      {{- product.description -}}
                    </div>
                  {%- endif -%}
                  {%- assign first_row = false -%}
                {%- endif -%}
  
              {%- when 'collapsible_tab' -%}
                {%- capture collapsible_content -%}
              {%- if block.settings.content_metafield != blank -%}
                {%- liquid
                  assign metafield_ref = block.settings.content_metafield
                  assign first_ref = metafield_ref | split: ',' | first | strip
                  
                  assign parts = first_ref | split: '.'
                  assign namespace = parts[0]
                  assign key = parts[1]
                  
                  assign is_dynamic = false
                  assign base_key = key
                  
                  if template.suffix == 'pdp-ortho-new'
                    if key contains '_no_no' or key contains '_no_yes' or key contains '_yes_no' or key contains '_yes_yes'
                      assign is_dynamic = true
                      assign base_key = key | remove: '_no_no' | remove: '_no_yes' | remove: '_yes_no' | remove: '_yes_yes'
                    endif
                  endif
                  
                  if is_dynamic
                    assign key_no_no = base_key | append: '_no_no'
                    assign key_no_yes = base_key | append: '_no_yes'
                    assign key_yes_no = base_key | append: '_yes_no'
                    assign key_yes_yes = base_key | append: '_yes_yes'
                  endif
                -%}
                
                <div class="col-span-full{% if is_dynamic %} dynamic-metafield-content{% endif %}" 
                     {% if is_dynamic %}data-dynamic-metafield="true" 
                     data-base-key="{{ base_key }}" 
                     data-namespace="{{ namespace }}"
                     data-content-no-no="{{ product.metafields[namespace][key_no_no].value | escape }}"
                     data-content-no-yes="{{ product.metafields[namespace][key_no_yes].value | escape }}"
                     data-content-yes-no="{{ product.metafields[namespace][key_yes_no].value | escape }}"
                     data-content-yes-yes="{{ product.metafields[namespace][key_yes_yes].value | escape }}"{% endif %}>
                  {{ product.metafields[namespace][key].value }}
                </div>
              {%- elsif block.settings.content != blank -%}
                <div class="col-span-full">

                  {{ block.settings.content }}
                </div>
              {%- endif -%}

              {%- if block.settings.metafields != blank -%}
                {%- assign metafields = block.settings.metafields | newline_to_br | split: '<br />' -%}
                {%- for line in metafields -%}
                  {%- liquid
                    assign metafield_parts = line | strip | split: '.'
                    assign metafield_namespace = metafield_parts | first
                    assign metafield_key = metafield_parts | last
                    assign metafield_name = metafield_key | replace: '_', ' ' | capitalize

                    if metafield_namespace contains ':'
                      assign parts = metafield_namespace | split: ':'
                      assign metafield_namespace = parts | last
                      assign metafield_name = parts | first
                    endif

                    assign metafield = product.metafields[metafield_namespace][metafield_key]
                  -%}

                  {%- if metafield.value != blank -%}
                    <div class="col-span-full md:col-span-6">
                      <h6 class="leading-none tracking-none">{{ metafield_name | escape }} <!-- v2 --></h6>
                      {%- if metafield.list? -%}
                        <p>
                          {%- liquid
                            for value in metafield.value
                              echo value
                              unless forloop.last
                                echo '<br />'
                              endunless
                            endfor
                          -%}
                        </p>
                      {%- else -%}
                        <div>{{ metafield.value }}</div>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
            {%- endcapture -%}

                {%- if collapsible_content != blank -%}
                  {%- if block.settings.heading != blank -%}
                    <div class="accordion">
                      <details class="details" is="accordion-details"{% if section.settings.open_first_row and first_row %} open{% endif %} {{ block.shopify_attributes }}>
                        <summary class="details__summary flex items-center justify-between gap-2 cursor-pointer">
                          <span class="heading text-base-xl font-medium leading-none flex items-center gap-2d5 md:gap-3">
                            {%- if block.settings.icon_image != blank -%}
                              {%- liquid
                                if block.settings.iwidth == 'fit'
                                  assign icon_width = block.settings.icon_image.width
                                else
                                  assign icon_width = block.settings.icon_width
                                endif
                              -%}
                              <figure class="media media--transparent relative inline-block">
                                {%- capture sizes -%}{{ icon_width }}px{%- endcapture -%}
                                {%- capture widths -%}{{ icon_width }}, {{ icon_width | times: 2 | at_most: block.settings.icon_image.width }}{%- endcapture -%}
                                {%- assign image_alt = block.settings.icon_image.alt | default: block.settings.accessibility_info | escape -%}
                                {%- assign image_alt = image_alt | default: block.settings.heading | escape -%}
                                {{- block.settings.icon_image | image_url: width: block.settings.icon_image.width | image_tag: loading: 'lazy', sizes: sizes, widths: widths, alt: image_alt, class: 'image-fit' -}}
                              </figure>
                            {%- elsif block.settings.icon != 'none' -%}
                              {%- liquid
                                if block.settings.iwidth == 'fit'
                                  render 'icon-guarantee', icon: block.settings.icon, size: 'lg', class: 'inline-block'
                                else
                                  render 'icon-guarantee', icon: block.settings.icon, size: 'custom', class: 'inline-block', width: block.settings.icon_width
                                endif
                              -%}
                            {%- endif -%}
                            {{- block.settings.heading | escape -}}
                          </span>
                          {%- render 'icon', icon: 'plus-2', size: 'xs', class: 'shrink-0' -%}
                        </summary>
                        <div class="details__content text-base rte">

                          <div class="specification grid grid-cols-12 gap-6 md:gap-10">
                            {{- collapsible_content -}}

                                {%- if block.settings.heading == "Description" -%}
                                  <p class="product__sku col-span-full" id="Sku-{{ section.id }}-{{ product.id }}">SKU:&nbsp;
                                    {{- product.selected_or_first_available_variant.sku -}}
                                  </p>
                                {%- endif -%}
                          </div>
             {%- if block.settings.heading == 'Size Chart' and block.settings.columns != blank and block.settings.rows != blank -%}
              {%- assign columns = block.settings.columns | split: ',' -%}
              {%- assign rows_raw = block.settings.rows | newline_to_br | split: '<br />' -%}
              {%- if columns.size > 0 and rows_raw.size > 0 -%}
                <!-- Main container -->

                        <!-- True Fit Start -->
                    <script>
                    (function(r,e,o){
                      var w=window,d=document,t,s,x;
                      w.tfcapi=t=w.tfcapi||function(){t.q=t.q||[]; t.q.push(arguments);};
                      t('init', {storeKey: r, environment: e, ...o});
                      x=d.getElementsByTagName('script')[0];
                      s=d.createElement('script');
                      s.type='text/javascript';s.async=true;
                      s.src='https://'+r+'-cdn'+(e==='dev'||e==='staging'?'.'+e:'')+ '.truefitcorp.com/fitrec/global/js/tf-integration.js?storeKey='+r;
                      x.parentNode.insertBefore(s,x);
                    })('atx', 'prd', {autoCalculate: true});
                    </script>

                    <div class="tfc-fitrec-product"
                         data-styleid="{{ product.id }}"
                         data-userid=""
                         data-colorid="{{ product.selected_or_first_available_variant.id }}"
                         data-locale="{{ request.locale.iso_code }}">
                    </div>
                    <!-- True Fit Ends -->
                    <div style="
                      max-width: 40em;
                      min-width: -webkit-fill-available;
                      width: 100%;
                      margin: 16px 0;
                      border-radius: 1em;
                      display: flex;
                      border: 1px solid #e5e5e5;
                      border-radius: 8px;
                      background: white;
                      overflow: hidden;">
                      <!-- Fixed first column -->
                      <div style="
                        flex-shrink: 0;
                        background: white;
                        border-right: 2px solid #ddd;
                        max-width: 150px;
                        overflow: hidden;">
                        <table style="border-collapse: collapse; width: 100%;">
                          <thead>
                            <tr style="background-color: #f8f8f8;">
                              <th style="border-bottom: 1px solid #e5e5e5;padding: 8px 12px;text-align: left;font-weight: 600;white-space: normal;word-break: break-word;line-height: 1.2;vertical-align: top;font-size: 12px;letter-spacing: 1px;">
                                {{ columns[0] | strip }}
                              </th>
                            </tr>
                          </thead>
                          <tbody>
                            {%- for row_raw in rows_raw -%}
                              {%- assign row_data = row_raw | strip | split: ',' -%}
                              {%- if row_data.size > 0 and row_raw != blank -%}
                                <tr style="border-bottom: 1px solid #f0f0f0;">
                                  <td style="padding: 6px 12px; font-size: 11px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; background: white;">
                                    {{ row_data[0] | strip }}
                                  </td>
                                </tr>
                              {%- endif -%}
                            {%- endfor -%}
                          </tbody>
                        </table>
                      </div>

                      <!-- Scrollable remaining columns -->
                      <div style="
                        flex: 1;
                        overflow-x: auto;
                        -webkit-overflow-scrolling: touch;">
                        <table style="border-collapse: collapse; width: 100%; min-width: 400px;">
                          <thead>
                            <tr style="background-color: #f8f8f8;">
                              {%- for column in columns -%}
                                {%- unless forloop.first -%}
                                  <th style="border-bottom: 1px solid #e5e5e5; padding: 12.5px 12px; text-align: left; font-weight: 600; white-space: nowrap; font-size: 12px;">
                                    {{ column | strip }}
                                  </th>
                                {%- endunless -%}
                              {%- endfor -%}
                            </tr>
                          </thead>
                          <tbody>
                            {%- for row_raw in rows_raw -%}
                              {%- assign row_data = row_raw | strip | split: ',' -%}
                              {%- if row_data.size > 0 and row_raw != blank -%}
                                <tr style="border-bottom: 1px solid #f0f0f0;">
                                  {%- for cell in row_data -%}
                                    {%- unless forloop.first -%}
                                      <td style="padding: 6px 12px; border-right: 1px solid #f0f0f0; white-space: nowrap; font-size: 11px;">
                                        {{ cell | strip }}
                                      </td>
                                    {%- endunless -%}
                                  {%- endfor -%}
                                </tr>
                              {%- endif -%}
                            {%- endfor -%}
                          </tbody>
                        </table>
                      </div>
                    </div>

                    <div style="text-align: center; font-size: 11px; color: #c00000; margin: 4px 0 16px 0;">
                      ← Scroll horizontally to see all sizes →
                    </div>
                  {%- endif -%}
                {%- endif -%}

                        </div>
                      </details>
                    </div>
                  {%- else -%}
                    <div class="text-base rte" {{ block.shopify_attributes }}>
                      <div class="specification grid grid-cols-12 gap-6 md:gap-10">
                        {{- collapsible_content -}}
                      </div>
                    </div>
                  {%- endif -%}
                  {%- assign first_row = false -%}
                {%- endif -%}
            {%- endcase -%}
          {%- endfor -%}
        </accordions-details>
      </div>
      {%- liquid
        assign show_sidebar = false
        assign sidebar_icons = null
        assign is_ortho_new = false
        
        if template.suffix == 'pdp-ortho-new'
          assign is_ortho_new = true
          assign show_sidebar = true
          assign sidebar_icons = product.metafields.custom.details_icons_no_no.value
        elsif specifications.size > 0
          assign show_sidebar = true
        endif
      -%}
      
      {%- if show_sidebar -%}
        <div class="grow-0">
          <sticky-element class="specs__sidebar flex flex-col gap-7d5 md:gap-10 sticky top-0 text-center" 
            id="dynamic-specs-sidebar"
            {%- if template.suffix == 'pdp-ortho-new' -%}
              {%- capture metafield_no_no_json -%}[{%- for item in product.metafields.custom.details_icons_no_no.value -%}{"icon":"{{ item.icon.value | image_url: width: 192 }}","label":"{{ item.label.value | escape }}"}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}]{%- endcapture -%}
              {%- capture metafield_no_yes_json -%}[{%- for item in product.metafields.custom.details_icons_no_yes.value -%}{"icon":"{{ item.icon.value | image_url: width: 192 }}","label":"{{ item.label.value | escape }}"}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}]{%- endcapture -%}
              {%- capture metafield_yes_no_json -%}[{%- for item in product.metafields.custom.details_icons_yes_no.value -%}{"icon":"{{ item.icon.value | image_url: width: 192 }}","label":"{{ item.label.value | escape }}"}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}]{%- endcapture -%}
              {%- capture metafield_yes_yes_json -%}[{%- for item in product.metafields.custom.details_icons_yes_yes.value -%}{"icon":"{{ item.icon.value | image_url: width: 192 }}","label":"{{ item.label.value | escape }}"}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}]{%- endcapture -%}
              data-metafield-no-no='{{ metafield_no_no_json }}'
              data-metafield-no-yes='{{ metafield_no_yes_json }}'
              data-metafield-yes-no='{{ metafield_yes_no_json }}'
              data-metafield-yes-yes='{{ metafield_yes_yes_json }}'
            {%- endif -%}>
            <svg class="icon-box" viewBox="0 0 234 74" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M0 20C0 8.95431 8.95431 0 20 0H214C225.046 0 234 8.9543 234 20V74H0V20Z" fill="currentColor"/>
              <rect x="58" y="32" width="118" height="19" rx="9.5" class="fill"/>
              <circle cx="117.5" cy="32.5" r="11.5" class="fill"/>
            </svg>
            <p class="heading lg:text-3xl text-2xl leading-none tracking-tight">{{ section.settings.specifications_heading | escape }}</p>
            <ul class="flex flex-wrap items-start justify-center gap-6 md:gap-10" id="specs-icon-list">
              {%- if template.suffix == 'pdp-ortho-new' and sidebar_icons != blank -%}
                {%- for item in sidebar_icons -%}
                  {%- assign item_icon = item.icon.value -%}
                  {%- assign item_label = item.label.value -%}
                  {%- if item_icon != blank or item_label != blank -%}
                    <li class="shrink-0 grid gap-2d5">
                      {%- if item_icon != blank -%}
                        <div class="media relative flex items-center justify-center rounded-full">
                          <img src="{{ item_icon | image_url: width: 192 }}" 
                               srcset="{{ item_icon | image_url: width: 80 }} 80w, {{ item_icon | image_url: width: 96 }} 96w, {{ item_icon | image_url: width: 160 }} 160w, {{ item_icon | image_url: width: 192 }} 192w"
                               sizes="(min-width: 768px) 96px, 80px"
                               loading="lazy"
                               is="lazy-image"
                               alt="{{ item_label | escape }}">
                        </div>
                      {%- endif -%}

                      {%- if item_label != blank -%}
                        <p class="text-sm">{{ item_label | escape }}</p>
                      {%- endif -%}
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              {%- else -%}
                {%- for block in specifications -%}
                  {%- if block.settings.icon != blank or block.settings.heading != blank -%}
                    <li class="shrink-0 grid gap-2d5">
                      {%- if block.settings.icon != blank -%}
                        <div class="media relative flex items-center justify-center rounded-full">
                          {{- block.settings.icon | image_url: width: block.settings.icon.width | image_tag: loading: 'lazy', widths: '80,96,160,192', is: 'lazy-image' -}}
                        </div>
                      {%- endif -%}

                      {%- if block.settings.heading != blank -%}
                        <p class="text-sm">{{ block.settings.heading | escape }}</p>
                      {%- endif -%}
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
            </ul>
          </sticky-element>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.product-details.name",
  "settings": [
    {
      "type": "select",
      "id": "style",
      "label": "t:sections.product-details.settings.style.label",
      "options": [
        {
          "value": "with-border",
          "label": "t:sections.product-details.settings.style.options__1.label"
        },
        {
          "value": "with-background",
          "label": "t:sections.product-details.settings.style.options__2.label"
        }
      ],
      "default": "with-border"
    },
    {
      "type": "checkbox",
      "id": "open_first_row",
      "default": false,
      "label": "t:sections.product-details.settings.open_first_row.label"
    },
    {
      "type": "inline_richtext",
      "id": "specifications_heading",
      "label": "t:sections.product-details.settings.specifications_heading.label",
      "default": "Included in the Box"
    },
    {
      "type": "header",
      "content": "t:sections.global.settings.header__heading.content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.global.settings.heading.label",
      "default": "Product details"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "title-sm",
          "label": "t:sections.global.settings.heading_size.options__1.label"
        },
        {
          "value": "title-md",
          "label": "t:sections.global.settings.heading_size.options__2.label"
        },
        {
          "value": "title-lg tracking-heading",
          "label": "t:sections.global.settings.heading_size.options__3.label"
        },
        {
          "value": "title-xl tracking-heading",
          "label": "t:sections.global.settings.heading_size.options__4.label"
        }
      ],
      "default": "title-md",
      "label": "t:sections.global.settings.heading_size.label"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:sections.global.settings.heading_alignment.label",
      "options": [
        {
          "value": "text-left md:items-end md:flex-row",
          "label": "t:sections.global.settings.heading_alignment.options__1.label"
        },
        {
          "value": "text-center md:items-center",
          "label": "t:sections.global.settings.heading_alignment.options__2.label"
        },
        {
          "value": "text-right md:items-end md:flex-row-reverse",
          "label": "t:sections.global.settings.heading_alignment.options__3.label"
        }
      ],
      "default": "text-left md:items-end md:flex-row"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
