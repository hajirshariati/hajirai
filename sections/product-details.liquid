<script>
(function() {
  // Store all variant SKUs
  const variantData = {
    {%- for variant in product.variants -%}
      {{ variant.id }}: "{{ variant.sku | escape }}"
      {%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  };

  const skuElement = document.querySelector('#Sku-{{ section.id }}-{{ product.id }}');
  
  if (!skuElement) return;

  // Function to update SKU display
  function updateSKU(variantId) {
    const newSku = variantData[variantId];
    if (newSku) {
      skuElement.innerHTML = 'SKU:&nbsp;' + newSku;
    }
  }

  // Method 1: Listen to product-info element changes (most themes)
  const productInfo = document.querySelector('product-info');
  if (productInfo) {
    const observer = new MutationObserver(function() {
      const currentVariant = productInfo.querySelector('[name="id"]');
      if (currentVariant && currentVariant.value) {
        updateSKU(parseInt(currentVariant.value));
      }
    });
    
    observer.observe(productInfo, {
      subtree: true,
      childList: true,
      attributes: true,
      attributeFilter: ['value']
    });
  }

  // Method 2: Listen to form changes
  const form = document.querySelector('[data-product-id="{{ product.id }}"]');
  if (form) {
    form.addEventListener('change', function(e) {
      if (e.target.name === 'id') {
        updateSKU(parseInt(e.target.value));
      }
    });
  }

  // Method 3: Watch for URL parameter changes
  let lastVariantId = null;
  setInterval(function() {
    const urlParams = new URLSearchParams(window.location.search);
    const variantId = urlParams.get('variant');
    if (variantId && variantId !== lastVariantId) {
      lastVariantId = variantId;
      updateSKU(parseInt(variantId));
    }
  }, 500);

  // Method 4: Listen to any variant change events
  document.addEventListener('variant:change', function(event) {
    if (event.detail && event.detail.variant && event.detail.variant.id) {
      updateSKU(event.detail.variant.id);
    }
  });

  // Initialize with current variant
  const currentVariantInput = document.querySelector('[name="id"]');
  if (currentVariantInput && currentVariantInput.value) {
    updateSKU(parseInt(currentVariantInput.value));
  }
})();
</script>

<script>
(function() {
  const sidebar = document.getElementById('dynamic-specs-sidebar');
  if (!sidebar) return;

  const iconList = document.getElementById('specs-icon-list');
  if (!iconList) return;

  // Function to get current option values
  function getCurrentOptions() {
    const option1Checked = document.querySelector('input[name="Do you have flat feet?"]:checked');
    const option2Checked = document.querySelector('input[name="Do you have ball of foot pain?"]:checked');
    
    if (!option1Checked || !option2Checked) return null;
    
    const option1Value = option1Checked.value.trim();
    const option2Value = option2Checked.value.trim();
    
    // Map "No / Unsure" to "no" and "Yes" to "yes"
    const option1 = (option1Value === "Yes") ? "yes" : "no";
    const option2 = (option2Value === "Yes") ? "yes" : "no";
    
    return { option1, option2 };
  }

  // Function to update sidebar icons
  function updateSidebarIcons() {
    const options = getCurrentOptions();
    if (!options) return;

    // Build the dataset key (camelCase for dataset API)
    const dataKey = `metafield${options.option1.charAt(0).toUpperCase() + options.option1.slice(1)}${options.option2.charAt(0).toUpperCase() + options.option2.slice(1)}`;
    
    const metafieldData = sidebar.dataset[dataKey];
    
    if (!metafieldData || metafieldData === 'null') return;

    let icons;
    try {
      icons = JSON.parse(metafieldData);
    } catch (e) {
      console.error('Error parsing metafield data:', e);
      return;
    }

    if (!icons || !Array.isArray(icons)) return;

    // Clear current icons
    iconList.innerHTML = '';

    // Add new icons
    icons.forEach(item => {
      if (!item.icon && !item.label) return;

      const li = document.createElement('li');
      li.className = 'shrink-0 grid gap-2d5';

      if (item.icon) {
        const mediaDiv = document.createElement('div');
        mediaDiv.className = 'media relative flex items-center justify-center rounded-full';
        
        const img = document.createElement('img');
        img.src = item.icon;
        img.loading = 'lazy';
        img.setAttribute('is', 'lazy-image');
        img.sizes = '(min-width: 768px) 96px, 80px';
        img.srcset = `${item.icon.replace('width=192', 'width=80')} 80w, ${item.icon.replace('width=192', 'width=96')} 96w, ${item.icon.replace('width=192', 'width=160')} 160w, ${item.icon} 192w`;
        img.alt = item.label || '';
        
        mediaDiv.appendChild(img);
        li.appendChild(mediaDiv);
      }

      if (item.label) {
        const p = document.createElement('p');
        p.className = 'text-sm';
        p.textContent = item.label;
        li.appendChild(p);
      }

      iconList.appendChild(li);
    });
  }

  // Function to update dynamic metafield content
  function updateDynamicMetafieldContent() {
    console.log('=== Dynamic Metafield Content Update ===');
    
    const dynamicContainers = document.querySelectorAll('.dynamic-metafield-content[data-dynamic-metafield="true"]');
    console.log('Found dynamic containers:', dynamicContainers.length);
    
    if (!dynamicContainers.length) {
      console.log('No dynamic containers found');
      return;
    }

    const option1Checked = document.querySelector('input[name="Do you have flat feet?"]:checked');
    const option2Checked = document.querySelector('input[name="Do you have ball of foot pain?"]:checked');
    
    console.log('Option 1 checked:', option1Checked ? option1Checked.value : 'none');
    console.log('Option 2 checked:', option2Checked ? option2Checked.value : 'none');
    
    if (!option1Checked || !option2Checked) {
      console.log('Missing option selections');
      return;
    }
    
    const option1Value = option1Checked.value.trim();
    const option2Value = option2Checked.value.trim();
    
    // Map "No / Unsure" to "no" and "Yes" to "yes"
    const option1 = (option1Value === "Yes") ? "yes" : "no";
    const option2 = (option2Value === "Yes") ? "yes" : "no";
    
    console.log('Mapped options:', option1, option2);
    
    // Build the data key
    const dataKey = `content${option1.charAt(0).toUpperCase() + option1.slice(1)}${option2.charAt(0).toUpperCase() + option2.slice(1)}`;
    console.log('Data key:', dataKey);
    
    dynamicContainers.forEach((container, index) => {
      console.log(`Container ${index + 1}:`, {
        baseKey: container.dataset.baseKey,
        namespace: container.dataset.namespace,
        hasContentNoNo: !!container.dataset.contentNoNo,
        hasContentNoYes: !!container.dataset.contentNoYes,
        hasContentYesNo: !!container.dataset.contentYesNo,
        hasContentYesYes: !!container.dataset.contentYesYes
      });
      
      const content = container.dataset[dataKey];
      console.log(`Content for ${dataKey}:`, content ? content.substring(0, 50) + '...' : 'empty');
      
      if (content) {
        container.innerHTML = content;
        console.log('Content updated successfully');
      } else {
        console.log('No content found for this key');
      }
    });
    
    console.log('=== End Dynamic Metafield Update ===');
  }

  // Listen for option changes
  document.addEventListener('change', function(e) {
    if (e.target.name === 'Do you have flat feet?' || e.target.name === 'Do you have ball of foot pain?') {
      setTimeout(function() {
        updateSidebarIcons();
        updateDynamicMetafieldContent();
      }, 100);
    }
  });

  // Initialize on page load with a delay to ensure DOM is ready
  setTimeout(function() {
    updateSidebarIcons();
    updateDynamicMetafieldContent();
  }, 500);
})();
</script>