{% comment %}
  ============================================================
  3D Shoe Scroll Section — Syntilay-Style (Enhanced)
  ============================================================
  CHANGES FROM ORIGINAL:
  1. Per-panel background color/gradient (hero has its own too)
     — Uses Shopify native color + gradient pickers
  2. Supporting image always visible on desktop AND mobile
  3. Two annotation pins per panel — bullet-proof positioning
     via a CSS custom property approach: the pin anchor is set
     as a percentage of the *canvas element* size (measured
     at runtime), then converted to absolute px so pins stay
     locked to the model on every screen size / orientation.
  4. Annotation content pre-filled from Jillian product data
  ============================================================

  SETUP:
  1. Upload your .glb to Shopify Admin → Content → Files
  2. Paste the CDN URL in section settings
  3. Add to homepage via theme editor

  ANNOTATION PIN POSITIONING:
  - Use the range sliders (0–100) in each panel block.
  - 0,0 = top-left of the 3D canvas; 100,100 = bottom-right.
  - Pins are positioned in JS against the canvas bounding rect
    so they are immune to page layout shifts, scrollbars, and
    responsive reflowing.
  ============================================================
{% endcomment %}

{%- liquid
  assign section_id   = 'shoe3d-' | append: section.id
  assign model_url    = section.settings.model_url
  assign text_color   = section.settings.text_color
  assign accent_color = section.settings.accent_color
  assign bg_value     = section.settings.background_color
  if section.settings.background_gradient != blank
    assign bg_value = section.settings.background_gradient
  endif
-%}

<section
  id="{{ section_id }}"
  class="shoe3d-section"
  aria-label="{{ section.settings.aria_label | default: '3D Product Showcase' }}"
  data-model="{{ model_url | escape }}"
  data-section-id="{{ section.id }}"
  itemscope
  itemtype="https://schema.org/Product"
>

  {%- comment -%}
    ── STICKY CANVAS WRAP ──
    Contains the Three.js canvas, vignette, loader and
    annotation pins. Pins are repositioned by JS on every
    resize so they always track the model correctly.
  {%- endcomment -%}
  <div class="shoe3d-canvas-wrap" aria-hidden="true">
    <canvas
      id="{{ section_id }}-canvas"
      class="shoe3d-canvas"
      role="img"
      aria-label="{{ section.settings.aria_label | default: '3D rotating shoe model' }}"
    ></canvas>
    <div class="shoe3d-vignette" id="{{ section_id }}-vignette"></div>
    <div class="shoe3d-loader" id="{{ section_id }}-loader" aria-live="polite" aria-atomic="true">
      <div class="shoe3d-loader__ring" aria-hidden="true"></div>
      <span class="shoe3d-loader__text">Loading model…</span>
    </div>

    {%- comment -%}
      ANNOTATION PINS
      One group per panel. Each group holds two pins.
      JS places them via inline `style="left:Xpx; top:Ypx"`
      computed from the canvas bounding rect + the % sliders.
      The data-ax / data-ay attributes carry the raw % values.
    {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- assign idx = forloop.index0 -%}

      {%- comment -%} Resolve annotation content from block settings OR product defaults {%- endcomment -%}
      {%- assign default_a1_labels  = "Memory Foam Cushioning,Genuine Leather Upper,Aetrex Arch Support,Braided Leather Strap" | split: "," -%}
      {%- assign default_a1_descs   = "Conforms to your foot, distributes weight evenly,Full-grain leather — breathable & durable,Strategically placed for full-body alignment,Signature style detail — comfort meets fashion" | split: "," -%}
      {%- assign default_a2_labels  = "Ultra-Light Cork Midsole,Antimicrobial Footbed,Met Bar Pod,Hook & Loop Closure" | split: "," -%}
      {%- assign default_a2_descs   = "Reduces fatigue for all-day wear,Fights everyday odors all day,Relieves ball-of-foot discomfort,Fully adjustable for multiple widths" | split: "," -%}

      {%- assign a1_label = default_a1_labels[idx] -%}
      {%- assign a1_desc  = default_a1_descs[idx] -%}
      {%- assign a2_label = default_a2_labels[idx] -%}
      {%- assign a2_desc  = default_a2_descs[idx] -%}
      {%- if block.settings.ann_1_label != blank -%}{%- assign a1_label = block.settings.ann_1_label -%}{%- endif -%}
      {%- if block.settings.ann_1_desc  != blank -%}{%- assign a1_desc  = block.settings.ann_1_desc  -%}{%- endif -%}
      {%- if block.settings.ann_2_label != blank -%}{%- assign a2_label = block.settings.ann_2_label -%}{%- endif -%}
      {%- if block.settings.ann_2_desc  != blank -%}{%- assign a2_desc  = block.settings.ann_2_desc  -%}{%- endif -%}

      <div
        class="shoe3d-annotations"
        data-ann-panel="{{ idx }}"
        aria-hidden="true"
      >
        {%- comment -%} Pin 1 {%- endcomment -%}
        <div
          class="shoe3d-pin shoe3d-pin--1"
          data-ax="{{ block.settings.ann_1_x | default: 52 }}"
          data-ay="{{ block.settings.ann_1_y | default: 38 }}"
          data-side="{{ block.settings.ann_1_side | default: 'right' }}"
        >
          <div class="shoe3d-pin__dot" aria-hidden="true">
            <span class="shoe3d-pin__pulse"></span>
          </div>
          <div class="shoe3d-pin__card shoe3d-pin__card--{{ block.settings.ann_1_side | default: 'right' }}">
            <span class="shoe3d-pin__label">{{ a1_label }}</span>
            {%- if a1_desc != blank -%}
              <span class="shoe3d-pin__desc">{{ a1_desc }}</span>
            {%- endif -%}
          </div>
        </div>

        {%- comment -%} Pin 2 {%- endcomment -%}
        <div
          class="shoe3d-pin shoe3d-pin--2"
          data-ax="{{ block.settings.ann_2_x | default: 48 }}"
          data-ay="{{ block.settings.ann_2_y | default: 65 }}"
          data-side="{{ block.settings.ann_2_side | default: 'left' }}"
        >
          <div class="shoe3d-pin__dot" aria-hidden="true">
            <span class="shoe3d-pin__pulse"></span>
          </div>
          <div class="shoe3d-pin__card shoe3d-pin__card--{{ block.settings.ann_2_side | default: 'left' }}">
            <span class="shoe3d-pin__label">{{ a2_label }}</span>
            {%- if a2_desc != blank -%}
              <span class="shoe3d-pin__desc">{{ a2_desc }}</span>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}

  </div>

  {%- comment -%} ── Scrollable content ── {%- endcomment -%}
  <div class="shoe3d-section__inner">

    {%- comment -%}
      HERO PANEL — transparent so the sticky 3D canvas is fully
      visible behind it. The hero_bg is only applied as a very
      subtle gradient overlay at the bottom edge (via a
      pseudo-element in CSS), not as a full block background.
      This way the shoe is never covered.
    {%- endcomment -%}
    <div
      class="shoe3d-hero"
      aria-hidden="true"
    >
      {%- if section.settings.hero_badge != blank -%}
        <div class="shoe3d-hero__badge"><span>{{ section.settings.hero_badge }}</span></div>
      {%- endif -%}
      <h2 class="shoe3d-hero__headline" itemprop="name">{{ section.settings.hero_headline | default: 'The Jillian' }}</h2>
      <p class="shoe3d-hero__sub">{{ section.settings.hero_subtext | default: 'Scroll to explore' }}</p>
      <div class="shoe3d-hero__scroll-hint" aria-hidden="true">
        <span class="shoe3d-hero__scroll-line"></span>
        <span class="shoe3d-hero__scroll-label">Scroll</span>
      </div>
    </div>

    <div class="shoe3d-panels" id="{{ section_id }}-panels">

      {%- liquid
        assign jillian_eyebrows = "All-Day Comfort,Premium Materials,Signature Arch Support,Style Meets Function" | split: ","
        assign jillian_headings = "Feels Like Walking on Air,Genuine Leather. Built to Last.,Aligned From the Ground Up,Comfort You Can See." | split: ","
        assign jillian_bodies   = "Memory foam cushioning and an ultra-light cork midsole work together to reduce fatigue — so you can go further, longer.,Crafted from real leather uppers with a soft microfiber footbed treated with antimicrobial technology — fresh all day every day.,Aetrex Signature Arch Support is strategically placed to align your entire body — relieving pressure from your feet all the way to your back.,The signature braided detailing makes the Jillian the sandal you'll reach for every morning — whether running errands or spending a full day on your feet." | split: ","
      -%}

      {%- for block in section.blocks -%}
        {%- assign is_right   = forloop.index | modulo: 2 -%}
        {%- assign panel_side = 'left' -%}
        {%- if is_right == 0 -%}{%- assign panel_side = 'right' -%}{%- endif -%}
        {%- assign idx = forloop.index0 -%}

        {%- assign eyebrow_text = jillian_eyebrows[idx] -%}
        {%- if block.settings.eyebrow != blank -%}{%- assign eyebrow_text = block.settings.eyebrow -%}{%- endif -%}
        {%- assign heading_text = jillian_headings[idx] -%}
        {%- if block.settings.heading != blank -%}{%- assign heading_text = block.settings.heading -%}{%- endif -%}
        {%- assign body_text = jillian_bodies[idx] -%}
        {%- if block.settings.body != blank -%}{%- assign body_text = block.settings.body -%}{%- endif -%}

        {%- comment -%} Resolve panel text color {%- endcomment -%}
        {%- assign panel_text = block.settings.panel_text_color | default: text_color -%}

        <div
          class="shoe3d-panel shoe3d-panel--{{ panel_side }}"
          data-panel-index="{{ idx }}"
          data-shoe-rot-x="{{ block.settings.rot_x | default: 0 }}"
          data-shoe-rot-y="{{ block.settings.rot_y | default: 0 }}"
          data-shoe-rot-z="{{ block.settings.rot_z | default: 0 }}"
          data-shoe-pos-x="{{ block.settings.pos_x | default: 0 }}"
          data-shoe-pos-y="{{ block.settings.pos_y | default: 0 }}"
          data-shoe-light-intensity="{{ block.settings.light_intensity | default: 1.0 }}"
          data-shoe-light-x="{{ block.settings.light_x | default: 5 }}"
          data-shoe-light-y="{{ block.settings.light_y | default: 5 }}"
          data-shoe-light-z="{{ block.settings.light_z | default: 5 }}"
          style="--panel-text: {{ panel_text }};"
          {{ block.shopify_attributes }}
        >
          {%- comment -%} Background layer so gradient/color fills only this panel's scroll height {%- endcomment -%}
          <div class="shoe3d-panel__bg" aria-hidden="true"></div>

          <div class="shoe3d-panel__inner shoe3d-panel__inner--{{ panel_side }}">

            {%- comment -%} ── Supporting image — shown on BOTH desktop and mobile ── {%- endcomment -%}
            {%- if block.settings.image != blank -%}
              <div class="shoe3d-panel__image-wrap shoe3d-panel__image-wrap--{{ panel_side }}">
                {{- block.settings.image | image_url: width: 800 | image_tag:
                    loading: 'lazy',
                    class: 'shoe3d-panel__image',
                    widths: '300,400,600,800',
                    sizes: '(max-width:767px) 90vw, (max-width:1024px) 40vw, 360px'
                -}}
              </div>
            {%- endif -%}

            <div class="shoe3d-panel__content shoe3d-panel__content--{{ panel_side }}">
              <span class="shoe3d-panel__eyebrow">{{ eyebrow_text }}</span>
              <h3 class="shoe3d-panel__heading">{{ heading_text }}</h3>
              <p class="shoe3d-panel__body">{{ body_text }}</p>

              {%- if block.settings.feature_1 != blank or block.settings.feature_2 != blank or block.settings.feature_3 != blank -%}
                <ul class="shoe3d-panel__features" aria-label="Features">
                  {%- if block.settings.feature_1 != blank -%}<li class="shoe3d-panel__feature">{{ block.settings.feature_1 }}</li>{%- endif -%}
                  {%- if block.settings.feature_2 != blank -%}<li class="shoe3d-panel__feature">{{ block.settings.feature_2 }}</li>{%- endif -%}
                  {%- if block.settings.feature_3 != blank -%}<li class="shoe3d-panel__feature">{{ block.settings.feature_3 }}</li>{%- endif -%}
                </ul>
              {%- endif -%}

              {%- if block.settings.cta_label != blank and block.settings.cta_url != blank -%}
                <a class="shoe3d-panel__cta" href="{{ block.settings.cta_url }}"
                  {%- if block.settings.cta_new_tab %} target="_blank" rel="noopener noreferrer"{%- endif -%}>
                  <span>{{ block.settings.cta_label }}</span>
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                    <path d="M3.75 9h10.5M9.75 4.5 14.25 9l-4.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              {%- endif -%}
            </div>

          </div>
        </div>
      {%- endfor -%}

      <div class="shoe3d-end-spacer" aria-hidden="true"></div>
    </div>

  </div>

</section>

<style>
/* ────────────────────────────────────────────────────────────
   DESIGN TOKENS  (section-scoped)
──────────────────────────────────────────────────────────── */
#{{ section_id }} {
  --bg:           {{ bg_value }};
  --text:         {{ text_color }};
  --accent:       {{ accent_color }};
  --panel-h:      80vh;
  --content-w:    min(380px, 40vw);
  --ease-spring:  cubic-bezier(0.22, 1, 0.36, 1);
  --max-w:        1520px;
  --pin-dot-size: 14px;
  --pin-card-w:   180px;
}

/* ── Section shell ── */
.shoe3d-section {
  position: relative;
  color: var(--text);
  background: var(--bg); /* single global background — set from section settings */
}

/* The inner scroll container sits above the sticky canvas */
.shoe3d-section__inner {
  max-width: var(--max-w);
  margin: -100vh auto 0;
  position: relative;
}

/* ── Sticky canvas ── */
.shoe3d-canvas-wrap {
  position: sticky;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  z-index: 1;
  pointer-events: none;
  overflow: hidden;
}
.shoe3d-canvas {
  display: block;
  width: 100%;
  height: 100%;
  will-change: contents;
}
.shoe3d-vignette {
  position: absolute;
  inset: 0;
  /* The vignette color is updated by JS when the active panel changes */
  background:
    radial-gradient(ellipse 55% 55% at 50% 50%, transparent 30%, var(--bg) 100%),
    linear-gradient(to bottom, var(--bg) 0%, transparent 15%, transparent 85%, var(--bg) 100%);
  transition: background 0.6s ease;
  pointer-events: none;
}

/* ── Loader ── */
.shoe3d-loader {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  transition: opacity .4s ease, visibility .4s ease;
  pointer-events: none;
}
.shoe3d-loader.is-hidden { opacity: 0; visibility: hidden; }
.shoe3d-loader__ring {
  width: 36px; height: 36px;
  border: 2px solid rgba(255,255,255,.15);
  border-top-color: rgba(255,255,255,.7);
  border-radius: 50%;
  animation: shoe3d-spin .8s linear infinite;
}
.shoe3d-loader__text {
  font-size: .7rem; letter-spacing: .12em;
  text-transform: uppercase; color: rgba(255,255,255,.4);
}

/* ════════════════════════════════════════════════════════════
   ANNOTATION PINS
   ─────────────────────────────────────────────────────────
   Each .shoe3d-annotations group is positioned absolute
   inside .shoe3d-canvas-wrap (inset:0).
   Each .shoe3d-pin is positioned absolute with left/top set
   by JS in pixels (derived from canvas bounding rect + %).
   This makes them 100% immune to layout reflow.
   The card flips left/right based on data-side attribute.
════════════════════════════════════════════════════════════ */
.shoe3d-annotations {
  position: absolute;
  inset: 0;
  pointer-events: none;
  visibility: hidden;
}
.shoe3d-annotations.is-active {
  visibility: visible;
}

/* Individual pin — JS sets left/top via style attribute */
.shoe3d-pin {
  position: absolute;
  /* transform centres the dot on the exact coordinate */
  transform: translate(-50%, -50%);
  pointer-events: none;
  /* Entry animation */
  opacity: 0;
  transition: opacity .45s var(--ease-spring);
}
.shoe3d-pin--2 { transition-delay: .12s; }
.shoe3d-annotations.is-active .shoe3d-pin { opacity: 1; }

/* Pulsing dot */
.shoe3d-pin__dot {
  position: relative;
  width: var(--pin-dot-size);
  height: var(--pin-dot-size);
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 0 2px rgba(255,255,255,.35);
  flex-shrink: 0;
}
.shoe3d-pin__pulse {
  position: absolute;
  inset: -4px;
  border-radius: 50%;
  border: 2px solid var(--accent);
  opacity: 0;
  animation: shoe3d-pulse 2.2s ease-out infinite;
}
.shoe3d-pin--2 .shoe3d-pin__pulse { animation-delay: .6s; }

/* Card — positioned absolutely relative to the pin dot */
.shoe3d-pin__card {
  position: absolute;
  /* Vertical centre on the dot */
  top: 50%;
  transform: translateY(-50%);
  width: var(--pin-card-w);
  background: rgba(10, 10, 12, 0.82);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border: 1px solid rgba(255,255,255,.18);
  border-radius: 10px;
  padding: 9px 13px;
  white-space: normal;
  pointer-events: none;
}

/* Card to the right of the dot */
.shoe3d-pin__card--right {
  left: calc(var(--pin-dot-size) + 10px);
}
/* Card to the left of the dot */
.shoe3d-pin__card--left {
  right: calc(var(--pin-dot-size) + 10px);
  left: auto;
  text-align: right;
}

/* Connector line between dot and card */
.shoe3d-pin__card::before {
  content: '';
  position: absolute;
  top: 50%;
  width: 10px;
  height: 1px;
  background: rgba(255,255,255,.3);
  transform: translateY(-50%);
}
.shoe3d-pin__card--right::before {
  right: 100%;
}
.shoe3d-pin__card--left::before {
  left: 100%;
}

.shoe3d-pin__label {
  display: block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .06em;
  text-transform: uppercase;
  color: #fff;
  line-height: 1.2;
  margin-bottom: 3px;
}
.shoe3d-pin__desc {
  display: block;
  font-size: 10px;
  font-weight: 400;
  color: rgba(255,255,255,.55);
  letter-spacing: .02em;
  line-height: 1.45;
}

/* Mobile: slightly smaller cards */
@media (max-width: 767px) {
  #{{ section_id }} {
    --pin-dot-size: 12px;
    --pin-card-w: 140px;
  }
  .shoe3d-pin__label { font-size: 10px; }
  .shoe3d-pin__desc  { font-size: 9px; }
  .shoe3d-pin__card  { padding: 7px 10px; border-radius: 8px; }
}

/* ── Hero ──
   Transparent — the sticky 3D canvas is the background.
   We sit at z-index 2 (above the canvas z-index:1) but with
   background:transparent so the shoe is always fully visible.
   A subtle radial fade at the bottom helps the first panel
   blend in as the user starts scrolling.
── */
.shoe3d-hero {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 2rem;
  text-align: center;
  pointer-events: none;
  background: transparent; /* NEVER cover the canvas */
}
/* Soft bottom fade so the hero blends into the first panel */
.shoe3d-hero::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 30%;
  background: linear-gradient(to bottom, transparent, rgba(0,0,0,0.35));
  pointer-events: none;
}
.shoe3d-hero__badge {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  border: 1px solid rgba(255,255,255,.25);
  border-radius: 50px;
  padding: .35em 1.1em;
  font-size: .7rem;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: rgba(255,255,255,.75);
  margin-bottom: 1.5rem;
}
.shoe3d-hero__badge:empty { display: none; }
.shoe3d-hero__headline {
  font-family: var(--font-heading-family, 'Georgia', serif);
  font-size: clamp(2.5rem, 8vw, 7rem);
  font-weight: 300;
  letter-spacing: -.04em;
  line-height: .95;
  color: var(--text);
  margin-bottom: 1rem;
}
.shoe3d-hero__sub {
  font-size: clamp(.85rem, 1.3vw, 1.1rem);
  color: rgba(255,255,255,.5);
  letter-spacing: .06em;
  text-transform: uppercase;
  margin-bottom: 3rem;
}
.shoe3d-hero__scroll-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .6rem;
  animation: shoe3d-bounce 2s ease-in-out infinite;
}
.shoe3d-hero__scroll-line {
  display: block;
  width: 1px; height: 48px;
  background: linear-gradient(to bottom, transparent, rgba(255,255,255,.6));
}
.shoe3d-hero__scroll-label {
  font-size: .65rem;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: rgba(255,255,255,.4);
}

/* ── Panels ── */
.shoe3d-panels { position: relative; z-index: 2; }

.shoe3d-panel {
  position: relative;
  min-height: var(--panel-h);
  display: flex;
  align-items: stretch;
  padding: 0;
}

/* Panel background div is now unused — section bg covers everything */
.shoe3d-panel__bg { display: none; }

/* Inner flex row — content + image side by side */
.shoe3d-panel__inner {
  position: relative;
  z-index: 1;
  width: 100%;
  display: flex;
  align-items: center;
  gap: 2.5rem;
  padding: 4rem 5vw;
}

/* Content side */
.shoe3d-panel--left  .shoe3d-panel__inner { justify-content: flex-end; }
.shoe3d-panel--right .shoe3d-panel__inner { justify-content: flex-start; }

/* ── Supporting image — always visible ── */
.shoe3d-panel__image-wrap {
  flex-shrink: 0;
  width: clamp(160px, 22vw, 320px);
  aspect-ratio: 1 / 1;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 24px 64px rgba(0,0,0,.55);
  order: 0; /* will be overridden per side below */
}

/* On left-aligned panels, image goes to the left of the text */
.shoe3d-panel--left  .shoe3d-panel__image-wrap { order: -1; }
/* On right-aligned panels, image goes to the right */
.shoe3d-panel--right .shoe3d-panel__image-wrap { order: 1; }

.shoe3d-panel__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* ── Panel text content ── */
.shoe3d-panel__content {
  pointer-events: all;
  width: var(--content-w);
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  opacity: 0;
  transform: translateY(40px);
  transition: opacity .7s var(--ease-spring), transform .7s var(--ease-spring);
  color: var(--panel-text, var(--text));
}
.shoe3d-panel__content.is-visible { opacity: 1; transform: translateY(0); }

.shoe3d-panel__eyebrow {
  display: inline-block;
  font-size: .65rem; font-weight: 600;
  letter-spacing: .2em; text-transform: uppercase;
  color: var(--accent); border: 1px solid var(--accent);
  border-radius: 50px; padding: .3em .9em; width: fit-content;
}
.shoe3d-panel__heading {
  font-family: var(--font-heading-family, 'Georgia', serif);
  font-size: clamp(1.6rem, 3.5vw, 3rem);
  font-weight: 300; letter-spacing: -.04em;
  line-height: 1.05;
  color: var(--panel-text, var(--text));
  margin: 0;
}
.shoe3d-panel__body {
  font-size: clamp(.85rem, 1.1vw, 1rem);
  line-height: 1.75;
  color: rgba(255,255,255,.6);
  margin: 0; max-width: 38ch;
}
.shoe3d-panel__features {
  list-style: none; padding: 0; margin: 0;
  display: flex; flex-direction: column; gap: .5rem;
}
.shoe3d-panel__feature {
  font-size: .85rem; color: rgba(255,255,255,.7);
  padding-left: 1.2em; position: relative; letter-spacing: .02em;
}
.shoe3d-panel__feature::before {
  content: ''; position: absolute;
  left: 0; top: .5em;
  width: 5px; height: 5px;
  background: var(--accent); border-radius: 50%;
}
.shoe3d-panel__cta {
  display: inline-flex; align-items: center; gap: .6rem;
  font-size: .75rem; font-weight: 600;
  letter-spacing: .08em; text-transform: uppercase;
  text-decoration: none;
  color: var(--panel-bg, #080808);
  background: var(--panel-text, var(--text));
  padding: .8em 1.7em; border-radius: 50px; width: fit-content;
  transition: background .2s ease, color .2s ease, transform .2s ease;
}
.shoe3d-panel__cta:hover { background: var(--accent); color: #000; transform: translateX(4px); }
.shoe3d-panel__cta:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
.shoe3d-panel__cta svg { flex-shrink: 0; transition: transform .2s ease; }
.shoe3d-panel__cta:hover svg { transform: translateX(4px); }

.shoe3d-end-spacer { height: 20vh; }

/* ── Mobile layout ── */
@media (max-width: 767px) {
  .shoe3d-panel__inner {
    flex-direction: column;
    align-items: flex-start;
    padding: 3rem 1.5rem 3rem;
    gap: 1.5rem;
    min-height: auto;
  }
  .shoe3d-panel--left  .shoe3d-panel__inner,
  .shoe3d-panel--right .shoe3d-panel__inner {
    justify-content: flex-start;
  }
  /* Image always on top on mobile */
  .shoe3d-panel__image-wrap {
    order: -1 !important;
    width: 100%;
    max-width: 280px;
    aspect-ratio: 1;
    align-self: center;
  }
  .shoe3d-panel__content { width: 100%; }
  .shoe3d-hero__headline { font-size: clamp(2rem, 10vw, 4rem); }
}

/* ── Keyframes ── */
@keyframes shoe3d-spin   { to { transform: rotate(360deg); } }
@keyframes shoe3d-bounce {
  0%,100% { transform: translateY(0); }
  50%     { transform: translateY(8px); }
}
@keyframes shoe3d-pulse {
  0%   { opacity: .7; transform: scale(1); }
  100% { opacity: 0;  transform: scale(2.4); }
}

/* ── Reduced motion ── */
@media (prefers-reduced-motion: reduce) {
  .shoe3d-hero__scroll-hint { animation: none; }
  .shoe3d-loader__ring { animation: none; border-top-color: rgba(255,255,255,.5); }
  .shoe3d-panel__content { opacity: 1; transform: none; transition: none; }
  .shoe3d-pin { opacity: 1; transition: none; }
  .shoe3d-pin__pulse { animation: none; opacity: 0; }
}
</style>

<script>
(function () {
  'use strict';

  function loadScript(src, cb) {
    var s = document.createElement('script');
    s.src = src; s.async = false; s.onload = cb;
    s.onerror = function () { console.error('[Shoe3D] Failed:', src); };
    document.head.appendChild(s);
  }

  loadScript('https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js', function () {
    loadScript('https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/GLTFLoader.js', function () {
      loadScript('https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/DRACOLoader.js', function () {
        loadScript('https://cdn.jsdelivr.net/npm/meshoptimizer@0.18.1/meshopt_decoder.js', function () {
          var T  = window.THREE,
              GL = T && T.GLTFLoader,
              DL = T && T.DRACOLoader,
              MOD= window.MeshoptDecoder;
          if (!T || !GL || !DL) { console.error('[Shoe3D] THREE not ready'); return; }
          if (MOD && GL.setMeshoptDecoder) GL.setMeshoptDecoder(MOD);
          initShoe3D(T, GL, DL, MOD);
        });
      });
    });
  });

  function initShoe3D(THREE, GLTFLoader, DRACOLoader, MeshoptDecoder) {
    var SECTION_ID = '{{ section_id }}';
    var section    = document.getElementById(SECTION_ID);
    if (!section) return;

    var MODEL_URL = section.dataset.model;
    if (!MODEL_URL) { console.warn('[Shoe3D] No model URL.'); return; }

    var canvas     = document.getElementById(SECTION_ID + '-canvas');
    var vignette   = document.getElementById(SECTION_ID + '-vignette');
    var loaderEl   = document.getElementById(SECTION_ID + '-loader');
    var panelEls   = [].slice.call(section.querySelectorAll('.shoe3d-panel'));
    var contentEls = [].slice.call(section.querySelectorAll('.shoe3d-panel__content'));

    /* ── Annotation pin groups ── */
    var annGroups = {};
    [].slice.call(section.querySelectorAll('.shoe3d-annotations')).forEach(function (el) {
      annGroups[el.dataset.annPanel] = el;
    });

    /* ────────────────────────────────────────────────────────
       PIN POSITIONING
       Called on load, on panel change, and on window resize.
       Reads the canvas bounding rect + the % data attrs on
       each .shoe3d-pin, then sets absolute left/top in px.
       Because left/top are in px (not %) they do NOT shift
       when anything on the page reflows.
    ──────────────────────────────────────────────────────── */
    function positionPins() {
      var rect = canvas.getBoundingClientRect();
      /* rect is relative to viewport; because the canvas-wrap
         is sticky top:0 and we're inside it, offsetTop of the
         canvas-wrap is 0 while it's visible.  We only need the
         width/height to convert %. */
      var W = rect.width;
      var H = rect.height;

      [].slice.call(section.querySelectorAll('.shoe3d-pin')).forEach(function (pin) {
        var ax = parseFloat(pin.dataset.ax || 50) / 100;
        var ay = parseFloat(pin.dataset.ay || 50) / 100;
        /* left/top set relative to the .shoe3d-annotations div
           which has inset:0 (same size as the canvas-wrap) */
        pin.style.left = (ax * W) + 'px';
        pin.style.top  = (ay * H) + 'px';
      });
    }

    /* ── Activate / deactivate annotation groups ── */
    function activateAnnotations(idx) {
      Object.keys(annGroups).forEach(function (k) {
        annGroups[k].classList.remove('is-active');
      });
      if (idx >= 0 && annGroups[idx]) {
        annGroups[idx].classList.add('is-active');
      }
    }

    /* ── Interpolation helpers ── */
    var lerp = function (a, b, t) { return a + (b - a) * t; };
    var LERP_SPEED = 0.08;
    var reduced    = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function getPose(el) {
      return {
        rotX: parseFloat(el.dataset.shoeRotX  || 0) * Math.PI / 180,
        rotY: parseFloat(el.dataset.shoeRotY  || 0) * Math.PI / 180,
        rotZ: parseFloat(el.dataset.shoeRotZ  || 0) * Math.PI / 180,
        posX: parseFloat(el.dataset.shoePosX  || 0) / 10,
        posY: parseFloat(el.dataset.shoePosY  || 0) / 10,
        lI:   parseFloat(el.dataset.shoeLightIntensity || 10) / 10,
        lX:   parseFloat(el.dataset.shoeLightX || 5),
        lY:   parseFloat(el.dataset.shoeLightY || 5),
        lZ:   parseFloat(el.dataset.shoeLightZ || 5),
      };
    }

    var shoe = null, raf = null, isVis = false;
    var idle = 0, activePanelIdx = -1;
    var cur = { rotX:0, rotY:0, rotZ:.2, posX:0, posY:0, lI:1, lX:5, lY:5, lZ:5 };
    var tgt = { rotX:0, rotY:0, rotZ:.2, posX:0, posY:0, lI:1, lX:5, lY:5, lZ:5 };

    /* ── Renderer ── */
    var renderer = new THREE.WebGLRenderer({
      canvas: canvas, antialias: true, alpha: true,
      powerPreference: 'high-performance'
    });
    renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
    renderer.outputEncoding      = THREE.sRGBEncoding;
    renderer.shadowMap.enabled   = true;
    renderer.shadowMap.type      = THREE.PCFSoftShadowMap;
    renderer.toneMapping         = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.2;

    var scene  = new THREE.Scene();
    var camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
    camera.position.set(0, 0, 5);

    scene.add(new THREE.AmbientLight(0xffffff, 0.4));
    var key = new THREE.DirectionalLight(0xffffff, 1.0);
    key.position.set(5,5,5); key.castShadow = true;
    key.shadow.mapSize.set(1024, 1024);
    scene.add(key);
    var rim = new THREE.DirectionalLight(0x8899ff, 0.3);
    rim.position.set(-5, 2, -5); scene.add(rim);
    scene.add(new THREE.HemisphereLight(0xffffff, 0x333333, 0.2));

    /* Resize */
    var rzTimer;
    function onResize() {
      var W = canvas.clientWidth  || window.innerWidth;
      var H = canvas.clientHeight || window.innerHeight;
      renderer.setSize(W, H, false);
      camera.aspect = W / H;
      camera.updateProjectionMatrix();
      positionPins(); /* re-anchor all pins after resize */
    }
    new ResizeObserver(function () {
      clearTimeout(rzTimer);
      rzTimer = setTimeout(onResize, 80);
    }).observe(canvas);
    onResize();

    /* Visibility gate */
    new IntersectionObserver(function (e) {
      isVis = e[0].isIntersecting;
      if (isVis && !raf) startLoop();
      if (!isVis && raf) { cancelAnimationFrame(raf); raf = null; }
    }, { threshold: 0 }).observe(section);

    /* ── Panel observer ── */
    var panelIO = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        var idx = parseInt(entry.target.dataset.panelIndex, 10);
        if (entry.isIntersecting) {
          activePanelIdx = idx;
          activateAnnotations(idx);
          positionPins(); /* ensure pins are placed for this panel */

          contentEls.forEach(function (el, i) {
            el.classList.toggle('is-visible', i === idx);
          });

          var pose = getPose(entry.target);
          tgt.rotX=pose.rotX; tgt.rotY=pose.rotY; tgt.rotZ=pose.rotZ;
          tgt.posX=pose.posX; tgt.posY=pose.posY;
          tgt.lX=pose.lX; tgt.lY=pose.lY; tgt.lZ=pose.lZ; tgt.lI=pose.lI;
        } else {
          if (activePanelIdx === idx) {
            activePanelIdx = -1;
            activateAnnotations(-1);
            contentEls.forEach(function (el) { el.classList.remove('is-visible'); });
          }
        }
      });
    }, { rootMargin: '-30% 0px -30% 0px', threshold: 0 });

    panelEls.forEach(function (el) { panelIO.observe(el); });

    /* ── Render loop ── */
    function startLoop() {
      (function frame() {
        raf = requestAnimationFrame(frame);
        if (!shoe) return;
        var speed = reduced ? 1 : LERP_SPEED;
        if (activePanelIdx === -1) {
          tgt.posX = 0;
          tgt.posY = reduced ? 0 : Math.sin(idle * .5) * .1;
          tgt.lX=5; tgt.lY=5; tgt.lZ=5; tgt.lI=1.0;
          if (!reduced) idle += .004;
          tgt.rotX=0; tgt.rotY=reduced ? .3 : idle; tgt.rotZ=.15;
        }
        for (var k in cur) cur[k] = lerp(cur[k], tgt[k], speed);
        shoe.rotation.set(cur.rotX, cur.rotY, cur.rotZ);
        shoe.position.set(-cur.posX * (camera.aspect * 1.6), cur.posY, 0);
        key.position.set(cur.lX, cur.lY, cur.lZ);
        key.intensity = cur.lI;
        renderer.render(scene, camera);
      })();
    }

    /* ── Load GLB ── */
    var draco = new DRACOLoader();
    draco.setDecoderPath('https://www.gstatic.com/draco/versioned/decoders/1.4.1/');
    var gltf = new GLTFLoader();
    gltf.setDRACOLoader(draco);

    function doLoad() {
      gltf.load(MODEL_URL,
        function (g) {
          shoe = g.scene;
          var box = new THREE.Box3().setFromObject(shoe);
          var sz  = new THREE.Vector3(), ct = new THREE.Vector3();
          box.getSize(sz); box.getCenter(ct);
          shoe.position.sub(ct);
          shoe.scale.setScalar(3.6 / Math.max(sz.x, sz.y, sz.z));
          shoe.traverse(function (c) {
            if (c.isMesh) {
              c.castShadow = c.receiveShadow = true;
              if (c.material) c.material.envMapIntensity = .6;
            }
          });
          cur.rotX=0; cur.rotY=.3; cur.rotZ=.15; idle=.3;
          if (panelEls[0]) {
            var p0 = getPose(panelEls[0]);
            cur.posX=tgt.posX=p0.posX; cur.posY=tgt.posY=p0.posY;
            tgt.lX=p0.lX; tgt.lY=p0.lY; tgt.lZ=p0.lZ; tgt.lI=p0.lI;
          }
          scene.add(shoe);
          if (loaderEl) loaderEl.classList.add('is-hidden');
          /* Position pins once the model has loaded and canvas is sized */
          positionPins();
        },
        function (xhr) {
          if (loaderEl && xhr.total) {
            var t = loaderEl.querySelector('.shoe3d-loader__text');
            if (t) t.textContent = 'Loading\u2026 ' + Math.round(xhr.loaded / xhr.total * 100) + '%';
          }
        },
        function (err) {
          console.error('[Shoe3D] Load error:', err);
          if (loaderEl) {
            var t = loaderEl.querySelector('.shoe3d-loader__text');
            var r = loaderEl.querySelector('.shoe3d-loader__ring');
            if (t) t.textContent = 'Could not load 3D model.';
            if (r) r.parentNode.removeChild(r);
          }
        }
      );
    }

    if (typeof MeshoptDecoder !== 'undefined' && MeshoptDecoder && gltf.setMeshoptDecoder) {
      var rdy = MeshoptDecoder.ready instanceof Promise ? MeshoptDecoder.ready : Promise.resolve();
      rdy.then(function () { gltf.setMeshoptDecoder(MeshoptDecoder); doLoad(); });
    } else {
      doLoad();
    }

    document.addEventListener('visibilitychange', function () {
      if (document.hidden && raf)         { cancelAnimationFrame(raf); raf = null; }
      else if (!document.hidden && isVis && !raf) startLoop();
    });
  }

})();
</script>

