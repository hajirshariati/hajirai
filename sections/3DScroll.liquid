  margin: 0 0 2px;
  line-height: 1.3;
}
.shoe3d-notation__callout-text {
  font-size: clamp(9px, calc(9px + .1vw), 12px);
  line-height: 1.4;
  color: var(--notation-callout-text-color);
  margin: 0;
}

/* ── Mobile drawer modals ── */
.shoe3d-notation__modal {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: opacity .25s ease, visibility .25s ease;
  pointer-events: none;
}
.shoe3d-notation__modal:not([hidden]) {
  opacity: 1;
  visibility: visible;
  pointer-events: all;
}
.shoe3d-notation__modal-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,.4);
  cursor: pointer;
}
.shoe3d-notation__modal-inner {
  position: relative;
  background: #fff;
  border-radius: 20px 20px 0 0;
  padding: 2rem 1.5rem 3rem;
  max-height: 60vh;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  z-index: 1;
  box-shadow: 0 -8px 40px rgba(0,0,0,.2);
}
.shoe3d-notation__modal-close {
  position: absolute;
  top: 1rem;
  right: 1rem;
  background: rgba(0,0,0,.06);
  border: none;
  border-radius: 50%;
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background .2s ease;
  color: #000;
  flex-shrink: 0;
}
.shoe3d-notation__modal-close:hover { background: rgba(0,0,0,.12); }
.shoe3d-notation__modal-close:focus-visible {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
}
.shoe3d-notation__modal-title {
  font-weight: 600;
  font-size: 1.1rem;
  color: #000;
  margin: 0 0 .5rem;
  padding-right: 2.5rem;
}
.shoe3d-notation__modal-text {
  font-size: .9rem;
  line-height: 1.6;
  color: #555;
  margin: 0;
}

/* ── End spacer ── */
.shoe3d-end-spacer { height: 20vh; }

/* ── Mobile: stack layout ── */
@media (max-width: 767px) {
  .shoe3d-panel {
    flex-direction: column;
    align-items: flex-start;
    padding: 3rem 1.5rem;
    justify-content: flex-start;
    min-height: auto;
    padding-top: 20vh;
  }
  .shoe3d-panel--left,
  .shoe3d-panel--right { justify-content: flex-start; }
  .shoe3d-panel__content { width: 100%; }
  .shoe3d-hero__headline { font-size: clamp(2rem, 10vw, 4rem); }
}

/* ── Keyframes ── */
@keyframes shoe3d-spin   { to { transform: rotate(360deg); } }
@keyframes shoe3d-bounce {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(8px); }
}

/* ── Reduced motion ── */
@media (prefers-reduced-motion: reduce) {
  .shoe3d-hero__scroll-hint       { animation: none; }
  .shoe3d-loader__ring            { animation: none; border-top-color: rgba(255,255,255,.5); }
  .shoe3d-panel__content          { opacity: 1; transform: none; transition: none; }
  .shoe3d-notation__line          { animation: none; stroke-dashoffset: 0; }
  .shoe3d-notation__dot-inner     { transform: scale(1) !important; transition: none; animation: none !important; }
  .shoe3d-notation__callout       { opacity: 1; transform: none; transition: none; }
  .shoe3d-notation-overlay        { opacity: 1; transition: none; }
}
