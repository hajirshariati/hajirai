    var notation = new NotationController(section);

    /* ── Lerp ── */
    var LERP_SPEED = 0.08;
    function lerp(a, b, t) { return a + (b - a) * t; }

    /* ── Read panel pose from data attributes ── */
    function getPanelPose(el) {
      return {
        rotX:  parseFloat(el.dataset.shoeRotX  || 0) * (Math.PI / 180),
        rotY:  parseFloat(el.dataset.shoeRotY  || 0) * (Math.PI / 180),
        rotZ:  parseFloat(el.dataset.shoeRotZ  || 0) * (Math.PI / 180),
        posX:  parseFloat(el.dataset.shoePosX  || 0) / 10,
        posY:  parseFloat(el.dataset.shoePosY  || 0) / 10,
        lightIntensity: parseFloat(el.dataset.shoeLightIntensity || 10) / 10,
        lightX: parseFloat(el.dataset.shoeLightX || 5),
        lightY: parseFloat(el.dataset.shoeLightY || 5),
        lightZ: parseFloat(el.dataset.shoeLightZ || 5),
      };
    }

    /* ── State ── */
    var shoe = null;
    var raf  = null;
    var isVisible = false;
    var W = 0, H = 0;
    var cur = { rotX: 0, rotY: 0, rotZ: 0.2, posX: 0, posY: 0, lX: 5, lY: 5, lZ: 5, lI: 1.0 };
    var tgt = { rotX: 0, rotY: 0, rotZ: 0.2, posX: 0, posY: 0, lX: 5, lY: 5, lZ: 5, lI: 1.0 };
