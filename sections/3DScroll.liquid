  ════════════════════════════════════════════ */
  function initShoe3D(THREE, GLTFLoader, DRACOLoader, MeshoptDecoder) {
    var SECTION_ID = '{{ section_id }}';
    var section    = document.getElementById(SECTION_ID);
    if (!section) return;

