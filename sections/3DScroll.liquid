  /* ── Mobile modal binding ── */
  NotationController.prototype._bindMobileModals = function () {
    var self = this;

    /* Dot tap → open modal on mobile */
    this.section.querySelectorAll('.shoe3d-notations__dot').forEach(function (dot) {
      dot.addEventListener('click', function (e) {
