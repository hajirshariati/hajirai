  NotationController.prototype._openModal = function (modal, triggerEl) {
    modal.removeAttribute('hidden');
    modal.setAttribute('aria-hidden', 'false');
    if (triggerEl) triggerEl.setAttribute('aria-expanded', 'true');
    /* Trap focus into modal */
    var focusable = modal.querySelectorAll(
      'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
    );
    if (focusable.length) focusable[0].focus();
    document.body.style.overflow = 'hidden';
    this._lastTrigger = triggerEl;
  };

  NotationController.prototype._closeModal = function (modal) {
    modal.setAttribute('hidden', '');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    if (this._lastTrigger) {
      this._lastTrigger.setAttribute('aria-expanded', 'false');
      this._lastTrigger.focus();
      this._lastTrigger = null;
    }
  };

  /* ══════════════════════════════════════════════════════════
