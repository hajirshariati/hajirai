  /* ════════════════════════════════════════════
     NOTATION CONTROLLER
     Manages show/hide and line drawing per panel
  ════════════════════════════════════════════ */
  function NotationController(sectionEl, sectionId) {
    this.section    = sectionEl;
    this.sectionId  = sectionId;
    this.active     = null;   // currently visible overlay element
    this.activeIdx  = -1;
    this.isMobile   = window.innerWidth <= 768;
    this._rTimer    = null;

    this._bindMobileModals();
    window.addEventListener('resize', this._onResize.bind(this), { passive: true });
  }

  NotationController.prototype._onResize = function () {
    clearTimeout(this._rTimer);
    var self = this;
    this._rTimer = setTimeout(function () {
      var was = self.isMobile;
      self.isMobile = window.innerWidth <= 768;
      /* Redraw lines if switching to desktop while an overlay is active */
      if (was && !self.isMobile && self.active) {
        self._drawLines(self.active, false);
      }
    }, 150);
  };

  /* Show the notation overlay for panel at index idx */
  NotationController.prototype.show = function (idx) {
    if (this.activeIdx === idx) return;

    /* Hide previous */
    if (this.active) {
      this._resetOverlay(this.active);
      this.active.classList.remove('is-active');
      this.active = null;
    }

    var overlay = this.section.querySelector(
      '.shoe3d-notations[data-notation-panel="' + idx + '"]'
