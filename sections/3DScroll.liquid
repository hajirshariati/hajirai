/* ══════════════════════════════════════════
   NOTATION SYSTEM
   Mirrors dynamic-feature-combo.liquid
══════════════════════════════════════════ */

/* ── Overlay — fills the canvas viewport area ── */
.shoe3d-notation-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  pointer-events: none;
  z-index: 3;
  opacity: 0;
  transition: opacity .4s ease;
}
.shoe3d-notation-overlay.is-visible {
  opacity: 1;
}

/* ── SVG lines ── */
.shoe3d-notation__lines {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  overflow: visible;
}

.shoe3d-notation__line {
  stroke: var(--notation-line-color);
  stroke-width: var(--notation-line-width);
  fill: none;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-dasharray: var(--line-length, 1000);
  stroke-dashoffset: var(--line-length, 1000);
  animation: none;
}

@keyframes shoe3d-drawLine {
  to { stroke-dashoffset: 0; }
}

.shoe3d-notation-overlay.is-visible .shoe3d-notation__line {
  animation: shoe3d-drawLine 2.5s ease-out forwards;
}
.shoe3d-notation-overlay.is-visible .shoe3d-notation__line[data-notation-index="1"] {
  animation-delay: .35s;
}

/* ── Dots ── */
.shoe3d-notation__dot {
  position: absolute;
  transform: translate(-50%, -50%);
  z-index: 5;
  background: none;
  border: none;
  padding: 0;
  cursor: pointer;
  /* Desktop: non-interactive visual only */
  pointer-events: none;
}
.shoe3d-notation__dot-inner {
  width: var(--notation-dot-size);
  height: var(--notation-dot-size);
  background: var(--notation-dot-color);
  border: var(--notation-dot-border-w) solid var(--notation-dot-border);
  border-radius: 50%;
  box-shadow: 0 2px 8px rgba(0,0,0,.25);
  transform: scale(0);
  transition: transform .3s ease;
  display: block;
}
.shoe3d-notation-overlay.is-visible .shoe3d-notation__dot-inner {
  transform: scale(1);
}
/* Stagger second dot */
.shoe3d-notation__dot:nth-child(3) .shoe3d-notation__dot-inner {
  transition-delay: .1s;
}

/* Hover scale (desktop, hover-capable devices) */
@media (hover: hover) and (pointer: fine) {
  .shoe3d-notation-overlay.is-visible .shoe3d-notation__dot:hover .shoe3d-notation__dot-inner {
    transform: scale(1.3);
    box-shadow: 0 4px 16px rgba(0,0,0,.35);
  }
}

/* Mobile: pulsing dot + tap-to-open */
@media (max-width: 768px) {
  @keyframes shoe3d-dotPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(255,255,255,.9), 0 2px 8px rgba(255,255,255,.4); }
    50%       { box-shadow: 0 0 0 10px rgba(255,255,255,.0), 0 2px 20px rgba(255,255,255,.8); }
  }
  .shoe3d-notation__dot {
    pointer-events: all;
    width: 44px; /* WCAG 2.5.5 — min touch target */
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .shoe3d-notation__dot-inner {
    width: var(--notation-dot-size-mobile) !important;
    height: var(--notation-dot-size-mobile) !important;
    transform: scale(1) !important;
  }
  .shoe3d-notation-overlay.is-visible .shoe3d-notation__dot-inner {
    animation: shoe3d-dotPulse 4s ease-in-out infinite;
  }
  /* Hide lines and callouts on mobile */
  .shoe3d-notation__lines,
  .shoe3d-notation__callout {
    display: none;
  }
}

/* ── Callouts (desktop only) ── */
.shoe3d-notation__callout {
  position: absolute;
  pointer-events: none;
  opacity: 0;
  transform: translateY(10px);
  z-index: 5;
  transition: opacity .4s ease, transform .4s ease;
}
.shoe3d-notation-overlay.is-visible .shoe3d-notation__callout {
  opacity: 1;
  transform: translateY(0);
}
.shoe3d-notation__callout-inner {
  background: rgba(255,255,255,.8);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
