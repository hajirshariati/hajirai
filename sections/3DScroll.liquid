{% comment %}
  ============================================================
  3D Shoe Scroll Section
  ============================================================
  NOTATIONS:
  - Notation overlays live INSIDE .shoe3d-canvas-wrap so they
    render on top of the sticky 3D canvas at the correct position
  - JS uses IntersectionObserver on each .shoe3d-panel with a
    generous rootMargin so notations appear as soon as the panel
    enters the viewport center zone, and hide when it leaves
  - On desktop: dot + animated SVG elbow-line + callout
  - On mobile:  dot only (44px touch target) → bottom-sheet modal
  ============================================================
{% endcomment %}

{%- liquid
  assign section_id   = 'shoe3d-' | append: section.id
  assign model_url    = section.settings.model_url
  assign bg_color     = section.settings.background_color
  assign accent_color = section.settings.accent_color
  assign text_color   = section.settings.text_color
-%}

<section
  id="{{ section_id }}"
  class="shoe3d-section"
  aria-label="{{ section.settings.aria_label | default: '3D Product Showcase' }}"
  data-model="{{ model_url | escape }}"
  data-section-id="{{ section.id }}"
  itemscope
  itemtype="https://schema.org/Product"
>

  {% comment %}
    STICKY CANVAS WRAP
    The canvas AND all notation overlays live here together.
    This is the key fix — notations must be siblings of the canvas
    inside the sticky container so they appear ON the shoe.
  {% endcomment %}
  <div class="shoe3d-canvas-wrap" id="{{ section_id }}-sticky" aria-hidden="true">
    <canvas
      id="{{ section_id }}-canvas"
      class="shoe3d-canvas"
      role="img"
      aria-label="{{ section.settings.aria_label | default: '3D rotating shoe model' }}"
    ></canvas>
    <div class="shoe3d-vignette"></div>
    <div class="shoe3d-loader" id="{{ section_id }}-loader" aria-live="polite" aria-atomic="true">
      <div class="shoe3d-loader__ring" aria-hidden="true"></div>
      <span class="shoe3d-loader__text">Loading model…</span>
    </div>

    {% comment %} ALL notation overlays — one per panel block, hidden by default {% endcomment %}
    {%- for block in section.blocks -%}
      {%- assign has_n1 = false -%}
      {%- assign has_n2 = false -%}
      {%- if block.settings.notation_1_heading != blank or block.settings.notation_1_text != blank -%}
        {%- assign has_n1 = true -%}
      {%- endif -%}
      {%- if block.settings.notation_2_heading != blank or block.settings.notation_2_text != blank -%}
        {%- assign has_n2 = true -%}
      {%- endif -%}
      {%- if has_n1 or has_n2 -%}
        <div
          class="shoe3d-notations"
          id="{{ section_id }}-notations-{{ forloop.index0 }}"
          data-notation-panel="{{ forloop.index0 }}"
          aria-hidden="true"
        >
          {% comment %} SVG lines — redrawn by JS on activation {% endcomment %}
          <svg class="shoe3d-notations__svg" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true" focusable="false">
            {%- if has_n1 -%}
              <path
                class="shoe3d-notations__line"
                data-idx="0"
                data-dot-x="{{ block.settings.notation_1_dot_x | default: 35 }}"
                data-dot-y="{{ block.settings.notation_1_dot_y | default: 40 }}"
                data-callout-x="{{ block.settings.notation_1_text_x | default: 55 }}"
                data-callout-y="{{ block.settings.notation_1_text_y | default: 40 }}"
                data-breaks="{{ block.settings.notation_1_line_breaks | default: '1' }}"
              />
            {%- endif -%}
            {%- if has_n2 -%}
              <path
                class="shoe3d-notations__line"
                data-idx="1"
                data-dot-x="{{ block.settings.notation_2_dot_x | default: 60 }}"
                data-dot-y="{{ block.settings.notation_2_dot_y | default: 65 }}"
                data-callout-x="{{ block.settings.notation_2_text_x | default: 40 }}"
                data-callout-y="{{ block.settings.notation_2_text_y | default: 65 }}"
                data-breaks="{{ block.settings.notation_2_line_breaks | default: '1' }}"
              />
            {%- endif -%}
          </svg>

          {% comment %} Dots {% endcomment %}
          {%- if has_n1 -%}
            <button
              class="shoe3d-notations__dot"
              id="{{ section_id }}-p{{ forloop.index0 }}-dot0"
              style="left:{{ block.settings.notation_1_dot_x | default: 35 }}%;top:{{ block.settings.notation_1_dot_y | default: 40 }}%;"
              aria-label="{{ block.settings.notation_1_heading | default: 'Feature detail' | escape }}"
              aria-expanded="false"
              aria-controls="{{ section_id }}-p{{ forloop.index0 }}-modal0"
              type="button"
              tabindex="-1"
            ><span class="shoe3d-notations__dot-inner" aria-hidden="true"></span></button>
          {%- endif -%}
          {%- if has_n2 -%}
            <button
              class="shoe3d-notations__dot"
              id="{{ section_id }}-p{{ forloop.index0 }}-dot1"
              style="left:{{ block.settings.notation_2_dot_x | default: 60 }}%;top:{{ block.settings.notation_2_dot_y | default: 65 }}%;"
              aria-label="{{ block.settings.notation_2_heading | default: 'Feature detail' | escape }}"
              aria-expanded="false"
              aria-controls="{{ section_id }}-p{{ forloop.index0 }}-modal1"
              type="button"
              tabindex="-1"
            ><span class="shoe3d-notations__dot-inner" aria-hidden="true"></span></button>
          {%- endif -%}

          {% comment %} Desktop callouts {% endcomment %}
          {%- if has_n1 -%}
            <div
              class="shoe3d-notations__callout"
              data-callout-idx="0"
              style="left:{{ block.settings.notation_1_text_x | default: 55 }}%;top:{{ block.settings.notation_1_text_y | default: 40 }}%;"
              aria-hidden="true"
            >
              {%- if block.settings.notation_1_heading != blank -%}
                <p class="shoe3d-notations__callout-title">{{ block.settings.notation_1_heading }}</p>
              {%- endif -%}
              {%- if block.settings.notation_1_text != blank -%}
                <p class="shoe3d-notations__callout-body">{{ block.settings.notation_1_text }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
          {%- if has_n2 -%}
            <div
              class="shoe3d-notations__callout"
              data-callout-idx="1"
              style="left:{{ block.settings.notation_2_text_x | default: 40 }}%;top:{{ block.settings.notation_2_text_y | default: 65 }}%;"
              aria-hidden="true"
            >
              {%- if block.settings.notation_2_heading != blank -%}
                <p class="shoe3d-notations__callout-title">{{ block.settings.notation_2_heading }}</p>
              {%- endif -%}
              {%- if block.settings.notation_2_text != blank -%}
                <p class="shoe3d-notations__callout-body">{{ block.settings.notation_2_text }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}

        </div>
      {%- endif -%}

      {% comment %} Mobile modals — outside sticky wrap so they can be fixed {% endcomment %}
    {%- endfor -%}

  </div>{% comment %} /.shoe3d-canvas-wrap {% endcomment %}

  {% comment %} Mobile modals rendered outside the sticky wrap {% endcomment %}
  {%- for block in section.blocks -%}
    {%- assign has_n1 = false -%}
    {%- assign has_n2 = false -%}
    {%- if block.settings.notation_1_heading != blank or block.settings.notation_1_text != blank -%}{%- assign has_n1 = true -%}{%- endif -%}
    {%- if block.settings.notation_2_heading != blank or block.settings.notation_2_text != blank -%}{%- assign has_n2 = true -%}{%- endif -%}
    {%- if has_n1 -%}
      <div
        class="shoe3d-modal"
        id="{{ section_id }}-p{{ forloop.index0 }}-modal0"
        role="dialog"
        aria-modal="true"
        aria-label="{{ block.settings.notation_1_heading | default: 'Feature detail' | escape }}"
        aria-hidden="true"
        hidden
      >
        <div class="shoe3d-modal__overlay" data-modal-close></div>
        <div class="shoe3d-modal__inner">
          <button class="shoe3d-modal__close" type="button" aria-label="Close" data-modal-close>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
          {%- if block.settings.notation_1_heading != blank -%}<p class="shoe3d-modal__title">{{ block.settings.notation_1_heading }}</p>{%- endif -%}
          {%- if block.settings.notation_1_text != blank -%}<p class="shoe3d-modal__body">{{ block.settings.notation_1_text }}</p>{%- endif -%}
        </div>
      </div>
    {%- endif -%}
    {%- if has_n2 -%}
      <div
        class="shoe3d-modal"
        id="{{ section_id }}-p{{ forloop.index0 }}-modal1"
        role="dialog"
        aria-modal="true"
        aria-label="{{ block.settings.notation_2_heading | default: 'Feature detail' | escape }}"
        aria-hidden="true"
        hidden
      >
        <div class="shoe3d-modal__overlay" data-modal-close></div>
        <div class="shoe3d-modal__inner">
          <button class="shoe3d-modal__close" type="button" aria-label="Close" data-modal-close>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
          {%- if block.settings.notation_2_heading != blank -%}<p class="shoe3d-modal__title">{{ block.settings.notation_2_heading }}</p>{%- endif -%}
          {%- if block.settings.notation_2_text != blank -%}<p class="shoe3d-modal__body">{{ block.settings.notation_2_text }}</p>{%- endif -%}
        </div>
      </div>
    {%- endif -%}
  {%- endfor -%}

  {% comment %} SCROLLABLE CONTENT — pulled up over canvas via negative margin-top {% endcomment %}
  <div class="shoe3d-section__inner">

    {% comment %} Hero {% endcomment %}
    <div class="shoe3d-hero">
      {%- if section.settings.hero_badge != blank -%}
        <div class="shoe3d-hero__badge"><span>{{ section.settings.hero_badge }}</span></div>
      {%- endif -%}
      <h2 class="shoe3d-hero__headline" itemprop="name">{{ section.settings.hero_headline | default: 'The Jillian' }}</h2>
      <p class="shoe3d-hero__sub">{{ section.settings.hero_subtext | default: 'Scroll to explore' }}</p>
      <div class="shoe3d-hero__scroll-hint" aria-hidden="true">
        <span class="shoe3d-hero__scroll-line"></span>
        <span class="shoe3d-hero__scroll-label">Scroll</span>
      </div>
    </div>

    {% comment %} Scroll panels {% endcomment %}
    <div class="shoe3d-panels" id="{{ section_id }}-panels">

      {%- liquid
        assign jillian_eyebrows = "All-Day Comfort,Premium Materials,Signature Arch Support,Style Meets Function" | split: ","
        assign jillian_headings = "Feels Like Walking on Air,Genuine Leather. Built to Last.,Aligned From the Ground Up,Comfort You Can See." | split: ","
        assign jillian_bodies   = "Memory foam cushioning and an ultra-light cork midsole work together to reduce fatigue — so you can go further, longer.,Crafted from real leather uppers with a soft microfiber footbed treated with antimicrobial technology — fresh all day every day.,Aetrex Signature Arch Support is strategically placed to align your entire body — relieving pressure from your feet all the way to your back.,The signature braided detailing makes the Jillian the sandal you'll reach for every morning — whether running errands or spending a full day on your feet." | split: ","
      -%}

      {%- for block in section.blocks -%}
        {%- assign is_right   = forloop.index | modulo: 2 -%}
        {%- assign panel_side = 'left' -%}
        {%- if is_right == 0 -%}{%- assign panel_side = 'right' -%}{%- endif -%}
        {%- assign idx = forloop.index0 -%}

        {%- assign eyebrow_text = jillian_eyebrows[idx] -%}
        {%- if block.settings.eyebrow != blank -%}{%- assign eyebrow_text = block.settings.eyebrow -%}{%- endif -%}
        {%- assign heading_text = jillian_headings[idx] -%}
        {%- if block.settings.heading != blank -%}{%- assign heading_text = block.settings.heading -%}{%- endif -%}
        {%- assign body_text = jillian_bodies[idx] -%}
        {%- if block.settings.body != blank -%}{%- assign body_text = block.settings.body -%}{%- endif -%}

        <div
          class="shoe3d-panel shoe3d-panel--{{ panel_side }}"
          data-panel-index="{{ forloop.index0 }}"
          data-shoe-rot-x="{{ block.settings.rot_x | default: 0 }}"
          data-shoe-rot-y="{{ block.settings.rot_y | default: 0 }}"
          data-shoe-rot-z="{{ block.settings.rot_z | default: 0 }}"
          data-shoe-pos-x="{{ block.settings.pos_x | default: 0 }}"
          data-shoe-pos-y="{{ block.settings.pos_y | default: 0 }}"
          data-shoe-light-intensity="{{ block.settings.light_intensity | default: 12 }}"
          data-shoe-light-x="{{ block.settings.light_x | default: 5 }}"
          data-shoe-light-y="{{ block.settings.light_y | default: 5 }}"
          data-shoe-light-z="{{ block.settings.light_z | default: 5 }}"
          {{ block.shopify_attributes }}
        >
          <div class="shoe3d-panel__content shoe3d-panel__content--{{ panel_side }}">
            <span class="shoe3d-panel__eyebrow">{{ eyebrow_text }}</span>
            <h3 class="shoe3d-panel__heading">{{ heading_text }}</h3>
            <p class="shoe3d-panel__body">{{ body_text }}</p>

            {%- if block.settings.feature_1 != blank or block.settings.feature_2 != blank or block.settings.feature_3 != blank -%}
              <ul class="shoe3d-panel__features" aria-label="Features">
                {%- if block.settings.feature_1 != blank -%}<li class="shoe3d-panel__feature">{{ block.settings.feature_1 }}</li>{%- endif -%}
                {%- if block.settings.feature_2 != blank -%}<li class="shoe3d-panel__feature">{{ block.settings.feature_2 }}</li>{%- endif -%}
                {%- if block.settings.feature_3 != blank -%}<li class="shoe3d-panel__feature">{{ block.settings.feature_3 }}</li>{%- endif -%}
              </ul>
            {%- endif -%}

            {%- if block.settings.cta_label != blank and block.settings.cta_url != blank -%}
              <a class="shoe3d-panel__cta" href="{{ block.settings.cta_url }}"
                {%- if block.settings.cta_new_tab %} target="_blank" rel="noopener noreferrer"{%- endif -%}>
                <span>{{ block.settings.cta_label }}</span>
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <path d="M3.75 9h10.5M9.75 4.5 14.25 9l-4.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            {%- endif -%}
          </div>

          {%- if block.settings.image != blank -%}
            <div class="shoe3d-panel__image-wrap">
              {{- block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'shoe3d-panel__image', widths: '300,400,600', sizes: '(max-width:768px) 90vw, 400px' -}}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}

      <div class="shoe3d-end-spacer" aria-hidden="true"></div>
    </div>
  </div>

</section>

<style>
/* ── CSS variables ── */
#{{ section_id }} {
  --bg:      {{ bg_color }};
  --text:    {{ text_color }};
  --accent:  {{ accent_color }};
  --panel-h: 80vh;
  --content-w: min(400px, 42vw);
  --ease-spring: cubic-bezier(0.22, 1, 0.36, 1);
  --max-w: 1520px;
  /* Notation tokens */
  --n-dot:        {{ section.settings.notation_dot_size   | default: 20 }}px;
  --n-dot-mob:    {{ section.settings.notation_dot_size_mobile | default: 16 }}px;
  --n-dot-fill:   {{ section.settings.notation_dot_color  | default: '#ffffff' }};
  --n-dot-border: {{ section.settings.notation_dot_border_color | default: '#000000' }};
  --n-dot-bw:     {{ section.settings.notation_dot_border_width | default: 2 }}px;
  --n-line:       {{ section.settings.notation_line_color | default: '#ffffff' }};
  --n-line-w:     {{ section.settings.notation_line_width | default: 0.8 }};
  --n-title:      {{ section.settings.notation_callout_title_color | default: '#000000' }};
  --n-body:       {{ section.settings.notation_callout_text_color  | default: '#555555' }};
}

/* ── Section ── */
.shoe3d-section {
  position: relative;
  background: var(--bg);
  color: var(--text);
  contain: layout style;
}

/* ── Sticky canvas layer ── */
.shoe3d-canvas-wrap {
  position: sticky;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  z-index: 1;
  pointer-events: none;
  overflow: hidden;
}
.shoe3d-canvas {
  display: block;
  width: 100%;
  height: 100%;
  will-change: contents;
}
.shoe3d-vignette {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 55% 55% at 50% 50%, transparent 30%, var(--bg) 100%),
    linear-gradient(to bottom, var(--bg) 0%, transparent 15%, transparent 85%, var(--bg) 100%);
  pointer-events: none;
}

/* ── Loader ── */
.shoe3d-loader {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  transition: opacity .4s ease, visibility .4s ease;
  pointer-events: none;
}
.shoe3d-loader.is-hidden { opacity: 0; visibility: hidden; }
.shoe3d-loader__ring {
  width: 36px; height: 36px;
  border: 2px solid rgba(255,255,255,.15);
  border-top-color: rgba(255,255,255,.7);
  border-radius: 50%;
  animation: shoe3d-spin .8s linear infinite;
}
.shoe3d-loader__text {
  font-size: .7rem; letter-spacing: .12em;
  text-transform: uppercase; color: rgba(255,255,255,.4);
}

/* ════════════════════════════════════════
   NOTATION OVERLAYS
   Live inside .shoe3d-canvas-wrap so they
   always overlay the sticky 3D canvas.
════════════════════════════════════════ */
.shoe3d-notations {
  position: absolute;
  inset: 0;
  pointer-events: none;
  /* Hidden state */
  opacity: 0;
  visibility: hidden;
  transition: opacity .5s var(--ease-spring), visibility .5s var(--ease-spring);
}
/* Visible state — toggled by JS when panel is active */
.shoe3d-notations.is-active {
  opacity: 1;
  visibility: visible;
  pointer-events: none; /* dots re-enable pointer-events below */
}

/* SVG lines container */
.shoe3d-notations__svg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  overflow: visible;
  pointer-events: none;
}
.shoe3d-notations__line {
  fill: none;
  stroke: var(--n-line);
  stroke-width: var(--n-line-w);
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-dasharray: var(--line-length, 2000);
  stroke-dashoffset: var(--line-length, 2000);
}
.shoe3d-notations.is-active .shoe3d-notations__line {
  animation: shoe3d-draw 1.8s ease-out forwards;
}
.shoe3d-notations.is-active .shoe3d-notations__line[data-idx="1"] {
  animation-delay: .3s;
}

@keyframes shoe3d-draw { to { stroke-dashoffset: 0; } }

/* Dots */
.shoe3d-notations__dot {
  position: absolute;
  transform: translate(-50%, -50%);
  width: 44px; height: 44px;         /* WCAG touch target */
  display: flex; align-items: center; justify-content: center;
  background: none; border: none; padding: 0;
  cursor: default;
  pointer-events: none;              /* desktop: no pointer needed */
  z-index: 2;
}
.shoe3d-notations__dot-inner {
  width: var(--n-dot); height: var(--n-dot);
  background: var(--n-dot-fill);
  border: var(--n-dot-bw) solid var(--n-dot-border);
  border-radius: 50%;
  box-shadow: 0 2px 8px rgba(0,0,0,.3);
  transform: scale(0);
  transition: transform .4s var(--ease-spring);
  display: block;
}
.shoe3d-notations.is-active .shoe3d-notations__dot-inner {
  transform: scale(1);
}
/* Stagger second dot */
.shoe3d-notations__dot:nth-of-type(3) .shoe3d-notations__dot-inner { transition-delay: .12s; }

/* Desktop hover scale */
@media (hover: hover) and (pointer: fine) {
  .shoe3d-notations.is-active .shoe3d-notations__dot:hover .shoe3d-notations__dot-inner {
    transform: scale(1.3);
  }
}

/* Callouts — desktop only */
.shoe3d-notations__callout {
  position: absolute;
  transform: translate(0, -50%);
  opacity: 0;
  pointer-events: none;
  transition: opacity .5s ease .8s, transform .5s var(--ease-spring) .8s;
}
.shoe3d-notations.is-active .shoe3d-notations__callout {
  opacity: 1;
}
.shoe3d-notations.is-active .shoe3d-notations__callout[data-callout-idx="1"] {
  transition-delay: 1.1s;
}
.shoe3d-notations__callout-inner-wrap {
  background: rgba(255,255,255,.82);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  padding: 7px 13px;
  border-radius: 9px;
  max-width: 200px;
  box-shadow: 0 2px 12px rgba(0,0,0,.12);
}
.shoe3d-notations__callout-title {
  font-weight: 600; font-size: 13px;
  color: var(--n-title); margin: 0 0 2px; line-height: 1.3;
}
.shoe3d-notations__callout-body {
  font-size: 11px; line-height: 1.45;
  color: var(--n-body); margin: 0;
}

/* Mobile: hide lines + callouts, enable dot taps, pulse dots */
@media (max-width: 768px) {
  .shoe3d-notations__svg,
  .shoe3d-notations__callout { display: none; }

  .shoe3d-notations__dot {
    pointer-events: all;
    cursor: pointer;
  }
  .shoe3d-notations__dot-inner {
    width: var(--n-dot-mob) !important;
    height: var(--n-dot-mob) !important;
    transform: scale(1) !important;
  }

  @keyframes shoe3d-pulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(255,255,255,.8); }
    50%      { box-shadow: 0 0 0 8px rgba(255,255,255,0); }
  }
  .shoe3d-notations.is-active .shoe3d-notations__dot-inner {
    animation: shoe3d-pulse 2.5s ease-in-out infinite;
  }
}

/* ── Mobile modals (fixed, outside sticky wrap) ── */
.shoe3d-modal {
  position: fixed; inset: 0;
  z-index: 9999;
  display: flex; align-items: flex-end;
  opacity: 0; visibility: hidden;
  transition: opacity .25s ease, visibility .25s ease;
  pointer-events: none;
}
.shoe3d-modal:not([hidden]) {
  opacity: 1; visibility: visible; pointer-events: all;
}
.shoe3d-modal__overlay {
  position: absolute; inset: 0;
  background: rgba(0,0,0,.45); cursor: pointer;
}
.shoe3d-modal__inner {
  position: relative; z-index: 1;
  background: #fff;
  border-radius: 20px 20px 0 0;
  padding: 2.2rem 1.5rem 3rem;
  width: 100%; max-height: 60vh;
  overflow-y: auto; -webkit-overflow-scrolling: touch;
  box-shadow: 0 -8px 40px rgba(0,0,0,.18);
}
.shoe3d-modal__close {
  position: absolute; top: 1rem; right: 1rem;
  width: 36px; height: 36px;
  background: rgba(0,0,0,.06); border: none; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; color: #000;
  transition: background .2s ease;
}
.shoe3d-modal__close:hover { background: rgba(0,0,0,.13); }
.shoe3d-modal__close:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
.shoe3d-modal__title {
  font-weight: 700; font-size: 1.1rem;
  color: #111; margin: 0 0 .5rem; padding-right: 2.5rem;
}
.shoe3d-modal__body {
  font-size: .9rem; line-height: 1.65; color: #555; margin: 0;
}

/* ── Scrollable inner content ── */
.shoe3d-section__inner {
  max-width: var(--max-w);
  margin: -100vh auto 0;
  position: relative;
  z-index: 2;
}

/* ── Hero ── */
.shoe3d-hero {
  position: relative;
  z-index: 3;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  min-height: 100vh;
  padding: 2rem; text-align: center;
  pointer-events: none;
}
.shoe3d-hero__badge {
  display: inline-flex; align-items: center;
  border: 1px solid rgba(255,255,255,.25);
  border-radius: 50px; padding: .35em 1.1em;
  font-size: .7rem; letter-spacing: .18em;
  text-transform: uppercase; color: rgba(255,255,255,.75);
  margin-bottom: 1.5rem;
}
.shoe3d-hero__headline {
  font-family: var(--font-heading-family, Georgia, serif);
  font-size: clamp(2.5rem, 8vw, 7rem);
  font-weight: 300; letter-spacing: -.04em;
  line-height: .95; color: var(--text);
  margin: 0 0 1rem;
}
.shoe3d-hero__sub {
  font-size: clamp(.85rem, 1.3vw, 1.1rem);
  color: rgba(255,255,255,.5);
  letter-spacing: .06em; text-transform: uppercase;
  margin: 0 0 3rem;
}
.shoe3d-hero__scroll-hint {
  display: flex; flex-direction: column;
  align-items: center; gap: .6rem;
  animation: shoe3d-bounce 2s ease-in-out infinite;
}
.shoe3d-hero__scroll-line {
  display: block; width: 1px; height: 48px;
  background: linear-gradient(to bottom, transparent, rgba(255,255,255,.6));
}
.shoe3d-hero__scroll-label {
  font-size: .65rem; letter-spacing: .2em;
  text-transform: uppercase; color: rgba(255,255,255,.4);
}

/* ── Panels ── */
.shoe3d-panels { position: relative; z-index: 2; }
.shoe3d-panel {
  min-height: var(--panel-h);
  display: flex; align-items: center;
  padding: 2rem 5vw;
  pointer-events: none;
}
.shoe3d-panel--left  { justify-content: flex-end; }
.shoe3d-panel--right { justify-content: flex-start; }

.shoe3d-panel__content {
  pointer-events: all;
  width: var(--content-w);
  display: flex; flex-direction: column; gap: 1.25rem;
  opacity: 0; transform: translateY(40px);
  transition: opacity .7s var(--ease-spring), transform .7s var(--ease-spring);
  position: relative; z-index: 4;
}
.shoe3d-panel__content.is-visible { opacity: 1; transform: translateY(0); }

.shoe3d-panel__eyebrow {
  display: inline-block;
  font-size: .65rem; font-weight: 600;
  letter-spacing: .2em; text-transform: uppercase;
  color: var(--accent); border: 1px solid var(--accent);
  border-radius: 50px; padding: .3em .9em; width: fit-content;
}
.shoe3d-panel__heading {
  font-family: var(--font-heading-family, Georgia, serif);
  font-size: clamp(1.6rem, 3.5vw, 3rem);
  font-weight: 300; letter-spacing: -.04em;
  line-height: 1.05; color: var(--text); margin: 0;
}
.shoe3d-panel__body {
  font-size: clamp(.85rem, 1.1vw, 1rem);
  line-height: 1.75; color: rgba(255,255,255,.6);
  margin: 0; max-width: 38ch;
}
.shoe3d-panel__features {
  list-style: none; padding: 0; margin: 0;
  display: flex; flex-direction: column; gap: .5rem;
}
.shoe3d-panel__feature {
  font-size: .85rem; color: rgba(255,255,255,.7);
  padding-left: 1.2em; position: relative; letter-spacing: .02em;
}
.shoe3d-panel__feature::before {
  content: ''; position: absolute;
  left: 0; top: .5em;
  width: 5px; height: 5px;
  background: var(--accent); border-radius: 50%;
}
.shoe3d-panel__cta {
  display: inline-flex; align-items: center; gap: .6rem;
  font-size: .75rem; font-weight: 600;
  letter-spacing: .08em; text-transform: uppercase;
  text-decoration: none; color: var(--bg); background: var(--text);
  padding: .8em 1.7em; border-radius: 50px; width: fit-content;
  transition: background .2s ease, color .2s ease, transform .2s ease;
}
.shoe3d-panel__cta:hover { background: var(--accent); color: var(--bg); transform: translateX(4px); }
.shoe3d-panel__cta:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
.shoe3d-panel__cta svg { flex-shrink: 0; transition: transform .2s ease; }
.shoe3d-panel__cta:hover svg { transform: translateX(4px); }

.shoe3d-panel__image-wrap { display: none; }
@media (max-width: 767px) {
  .shoe3d-panel__image-wrap {
    display: block; border-radius: 16px; overflow: hidden;
    width: 100%; max-width: 280px; aspect-ratio: 1;
    margin-top: 1rem; box-shadow: 0 20px 50px rgba(0,0,0,.5);
  }
  .shoe3d-panel__image { width: 100%; height: 100%; object-fit: cover; display: block; }
}

.shoe3d-end-spacer { height: 20vh; }

/* ── Mobile layout ── */
@media (max-width: 767px) {
  .shoe3d-panel {
    flex-direction: column; align-items: flex-start;
    padding: 3rem 1.5rem;
    justify-content: flex-start;
    min-height: auto; padding-top: 20vh;
  }
  .shoe3d-panel--left, .shoe3d-panel--right { justify-content: flex-start; }
  .shoe3d-panel__content { width: 100%; }
  .shoe3d-hero__headline { font-size: clamp(2rem, 10vw, 4rem); }
}

/* ── Keyframes ── */
@keyframes shoe3d-spin   { to { transform: rotate(360deg); } }
@keyframes shoe3d-bounce {
  0%,100% { transform: translateY(0); }
  50%     { transform: translateY(8px); }
}

/* ── Reduced motion ── */
@media (prefers-reduced-motion: reduce) {
  .shoe3d-hero__scroll-hint { animation: none; }
  .shoe3d-loader__ring { animation: none; border-top-color: rgba(255,255,255,.5); }
