    if (!overlay) { this.activeIdx = idx; return; } /* panel has no notations */

    this.active    = overlay;
    this.activeIdx = idx;

    /* Draw lines BEFORE adding is-active so getBoundingClientRect is accurate */
    if (!this.isMobile) {
      this._drawLines(overlay, true);
    }

    overlay.classList.add('is-active');

    /* Enable keyboard access on dots when visible */
    overlay.querySelectorAll('.shoe3d-notations__dot').forEach(function (d) {
      d.removeAttribute('tabindex');
    });
  };

  /* Hide all overlays */
  NotationController.prototype.hide = function () {
    if (!this.active) return;
    this._resetOverlay(this.active);
    this.active.classList.remove('is-active');
    this.active.querySelectorAll('.shoe3d-notations__dot').forEach(function (d) {
      d.setAttribute('tabindex', '-1');
    });
    this.active    = null;
    this.activeIdx = -1;
  };

  /* Reset line animations so they can replay next time */
  NotationController.prototype._resetOverlay = function (overlay) {
    overlay.querySelectorAll('.shoe3d-notations__line').forEach(function (l) {
      l.style.animation      = 'none';
      l.style.strokeDashoffset = l.style.strokeDasharray || '2000';
    });
  };

  /* ── Line drawing — same elbow algorithm as dynamic-feature-combo ── */
  NotationController.prototype._drawLines = function (overlay, animate) {
    var svg      = overlay.querySelector('.shoe3d-notations__svg');
    var lines    = overlay.querySelectorAll('.shoe3d-notations__line');
    var dots     = overlay.querySelectorAll('.shoe3d-notations__dot');
    var callouts = overlay.querySelectorAll('.shoe3d-notations__callout');
    if (!svg || !lines.length) return;

    var svgRect = svg.getBoundingClientRect();
    if (svgRect.width === 0) return;

    lines.forEach(function (line, i) {
      var dot     = dots[i];
      var callout = callouts[i];
      if (!dot || !callout) return;

      var dotR     = dot.getBoundingClientRect();
      var calR     = callout.getBoundingClientRect();
      var GAP      = 10;

      /* dot centre in SVG % coords */
      var sx = ((dotR.left + dotR.width  / 2 - svgRect.left) / svgRect.width)  * 100;
      var sy = ((dotR.top  + dotR.height / 2 - svgRect.top)  / svgRect.height) * 100;

      /* callout edge in SVG % coords */
      var goRight = calR.left > dotR.left;
      var exPx    = goRight ? calR.left - GAP : calR.right + GAP;
      var ex      = ((exPx - svgRect.left) / svgRect.width) * 100;
      var ey      = ((calR.top + calR.height / 2 - svgRect.top) / svgRect.height) * 100;

      var hasBend  = parseInt(line.dataset.breaks, 10) === 1;
      var deltaY   = Math.abs(ey - sy);
      var path;

      if (!hasBend || deltaY < 3) {
        path = 'M ' + sx + ',' + sy + ' L ' + ex + ',' + ey;
      } else {
        var elbowX  = goRight
          ? sx + Math.abs(ex - sx) * 0.5
          : sx - Math.abs(ex - sx) * 0.5;
        var r       = Math.min(4, Math.abs(ex - sx) / 4);
        var vd      = ey > sy ? 1 : -1;
        var sign    = goRight ? 1 : -1;
        path = [
          'M ' + sx + ',' + sy,
          'L ' + (elbowX - r * sign) + ',' + sy,
          'Q ' + elbowX + ',' + sy + ' ' + elbowX + ',' + (sy + r * vd),
          'L ' + elbowX + ',' + (ey - r * vd),
          'Q ' + elbowX + ',' + ey + ' ' + (elbowX + r * sign) + ',' + ey,
          'L ' + ex + ',' + ey
