<script>
(function () {
  'use strict';

  /* ── Utility: load a script tag sequentially ── */
  function loadScript(src, cb) {
    var s = document.createElement('script');
    s.src = src;
    s.async = false;
    s.onload = cb;
    s.onerror = function () { console.error('[Shoe3D] Script load failed:', src); };
    document.head.appendChild(s);
  }

