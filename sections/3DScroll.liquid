<script>
(function () {
  'use strict';

  /* ── Script loader ── */
  function loadScript(src, cb) {
    var s = document.createElement('script');
    s.src = src; s.async = false;
    s.onload = cb;
    s.onerror = function () { console.error('[Shoe3D] Failed:', src); };
