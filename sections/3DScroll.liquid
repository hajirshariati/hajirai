  /* ══════════════════════════════════════════════════════════
     NOTATION SYSTEM
     Mirrors DynamicFeatureSection from dynamic-feature-combo
  ══════════════════════════════════════════════════════════ */
  function NotationController(sectionEl) {
    this.section       = sectionEl;
    this.activeOverlay = null;
    this.isMobile      = window.innerWidth <= 768;
    this._resizeTimer  = null;

    this._bindModals();
    window.addEventListener('resize', this._onResize.bind(this), { passive: true });
  }

  NotationController.prototype._onResize = function () {
    clearTimeout(this._resizeTimer);
    var self = this;
    this._resizeTimer = setTimeout(function () {
      var wasMobile = self.isMobile;
      self.isMobile = window.innerWidth <= 768;
      /* Re-draw lines on desktop if switching from mobile */
      if (wasMobile && !self.isMobile && self.activeOverlay) {
        self._drawLines(self.activeOverlay, false);
      }
    }, 150);
  };

  NotationController.prototype.activate = function (panelIndex) {
    var overlay = this.section.querySelector(
      '.shoe3d-notation-overlay[data-panel-notation="' + panelIndex + '"]'
    );
    if (!overlay) return;
    if (this.activeOverlay && this.activeOverlay !== overlay) {
      this.deactivate();
    }
    this.activeOverlay = overlay;
    overlay.classList.add('is-visible');
    if (!this.isMobile) {
      this._drawLines(overlay, true);
    }
  };

  NotationController.prototype.deactivate = function () {
    if (!this.activeOverlay) return;
    this.activeOverlay.classList.remove('is-visible');
    /* Reset line animations */
    var lines = this.activeOverlay.querySelectorAll('.shoe3d-notation__line');
    lines.forEach(function (l) {
      l.style.animation = 'none';
      l.style.strokeDashoffset = l.style.strokeDasharray;
    });
    this.activeOverlay = null;
  };

  NotationController.prototype._drawLines = function (overlay, animate) {
    if (this.isMobile) return;
    var self = this;
    var svg  = overlay.querySelector('.shoe3d-notation__lines');
    if (!svg) return;

    var lines    = overlay.querySelectorAll('.shoe3d-notation__line');
    var callouts = overlay.querySelectorAll('.shoe3d-notation__callout');
    var dots     = overlay.querySelectorAll('.shoe3d-notation__dot');

    lines.forEach(function (line, index) {
      var dot     = dots[index];
      var callout = callouts[index];
      if (!dot || !callout) return;

      var svgRect     = svg.getBoundingClientRect();
      var dotRect     = dot.getBoundingClientRect();
      var calloutRect = callout.getBoundingClientRect();
      var GAP         = 12;

      var sx = ((dotRect.left + dotRect.width  / 2 - svgRect.left) / svgRect.width)  * 100;
      var sy = ((dotRect.top  + dotRect.height / 2 - svgRect.top)  / svgRect.height) * 100;

      var goingRight = calloutRect.left > dotRect.left;
      var endXpx     = goingRight ? calloutRect.left - GAP : calloutRect.right + GAP;
      var endX       = ((endXpx - svgRect.left) / svgRect.width)  * 100;
      var endY       = ((calloutRect.top + calloutRect.height / 2 - svgRect.top) / svgRect.height) * 100;

      var hasBend     = parseInt(line.dataset.breaks, 10) === 1;
      var deltaY      = Math.abs(endY - sy);
      var MIN_BEND    = 3;
      var path;

      if (!hasBend || deltaY < MIN_BEND) {
        path = 'M ' + sx + ',' + sy + ' L ' + endX + ',' + endY;
      } else {
        var elbowX  = goingRight
          ? sx + Math.abs(endX - sx) * 0.5
          : sx - Math.abs(endX - sx) * 0.5;
        var radius  = Math.min(4, Math.abs(endX - sx) / 4);
        var vertDir = endY > sy ? 1 : -1;
        path = [
          'M '  + sx + ',' + sy,
          'L '  + (elbowX - radius * (goingRight ? 1 : -1)) + ',' + sy,
          'Q '  + elbowX + ',' + sy + ' ' + elbowX + ',' + (sy + radius * vertDir),
          'L '  + elbowX + ',' + (endY - radius * vertDir),
          'Q '  + elbowX + ',' + endY + ' ' + (elbowX + radius * (goingRight ? 1 : -1)) + ',' + endY,
          'L '  + endX + ',' + endY,
        ].join(' ');
      }

      line.setAttribute('d', path);
      var length = line.getTotalLength();
      line.style.setProperty('--line-length', length);
      line.style.strokeDasharray  = length;
      line.style.strokeDashoffset = length;

      if (animate) {
        line.style.animation      = 'shoe3d-drawLine 2.5s ease-out forwards';
        line.style.animationDelay = (index * 0.35) + 's';
      } else {
        line.style.strokeDashoffset = 0;
      }
    });
  };

  /* ── Modal binding ── */
  NotationController.prototype._bindModals = function () {
    var self = this;

    /* Dot buttons — open modal on mobile */
    var dots = this.section.querySelectorAll('.shoe3d-notation__dot');
    dots.forEach(function (dot) {
      dot.addEventListener('click', function (e) {
        if (window.innerWidth > 768) return;
        e.preventDefault();
        e.stopPropagation();
        var targetId = dot.getAttribute('aria-controls');
        if (!targetId) return;
        var modal = document.getElementById(targetId);
        if (modal) self._openModal(modal, dot);
      });

      /* Keyboard: Enter / Space */
      dot.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          dot.click();
        }
      });
    });

    /* Close triggers inside modals */
    var modals = this.section.querySelectorAll('.shoe3d-notation__modal');
    modals.forEach(function (modal) {
      modal.querySelectorAll('[data-modal-close]').forEach(function (trigger) {
        trigger.addEventListener('click', function () { self._closeModal(modal); });
      });
      /* ESC key */
      modal.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') self._closeModal(modal);
      });
    });
