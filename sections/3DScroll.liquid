        rotZ: parseFloat(el.dataset.shoeRotZ || 0) * Math.PI / 180,
        posX: parseFloat(el.dataset.shoePosX || 0) / 10,
        posY: parseFloat(el.dataset.shoePosY || 0) / 10,
        lI:   parseFloat(el.dataset.shoeLightIntensity || 12) / 10,
        lX:   parseFloat(el.dataset.shoeLightX || 5),
        lY:   parseFloat(el.dataset.shoeLightY || 5),
        lZ:   parseFloat(el.dataset.shoeLightZ || 5),
