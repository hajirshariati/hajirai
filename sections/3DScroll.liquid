      },
      function (xhr) {
        if (loaderEl && xhr.total) {
          var t = loaderEl.querySelector('.shoe3d-loader__text');
          if (t) t.textContent = 'Loading\u2026 ' + Math.round(xhr.loaded/xhr.total*100) + '%';
        }
      },
      function (err) {
        console.error('[Shoe3D] Load error:', err);
        if (loaderEl) {
          var t = loaderEl.querySelector('.shoe3d-loader__text');
          var r = loaderEl.querySelector('.shoe3d-loader__ring');
          if (t) t.textContent = 'Could not load 3D model.';
          if (r) r.parentNode.removeChild(r);
        }
      });
    }

    if (typeof MeshoptDecoder !== 'undefined' && MeshoptDecoder && gltf.setMeshoptDecoder) {
      var rdy = MeshoptDecoder.ready instanceof Promise ? MeshoptDecoder.ready : Promise.resolve();
      rdy.then(function () { gltf.setMeshoptDecoder(MeshoptDecoder); doLoad(); });
    } else { doLoad(); }

    /* BFCache */
    document.addEventListener('visibilitychange', function () {
      if (document.hidden && raf) { cancelAnimationFrame(raf); raf = null; }
      else if (!document.hidden && isVis && !raf) startLoop();
    });
  }

})();
</script>

