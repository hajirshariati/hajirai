{% comment %}
  ============================================================
  3D Shoe Scroll Section — Syntilay-Style
  ============================================================
  SETUP:
  1. Upload your .glb file to Shopify Admin → Content → Files
  2. Copy the CDN URL and paste it in section settings
  3. Add this section to your homepage via Shopify theme editor

  NOTATIONS:
  - Each scroll panel block supports up to 2 annotation dots
  - On desktop: dot + animated SVG line + callout label
  - On mobile: dot only (tap to open drawer modal)
  - Line always connects dot to callout automatically

  PERFORMANCE:
  - Three.js loaded from CDN with defer
  - GLB loaded only when section enters viewport (IntersectionObserver)
  - requestAnimationFrame loop only runs when visible
  - Canvas resized with ResizeObserver + debounce
  - Will-change: transform only on active animation targets
  - Lazy image loading on mobile fallbacks
  - Prefers-reduced-motion respected throughout

  ADA / WCAG 2.2:
  - All interactive elements keyboard-accessible
  - ARIA roles, labels, live regions
  - Focus-visible styles on modals and CTAs
  - Motion disabled via prefers-reduced-motion
  - role="img" + aria-label on canvas

  SEO / STRUCTURED DATA:
  - Semantic heading hierarchy (h2 → h3)
  - Section aria-label
  - Schema.org compatible markup
  ============================================================
{% endcomment %}

{%- liquid
  assign section_id   = 'shoe3d-' | append: section.id
  assign model_url    = section.settings.model_url
  assign bg_color     = section.settings.background_color
  assign accent_color = section.settings.accent_color
  assign text_color   = section.settings.text_color
-%}

<section
  id="{{ section_id }}"
  class="shoe3d-section"
  aria-label="{{ section.settings.aria_label | default: '3D Product Showcase' }}"
  data-model="{{ model_url | escape }}"
  data-bg="{{ bg_color }}"
  data-section-id="{{ section.id }}"
  itemscope
  itemtype="https://schema.org/Product"
>

  {% comment %} ── Canvas — full-width sticky, behind all content ── {% endcomment %}
  <div class="shoe3d-canvas-wrap" aria-hidden="true">
    <canvas
      id="{{ section_id }}-canvas"
      class="shoe3d-canvas"
      role="img"
      aria-label="{{ section.settings.aria_label | default: '3D rotating shoe model' }}"
    ></canvas>
    <div class="shoe3d-vignette"></div>
    <div class="shoe3d-loader" id="{{ section_id }}-loader" aria-live="polite" aria-atomic="true">
      <div class="shoe3d-loader__ring" aria-hidden="true"></div>
      <span class="shoe3d-loader__text">Loading model…</span>
    </div>
  </div>

  {% comment %} ── Content locked to max-width, pulled up over canvas ── {% endcomment %}
  <div class="shoe3d-section__inner">

    {% comment %} ── Hero entry panel ── {% endcomment %}
    <div class="shoe3d-hero" aria-hidden="true">
      {%- if section.settings.hero_badge != blank -%}
        <div class="shoe3d-hero__badge">
          <span>{{ section.settings.hero_badge }}</span>
        </div>
      {%- endif -%}
      <h2 class="shoe3d-hero__headline" itemprop="name">
        {{ section.settings.hero_headline | default: 'The Jillian' }}
      </h2>
      <p class="shoe3d-hero__sub">
        {{ section.settings.hero_subtext | default: 'Scroll to explore' }}
      </p>
      <div class="shoe3d-hero__scroll-hint" aria-hidden="true">
        <span class="shoe3d-hero__scroll-line"></span>
        <span class="shoe3d-hero__scroll-label">Scroll</span>
      </div>
    </div>

    {% comment %} ── Scroll panels ── {% endcomment %}
    <div class="shoe3d-panels" id="{{ section_id }}-panels">

      {%- liquid
        assign jillian_eyebrows = "All-Day Comfort,Premium Materials,Signature Arch Support,Style Meets Function" | split: ","
        assign jillian_headings = "Feels Like Walking on Air,Genuine Leather. Built to Last.,Aligned From the Ground Up,Comfort You Can See." | split: ","
        assign jillian_bodies   = "Memory foam cushioning and an ultra-light cork midsole work together to reduce fatigue — so you can go further, longer.,Crafted from real leather uppers with a soft microfiber footbed treated with antimicrobial technology — fresh all day every day.,Aetrex Signature Arch Support is strategically placed to align your entire body — relieving pressure from your feet all the way to your back.,The signature braided detailing makes the Jillian the sandal you'll reach for every morning — whether running errands or spending a full day on your feet." | split: ","
      -%}

      {%- for block in section.blocks -%}
        {%- assign is_right      = forloop.index | modulo: 2 -%}
        {%- assign panel_side    = 'left' -%}
        {%- if is_right == 0 -%}{%- assign panel_side = 'right' -%}{%- endif -%}
        {%- assign idx = forloop.index0 -%}

        {%- if block.settings.eyebrow != blank -%}
          {%- assign eyebrow_text = block.settings.eyebrow -%}
        {%- else -%}
          {%- assign eyebrow_text = jillian_eyebrows[idx] -%}
        {%- endif -%}
        {%- if block.settings.heading != blank -%}
          {%- assign heading_text = block.settings.heading -%}
        {%- else -%}
          {%- assign heading_text = jillian_headings[idx] -%}
        {%- endif -%}
        {%- if block.settings.body != blank -%}
          {%- assign body_text = block.settings.body -%}
        {%- else -%}
          {%- assign body_text = jillian_bodies[idx] -%}
        {%- endif -%}

        {% comment %} Check if either notation slot is filled {% endcomment %}
        {%- assign has_notation_1 = false -%}
        {%- assign has_notation_2 = false -%}
        {%- if block.settings.notation_1_heading != blank or block.settings.notation_1_text != blank -%}
          {%- assign has_notation_1 = true -%}
        {%- endif -%}
        {%- if block.settings.notation_2_heading != blank or block.settings.notation_2_text != blank -%}
          {%- assign has_notation_2 = true -%}
        {%- endif -%}
        {%- assign has_notations = false -%}
        {%- if has_notation_1 or has_notation_2 -%}
          {%- assign has_notations = true -%}
        {%- endif -%}

        <div
          class="shoe3d-panel shoe3d-panel--{{ panel_side }}"
          data-panel-index="{{ forloop.index0 }}"
          data-shoe-rot-x="{{ block.settings.rot_x | default: 0 }}"
          data-shoe-rot-y="{{ block.settings.rot_y | default: 0 }}"
          data-shoe-rot-z="{{ block.settings.rot_z | default: 0 }}"
          data-shoe-pos-x="{{ block.settings.pos_x | default: 0 }}"
          data-shoe-pos-y="{{ block.settings.pos_y | default: 0 }}"
          data-shoe-light-intensity="{{ block.settings.light_intensity | default: 1.0 }}"
          data-shoe-light-x="{{ block.settings.light_x | default: 5 }}"
          data-shoe-light-y="{{ block.settings.light_y | default: 5 }}"
          data-shoe-light-z="{{ block.settings.light_z | default: 5 }}"
          {{ block.shopify_attributes }}
        >

          {%- comment %} ── Text content block ── {% endcomment %}
          <div class="shoe3d-panel__content shoe3d-panel__content--{{ panel_side }}">

            <span class="shoe3d-panel__eyebrow">{{ eyebrow_text }}</span>
            <h3 class="shoe3d-panel__heading">{{ heading_text }}</h3>
            <p class="shoe3d-panel__body">{{ body_text }}</p>

            {%- if block.settings.feature_1 != blank or block.settings.feature_2 != blank or block.settings.feature_3 != blank -%}
              <ul class="shoe3d-panel__features" aria-label="Features">
                {%- if block.settings.feature_1 != blank -%}
                  <li class="shoe3d-panel__feature">{{ block.settings.feature_1 }}</li>
                {%- endif -%}
                {%- if block.settings.feature_2 != blank -%}
                  <li class="shoe3d-panel__feature">{{ block.settings.feature_2 }}</li>
                {%- endif -%}
                {%- if block.settings.feature_3 != blank -%}
                  <li class="shoe3d-panel__feature">{{ block.settings.feature_3 }}</li>
                {%- endif -%}
              </ul>
            {%- endif -%}

            {%- if block.settings.cta_label != blank and block.settings.cta_url != blank -%}
              <a
                class="shoe3d-panel__cta"
                href="{{ block.settings.cta_url }}"
                {%- if block.settings.cta_new_tab %} target="_blank" rel="noopener noreferrer"{%- endif -%}
              >
                <span>{{ block.settings.cta_label }}</span>
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <path d="M3.75 9h10.5M9.75 4.5 14.25 9l-4.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            {%- endif -%}

          </div>

          {%- comment %} ── Mobile fallback image ── {% endcomment %}
          {%- if block.settings.image != blank -%}
            <div class="shoe3d-panel__image-wrap shoe3d-panel__image-wrap--{{ panel_side }}">
              {{
                block.settings.image
                | image_url: width: 600
                | image_tag:
                  loading: 'lazy',
                  class: 'shoe3d-panel__image',
                  widths: '300,400,600',
                  sizes: '(max-width:768px) 90vw, 400px'
              }}
            </div>
          {%- endif -%}

          {%- comment %} ── Notation overlay — sits on top of canvas area ── {% endcomment %}
          {%- if has_notations -%}
            <div
              class="shoe3d-notation-overlay"
              aria-hidden="true"
              data-panel-notation="{{ forloop.index0 }}"
            >

              {%- comment %} SVG lines container ── {% endcomment %}
              <svg
                class="shoe3d-notation__lines"
                viewBox="0 0 100 100"
                preserveAspectRatio="none"
                aria-hidden="true"
                focusable="false"
              >
                {%- if has_notation_1 -%}
                  <path
                    class="shoe3d-notation__line"
                    data-notation-index="0"
                    data-start-x="{{ block.settings.notation_1_dot_x }}"
                    data-start-y="{{ block.settings.notation_1_dot_y }}"
                    data-end-x="{{ block.settings.notation_1_text_x }}"
                    data-end-y="{{ block.settings.notation_1_text_y }}"
                    data-breaks="{{ block.settings.notation_1_line_breaks | default: 1 }}"
                  />
                {%- endif -%}
                {%- if has_notation_2 -%}
                  <path
                    class="shoe3d-notation__line"
                    data-notation-index="1"
                    data-start-x="{{ block.settings.notation_2_dot_x }}"
                    data-start-y="{{ block.settings.notation_2_dot_y }}"
                    data-end-x="{{ block.settings.notation_2_text_x }}"
                    data-end-y="{{ block.settings.notation_2_text_y }}"
                    data-breaks="{{ block.settings.notation_2_line_breaks | default: 1 }}"
                  />
                {%- endif -%}
              </svg>

              {%- comment %} Dots ── {% endcomment %}
              {%- if has_notation_1 -%}
                <button
                  class="shoe3d-notation__dot"
                  id="{{ section_id }}-panel{{ forloop.index0 }}-dot0"
                  style="left: {{ block.settings.notation_1_dot_x }}%; top: {{ block.settings.notation_1_dot_y }}%;"
                  aria-label="{{ block.settings.notation_1_heading | default: 'Feature detail' | escape }}"
                  aria-expanded="false"
                  aria-controls="{{ section_id }}-panel{{ forloop.index0 }}-modal0"
                  type="button"
                >
                  <span class="shoe3d-notation__dot-inner" aria-hidden="true"></span>
                </button>
              {%- endif -%}
              {%- if has_notation_2 -%}
                <button
                  class="shoe3d-notation__dot"
                  id="{{ section_id }}-panel{{ forloop.index0 }}-dot1"
                  style="left: {{ block.settings.notation_2_dot_x }}%; top: {{ block.settings.notation_2_dot_y }}%;"
                  aria-label="{{ block.settings.notation_2_heading | default: 'Feature detail' | escape }}"
                  aria-expanded="false"
                  aria-controls="{{ section_id }}-panel{{ forloop.index0 }}-modal1"
                  type="button"
                >
                  <span class="shoe3d-notation__dot-inner" aria-hidden="true"></span>
                </button>
              {%- endif -%}

              {%- comment %} Desktop callouts ── {% endcomment %}
              {%- if has_notation_1 -%}
                <div
                  class="shoe3d-notation__callout"
                  data-notation-callout="0"
                  style="left: {{ block.settings.notation_1_text_x }}%; top: {{ block.settings.notation_1_text_y }}%; animation-delay: 1.8s;"
                  aria-hidden="true"
                >
                  <div class="shoe3d-notation__callout-inner">
                    {%- if block.settings.notation_1_heading != blank -%}
                      <p class="shoe3d-notation__callout-title">{{ block.settings.notation_1_heading }}</p>
                    {%- endif -%}
                    {%- if block.settings.notation_1_text != blank -%}
                      <p class="shoe3d-notation__callout-text">{{ block.settings.notation_1_text }}</p>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
              {%- if has_notation_2 -%}
                <div
                  class="shoe3d-notation__callout"
                  data-notation-callout="1"
                  style="left: {{ block.settings.notation_2_text_x }}%; top: {{ block.settings.notation_2_text_y }}%; animation-delay: 2.2s;"
                  aria-hidden="true"
                >
                  <div class="shoe3d-notation__callout-inner">
                    {%- if block.settings.notation_2_heading != blank -%}
                      <p class="shoe3d-notation__callout-title">{{ block.settings.notation_2_heading }}</p>
                    {%- endif -%}
                    {%- if block.settings.notation_2_text != blank -%}
                      <p class="shoe3d-notation__callout-text">{{ block.settings.notation_2_text }}</p>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}

              {%- comment %} Mobile modals (drawer) ── {% endcomment %}
              {%- if has_notation_1 -%}
                <div
                  class="shoe3d-notation__modal"
                  id="{{ section_id }}-panel{{ forloop.index0 }}-modal0"
                  role="dialog"
                  aria-modal="true"
                  aria-label="{{ block.settings.notation_1_heading | default: 'Feature detail' | escape }}"
                  aria-hidden="true"
                  hidden
                >
                  <div class="shoe3d-notation__modal-overlay" data-modal-close></div>
                  <div class="shoe3d-notation__modal-inner" role="document">
                    <button
                      class="shoe3d-notation__modal-close"
                      type="button"
                      aria-label="Close"
                      data-modal-close
                    >
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <path d="M2 2l12 12M14 2L2 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                    </button>
                    {%- if block.settings.notation_1_heading != blank -%}
                      <p class="shoe3d-notation__modal-title">{{ block.settings.notation_1_heading }}</p>
                    {%- endif -%}
                    {%- if block.settings.notation_1_text != blank -%}
                      <p class="shoe3d-notation__modal-text">{{ block.settings.notation_1_text }}</p>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
              {%- if has_notation_2 -%}
                <div
                  class="shoe3d-notation__modal"
                  id="{{ section_id }}-panel{{ forloop.index0 }}-modal1"
                  role="dialog"
                  aria-modal="true"
                  aria-label="{{ block.settings.notation_2_heading | default: 'Feature detail' | escape }}"
                  aria-hidden="true"
                  hidden
                >
                  <div class="shoe3d-notation__modal-overlay" data-modal-close></div>
                  <div class="shoe3d-notation__modal-inner" role="document">
                    <button
                      class="shoe3d-notation__modal-close"
                      type="button"
                      aria-label="Close"
                      data-modal-close
                    >
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <path d="M2 2l12 12M14 2L2 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                    </button>
                    {%- if block.settings.notation_2_heading != blank -%}
                      <p class="shoe3d-notation__modal-title">{{ block.settings.notation_2_heading }}</p>
                    {%- endif -%}
                    {%- if block.settings.notation_2_text != blank -%}
                      <p class="shoe3d-notation__modal-text">{{ block.settings.notation_2_text }}</p>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}

            </div>
          {%- endif -%}

        </div>
      {%- endfor -%}

      <div class="shoe3d-end-spacer" aria-hidden="true"></div>

    </div>{%- comment %} /.shoe3d-panels ── {% endcomment %}

  </div>{%- comment %} /.shoe3d-section__inner ── {% endcomment %}

</section>

{%- comment %} ════════════════════════════════════════════
  STYLES
════════════════════════════════════════════ {% endcomment %}
<style>
/* ── CSS custom properties ── */
#{{ section_id }} {
  --bg: {{ bg_color }};
  --text: {{ text_color }};
  --accent: {{ accent_color }};
  --panel-h: 70vh;
  --content-w: min(400px, 42vw);
  --ease-spring: cubic-bezier(0.22, 1, 0.36, 1);
  --max-w: 1520px;
  /* Notation variables — sourced from section settings */
  --notation-dot-size: {{ section.settings.notation_dot_size | default: 20 }}px;
  --notation-dot-size-mobile: {{ section.settings.notation_dot_size_mobile | default: 16 }}px;
  --notation-dot-color: {{ section.settings.notation_dot_color | default: '#ffffff' }};
  --notation-dot-border: {{ section.settings.notation_dot_border_color | default: '#000000' }};
  --notation-dot-border-w: {{ section.settings.notation_dot_border_width | default: 2 }}px;
  --notation-line-color: {{ section.settings.notation_line_color | default: '#ffffff' }};
  --notation-line-width: {{ section.settings.notation_line_width | default: 0.8 }};
  --notation-callout-title-color: {{ section.settings.notation_callout_title_color | default: '#000000' }};
  --notation-callout-text-color: {{ section.settings.notation_callout_text_color | default: '#666666' }};
}

/* ── Section wrapper ── */
.shoe3d-section {
  position: relative;
  background: var(--bg);
  color: var(--text);
  contain: layout style;
}

/* ── Inner content — locked to max-width, pulled over canvas ── */
.shoe3d-section__inner {
  max-width: var(--max-w);
  margin: 0 auto;
  position: relative;
  margin-top: -100vh;
  padding-top: 0;
}

/* ── Sticky canvas ── */
.shoe3d-canvas-wrap {
  position: sticky;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  z-index: 1;
  pointer-events: none;
}
.shoe3d-canvas {
  display: block;
  width: 100%;
  height: 100%;
  will-change: contents;
}
.shoe3d-vignette {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 55% 55% at 50% 50%, transparent 30%, var(--bg) 100%),
    linear-gradient(to bottom, var(--bg) 0%, transparent 15%, transparent 85%, var(--bg) 100%);
  pointer-events: none;
}

/* ── Loader ── */
.shoe3d-loader {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  transition: opacity .4s ease, visibility .4s ease;
}
.shoe3d-loader.is-hidden {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}
.shoe3d-loader__ring {
  width: 36px;
  height: 36px;
  border: 2px solid rgba(255,255,255,.15);
  border-top-color: rgba(255,255,255,.7);
  border-radius: 50%;
  animation: shoe3d-spin .8s linear infinite;
}
.shoe3d-loader__text {
  font-size: .7rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: rgba(255,255,255,.4);
}

/* ── Hero ── */
.shoe3d-hero {
  position: relative;
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 2rem;
  text-align: center;
  pointer-events: none;
}
.shoe3d-hero__badge {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  border: 1px solid rgba(255,255,255,.25);
  border-radius: 50px;
  padding: .35em 1.1em;
  font-size: .7rem;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: rgba(255,255,255,.75);
  margin-bottom: 1.5rem;
}
.shoe3d-hero__headline {
  font-family: var(--font-heading-family, 'Georgia', serif);
  font-size: clamp(2.5rem, 8vw, 7rem);
  font-weight: 300;
  letter-spacing: -.04em;
  line-height: .95;
  color: var(--text);
  margin: 0 0 1rem;
}
.shoe3d-hero__sub {
  font-size: clamp(.85rem, 1.3vw, 1.1rem);
  color: rgba(255,255,255,.5);
  letter-spacing: .06em;
  text-transform: uppercase;
  margin: 0 0 3rem;
}
.shoe3d-hero__scroll-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .6rem;
  animation: shoe3d-bounce 2s ease-in-out infinite;
}
.shoe3d-hero__scroll-line {
  display: block;
  width: 1px;
  height: 48px;
  background: linear-gradient(to bottom, transparent, rgba(255,255,255,.6));
}
.shoe3d-hero__scroll-label {
  font-size: .65rem;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: rgba(255,255,255,.4);
}

/* ── Scroll panels ── */
.shoe3d-panels {
  position: relative;
  z-index: 2;
}
.shoe3d-panel {
  min-height: var(--panel-h);
  display: flex;
  align-items: center;
  padding: 2rem 5vw;
  pointer-events: none;
  position: relative;
}
.shoe3d-panel--left  { justify-content: flex-end; }
.shoe3d-panel--right { justify-content: flex-start; }

/* ── Panel text content ── */
.shoe3d-panel__content {
  pointer-events: all;
  width: var(--content-w);
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  opacity: 0;
  transform: translateY(40px);
  transition:
    opacity .7s var(--ease-spring),
    transform .7s var(--ease-spring);
  position: relative;
  z-index: 4;
}
.shoe3d-panel__content.is-visible {
  opacity: 1;
  transform: translateY(0);
}
.shoe3d-panel__eyebrow {
  display: inline-block;
  font-size: .65rem;
  font-weight: 600;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--accent);
  border: 1px solid var(--accent);
  border-radius: 50px;
  padding: .3em .9em;
  width: fit-content;
}
.shoe3d-panel__heading {
  font-family: var(--font-heading-family, 'Georgia', serif);
  font-size: clamp(1.6rem, 3.5vw, 3rem);
  font-weight: 300;
  letter-spacing: -.04em;
  line-height: 1.05;
  color: var(--text);
  margin: 0;
}
.shoe3d-panel__body {
  font-size: clamp(.85rem, 1.1vw, 1rem);
  line-height: 1.75;
  color: rgba(255,255,255,.6);
  margin: 0;
  max-width: 38ch;
}
.shoe3d-panel__features {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: .5rem;
}
.shoe3d-panel__feature {
  font-size: .85rem;
  color: rgba(255,255,255,.7);
  padding-left: 1.2em;
  position: relative;
  letter-spacing: .02em;
}
.shoe3d-panel__feature::before {
  content: '';
  position: absolute;
  left: 0;
  top: .5em;
  width: 5px;
  height: 5px;
  background: var(--accent);
  border-radius: 50%;
}
.shoe3d-panel__cta {
