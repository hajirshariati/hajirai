      if (idx >= 0 && panelEls[idx]) {
        var pose = getPanelPose(panelEls[idx]);
        tgt.rotX = pose.rotX;
        tgt.rotY = pose.rotY;
        tgt.rotZ = pose.rotZ;
        tgt.posX = pose.posX;
        tgt.posY = pose.posY;
        tgt.lX   = pose.lightX;
        tgt.lY   = pose.lightY;
        tgt.lZ   = pose.lightZ;
        tgt.lI   = pose.lightIntensity;
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });

    /* ── Render loop ── */
    function startLoop() {
      function frame() {
        raf = requestAnimationFrame(frame);
        if (!shoe) return;

        var speed = prefersReduced ? 1 : LERP_SPEED;

        if (activePanelIndex === -1) {
          tgt.posX = 0;
          tgt.posY = prefersReduced ? 0 : Math.sin(idleAngle * 0.5) * 0.1;
          tgt.lX = 5; tgt.lY = 5; tgt.lZ = 5; tgt.lI = 1.0;
          if (!prefersReduced) idleAngle += 0.004;
          tgt.rotX = 0;
          tgt.rotY = prefersReduced ? 0.3 : idleAngle;
          tgt.rotZ = 0.15;
        }

        cur.rotX = lerp(cur.rotX, tgt.rotX, speed);
        cur.rotY = lerp(cur.rotY, tgt.rotY, speed);
        cur.rotZ = lerp(cur.rotZ, tgt.rotZ, speed);
        cur.posX = lerp(cur.posX, tgt.posX, speed);
        cur.posY = lerp(cur.posY, tgt.posY, speed);
        cur.lX   = lerp(cur.lX,   tgt.lX,   speed);
        cur.lY   = lerp(cur.lY,   tgt.lY,   speed);
        cur.lZ   = lerp(cur.lZ,   tgt.lZ,   speed);
        cur.lI   = lerp(cur.lI,   tgt.lI,   speed);

        var worldOffsetX = -cur.posX * (camera.aspect * 1.6);
        shoe.rotation.set(cur.rotX, cur.rotY, cur.rotZ);
        shoe.position.set(worldOffsetX, cur.posY, 0);
        keyLight.position.set(cur.lX, cur.lY, cur.lZ);
        keyLight.intensity = cur.lI;

        renderer.render(scene, camera);
      }
      frame();
    }

    /* ── Load GLB ── */
    var dracoLoader = new DRACOLoader();
    dracoLoader.setDecoderPath('https://www.gstatic.com/draco/versioned/decoders/1.4.1/');
    var gltfLoader = new GLTFLoader();
    gltfLoader.setDRACOLoader(dracoLoader);

    function doLoad() {
      gltfLoader.load(MODEL_URL, onModelLoad, onModelProgress, onModelError);
    }

    if (typeof MeshoptDecoder !== 'undefined' && MeshoptDecoder && gltfLoader.setMeshoptDecoder) {
      var meshoptReady = (MeshoptDecoder.ready instanceof Promise) ? MeshoptDecoder.ready : Promise.resolve();
      meshoptReady.then(function () {
        gltfLoader.setMeshoptDecoder(MeshoptDecoder);
        doLoad();
      });
    } else {
      doLoad();
    }

    function onModelLoad(gltf) {
      shoe = gltf.scene;

      var box    = new THREE.Box3().setFromObject(shoe);
      var size   = new THREE.Vector3();
      var center = new THREE.Vector3();
      box.getSize(size);
      box.getCenter(center);
      shoe.position.sub(center);

      var maxDim = Math.max(size.x, size.y, size.z);
      shoe.scale.setScalar(3.6 / maxDim);

      shoe.traverse(function (child) {
        if (child.isMesh) {
          child.castShadow    = true;
          child.receiveShadow = true;
          if (child.material) child.material.envMapIntensity = 0.6;
        }
      });

      cur.rotX    = 0;
      cur.rotY    = 0.3;
      cur.rotZ    = 0.15;
      idleAngle   = 0.3;

      if (panelEls[0]) {
        var firstPose = getPanelPose(panelEls[0]);
        cur.posX = firstPose.posX; tgt.posX = firstPose.posX;
        cur.posY = firstPose.posY; tgt.posY = firstPose.posY;
        tgt.lX = firstPose.lightX;
        tgt.lY = firstPose.lightY;
        tgt.lZ = firstPose.lightZ;
        tgt.lI = firstPose.lightIntensity;
      }

      scene.add(shoe);
      if (loader) loader.classList.add('is-hidden');
      onScroll();
    }

    function onModelProgress(xhr) {
      if (loader && xhr.total) {
        var pct = Math.round((xhr.loaded / xhr.total) * 100);
        var txt = loader.querySelector('.shoe3d-loader__text');
        if (txt) txt.textContent = 'Loading\u2026 ' + pct + '%';
      }
    }

    function onModelError(err) {
      console.error('[Shoe3D] Failed to load model:', err);
      if (loader) {
        var txt  = loader.querySelector('.shoe3d-loader__text');
        var ring = loader.querySelector('.shoe3d-loader__ring');
        if (txt)  txt.textContent = 'Could not load 3D model.';
        if (ring) ring.parentNode.removeChild(ring);
      }
    }

    /* ── BFCache / visibility cleanup ── */
    document.addEventListener('visibilitychange', function () {
      if (document.hidden && raf) {
        cancelAnimationFrame(raf);
        raf = null;
      } else if (!document.hidden && isVisible && !raf) {
        startLoop();
      }
    });
  } // end initShoe3D

})(); // end IIFE
</script>

