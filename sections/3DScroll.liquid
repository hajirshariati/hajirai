{% comment %}
  ============================================================
  3D Shoe Scroll Section — Syntilay-Style
  ============================================================
  SETUP:
  1. Upload your .glb file to Shopify Admin → Content → Files
  2. Copy the CDN URL and paste it in section settings
  3. Add this section to your homepage via Shopify theme editor
  
  PERFORMANCE:
  - Three.js loaded from CDN with defer
  - GLB loaded only when section enters viewport (IntersectionObserver)
  - requestAnimationFrame loop only runs when visible
  - Textures/materials compressed via GLB export settings
  - Canvas resized with ResizeObserver + debounce
  - Will-change: transform only on active animation targets
  ============================================================
{% endcomment %}

{%- liquid
  assign section_id = 'shoe3d-' | append: section.id
  assign model_url = section.settings.model_url
  assign bg_color = section.settings.background_color
  assign accent_color = section.settings.accent_color
  assign text_color = section.settings.text_color
-%}

<section
  id="{{ section_id }}"
  class="shoe3d-section"
  aria-label="{{ section.settings.aria_label | default: '3D Product Showcase' }}"
  data-model="{{ model_url | escape }}"
  data-bg="{{ bg_color }}"
>

  {%- comment %} Canvas is full-width/full-height sticky — no max-width ── {% endcomment %}
  <div class="shoe3d-canvas-wrap" aria-hidden="true">
    <canvas
      id="{{ section_id }}-canvas"
      class="shoe3d-canvas"
      role="img"
      aria-label="3D rotating shoe model"
    ></canvas>
    <div class="shoe3d-vignette"></div>
    <div class="shoe3d-loader" id="{{ section_id }}-loader" aria-live="polite">
      <div class="shoe3d-loader__ring"></div>
      <span class="shoe3d-loader__text">Loading model…</span>
    </div>
  </div>

  {%- comment %} Content locked to 1920px max-width ── {% endcomment %}
  <div class="shoe3d-section__inner">

    {%- comment %} ── Hero entry panel ── {% endcomment %}
    <div class="shoe3d-hero" aria-hidden="true">
      <div class="shoe3d-hero__badge">
        <span>{{ section.settings.hero_badge | default: 'Best Seller' }}</span>
      </div>
      <h2 class="shoe3d-hero__headline">{{ section.settings.hero_headline | default: 'The Jillian' }}</h2>
      <p class="shoe3d-hero__sub">{{ section.settings.hero_subtext | default: 'Scroll to explore' }}</p>
      <div class="shoe3d-hero__scroll-hint">
        <span class="shoe3d-hero__scroll-line"></span>
        <span class="shoe3d-hero__scroll-label">Scroll</span>
      </div>
    </div>

    {%- comment %} ── Scroll panels — each drives a shoe pose ── {% endcomment %}
    <div class="shoe3d-panels" id="{{ section_id }}-panels">

    {%- liquid
      assign jillian_eyebrows = "All-Day Comfort,Premium Materials,Signature Arch Support,Style Meets Function" | split: ","
      assign jillian_headings = "Feels Like Walking on Air,Genuine Leather. Built to Last.,Aligned From the Ground Up,Comfort You Can See." | split: ","
      assign jillian_bodies   = "Memory foam cushioning and an ultra-light cork midsole work together to reduce fatigue — so you can go further, longer.,Crafted from real leather uppers with a soft microfiber footbed treated with antimicrobial technology — fresh all day every day.,Aetrex Signature Arch Support is strategically placed to align your entire body — relieving pressure from your feet all the way to your back.,The signature braided detailing makes the Jillian the sandal you'll reach for every morning — whether running errands or spending a full day on your feet." | split: ","
    -%}

    {%- for block in section.blocks -%}
      {%- assign is_right = forloop.index | modulo: 2 -%}
      {%- assign panel_side = 'left' -%}
      {%- if is_right == 0 -%}{%- assign panel_side = 'right' -%}{%- endif -%}
      {%- assign idx = forloop.index0 -%}

      {%- comment %} Use block setting if set, else fall back to Jillian defaults -%}
      {%- assign eyebrow_text = block.settings.eyebrow | default: jillian_eyebrows[idx] -%}
      {%- assign heading_text = block.settings.heading | default: jillian_headings[idx] -%}
      {%- assign body_text    = block.settings.body    | default: jillian_bodies[idx] -%}
      {%- endcomment -%}

      {%- if block.settings.eyebrow != blank -%}
        {%- assign eyebrow_text = block.settings.eyebrow -%}
      {%- else -%}
        {%- assign eyebrow_text = jillian_eyebrows[idx] -%}
      {%- endif -%}
      {%- if block.settings.heading != blank -%}
        {%- assign heading_text = block.settings.heading -%}
      {%- else -%}
        {%- assign heading_text = jillian_headings[idx] -%}
      {%- endif -%}
      {%- if block.settings.body != blank -%}
        {%- assign body_text = block.settings.body -%}
      {%- else -%}
        {%- assign body_text = jillian_bodies[idx] -%}
      {%- endif -%}

      <div
        class="shoe3d-panel shoe3d-panel--{{ panel_side }}"
        data-panel-index="{{ forloop.index0 }}"
        data-shoe-rot-x="{{ block.settings.rot_x | default: 0 }}"
        data-shoe-rot-y="{{ block.settings.rot_y | default: 0 }}"
        data-shoe-rot-z="{{ block.settings.rot_z | default: 0 }}"
        data-shoe-pos-x="{{ block.settings.pos_x | default: 0 }}"
        data-shoe-pos-y="{{ block.settings.pos_y | default: 0 }}"
        data-shoe-light-intensity="{{ block.settings.light_intensity | default: 1.0 }}"
        data-shoe-light-x="{{ block.settings.light_x | default: 5 }}"
        data-shoe-light-y="{{ block.settings.light_y | default: 5 }}"
        data-shoe-light-z="{{ block.settings.light_z | default: 5 }}"
        {{ block.shopify_attributes }}
      >
        <div class="shoe3d-panel__content shoe3d-panel__content--{{ panel_side }}">

          <span class="shoe3d-panel__eyebrow">{{ eyebrow_text }}</span>
          <h3 class="shoe3d-panel__heading">{{ heading_text }}</h3>
          <p class="shoe3d-panel__body">{{ body_text }}</p>

          {%- if block.settings.feature_1 != blank or block.settings.feature_2 != blank or block.settings.feature_3 != blank -%}
            <ul class="shoe3d-panel__features" aria-label="Features">
              {%- if block.settings.feature_1 != blank -%}
                <li class="shoe3d-panel__feature">{{ block.settings.feature_1 }}</li>
              {%- endif -%}
              {%- if block.settings.feature_2 != blank -%}
                <li class="shoe3d-panel__feature">{{ block.settings.feature_2 }}</li>
              {%- endif -%}
              {%- if block.settings.feature_3 != blank -%}
                <li class="shoe3d-panel__feature">{{ block.settings.feature_3 }}</li>
              {%- endif -%}
            </ul>
          {%- endif -%}

          {%- if block.settings.cta_label != blank and block.settings.cta_url != blank -%}
            <a
              class="shoe3d-panel__cta"
              href="{{ block.settings.cta_url }}"
              {%- if block.settings.cta_new_tab %} target="_blank" rel="noopener noreferrer"{%- endif -%}
            >
              <span>{{ block.settings.cta_label }}</span>
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                <path d="M3.75 9h10.5M9.75 4.5 14.25 9l-4.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          {%- endif -%}

        </div>

        {%- if block.settings.image != blank -%}
          <div class="shoe3d-panel__image-wrap shoe3d-panel__image-wrap--{{ panel_side }}">
            {{
              block.settings.image
              | image_url: width: 600
              | image_tag:
                loading: 'lazy',
                class: 'shoe3d-panel__image',
                widths: '300,400,600',
                sizes: '(max-width:768px) 90vw, 400px'
            }}
          </div>
        {%- endif -%}

      </div>
    {%- endfor -%}

    {%- comment %} Final spacer so last panel fully exits ── {% endcomment %}
    <div class="shoe3d-end-spacer" aria-hidden="true"></div>

  </div>{%- comment %} /.shoe3d-panels ── {% endcomment %}

  </div>{%- comment %} /.shoe3d-section__inner ── {% endcomment %}

</section>

{%- comment %} ════════════════════════════════════════════
  STYLES
════════════════════════════════════════════ {% endcomment %}
<style>
/* ── CSS custom properties ── */
#{{ section_id }} {
  --bg: {{ bg_color }};
  --text: {{ text_color }};
  --accent: {{ accent_color }};
  --panel-h: 70vh;
  --content-w: min(400px, 42vw);
  --ease-spring: cubic-bezier(0.22, 1, 0.36, 1);
  --max-w: 1520px;
}

/* ── Section wrapper ── */
.shoe3d-section {
  position: relative;
  background: var(--bg);
  color: var(--text);
  contain: layout style;
}

/* Inner content locked to 1920px, centered, background bleeds full width */
.shoe3d-section__inner {
  max-width: var(--max-w);
  margin: 0 auto;
  position: relative;
  /* Hero overlaps canvas, panels overlap canvas — same as before but now constrained */
}

/* Canvas is full-width, sits behind everything */
.shoe3d-canvas-wrap {
  position: sticky;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  z-index: 1;
  pointer-events: none;
}

/* The inner wrapper needs to pull up to overlap the canvas */
.shoe3d-section__inner {
  margin-top: -100vh; /* pull up over canvas */
  padding-top: 0;
}

/* ── Hero ── */
.shoe3d-hero {
  position: relative;
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 2rem;
  text-align: center;
  pointer-events: none;
}
.shoe3d-hero__badge {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  border: 1px solid rgba(255,255,255,.25);
  border-radius: 50px;
  padding: .35em 1.1em;
  font-size: .7rem;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: rgba(255,255,255,.75);
  margin-bottom: 1.5rem;
}
.shoe3d-hero__badge:empty { display: none; }
.shoe3d-hero__headline {
  font-family: var(--font-heading-family, 'Georgia', serif);
  font-size: clamp(2.5rem, 8vw, 7rem);
  font-weight: 300;
  letter-spacing: -.04em;
  line-height: .95;
  color: var(--text);
  margin-bottom: 1rem;
}
.shoe3d-hero__sub {
  font-size: clamp(.85rem, 1.3vw, 1.1rem);
  color: rgba(255,255,255,.5);
  letter-spacing: .06em;
  text-transform: uppercase;
  margin-bottom: 3rem;
}
.shoe3d-hero__scroll-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .6rem;
  animation: shoe3d-bounce 2s ease-in-out infinite;
}
.shoe3d-hero__scroll-line {
  display: block;
  width: 1px;
  height: 48px;
  background: linear-gradient(to bottom, transparent, rgba(255,255,255,.6));
}
.shoe3d-hero__scroll-label {
  font-size: .65rem;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: rgba(255,255,255,.4);
}

/* ── Sticky canvas — full width, sits behind content ── */
.shoe3d-canvas-wrap {
  position: sticky;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  z-index: 1;
  pointer-events: none;
}
.shoe3d-canvas {
  display: block;
  width: 100%;
  height: 100%;
  /* GPU compositing hint — only on canvas, not the whole page */
  will-change: contents;
}
.shoe3d-vignette {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 55% 55% at 50% 50%, transparent 30%, var(--bg) 100%),
    linear-gradient(to bottom, var(--bg) 0%, transparent 15%, transparent 85%, var(--bg) 100%);
  pointer-events: none;
}

/* ── Loader ── */
.shoe3d-loader {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  transition: opacity .4s ease, visibility .4s ease;
}
.shoe3d-loader.is-hidden {
  opacity: 0;
  visibility: hidden;
}
.shoe3d-loader__ring {
  width: 36px;
  height: 36px;
  border: 2px solid rgba(255,255,255,.15);
  border-top-color: rgba(255,255,255,.7);
  border-radius: 50%;
  animation: shoe3d-spin .8s linear infinite;
}
.shoe3d-loader__text {
  font-size: .7rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: rgba(255,255,255,.4);
}

/* ── Scroll panels ── */
.shoe3d-panels {
  position: relative;
  z-index: 2;
}
.shoe3d-panel {
  min-height: var(--panel-h);
  display: flex;
  align-items: center;
  padding: 2rem 5vw;
  pointer-events: none;
}
.shoe3d-panel--left  { justify-content: flex-end; }
.shoe3d-panel--right { justify-content: flex-start; }

.shoe3d-panel__content {
  pointer-events: all;
  width: var(--content-w);
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  opacity: 0;
  transform: translateY(40px);
  transition:
    opacity .7s var(--ease-spring),
    transform .7s var(--ease-spring);
}
.shoe3d-panel__content.is-visible {
  opacity: 1;
  transform: translateY(0);
}

/* Eyebrow */
.shoe3d-panel__eyebrow {
  display: inline-block;
  font-size: .65rem;
  font-weight: 600;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--accent);
  border: 1px solid var(--accent);
  border-radius: 50px;
  padding: .3em .9em;
  width: fit-content;
}

/* Heading */
.shoe3d-panel__heading {
  font-family: var(--font-heading-family, 'Georgia', serif);
  font-size: clamp(1.6rem, 3.5vw, 3rem);
  font-weight: 300;
  letter-spacing: -.04em;
  line-height: 1.05;
  color: var(--text);
  margin: 0;
}

/* Body */
.shoe3d-panel__body {
  font-size: clamp(.85rem, 1.1vw, 1rem);
  line-height: 1.75;
  color: rgba(255,255,255,.6);
  margin: 0;
  max-width: 38ch;
}

/* Features list */
.shoe3d-panel__features {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: .5rem;
}
.shoe3d-panel__feature {
  font-size: .85rem;
  color: rgba(255,255,255,.7);
  padding-left: 1.2em;
  position: relative;
  letter-spacing: .02em;
}
.shoe3d-panel__feature::before {
  content: '';
  position: absolute;
  left: 0;
  top: .5em;
  width: 5px;
  height: 5px;
  background: var(--accent);
  border-radius: 50%;
}

/* CTA */
.shoe3d-panel__cta {
  display: inline-flex;
  align-items: center;
  gap: .6rem;
  font-size: .75rem;
  font-weight: 600;
  letter-spacing: .08em;
  text-transform: uppercase;
  text-decoration: none;
  color: var(--bg);
  background: var(--text);
  padding: .8em 1.7em;
  border-radius: 50px;
  width: fit-content;
  transition: background .2s ease, color .2s ease, transform .2s ease;
}
.shoe3d-panel__cta:hover {
  background: var(--accent);
  color: var(--bg);
  transform: translateX(4px);
}
.shoe3d-panel__cta svg { flex-shrink: 0; transition: transform .2s ease; }
.shoe3d-panel__cta:hover svg { transform: translateX(4px); }

/* Image */
.shoe3d-panel__image-wrap {
  display: none; /* hidden on desktop, shown on mobile below canvas */
}
@media (max-width: 767px) {
  .shoe3d-panel__image-wrap {
    display: block;
    border-radius: 16px;
    overflow: hidden;
    width: 100%;
    max-width: 280px;
    aspect-ratio: 1;
    margin-top: 1rem;
    box-shadow: 0 20px 50px rgba(0,0,0,.5);
  }
  .shoe3d-panel__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
}

/* End spacer */
.shoe3d-end-spacer { height: 20vh; }

/* ── Mobile: stack layout ── */
@media (max-width: 767px) {
  .shoe3d-panel {
    flex-direction: column;
    align-items: flex-start;
    padding: 3rem 1.5rem;
    justify-content: flex-start;
    min-height: auto;
    padding-top: 20vh; /* leave room for canvas above */
  }
  .shoe3d-panel--left,
  .shoe3d-panel--right {
    justify-content: flex-start;
  }
  .shoe3d-panel__content {
    width: 100%;
  }
  .shoe3d-hero__headline {
    font-size: clamp(2rem, 10vw, 4rem);
  }
}

/* ── Keyframes ── */
@keyframes shoe3d-spin {
  to { transform: rotate(360deg); }
}
@keyframes shoe3d-bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(8px); }
}

/* ── Reduced motion ── */
@media (prefers-reduced-motion: reduce) {
  .shoe3d-hero__scroll-hint { animation: none; }
  .shoe3d-loader__ring { animation: none; }
  .shoe3d-panel__content {
    opacity: 1;
    transform: none;
    transition: none;
  }
}
</style>

{%- comment %} ════════════════════════════════════════════
  JAVASCRIPT — loaded defer, Three.js from CDN
════════════════════════════════════════════ {% endcomment %}

{%- comment %}
  We load Three.js core + GLTFLoader + DRACOLoader from cdnjs.
  These are pinned versions for predictable caching.
{% endcomment %}

<script>
/* ──────────────────────────────────────────────────────────
   3D Shoe Scroll Controller — UMD globals approach
   Loads Three.js as plain <script> tags, zero module system
────────────────────────────────────────────────────────── */
(function() {

  function loadScript(src, cb) {
    var s = document.createElement('script');
    s.src = src;
    s.async = false;
    s.onload = cb;
    s.onerror = function() { console.error('[Shoe3D] Script load failed:', src); };
    document.head.appendChild(s);
  }

  // Step 1: Three.js core UMD r128 → window.THREE
  loadScript('https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js', function() {

    // Step 2: GLTFLoader
    loadScript('https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/GLTFLoader.js', function() {

      // Step 3: DRACOLoader
      loadScript('https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/DRACOLoader.js', function() {

        // Step 4: MeshoptDecoder — required for Meshopt-compressed GLBs (exported from gltf.report)
        loadScript('https://cdn.jsdelivr.net/npm/meshoptimizer@0.18.1/meshopt_decoder.js', function() {

          var T   = window.THREE;
          var GL  = T && T.GLTFLoader;
          var DL  = T && T.DRACOLoader;
          var MOD = window.MeshoptDecoder;

          if (!T || !GL || !DL) {
            console.error('[Shoe3D] THREE libs not ready', { T: !!T, GL: !!GL, DL: !!DL });
            return;
          }

          // Register MeshoptDecoder globally on GLTFLoader if available
          if (MOD && GL.setMeshoptDecoder) {
            GL.setMeshoptDecoder(MOD);
          }

          initShoe3D(T, GL, DL, MOD);
        });
      });
    });
  });

function initShoe3D(THREE, GLTFLoader, DRACOLoader, MeshoptDecoder) {
  const SECTION_ID = '{{ section_id }}';
  const section    = document.getElementById(SECTION_ID);
  if (!section) return;

  const MODEL_URL  = section.dataset.model;
  if (!MODEL_URL)  { console.warn('[Shoe3D] No model URL set in section settings.'); return; }

  const canvas   = document.getElementById(SECTION_ID + '-canvas');
  const loader   = document.getElementById(SECTION_ID + '-loader');
  const panels   = document.getElementById(SECTION_ID + '-panels');
  const panelEls = [...section.querySelectorAll('.shoe3d-panel')];
  const contentEls = [...section.querySelectorAll('.shoe3d-panel__content')];

  // ── Lerp helper ──────────────────────────────────────────
  const lerp = (a, b, t) => a + (b - a) * t;
  const LERP_SPEED = 0.08; // lower = smoother/slower chase

  // ── Panel poses ─────────────────────────────────────────
  // Read from data attributes set by Shopify section schema
  function getPanelPose(el) {
    return {
      rotX:  parseFloat(el.dataset.shoeRotX  || 0) * (Math.PI / 180),
      rotY:  parseFloat(el.dataset.shoeRotY  || 0) * (Math.PI / 180),
      rotZ:  parseFloat(el.dataset.shoeRotZ  || 0) * (Math.PI / 180),
      posX:  parseFloat(el.dataset.shoePosX  || 0) / 10,   // schema: −10..10 → world: −1..1
      posY:  parseFloat(el.dataset.shoePosY  || 0) / 10,
      lightIntensity: parseFloat(el.dataset.shoeLightIntensity || 10) / 10, // schema: 0..30 → 0..3
      lightX: parseFloat(el.dataset.shoeLightX || 5),
      lightY: parseFloat(el.dataset.shoeLightY || 5),
      lightZ: parseFloat(el.dataset.shoeLightZ || 5),
    };
  }

  // ── State ────────────────────────────────────────────────
  let shoe = null;   // THREE.Group
  let raf  = null;
  let isVisible = false;
  let W = 0, H = 0;

  // Current animated values (lerped each frame)
  const cur = { rotX: 0, rotY: 0, rotZ: 0.2, posX: 0, posY: 0, lX: 5, lY: 5, lZ: 5, lI: 1.0 };
  // Target values (set from active panel)
  const tgt = { ...cur };

  // ── Scene setup ──────────────────────────────────────────
  const renderer = new THREE.WebGLRenderer({
    canvas,
    antialias: true,
    alpha: true,         // transparent background
    powerPreference: 'high-performance',
  });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2)); // cap at 2x
  renderer.outputEncoding = THREE.sRGBEncoding;
  renderer.shadowMap.enabled = true;
  renderer.shadowMap.type    = THREE.PCFSoftShadowMap;
  renderer.toneMapping       = THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure = 1.2;

  const scene  = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
  camera.position.set(0, 0, 5);

  // ── Lighting ─────────────────────────────────────────────
  // Ambient — soft fill
  const ambientLight = new THREE.AmbientLight(0xffffff, 0.4);
  scene.add(ambientLight);

  // Key light (moves with scroll pose)
  const keyLight = new THREE.DirectionalLight(0xffffff, 1.0);
  keyLight.position.set(5, 5, 5);
  keyLight.castShadow = true;
  keyLight.shadow.mapSize.set(1024, 1024);
  keyLight.shadow.camera.near = 0.1;
  keyLight.shadow.camera.far  = 20;
  scene.add(keyLight);

  // Rim light — always opposite key
  const rimLight = new THREE.DirectionalLight(0x8899ff, 0.3);
  rimLight.position.set(-5, 2, -5);
  scene.add(rimLight);

  // Ground bounce
  const bounceLight = new THREE.HemisphereLight(0xffffff, 0x333333, 0.2);
  scene.add(bounceLight);

  // ── Resize ───────────────────────────────────────────────
  function onResize() {
    W = canvas.clientWidth  || section.clientWidth  || window.innerWidth;
    H = canvas.clientHeight || window.innerHeight;
    renderer.setSize(W, H, false); // false = don't set style (CSS handles it)
    camera.aspect = W / H;
    camera.updateProjectionMatrix();
  }

  // Debounced resize
  let resizeTimer;
  const ro = new ResizeObserver(() => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(onResize, 100);
  });
  ro.observe(canvas);
  onResize();

  // ── Intersection Observer — gate rAF ────────────────────
  const io = new IntersectionObserver(entries => {
    isVisible = entries[0].isIntersecting;
    if (isVisible && !raf) startLoop();
    if (!isVisible && raf) { cancelAnimationFrame(raf); raf = null; }
  }, { threshold: 0 });
  io.observe(section);

  // ── Scroll handler ───────────────────────────────────────
  // Determine which panel is "active" based on scroll position
  let activePanelIndex = -1;

  function getActivePanelIndex() {
    const vh = window.innerHeight;
    const center = vh * 0.5;
    let best = -1;
    let bestDist = Infinity;

    panelEls.forEach((el, i) => {
      const rect = el.getBoundingClientRect();
      // Panel must be at least partially in view
      if (rect.bottom < 0 || rect.top > vh) return;
      // Distance from panel midpoint to screen center
      const mid  = rect.top + rect.height * 0.5;
      const dist = Math.abs(mid - center);
      if (dist < bestDist) {
        bestDist = dist;
        best = i;
      }
    });
    return best;
  }

  function onScroll() {
    const idx = getActivePanelIndex();

    // Show / hide panel content
    contentEls.forEach((el, i) => {
      if (i === idx) {
        el.classList.add('is-visible');
      } else {
        el.classList.remove('is-visible');
      }
    });

    if (idx === activePanelIndex) return;
    activePanelIndex = idx;

    if (idx >= 0 && panelEls[idx]) {
      const pose = getPanelPose(panelEls[idx]);
      tgt.rotX = pose.rotX;
      tgt.rotY = pose.rotY;
      tgt.rotZ = pose.rotZ;
      tgt.posX = pose.posX;
      tgt.posY = pose.posY;
      tgt.lX   = pose.lightX;
      tgt.lY   = pose.lightY;
      tgt.lZ   = pose.lightZ;
      tgt.lI   = pose.lightIntensity;
    }
  }

  window.addEventListener('scroll', onScroll, { passive: true });

  // ── Render loop ──────────────────────────────────────────
  // Idle auto-rotation when no panel is active (hero section)
  let idleAngle = 0;

  function startLoop() {
    function frame() {
      raf = requestAnimationFrame(frame);
      if (!shoe) return;

      const speed = LERP_SPEED;

      // Set targets — idle lerps to center, panels lerp to their pose
      if (activePanelIndex === -1) {
        // Hero idle: drift toward center, keep gentle float
        tgt.posX = 0;
        tgt.posY = Math.sin(idleAngle * 0.5) * 0.1;
        tgt.lX = 5; tgt.lY = 5; tgt.lZ = 5; tgt.lI = 1.0;
        idleAngle += 0.004;
        // Idle rotation — lerp Y toward slow spin
        tgt.rotX = 0;
        tgt.rotY = idleAngle;
        tgt.rotZ = 0.15;
      }

      // Always lerp cur toward tgt — no jumps ever
      cur.rotX = lerp(cur.rotX, tgt.rotX, speed);
      cur.rotY = lerp(cur.rotY, tgt.rotY, speed);
      cur.rotZ = lerp(cur.rotZ, tgt.rotZ, speed);
      cur.posX = lerp(cur.posX, tgt.posX, speed);
      cur.posY = lerp(cur.posY, tgt.posY, speed);
      cur.lX   = lerp(cur.lX,   tgt.lX,   speed);
      cur.lY   = lerp(cur.lY,   tgt.lY,   speed);
      cur.lZ   = lerp(cur.lZ,   tgt.lZ,   speed);
      cur.lI   = lerp(cur.lI,   tgt.lI,   speed);

      const worldOffsetX = -cur.posX * (camera.aspect * 1.6);
      shoe.rotation.set(cur.rotX, cur.rotY, cur.rotZ);
      shoe.position.set(worldOffsetX, cur.posY, 0);
      keyLight.position.set(cur.lX, cur.lY, cur.lZ);
      keyLight.intensity = cur.lI;

      renderer.render(scene, camera);
    }
    frame();
  }

  // ── Load GLB ─────────────────────────────────────────────
  const dracoLoader = new DRACOLoader();
  // Use CDN-hosted Draco decoder (no self-hosting needed)
  dracoLoader.setDecoderPath('https://www.gstatic.com/draco/versioned/decoders/1.4.1/');

  const gltfLoader = new GLTFLoader();
  gltfLoader.setDRACOLoader(dracoLoader);

  // Register Meshopt decoder — required when GLB is compressed via gltf.report Meshopt
  if (typeof MeshoptDecoder !== 'undefined' && MeshoptDecoder && gltfLoader.setMeshoptDecoder) {
    var meshoptReady = (MeshoptDecoder.ready instanceof Promise) ? MeshoptDecoder.ready : Promise.resolve();
    meshoptReady.then(function() {
      gltfLoader.setMeshoptDecoder(MeshoptDecoder);
      gltfLoader.load(MODEL_URL, onModelLoad, onModelProgress, onModelError);
    });
  } else {
    gltfLoader.load(MODEL_URL, onModelLoad, onModelProgress, onModelError);
  }

  function onModelLoad(gltf) {
    shoe = gltf.scene;

      // Auto-center and normalize scale
      const box    = new THREE.Box3().setFromObject(shoe);
      const size   = new THREE.Vector3();
      const center = new THREE.Vector3();
      box.getSize(size);
      box.getCenter(center);

      // Move pivot to object center
      shoe.position.sub(center);

      // Scale to fit within unit sphere, target ~1.6 world units tall
      const maxDim = Math.max(size.x, size.y, size.z);
      shoe.scale.setScalar(3.6 / maxDim);

      // Enable shadows on all meshes
      shoe.traverse(child => {
        if (child.isMesh) {
          child.castShadow    = true;
          child.receiveShadow = true;
          if (child.material) {
            child.material.envMapIntensity = 0.6;
          }
        }
      });

      // Initial pose — hero view (centered, slight tilt)
      cur.rotX = 0;
      cur.rotY = 0.3;
      cur.rotZ = 0.15;
      idleAngle = 0.3;

      // Pre-seed cur AND tgt from the first panel so there's no position jump
      // when the user starts scrolling from the hero into panel 1
      if (panelEls[0]) {
        const firstPose = getPanelPose(panelEls[0]);
        cur.posX = firstPose.posX;
        cur.posY = firstPose.posY;
        tgt.posX = firstPose.posX;
        tgt.posY = firstPose.posY;
        tgt.lX   = firstPose.lightX;
        tgt.lY   = firstPose.lightY;
        tgt.lZ   = firstPose.lightZ;
        tgt.lI   = firstPose.lightIntensity;
      }

      scene.add(shoe);
      if (loader) loader.classList.add('is-hidden');
      onScroll();
  }

  function onModelProgress(xhr) {
      if (loader) {
        const pct = Math.round((xhr.loaded / xhr.total) * 100);
        const txt = loader.querySelector('.shoe3d-loader__text');
        if (txt) txt.textContent = `Loading… ${pct}%`;
      }
  }

  function onModelError(err) {
      console.error('[Shoe3D] Failed to load model:', err);
      if (loader) {
        const txt = loader.querySelector('.shoe3d-loader__text');
        if (txt) txt.textContent = 'Could not load 3D model.';
        loader.querySelector('.shoe3d-loader__ring')?.remove();
      }
  }

  // ── Cleanup on page hide (Safari BFCache friendly) ──────
  document.addEventListener('visibilitychange', () => {
    if (document.hidden && raf) {
      cancelAnimationFrame(raf);
      raf = null;
    } else if (!document.hidden && isVisible && !raf) {
      startLoop();
    }
  });

} // end initShoe3D

})(); // end outer IIFE
</script>

