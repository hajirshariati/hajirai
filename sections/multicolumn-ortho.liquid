<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- render 'section-variables', section: section -%}
  }

  @media screen and (min-width: 1024px) {
    #shopify-section-{{ section.id }} .multicolumn {
      --card-grid-gap: {% if section.settings.gap == 'small' %}var(--sp-4){% elsif section.settings.gap == 'medium' %}var(--sp-6){% else %}clamp(40px, 3.5vw, 60px){% endif %};
    }
  }
</style>
{% liquid
  assign highlights = product.metafields.custom.product_highlights_no_no.value
  assign show_section = false
  
  if template.suffix == 'pdp-ortho-new'
    if highlights != blank
      assign show_section = true
    endif
  endif
%}
{% if show_section %}
  <div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}{% if section.settings.abra_promo_code_show != blank %} abra--{{ section.settings.abra_promo_code_show | handleize }}-activated{% endif %}"
    {% if section.settings.abra_promo_code_hide != blank %}
      data-abra-default="{{ section.settings.abra_promo_code_hide | handleize }}"
    {% endif %}
    {% if section.settings.abra_promo_code_show != blank %}
      data-abra-promo="{{ section.settings.abra_promo_code_show | handleize }}"
    {% endif %}
  >
    <div class="page-width{% if section.settings.full_width %} page-width--full{% endif %} relative">
      {%- render 'section-heading', section: section -%}

      <slider-element
        id="Slider-{{ section.id }}"
        class="grid slider{% if section.settings.carousel_on_desktop %} slider--desktop{% endif %}{% if section.settings.swipe_on_mobile %} slider--tablet{% endif %}"
        selector=".card-grid>.card"
        {% if section.settings.swipe_on_mobile %}
          tabindex="0"
        {% endif %}
        {%- if template.suffix == 'pdp-ortho-new' -%}
          {%- capture highlights_no_no_json -%}[{%- for item in product.metafields.custom.product_highlights_no_no.value -%}{"image":"{{ item.image.value | image_url: width: 192 }}","heading":"{{ item.heading.value | escape }}","text":"{{ item.text.value | escape }}","copy":"{{ item.copy.value | escape }}"}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}]{%- endcapture -%}
          {%- capture highlights_no_yes_json -%}[{%- for item in product.metafields.custom.product_highlights_no_yes.value -%}{"image":"{{ item.image.value | image_url: width: 192 }}","heading":"{{ item.heading.value | escape }}","text":"{{ item.text.value | escape }}","copy":"{{ item.copy.value | escape }}"}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}]{%- endcapture -%}
          {%- capture highlights_yes_no_json -%}[{%- for item in product.metafields.custom.product_highlights_yes_no.value -%}{"image":"{{ item.image.value | image_url: width: 192 }}","heading":"{{ item.heading.value | escape }}","text":"{{ item.text.value | escape }}","copy":"{{ item.copy.value | escape }}"}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}]{%- endcapture -%}
          {%- capture highlights_yes_yes_json -%}[{%- for item in product.metafields.custom.product_highlights_yes_yes.value -%}{"image":"{{ item.image.value | image_url: width: 192 }}","heading":"{{ item.heading.value | escape }}","text":"{{ item.text.value | escape }}","copy":"{{ item.copy.value | escape }}"}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}]{%- endcapture -%}
          data-highlights-no-no='{{ highlights_no_no_json }}'
          data-highlights-no-yes='{{ highlights_no_yes_json }}'
          data-highlights-yes-no='{{ highlights_yes_no_json }}'
          data-highlights-yes-yes='{{ highlights_yes_yes_json }}'
        {%- endif -%}
      >
        <div id="dynamic-highlights-grid" class="multicolumn card-grid card-grid--{{ section.settings.columns }} mobile:card-grid--{{ section.settings.columns_mobile }} grid relative z-1">
          {%- for item in highlights -%}
            {%- assign item_image = item.image.value -%}
            {%- assign item_heading = item.heading.value -%}
            {%- assign item_text = item.text.value -%}
            {%- assign item_copy = item.copy.value -%}
            
            <div style="background: white;padding: 2em 2em 2em;"
              class="multicolumn-card card flex gap-5 w-full flex-col items-start xl:flex-row md:text-left text-left"
            >
              <div class="grid gap-4 lg:gap-6 w-full">
                {%- if item_image != blank -%}
                  {%- capture sizes -%}(max-width: 639px) 100vw, (max-width: 1023px) calc(100vw / 2 - 40px), (max-width: 1535px) calc(min(100vw, {{ settings.page_width }}px) / 3 - 40px), calc(min(100vw, {{ settings.page_width }}px) / 3 - 80px){%- endcapture -%}
                  <div class="block media media--adapt media--transparent relative overflow-hidden">
                    <img src="{{ item_image | image_url: width: 192 }}" 
                         srcset="{{ item_image | image_url: width: 180 }} 180w, {{ item_image | image_url: width: 360 }} 360w, {{ item_image | image_url: width: 540 }} 540w, {{ item_image | image_url: width: 720 }} 720w"
                         sizes="{{ sizes }}"
                         loading="lazy"
                         is="lazy-image"
                         class="inline-block w-full"
                         alt="{{ item_heading | escape }}">
                  </div>
                {%- endif -%}

                <div class="multicolumn-card__info grid gap-4 lg:gap-6">
                  {%- if item_heading != blank -%}
                    <p class="heading text-lg-2xl leading-tight tracking-tight">
                      {{ item_heading }}
                    </p>
                  {%- endif -%}

                  {%- if item_text != blank -%}
                    <div class="rte leading-normal">
                      <p>{{ item_text }}</p>
                    </div>
                  {%- endif -%}

                  {%- if item_copy != blank -%}
                    <div class="rte leading-normal">
                      <p>{{ item_copy }}</p>
                    </div>
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
        {%- if section.settings.heading == blank
          or section.settings.subheading == blank
          or section.settings.description == blank
        -%}
          {%- if section.settings.carousel_on_desktop -%}
            <div class="indicators hidden lg:flex gap-2d5 items-center absolute top-0 left-0 w-full h-full pointer-events-none opacity-0 page-width">
              <button
                class="button button--primary pointer-events-auto"
                type="button"
                is="previous-button"
                aria-controls="Slider-{{ section.id }}"
                aria-label="{{ 'general.pagination.previous' | t | escape }}"
                disabled
                tabindex="-1"
              >
                <span class="btn-fill" data-fill></span>
                <span class="btn-text">
                  {%- render 'icon', icon: 'chevron-left', class: 'stroke-2 transform' -%}
                </span>
              </button>
              <button
                class="button button--primary pointer-events-auto"
                type="button"
                is="next-button"
                aria-controls="Slider-{{ section.id }}"
                aria-label="{{ 'general.pagination.next' | t | escape }}"
                tabindex="-1"
              >
                <span class="btn-fill" data-fill></span>
                <span class="btn-text">
                  {%- render 'icon', icon: 'chevron-right', class: 'stroke-2 transform' -%}
                </span>
              </button>
            </div>
          {%- endif -%}
        {%- endif -%}
      </slider-element>
    </div>
  </div>
{% endif %}

<script>
(function() {
  const sliderElement = document.getElementById('Slider-{{ section.id }}');
  if (!sliderElement) return;

  const highlightsGrid = document.getElementById('dynamic-highlights-grid');
  if (!highlightsGrid) return;

  // Function to get current option values
  function getCurrentOptions() {
    const option1Checked = document.querySelector('input[name="Do you have flat feet?"]:checked');
    const option2Checked = document.querySelector('input[name="Do you have ball of foot pain?"]:checked');
    
    if (!option1Checked || !option2Checked) return null;
    
    const option1Value = option1Checked.value.trim();
    const option2Value = option2Checked.value.trim();
    
    // Map "No / Unsure" to "no" and "Yes" to "yes"
    const option1 = (option1Value === "Yes") ? "yes" : "no";
    const option2 = (option2Value === "Yes") ? "yes" : "no";
    
    return { option1, option2 };
  }

  // Function to update highlights
  function updateHighlights() {
    const options = getCurrentOptions();
    if (!options) return;

    // Build the dataset key
    const dataKey = `highlights${options.option1.charAt(0).toUpperCase() + options.option1.slice(1)}${options.option2.charAt(0).toUpperCase() + options.option2.slice(1)}`;
    
    const highlightsData = sliderElement.dataset[dataKey];
    
    if (!highlightsData || highlightsData === 'null') return;

    let highlights;
    try {
      highlights = JSON.parse(highlightsData);
    } catch (e) {
      console.error('Error parsing highlights data:', e);
      return;
    }

    if (!highlights || !Array.isArray(highlights)) return;

    // Clear current highlights
    highlightsGrid.innerHTML = '';

    // Add new highlights
    highlights.forEach(item => {
      if (!item.image && !item.heading && !item.text && !item.copy) return;

      const card = document.createElement('div');
      card.style.cssText = 'background: white; padding: 2em 2em 2em;';
      card.className = 'multicolumn-card card flex gap-5 w-full flex-col items-start xl:flex-row md:text-left text-left';

      const innerDiv = document.createElement('div');
      innerDiv.className = 'grid gap-4 lg:gap-6 w-full';

      if (item.image) {
        const mediaDiv = document.createElement('div');
        mediaDiv.className = 'block media media--adapt media--transparent relative overflow-hidden';
        
        const img = document.createElement('img');
        img.src = item.image;
        img.loading = 'lazy';
        img.setAttribute('is', 'lazy-image');
        img.className = 'inline-block w-full';
        img.alt = item.heading || '';
        img.srcset = `${item.image.replace('width=192', 'width=180')} 180w, ${item.image.replace('width=192', 'width=360')} 360w, ${item.image.replace('width=192', 'width=540')} 540w, ${item.image} 720w`;
        img.sizes = '(max-width: 639px) 100vw, (max-width: 1023px) calc(100vw / 2 - 40px), (max-width: 1535px) calc(min(100vw, 1440px) / 3 - 40px), calc(min(100vw, 1440px) / 3 - 80px)';
        
        mediaDiv.appendChild(img);
        innerDiv.appendChild(mediaDiv);
      }

      const infoDiv = document.createElement('div');
      infoDiv.className = 'multicolumn-card__info grid gap-4 lg:gap-6';

      if (item.heading) {
        const heading = document.createElement('p');
        heading.className = 'heading text-lg-2xl leading-tight tracking-tight';
        heading.textContent = item.heading;
        infoDiv.appendChild(heading);
      }

      if (item.text) {
        const textDiv = document.createElement('div');
        textDiv.className = 'rte leading-normal';
        const p = document.createElement('p');
        p.textContent = item.text;
        textDiv.appendChild(p);
        infoDiv.appendChild(textDiv);
      }

      if (item.copy) {
        const copyDiv = document.createElement('div');
        copyDiv.className = 'rte leading-normal';
        const p = document.createElement('p');
        p.textContent = item.copy;
        copyDiv.appendChild(p);
        infoDiv.appendChild(copyDiv);
      }

      innerDiv.appendChild(infoDiv);
      card.appendChild(innerDiv);
      highlightsGrid.appendChild(card);
    });
  }

  // Listen for option changes
  document.addEventListener('change', function(e) {
    if (e.target.name === 'Do you have flat feet?' || e.target.name === 'Do you have ball of foot pain?') {
      setTimeout(updateHighlights, 100);
    }
  });

  // Initialize on page load
  setTimeout(updateHighlights, 500);
})();
</script>

