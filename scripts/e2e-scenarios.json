[
  {
    "name": "condition + category named: must call search_products with orthotic intent",
    "messages": [
      "I have flat feet, what orthotic do you recommend?"
    ],
    "merchantConfig": {
      "shop": "test.myshopify.com",
      "catalogProductTypes": ["Orthotics", "Sneakers", "Sandals", "Boots"],
      "scopedGender": "women",
      "answeredChoices": [
        { "question": "Are these for men's or women's?", "answer": "Women's", "rawAnswer": "Women's", "options": ["Men's", "Women's"] }
      ]
    },
    "toolStubs": {
      "search_products": [
        {
          "if_query_matches": "orthotic|posted|insert|footbed",
          "return": {
            "products": [
              { "handle": "casual-comfort-posted-w", "title": "Women's Casual Comfort Posted Orthotic", "_category": "Orthotics" }
            ]
          }
        },
        {
          "if_query_matches": ".",
          "return": { "products": [] }
        }
      ]
    },
    "expect": {
      "must_call_tool": "search_products",
      "tool_query_matches": "orthotic|posted|insert|footbed|flat",
      "text_must_not_contain": ["sneaker", "casual slip"]
    }
  },

