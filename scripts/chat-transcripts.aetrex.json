          "text": {
            "mustIncludeAny": ["footwear", "orthotic", "insert", "shoes"]
          },
          "products": {
            "max": 0
          },
          "chips": {
            "mustIncludeAny": ["Footwear with arch support", "Orthotic insole"]
          }
        }
      }
    ]
  },
  {
    "name": "return policy is text-only support answer",
    "turns": [
      {
        "user": "What's your return policy?",
        "expect": {
          "text": {
            "mustIncludeAny": ["return", "30", "unworn", "policy"],
            "mustNotInclude": ["sneaker", "sandals", "orthotic recommendation"]
          },
          "products": {
            "max": 0
          }
        }
      }
    ]
  },
  {
    "name": "unknown sku is not hallucinated as a product",
    "turns": [
      {
        "user": "Show me the L9999.",
        "expect": {
          "text": {
            "mustNotMatch": "L9999.{0,80}(perfect|recommend|best|here)",
            "mustNotInclude": ["view product"]
          },
          "products": {
            "max": 0
          }
        }
      }
    ]
  },
  {
    "name": "size stock claim requires product details grounding",
    "turns": [
      {
        "user": "show me men's sneakers",
        "expect": {
          "products": {
            "min": 1
          }
        }
      },
      {
        "user": "do these come in size 9 wide?",
        "expect": {
          "text": {
            "mustNotInclude": ["definitely available", "currently available in size 9", "in stock in size 9"]
          }
        }
      }
    ]
  },
  {
    "name": "soft gender gate lets unsure shopper browse products",
    "turns": [
      {
        "user": "hi i need new shoes",
        "expect": {
          "text": {
            "mustIncludeAny": ["men", "women", "styles", "browse"]
          },
          "products": {
            "max": 0
          },
          "chips": {
            "mustIncludeAny": ["Men's", "Women's"]
          }
        }
      },
      {
        "user": "i don't know, what do you have that's cheap?",
        "expect": {
          "text": {
            "mustIncludeAny": ["styles", "narrow", "price", "browse"],
            "mustNotInclude": ["which styles would you like to browse", "men's or women's", "are you shopping for"]
          },
          "products": {
            "min": 1,
            "allTitleOrHandleMustNotMatch": "orthotic|insole|accessor"
          },
          "chips": {
            "mustNotInclude": ["Men's", "Women's"]
          }
        }
      }
    ]
  },
  {
    "name": "soft gender gate breaks repeated non-answer loop",
    "turns": [
      {
        "user": "i need shoes",
        "expect": {
          "chips": {
            "mustIncludeAny": ["Men's", "Women's"]
          },
          "products": {
            "max": 0
          }
        }
      },
      {
        "user": "not sure",
        "expect": {
          "text": {
            "mustNotInclude": ["which styles would you like to browse", "men's or women's", "are you shopping for"]
          },
          "products": {
            "min": 1
          },
          "chips": {
            "mustNotInclude": ["Men's", "Women's"]
          }
        }
      }
    ]
  },
  {
    "name": "support contact does not show unrelated product cards",
    "turns": [
      {
        "user": "How do I contact customer support about my order?",
        "expect": {
          "text": {
            "mustIncludeAny": ["support", "customer", "order", "contact"],
            "mustNotInclude": ["here are", "take a look"]
          },
          "products": {
            "max": 0
          }
        }
      }
    ]
  }
