{% comment %}
  Hajirai AI Chat — app embed block.
  Loads the chat launcher on every storefront page when enabled in the theme editor.
  Most settings (branding, greetings, knowledge base, CTAs) come from the Hajirai app admin.
  The fallback values here are used before the admin config is fetched.
{% endcomment %}

<div
  id="hajirai-chat-root"
  data-shop="{{ shop.permanent_domain }}"
  data-position="{{ block.settings.position }}"
  data-primary="{{ block.settings.primary_color }}"
  data-accent="{{ block.settings.accent_color }}"
  data-greeting="{{ block.settings.greeting | escape }}"
  data-assistant-name="{{ block.settings.assistant_name | escape }}"
></div>

<link rel="stylesheet" href="{{ 'hajirai-chat-widget.css' | asset_url }}">
<script src="{{ 'hajirai-chat-widget.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Hajirai AI Chat",
  "target": "body",
  "settings": [
    {
      "type": "header",
      "content": "Hajirai AI Chat Assistant"
    },
    {
      "type": "paragraph",
      "content": "Most settings (branding, greetings, knowledge base) are configured in the Hajirai app admin. The values below are fallbacks until your admin config loads."
    },
    {
      "type": "text",
      "id": "assistant_name",
      "label": "Assistant Name",
      "default": "AI Shopping Assistant"
    },
    {
      "type": "text",
      "id": "greeting",
      "label": "Greeting (fallback)",
      "default": "Hi! I'm your personal shopping assistant."
    },
    {
      "type": "select",
      "id": "position",
      "label": "Launcher Position",
      "options": [
        { "value": "bottom-right", "label": "Bottom Right" },
        { "value": "bottom-center", "label": "Bottom Center" },
        { "value": "bottom-left", "label": "Bottom Left" }
      ],
      "default": "bottom-center"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary Color (fallback)",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (fallback)",
      "default": "#FFFFFF"
    }
  ]
}
{% endschema %}
